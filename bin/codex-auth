#!/usr/bin/env bash
set -euo pipefail

umask 077

CODEX_HOME="${CODEX_HOME:-$HOME/.codex}"
AUTH_FILE="$CODEX_HOME/auth.json"
PROFILE_DIR="${CODEX_AUTH_PROFILES_DIR:-$CODEX_HOME/auth-profiles}"
BACKUP_DIR="$CODEX_HOME/auth-backups"
STATE_FILE="${CODEX_AUTH_STATE_FILE:-$CODEX_HOME/auth-state.json}"
CACHE_TTL="${CODEX_AUTH_CACHE_TTL:-900}"
CODEX_BIN="${CODEX_AUTH_CODEX_BIN:-}"
USAGE_VERBOSE=0
USAGE_QUIET=0
USAGE_CACHED=0
USAGE_REFRESH=0
USAGE_BACKGROUND=1
USAGE_SELECT=0
USAGE_FAST_REFRESH=0
MUTATION_LOCK_HELD=0
MUTATION_LOCK_FD=""

USAGE_RECORD_EXTRACT_JQ='
  def blanks: "", "", "", "", "", "", "", "", "";
  def no_usage($age; $stale): ["no_usage", "", $age, $stale, blanks];
  def empty_limit: {used: 0, window: "-", window_num: 0, reset: "-"};
  def limit_row: {used: ((.usedPercent // 0) | tonumber? // 0 | floor), window: (.windowDurationMins // "-"), window_num: ((.windowDurationMins // 0) | tonumber? // 0), reset: (.resetsAt // "-")};
  def credit_label: if . == null then "-" elif .unlimited then "unlimited" elif .hasCredits then (.balance // "yes") else "0" end;
  def error_label: ((.error.message // .error.data.message // .error.data.error.message // .error // "error") | tostring | gsub("[\n\t]+"; " ") | gsub("  +"; " ") | gsub("^ "; "") | gsub(" $"; ""));
  (._codexAuthAgeSec // "") as $age
  | (._codexAuthStale // false | tostring) as $stale
  | if .error? != null then
      ["error", error_label, $age, $stale, blanks]
    else
      (.rateLimitsByLimitId.codex // .rateLimits // null) as $r
      | if $r == null then
          no_usage($age; $stale)
        else
          [($r.primary // empty), ($r.secondary // empty)]
          | map(select(type == "object") | limit_row)
          | map(select(.window_num > 0))
          | sort_by(if .window_num == 0 then 999999999 else .window_num end) as $limits
          | if ($limits | length) == 0 then
              no_usage($age; $stale)
            else
              (if ($limits | length) == 1 and ($limits[0].window_num >= 1440)
               then empty_limit
               else $limits[0]
               end) as $shortLimit
              | (if ($limits | length) == 1 and ($limits[0].window_num < 1440)
               then empty_limit
               else $limits[-1]
               end) as $weeklyLimit
              | ["usage", "", $age, $stale, ($r.planType // "-"),
                 $shortLimit.used, $shortLimit.window, $shortLimit.reset,
                 $weeklyLimit.used, $weeklyLimit.window, $weeklyLimit.reset,
                 ($r.credits | credit_label), ($r.rateLimitReachedType // "")]
            end
        end
    end
  | map(tostring)
  | join("\u001f")
'

usage() {
  local width
  width="$(terminal_width)"
  USAGE_COLOR_ENABLED=0
  color_enabled && USAGE_COLOR_ENABLED=1
  print_help_summary "$width"
  print_help_section "daily" "$width"
  print_help_item "usage --refresh --select" "Refresh and select" "$width"
  print_help_item "usage --cached" "Cached usage" "$width"
  print_help_item "usage --refresh -v" "Wide usage" "$width"
  print_help_item "add <name>" "Browser login" "$width"
  print_help_section "lookup" "$width"
  print_help_item "current" "Active auth" "$width"
  print_help_item "list [-v]" "Saved profiles" "$width"
  print_help_item "paths" "Auth paths" "$width"
  print_help_section "switch" "$width"
  print_help_item "use <name>" "Select profile" "$width"
  print_help_item "add <name> --current" "Save current auth" "$width"
  print_help_item "add <name> --file <file>" "Import auth file" "$width"
  print_help_item "login <name>" "Login profile" "$width"
  print_help_section "maintenance" "$width"
  print_help_item "refresh" "Refresh usage" "$width"
  print_help_item "auto" "Select best profile" "$width"
  print_help_item "patch-codex" "Build patched Codex" "$width"
  print_help_item "recover [session]" "Resume with best" "$width"
  print_help_item "run -- <args>" "Rolling session" "$width"
  print_help_item "remove <name> --yes" "Delete profile" "$width"
  print_help_item "doctor" "Process audit" "$width"
  print_help_section "advanced" "$width"
  print_help_item "save <name> [file]" "Save auth file" "$width"
  print_help_item "import <name> <file>" "Import profile" "$width"
  print_help_item "export <name> <file>" "Export auth file" "$width"
  printf '\n'
}

print_help_summary() {
  local width="$1"
  local path path_w

  if (( width < 32 )); then
    if (( width < 22 )); then
      print_palette_title_line "Auth" "Commands" "" "$width"
      return 0
    fi
    path="profiles auth-profiles"
  else
    path_w=$((width - 9))
    (( path_w < 1 )) && path_w=1
    path="$(compact_display_path "$PROFILE_DIR" "$path_w")"
    path="profiles $path"
  fi

  print_palette_title_line "Auth" "Commands" "" "$width"
  print_flat_context_line "$path" "$width"
}

print_help_section() {
  local label="$1"
  local width="$2"
  printf '\n'
  print_toned_fit_rtrim "$label" "$width" muted
  printf '\n'
}

print_help_item() {
  local cmd="$1"
  local desc="$2"
  local width="$3"
  local action action_w command_w desc_w line gap

  action="$(help_item_action "$cmd" "$desc")"
  action_w=7
  (( width < 56 )) && action_w=6

  if (( width < 56 )); then
    print_help_compact_command "$action" "$cmd" "$width" "$action_w"
    return 0
  fi

  command_w=27
  (( width >= 72 )) && command_w=31
  (( width >= 96 )) && command_w=34
  if (( command_w > width - action_w - 19 )); then
    command_w=$((width - action_w - 19))
  fi
  (( command_w < 14 )) && command_w=14
  desc_w=$((width - action_w - command_w - 3))
  (( desc_w < 1 )) && desc_w=1
  print_toned_fit "$action" "$action_w" "$(help_action_tone "$action")"
  printf ' '
  print_toned_fit "$cmd" "$command_w" accent
  gap=2
  printf '%*s' "$gap" ''
  print_toned_fit_rtrim "$desc" "$desc_w" muted
  printf '\n'
}

print_help_compact_command() {
  local action="$1"
  local cmd="$2"
  local width="$3"
  local action_w="$4"
  local command_w token line="" first=1
  local tokens=()

  command_w=$((width - action_w - 1))
  (( command_w < 1 )) && command_w=1
  read -r -a tokens <<<"$cmd"

  for token in "${tokens[@]}"; do
    if [[ -z "$line" ]]; then
      line="$token"
    elif (( ${#line} + 1 + ${#token} <= command_w )); then
      line+=" $token"
    else
      print_help_compact_line "$action" "$line" "$action_w" "$command_w" "$first"
      first=0
      line="$token"
    fi
  done

  if [[ -n "$line" ]]; then
    print_help_compact_line "$action" "$line" "$action_w" "$command_w" "$first"
  fi
}

print_help_compact_line() {
  local action="$1"
  local cmd="$2"
  local action_w="$3"
  local command_w="$4"
  local first="${5:-0}"

  if (( first )); then
    print_toned_fit "$action" "$action_w" "$(help_action_tone "$action")"
  else
    printf '%*s' "$action_w" ''
  fi
  printf ' '
  print_toned_fit_rtrim "$cmd" "$command_w" accent
  printf '\n'
}

help_item_action() {
  local cmd="$1"
  local desc="$2"
  local row pattern action
  local rows=(
    "usage --refresh --select"$'\t'"select"
    "usage --cached"$'\t'"cache"
    "usage --refresh -v"$'\t'"wide"
    "add <name>"$'\t'"new"
    "current"$'\t'"view"
    "list*"$'\t'"view"
    "paths"$'\t'"view"
    "use <name>"$'\t'"use"
    "add <name> --current"$'\t'"save"
    "save*"$'\t'"copy"
    "add <name> --file <file>"$'\t'"import"
    "import*"$'\t'"load"
    "login <name>"$'\t'"auth"
    "refresh"$'\t'"sync"
    "auto"$'\t'"best"
    "patch-codex"$'\t'"patch"
    "recover*"$'\t'"resume"
    "run -- <args>"$'\t'"roll"
    "remove*"$'\t'"delete"
    "doctor"$'\t'"audit"
    "export*"$'\t'"write"
  )

  for row in "${rows[@]}"; do
    IFS=$'\t' read -r pattern action <<<"$row"
    if [[ "$cmd" == $pattern ]]; then
      printf '%s' "$action"
      return 0
    fi
  done
  printf '%s' "${desc%% *}"
}

help_action_tone() {
  case "${1:-}" in
    select|best)
      printf 'accent'
      ;;
    use|save|view|cache|export|new|copy|load|write)
      printf 'good'
      ;;
    auth|login|import|wide|refresh|resume|roll|audit)
      printf 'warn'
      ;;
    delete|remove)
      printf 'bad'
      ;;
    *)
      printf 'muted'
      ;;
  esac
}

display_path() {
  local path="$1"
  local home_prefix="${HOME%/}/"

  if [[ -n "${HOME:-}" && "$path" == "$HOME" ]]; then
    printf '~'
  elif [[ -n "${HOME:-}" && "$path" == "$home_prefix"* ]]; then
    printf '~/%s' "${path#$home_prefix}"
  else
    printf '%s' "$path"
  fi
}

compact_display_path() {
  local path="$1"
  local width="${2:-0}"
  local rendered base prefix candidate

  rendered="$(display_path "$path")"
  if [[ "$width" =~ ^[0-9]+$ && "$width" -gt 0 && ${#rendered} -gt width && "$rendered" == */* ]]; then
    base="${rendered##*/}"
    if usage_unicode_enabled; then
      prefix="…/"
    else
      prefix=".../"
    fi
    candidate="$prefix$base"
    fit_profile_text_rtrim "$candidate" "$width"
    return 0
  fi
  printf '%s' "$rendered"
}

compact_codex_status() {
  local status="$1"
  local width="${2:-0}"

  if [[ "$status" == "Logged in using "* ]]; then
    printf '%s' "${status#Logged in using }"
  else
    printf '%s' "$status"
  fi
}

die() {
  print_error "$*"
  exit 1
}

require_arg_count_between() {
  local count="$1" min="$2" max="$3"
  shift 3
  (( count >= min && count <= max )) || die "$*"
}

codex_bin() {
  if [[ -n "$CODEX_BIN" && -x "$CODEX_BIN" ]]; then
    printf '%s\n' "$CODEX_BIN"
  elif [[ -x "$HOME/.bun/bin/codex-real" ]]; then
    printf '%s\n' "$HOME/.bun/bin/codex-real"
  elif [[ -x "$HOME/.bun/bin/codex" ]]; then
    printf '%s\n' "$HOME/.bun/bin/codex"
  else
    command -v codex 2>/dev/null || return 1
  fi
}

codex_launcher_needs_node() {
  local codex_cli="$1"
  local first_line=""

  [[ -r "$codex_cli" ]] || return 1
  IFS= read -r first_line < "$codex_cli" || return 1
  [[ "$first_line" == "#!"*"env node"* ]]
}

codex_launcher_ready() {
  local codex_cli="$1"

  if codex_launcher_needs_node "$codex_cli"; then
    command -v node >/dev/null 2>&1 || return 1
  fi
  return 0
}

require_codex_launcher() {
  local codex_cli="$1"

  if codex_launcher_needs_node "$codex_cli" && ! command -v node >/dev/null 2>&1; then
    die "node needed for codex"
  fi
}

ensure_dirs() {
  mkdir -p "$CODEX_HOME" "$PROFILE_DIR" "$BACKUP_DIR" "$CODEX_HOME/.tmp"
  chmod 700 "$CODEX_HOME" "$PROFILE_DIR" "$BACKUP_DIR" "$CODEX_HOME/.tmp" 2>/dev/null || true
}

acquire_mutation_lock() {
  local wait
  if (( MUTATION_LOCK_HELD )); then
    return 0
  fi

  ensure_dirs
  wait="${CODEX_AUTH_MUTATION_LOCK_WAIT:-30}"
  [[ "$wait" =~ ^[0-9]+$ ]] || wait=30
  exec {MUTATION_LOCK_FD}>"$CODEX_HOME/.tmp/codex-auth-mutation.lock"
  flock -w "$wait" "$MUTATION_LOCK_FD" || die "auth change already running"
  MUTATION_LOCK_HELD=1
}

require_name() {
  local name="${1:-}"
  [[ -n "$name" ]] || die "missing profile name"
  [[ "$name" =~ ^[A-Za-z0-9._-]+$ ]] || die "profile names may only use letters, numbers, dot, underscore, and dash"
}

profile_path() {
  local name="$1"
  printf '%s/%s.json\n' "$PROFILE_DIR" "$name"
}

require_auth_file() {
  local path="$1"
  [[ -f "$path" ]] || die "auth file not found: $path"
  [[ -s "$path" ]] || die "auth file is empty: $path"
  if command -v jq >/dev/null 2>&1; then
    jq -e 'has("OPENAI_API_KEY") or has("tokens")' "$path" >/dev/null 2>&1 \
      || die "not a Codex auth.json with OPENAI_API_KEY or tokens: $path"
  fi
}

auth_file_is_valid() {
  local path="$1"
  [[ -f "$path" && -s "$path" ]] || return 1
  if command -v jq >/dev/null 2>&1; then
    jq -e 'has("OPENAI_API_KEY") or has("tokens")' "$path" >/dev/null 2>&1 || return 1
  fi
}

copy_auth_file_atomic() {
  local source="$1"
  local dest="$2"
  local dest_dir dest_base tmp

  dest_dir="$(dirname "$dest")"
  dest_base="$(basename "$dest")"
  tmp="$(mktemp "$dest_dir/.${dest_base}.tmp.XXXXXX")"
  if ! cp -p "$source" "$tmp"; then
    rm -f "$tmp"
    return 1
  fi
  if ! chmod 600 "$tmp"; then
    rm -f "$tmp"
    return 1
  fi
  if ! mv -f "$tmp" "$dest"; then
    rm -f "$tmp"
    return 1
  fi
}

restore_hidden_auth() {
  local hidden_auth="${1:-}"
  [[ -n "$hidden_auth" && -f "$hidden_auth" ]] || return 1
  rm -f "$AUTH_FILE"
  mv "$hidden_auth" "$AUTH_FILE"
  chmod 600 "$AUTH_FILE"
}

credential_fingerprint() {
  local path="$1"
  [[ -f "$path" ]] || return 1
  if command -v jq >/dev/null 2>&1; then
    jq -r 'if .OPENAI_API_KEY then "api:" + .OPENAI_API_KEY elif .tokens.refresh_token then "chatgpt:" + .tokens.refresh_token elif .tokens.access_token then "chatgpt-access:" + .tokens.access_token else empty end' "$path" \
      | sha256sum \
      | awk '{print $1}'
  else
    sha256sum "$path" | awk '{print $1}'
  fi
}

fingerprint_secret() {
  local secret="${1:-}"
  if [[ -n "$secret" ]]; then
    printf '%s\n' "$secret" | sha256sum | awk '{print $1}'
  else
    printf '' | sha256sum | awk '{print $1}'
  fi
}

auth_metadata() {
  local path="$1"
  local mode="unknown"
  local hint=""
  local secret=""
  local fp=""
  local fields=()

  [[ -f "$path" ]] || return 1
  if command -v jq >/dev/null 2>&1; then
    mapfile -t fields < <(
      jq -r '
        if .OPENAI_API_KEY then
          "api_key",
          "",
          ("api:" + .OPENAI_API_KEY)
        elif .tokens then
          "chatgpt",
          ((.tokens.account_id // "") | tostring | gsub("[[:space:]]"; "")),
          (if .tokens.refresh_token then
             "chatgpt:" + .tokens.refresh_token
           elif .tokens.access_token then
             "chatgpt-access:" + .tokens.access_token
           else
             ""
           end)
        else
          "unknown",
          "",
          ""
        end
      ' "$path" 2>/dev/null || true
    )
    mode="${fields[0]:-unknown}"
    hint="${fields[1]:-}"
    secret="${fields[2]:-}"
    fp="$(fingerprint_secret "$secret")"
  else
    fp="$(sha256sum "$path" | awk '{print $1}')"
  fi

  printf '%s\n%s\n%s\n' "$mode" "$hint" "$fp"
}

auth_metadata_records() {
  if (( $# == 0 )); then
    return 0
  fi

  if command -v jq >/dev/null 2>&1; then
    jq -r '
      def clean: tostring | gsub("[[:space:]]"; "");
      if .OPENAI_API_KEY then
        [input_filename, "api_key", "", ("api:" + .OPENAI_API_KEY)]
      elif .tokens then
        [input_filename,
         "chatgpt",
         ((.tokens.account_id // "") | clean),
         (if .tokens.refresh_token then
            "chatgpt:" + .tokens.refresh_token
          elif .tokens.access_token then
            "chatgpt-access:" + .tokens.access_token
          else
            ""
          end)]
      else
        [input_filename, "unknown", "", ""]
      end
      | join("\u001f")
    ' "$@" 2>/dev/null
  else
    local path
    for path in "$@"; do
      [[ -f "$path" ]] || continue
      printf '%s\037unknown\037\037%s\n' "$path" "$(sha256sum "$path" | awk '{print $1}')"
    done
  fi
}

auth_record_fingerprint() {
  local secret="$1"

  if [[ -n "$secret" && ! "$secret" =~ ^[0-9a-f]{64}$ ]]; then
    fingerprint_secret "$secret"
  elif [[ -n "$secret" ]]; then
    printf '%s' "$secret"
  else
    fingerprint_secret ""
  fi
}

reserve_unique_backup_path() {
  local label="$1"
  local stamp base candidate suffix=0

  stamp="$(date +%Y%m%d_%H%M%S)"
  base="$BACKUP_DIR/auth.json.$stamp.$label"
  while true; do
    candidate="$base"
    (( suffix > 0 )) && candidate="$base.$suffix"
    if ( set -o noclobber; : > "$candidate" ) 2>/dev/null; then
      chmod 600 "$candidate"
      printf '%s\n' "$candidate"
      return 0
    fi
    suffix=$((suffix + 1))
  done
}

backup_current() {
  local label="${1:-switch}"
  ensure_dirs
  if [[ ! -f "$AUTH_FILE" ]]; then
    return 0
  fi
  local backup
  backup="$(reserve_unique_backup_path "$label")"
  if ! copy_auth_file_atomic "$AUTH_FILE" "$backup"; then
    rm -f "$backup"
    return 1
  fi
  printf '%s\n' "$backup"
}

short_account_hint() {
  local hint="$1"
  local width="${2:-13}"
  local length=${#hint}
  if [[ -z "$hint" ]]; then
    usage_meta_glyph
  elif (( width < 13 && length > width )); then
    fit_profile_text "$hint" "$width"
  elif (( length > 13 )); then
    printf '%s%s%s' "${hint:0:8}" "$(usage_trunc_glyph)" "${hint:length-4:4}"
  else
    printf '%s' "$hint"
  fi
}

verbose_account_hint() {
  local hint="$1"
  local width="${2:-13}"
  local clean length right left

  if [[ -z "$hint" ]]; then
    usage_meta_glyph
    return 0
  fi
  if (( ${#hint} <= width )); then
    printf '%s' "$hint"
    return 0
  fi

  clean="${hint//-/}"
  if [[ "$hint" =~ ^[0-9a-fA-F-]+$ && ${#clean} -gt 12 ]]; then
    if (( width >= 13 )); then
      right=$((width - 9))
      (( right < 4 )) && right=4
      printf '%s%s%s' "${clean:0:8}" "$(usage_trunc_glyph)" "${clean:${#clean}-right:right}"
    elif (( width >= 8 )); then
      right=4
      left=$((width - right - 1))
      (( left < 3 )) && left=3
      printf '%s%s%s' "${clean:0:left}" "$(usage_trunc_glyph)" "${clean:${#clean}-right:right}"
    else
      fit_profile_text "$clean" "$width"
    fi
  else
    fit_profile_text "$hint" "$width"
  fi
}

profile_list_widths() {
  local cols="$1"
  local role_w=5
  local profile_w
  local wanted_profile_w
  local mode_w=7
  local account_min=10
  local max_profile_w account_w

  wanted_profile_w="${PROFILE_LIST_WIDTH_HINT:-12}"
  wanted_profile_w="$(usage_profile_width_hint "$cols" "$wanted_profile_w" "$USAGE_VERBOSE")"

  if (( cols < 34 )); then
    role_w=1
    mode_w=4
    account_min=8
  elif (( cols < 40 )); then
    role_w=1
    mode_w=7
    account_min=10
  fi

  max_profile_w=$((cols - role_w - mode_w - account_min - 3))
  profile_w="$wanted_profile_w"
  (( profile_w > max_profile_w )) && profile_w="$max_profile_w"
  if (( cols < 23 )); then
    (( profile_w < 4 )) && profile_w=4
  else
    (( profile_w < 5 )) && profile_w=5
  fi
  account_w=$((cols - role_w - profile_w - mode_w - 3))
  (( account_w < account_min )) && account_w="$account_min"

  printf '%s\t%s\t%s\t%s\n' "$role_w" "$profile_w" "$mode_w" "$account_w"
}

profile_list_mode_label() {
  local mode="$1"
  local width="$2"

  if (( width <= 4 )); then
    case "$mode" in
      chatgpt)
        printf 'chat'
        ;;
      api_key)
        printf 'api'
        ;;
      unknown|"")
        printf 'n/a'
        ;;
      *)
        fit_text "$mode" "$width"
        ;;
    esac
  else
    fit_text "$(auth_mode_display_label "$mode")" "$width"
  fi
}

auth_mode_display_label() {
  local mode="$1"

  case "$mode" in
    chatgpt)
      printf 'ChatGPT'
      ;;
    api_key)
      printf 'API key'
      ;;
    unknown|"")
      printf 'n/a'
      ;;
    *)
      printf '%s' "$mode"
      ;;
  esac
}

profile_alias_text() {
  local base="$1"
  local alias_label="$2"

  if usage_unicode_enabled; then
    printf '%s ↔ %s' "$base" "$alias_label"
  else
    printf '%s = %s' "$base" "$alias_label"
  fi
}

profile_compact_alias_text() {
  local alias_label="$1"

  if usage_unicode_enabled; then
    printf '↔ %s' "$alias_label"
  else
    printf '= %s' "$alias_label"
  fi
}

profile_fit_alias_prefix() {
  local alias_label="$1"
  local width="$2"

  if usage_unicode_enabled; then
    printf '↔'
  else
    printf '='
  fi
  fit_profile_text "$alias_label" "$((width - 1))"
}

profile_account_alias_display() {
  local hint="$1"
  local width="$2"
  local verbose="$3"
  local alias_of="$4"
  local alias_label base alias_text compact_alias

  alias_label="$(usage_display_profile_name "$alias_of" "" "$width")"
  if (( verbose )) && [[ -n "$hint" ]]; then
    base="$hint"
  else
    base="$(short_account_hint "$hint" 13)"
  fi
  alias_text="$(profile_alias_text "$base" "$alias_label")"
  compact_alias="$(profile_compact_alias_text "$alias_label")"
  if (( ${#alias_text} > width )) && (( verbose )); then
    base="$(short_account_hint "$hint" 13)"
    alias_text="$(profile_alias_text "$base" "$alias_label")"
  fi
  if (( ${#alias_text} <= width )); then
    printf '%s' "$alias_text"
  elif (( ${#compact_alias} <= width )); then
    printf '%s' "$compact_alias"
  elif (( width >= 5 )); then
    alias_label="$(usage_display_profile_name "$alias_of" "" "$((width - 2))")"
    compact_alias="$(profile_compact_alias_text "$alias_label")"
    if (( ${#compact_alias} <= width )); then
      printf '%s' "$compact_alias"
    else
      profile_fit_alias_prefix "$alias_label" "$width"
    fi
  elif (( width >= 2 )); then
    profile_fit_alias_prefix "$alias_label" "$width"
  else
    fit_text "$(short_account_hint "$hint" "$width")" "$width"
  fi
}

print_profile_list_line() {
  local role="$1"
  local profile="$2"
  local mode="$3"
  local account="$4"
  local role_w="$5"
  local profile_w="$6"
  local mode_w="$7"
  local account_w="$8"
  local role_tone="muted"

  if [[ "$role" == "$(usage_active_glyph)" || "$role" == "active" || "$role" == "stay" || "$role" == "s" || "$role" == "*" ]]; then
    role_tone="active"
  fi
  case "$role" in
    use|u)
      role_tone="good"
      ;;
    alias|a|=)
      role_tone="warn"
      ;;
  esac
  print_toned_fit "$role" "$role_w" "$role_tone"
  printf ' '
  fit_profile_text "$(usage_display_profile_name "$profile" "$role" "$profile_w")" "$profile_w"
  printf ' '
  profile_list_mode_label "$mode" "$mode_w"
  printf ' '
  fit_profile_text_rtrim "$account" "$account_w"
  printf '\n'
}

profile_list_action_label() {
  local role="$1"
  local width="$2"

  if (( width <= 1 )); then
    case "$role" in
      stay)
        printf 's'
        ;;
      alias)
        printf 'a'
        ;;
      use)
        printf 'u'
        ;;
      *)
        printf ''
        ;;
    esac
    return 0
  fi

  case "$role" in
    stay)
      printf 'stay'
      ;;
    alias)
      printf 'alias'
      ;;
    use)
      printf 'use'
      ;;
    *)
      printf ''
      ;;
  esac
}

detail_widths() {
  local cols="$1"
  local label_w=8
  local value_w

  if (( cols < 39 )); then
    label_w=8
  elif (( cols >= 72 )); then
    label_w=10
  fi
  value_w=$((cols - label_w - 1))
  (( value_w < 10 )) && value_w=10

  printf '%s\t%s\n' "$label_w" "$value_w"
}

print_detail_line() {
  local label="$1"
  local value="$2"
  local label_w="$3"
  local value_w="$4"
  local tone="${5:-muted}"

  print_toned_fit "$label" "$label_w" "$tone"
  printf ' '
  fit_profile_text_rtrim "$value" "$value_w"
  printf '\n'
}

print_detail_text_line() {
  local label="$1"
  local value="$2"
  local label_w="$3"
  local value_w="$4"
  local tone="${5:-muted}"

  print_toned_fit "$label" "$label_w" "$tone"
  printf ' '
  fit_text_rtrim "$value" "$value_w"
  printf '\n'
}

path_row_widths() {
  local cols="$1"
  local role_w=5
  local target_w=8
  local path_w

  if (( cols < 22 )); then
    role_w=5
    target_w=0
  elif (( cols < 39 )); then
    role_w=5
    target_w=0
  elif (( cols >= 72 )); then
    role_w=6
    target_w=9
  fi
  if (( target_w <= 0 )); then
    path_w=$((cols - role_w - 1))
  else
    path_w=$((cols - role_w - target_w - 2))
  fi
  (( path_w < 8 )) && path_w=8
  printf '%s\t%s\t%s\n' "$role_w" "$target_w" "$path_w"
}

path_basename_if_fits() {
  local path="$1"
  local path_w="$2"
  local base

  [[ "$path" == */* ]] || return 1
  base="${path##*/}"
  (( ${#base} <= path_w )) || return 1
  printf '%s' "$base"
}

path_rendered_value() {
  local target="$1" path="$2" target_w="$3" path_w="$4"
  local rendered base

  rendered="$(compact_display_path "$path" "$path_w")"
  if (( target_w <= 0 )) && { (( path_w < 24 )) && [[ "$target" != "auth" ]] || [[ "$rendered" == "…/"* || "$rendered" == "*/"* ]]; }; then
    base="$(path_basename_if_fits "$path" "$path_w" || true)"
    rendered="${base:-$rendered}"
  fi
  if (( ${#rendered} > path_w )); then
    base="$(path_basename_if_fits "$path" "$path_w" || true)"
    rendered="${base:-$rendered}"
  fi
  if (( target_w <= 0 )) && [[ "$target" == "usage" && "$path_w" -lt 15 ]]; then
    base="state.json"
    (( ${#base} <= path_w )) && rendered="$base"
  fi
  printf '%s' "$rendered"
}

print_path_line() {
  local role="$1" target="$2" path="$3" role_w="$4" target_w="$5" path_w="$6"
  local tone="${7:-muted}" rendered role_label target_label

  rendered="$(path_rendered_value "$target" "$path" "$target_w" "$path_w")"
  role_label="$role"
  if (( role_w <= 4 )); then
    case "$role" in
      saved) role_label="save" ;;
      cache) role_label="cach" ;;
    esac
  fi
  print_toned_fit "$role_label" "$role_w" "$tone"
  printf ' '
  if (( target_w > 0 )); then
    target_label="$target"
    if (( target_w <= 4 )); then
      case "$target" in
        profiles) target_label="prof" ;;
        backups) target_label="back" ;;
        usage) target_label="usg" ;;
      esac
    fi
    fit_text "$target_label" "$target_w"
    printf ' '
  fi
  fit_profile_text_rtrim "$rendered" "$path_w"
  printf '\n'
}

compact_command_display() {
  local command="$1"
  local width="$2"

  if (( ${#command} > width )) && [[ "$command" == codex-auth\ * ]]; then
    command="${command#codex-auth }"
  fi
  if (( ${#command} > width )) && [[ "$command" == "add current --current" ]]; then
    command="save current"
  fi
  if (( ${#command} > width )) && [[ "$command" == "save current" ]]; then
    command="current"
  fi
  printf '%s' "$command"
}

result_title_for_summary() {
  local summary="$1"

  case "$summary" in
    active\ *|using\ profile\ *)
      printf 'Active profile'
      ;;
    saved\ *|login\ *|imported\ *|saved\ profile\ *|logged\ in\ profile\ *|imported\ profile\ *)
      printf 'Saved profile'
      ;;
    export\ *|exported\ profile\ *)
      printf 'Export'
      ;;
    removed\ active\ *|removed\ *|removed\ active\ profile\ *|removed\ profile\ *)
      printf 'Removed profile'
      ;;
    *)
      printf 'Result'
      ;;
  esac
}

result_detail_label() {
  local label="$1"
  local summary="${2:-}"

  case "$label" in
    auth)
      printf 'live'
      ;;
    profile)
      if [[ "$summary" == removed* ]]; then
        printf 'gone'
      else
        printf 'saved'
      fi
      ;;
    source)
      printf 'from'
      ;;
    dest)
      printf 'out'
      ;;
    backup)
      printf 'undo'
      ;;
    active)
      printf 'state'
      ;;
    *)
      printf '%s' "$label"
      ;;
  esac
}

result_value_path() {
  local path="$1"
  local width="$2"
  local base

  if [[ "$path" == */* ]] && (( width < 18 )); then
    base="${path##*/}"
    fit_profile_text_rtrim "$base" "$width"
    return 0
  fi
  compact_display_path "$path" "$width"
}

result_summary_display() {
  local summary="$1"
  local width="$2"

  if (( width < 24 )) && [[ "$summary" == removed\ active\ * ]]; then
    printf 'removed %s' "${summary#removed active }"
  else
    printf '%s' "$summary"
  fi
}

result_backup_value() {
  local value="$1"
  local value_w="$2"

  if [[ "$value" == */* ]]; then
    if [[ "${CODEX_AUTH_SHOW_BACKUP_PATH:-0}" != "1" ]]; then
      printf 'created'
    elif (( value_w < 46 )); then
      printf 'created'
    else
      compact_display_path "$value" "$value_w"
    fi
  else
    printf '%s' "$value"
  fi
}

result_detail_value() {
  local label="$1"
  local value="$2"
  local value_w="$3"

  case "$label" in
    backup)
      result_backup_value "$value" "$value_w"
      ;;
    active|profile|source|dest|dir|auth|profiles|backups|state)
      if [[ "$value" == */* ]]; then
        result_value_path "$value" "$value_w"
      else
        printf '%s' "$value"
      fi
      ;;
    *)
      printf '%s' "$value"
      ;;
  esac
}

result_compact_active_value() {
  local label="$1"
  local value="$2"
  local value_w="$3"

  if [[ "$label" == "active" && "$value" == "unsaved auth" && "$value_w" -lt 12 ]]; then
    printf 'unsaved'
  elif [[ "$label" == "active" && "$value" == "already active" && "$value_w" -lt 14 ]]; then
    printf 'already'
  elif [[ "$label" == "active" && "$value" == saved\ * && "$value_w" -lt 12 ]]; then
    printf 'saved'
  else
    printf '%s' "$value"
  fi
}

print_result_row() {
  local summary="$1"
  local row="$2"
  local label_w="$3"
  local value_w="$4"
  local label value tone display_label

  IFS=$'\t' read -r label value tone <<<"$row"
  [[ -n "$tone" ]] || tone="muted"
  value="$(result_detail_value "$label" "$value" "$value_w")"
  value="$(result_compact_active_value "$label" "$value" "$value_w")"
  display_label="$(result_detail_label "$label" "$summary")"
  print_detail_line "$display_label" "$value" "$label_w" "$value_w" "$tone"
}

print_result_block() {
  local summary="$1"
  shift
  local cols label_w value_w total_w row title display_summary

  cols="$(terminal_width)"
  IFS=$'\t' read -r label_w value_w <<<"$(detail_widths "$cols")"
  total_w=$((label_w + 1 + value_w))
  USAGE_COLOR_ENABLED=0
  color_enabled && USAGE_COLOR_ENABLED=1

  title="$(result_title_for_summary "$summary")"
  display_summary="$(result_summary_display "$summary" "$total_w")"
  print_palette_summary_header "Auth" "$title" "$display_summary" "$total_w"
  for row in "$@"; do
    print_result_row "$summary" "$row" "$label_w" "$value_w"
  done
}

compact_width_choice() {
  local cols="$1"
  local cutoff="$2"
  local short="$3"
  local wide="$4"

  if (( cols < cutoff )); then
    printf '%s' "$short"
  else
    printf '%s' "$wide"
  fi
}

compact_value_choice() {
  local cols="$1"
  local cutoff="$2"
  local short_format="$3"
  local wide_format="$4"
  local value="$5"

  if (( cols < cutoff )); then
    printf "$short_format" "$value"
  else
    printf "$wide_format" "$value"
  fi
}

compact_missing_dir_message() {
  local cols="$1"
  local base="$2"

  if (( cols < 24 )); then
    printf 'missing dir'
  elif (( cols < 28 )); then
    printf 'missing dir %s' "$base"
  else
    printf 'missing dir: %s' "$base"
  fi
}

COMPACT_ERROR_STATIC_ROWS=(
  $'refusing to remove without --yes\t-\tremove needs --yes'
  $'usage: --ttl seconds\t-\tttl needs seconds'
  $'usage: codex-auth add <name> --file <file>\t28\tadd needs file\tadd needs --file <file>'
  $'usage: codex-auth add <name> [--current | --file <file> | codex login args...]\t28\tadd needs name\tusage: add <name>'
  $'add accepts one source: --current or --file\t40\tchoose one source\tchoose --current or --file'
  $'add cannot mix --file/--current with login args\t40\tfile + login args\tcannot mix file and login args'
  $'no active auth to save\t-\tno active auth'
  $'jq is required for usage output\t24\tjq needed\tjq needed for usage'
  $'jq is required for usage refresh\t24\tjq needed\tjq needed for refresh'
  $'jq is required for recovery\t24\tjq needed\tjq needed for recover'
  $'node needed for codex\t24\tnode needed\tnode needed for codex'
  $'codex command not found\t32\tcodex missing\tcodex command not found'
  $'auth change already running\t32\tauth busy\tauth change busy'
  $'could not hide active auth for login\t32\thide auth failed\tcould not hide active auth'
  $'login failed; restored previous auth\t32\tlogin failed; restored\tlogin failed; auth restored'
  $'login did not produce valid auth; restored previous auth\t32\tbad login auth; restored\tlogin auth invalid; restored'
  $'login did not produce valid auth\t32\tbad login auth\tlogin auth invalid'
  $'profile names may only use letters, numbers, dot, underscore, and dash\t28\tbad profile name\tbad name: A-Z 0-9 . _ -'
  $'usage: codex-auth list [-v]\t-\tusage: list [-v]'
  $'usage: codex-auth remove <name> --yes\t28\tremove name --yes\tusage: remove <name> --yes'
  $'usage: codex-auth import <name> <file>\t34\timport name file\tusage: import <name> <file>'
  $'usage: codex-auth export <name> <file>\t34\texport name file\tusage: export <name> <file>'
  $'usage: codex-auth save <name> [file]\t34\tsave name file\tusage: save <name> [file]'
  $'usage: codex-auth use <name>\t34\tuse name\tusage: use <name>'
  $'usage: codex-auth login <name> [codex login args...]\t28\tlogin needs name\tusage: login <name>'
)

COMPACT_ERROR_PREFIX_ROWS=(
  $'auth file not found: \tbase\t28\tmissing %s\tmissing file: %s'
  $'auth file is empty: \tbase\t28\tempty %s\tempty file: %s'
  $'not a Codex auth.json with OPENAI_API_KEY or tokens: \tbase\t28\tbad auth %s\tbad auth file: %s'
  $'export dir missing: \tdir'
  $'export path is a directory: \tbase\t60\texport path is dir\texport path is dir: %s'
  $'unknown command: \tcommand\t28\tunknown %s\tunknown %s; help\t. Use: codex-auth help'
  $'unknown usage option: \traw\t28\tbad opt %s\tunknown option %s'
  $'profile not found: \tprofile'
)

compact_error_static_message() {
  local cols="$1"
  local message="$2"
  local row source cutoff short wide

  for row in "${COMPACT_ERROR_STATIC_ROWS[@]}"; do
    IFS=$'\t' read -r source cutoff short wide <<<"$row"
    if [[ "$message" == "$source" ]]; then
      if [[ "$cutoff" == "-" ]]; then
        printf '%s' "$short"
      else
        compact_width_choice "$cols" "$cutoff" "$short" "$wide"
      fi
      return 0
    fi
  done
  return 1
}

compact_profile_not_found_message() {
  local cols="$1"
  local tail="$2"

  if (( cols < 40 )); then
    tail="$(fit_profile_text_rtrim "$tail" "$((cols - 15))")"
    printf 'missing %s' "$tail"
  else
    printf 'not found: %s' "$tail"
  fi
}

compact_error_prefixed_message() {
  local cols="$1"
  local message="$2"
  local row prefix kind cutoff short wide suffix tail value

  for row in "${COMPACT_ERROR_PREFIX_ROWS[@]}"; do
    IFS=$'\t' read -r prefix kind cutoff short wide suffix <<<"$row"
    [[ "$message" == "$prefix"* ]] || continue
    tail="${message#"$prefix"}"
    case "$kind" in
      base)
        value="${tail##*/}"
        ;;
      dir)
        compact_missing_dir_message "$cols" "${tail##*/}"
        return 0
        ;;
      command)
        value="${tail%"$suffix"}"
        ;;
      raw)
        value="$tail"
        ;;
      profile)
        compact_profile_not_found_message "$cols" "$tail"
        return 0
        ;;
    esac
    compact_value_choice "$cols" "$cutoff" "$short" "$wide" "$value"
    return 0
  done
  return 1
}

compact_error_message() {
  local message="$1"
  local cols="$2"

  if (( cols < 68 )); then
    if compact_error_static_message "$cols" "$message"; then
      return 0
    fi
    if compact_error_prefixed_message "$cols" "$message"; then
      return 0
    fi
  fi

  if (( cols < 32 )) && [[ "$message" == usage:\ codex-auth\ * ]]; then
    printf 'usage:%s' "${message#usage: codex-auth}"
    return 0
  fi

  printf '%s' "$message"
}

print_error_prefix() {
  if usage_unicode_enabled || (( $1 < 30 )); then
    printf '! '
  else
    printf 'error: '
  fi
}

print_error_has_body() {
  [[ "$1" != "$2" && "$1" != "$3" ]]
}

print_error() {
  local message="$*"
  local cols prefix indent current word candidate rendered line_prefix line_width
  local wrote_line=0
  local words=()
  local line_prefixes=()

  cols="$(terminal_width)"
  message="$(compact_error_message "$message" "$cols")"
  prefix="$(print_error_prefix "$cols")"
  indent="$(printf '%*s' "${#prefix}" '')"
  line_prefixes=("$prefix" "$indent")
  current="$prefix"
  read -r -a words <<<"$message"

  for word in "${words[@]}"; do
    if (( ${#current} == ${#prefix} || ${#current} == ${#indent} )); then
      candidate="${current}${word}"
    else
      candidate="$current $word"
    fi

    if (( ${#candidate} <= cols )); then
      current="$candidate"
      continue
    fi

    if print_error_has_body "$current" "$prefix" "$indent"; then
      rendered="$(fit_text_rtrim "$current" "$cols")"
      printf '%s\n' "$rendered" >&2
      wrote_line=1
    fi

    if (( ${#prefix} + ${#word} > cols )); then
      line_prefix="${line_prefixes[$wrote_line]}"
      line_width=$((cols - ${#line_prefix}))
      line_width=$(( line_width < 1 ? 1 : line_width ))
      rendered="$(fit_profile_text_rtrim "$word" "$line_width")"
      printf '%s%s\n' "$line_prefix" "$rendered" >&2
      wrote_line=1
      current="$indent"
    else
      current="${indent}${word}"
    fi
  done

  if print_error_has_body "$current" "$prefix" "$indent"; then
    rendered="$(fit_text_rtrim "$current" "$cols")"
    printf '%s\n' "$rendered" >&2
  fi
}

print_empty_profiles() {
  local cols label_w value_w total_w command action saved_path

  cols="$(terminal_width)"
  IFS=$'\t' read -r label_w value_w <<<"$(detail_widths "$cols")"
  total_w=$((label_w + 1 + value_w))
  USAGE_COLOR_ENABLED=0
  color_enabled && USAGE_COLOR_ENABLED=1

  print_palette_summary_header "Auth" "Profiles" "no saved profiles" "$total_w"
  if [[ -f "$AUTH_FILE" ]]; then
    if (( total_w < 32 )); then
      command="current"
    else
      command="codex-auth add current --current"
    fi
    action="save"
  else
    command="codex-auth add <name>"
    action="login"
  fi
  print_detail_text_line "$action" "$(compact_command_display "$command" "$value_w")" "$label_w" "$value_w" active
  if (( value_w < 13 )); then
    saved_path="profiles"
  elif (( value_w < 18 )); then
    saved_path="$(basename "$PROFILE_DIR")"
  else
    saved_path="$(compact_display_path "$PROFILE_DIR" "$value_w")"
  fi
  print_detail_line "saved" "$saved_path" "$label_w" "$value_w" good
}

print_no_active_auth() {
  local cols label_w value_w total_w first_profile next_command action

  cols="$(terminal_width)"
  IFS=$'\t' read -r label_w value_w <<<"$(detail_widths "$cols")"
  total_w=$((label_w + 1 + value_w))
  USAGE_COLOR_ENABLED=0
  color_enabled && USAGE_COLOR_ENABLED=1

  shopt -s nullglob
  local profiles=("$PROFILE_DIR"/*.json)
  shopt -u nullglob

  print_palette_summary_header "Auth" "Active profile" "no active auth" "$total_w"
  if (( ${#profiles[@]} > 0 )); then
    first_profile="$(basename "${profiles[0]}" .json)"
    next_command="$first_profile"
    action="use"
  else
    next_command="codex-auth add <name>"
    action="login"
  fi
  print_detail_text_line "$action" "$(compact_command_display "$next_command" "$value_w")" "$label_w" "$value_w" active
  print_detail_line "live" "$(compact_display_path "$AUTH_FILE" "$value_w")" "$label_w" "$value_w" bad
}

print_bad_active_auth() {
  local cols label_w value_w total_w first_profile next_command action

  cols="$(terminal_width)"
  IFS=$'\t' read -r label_w value_w <<<"$(detail_widths "$cols")"
  total_w=$((label_w + 1 + value_w))
  USAGE_COLOR_ENABLED=0
  color_enabled && USAGE_COLOR_ENABLED=1

  shopt -s nullglob
  local profiles=("$PROFILE_DIR"/*.json)
  shopt -u nullglob

  print_palette_summary_header "Auth" "Active profile" "bad active auth" "$total_w"
  print_detail_line "live" "$(compact_display_path "$AUTH_FILE" "$value_w")" "$label_w" "$value_w" bad
  if (( ${#profiles[@]} > 0 )); then
    first_profile="$(basename "${profiles[0]}" .json)"
    next_command="$first_profile"
    action="use"
  else
    if (( total_w < 24 )); then
      next_command="login"
    else
      next_command="codex-auth login <name>"
    fi
    action="fix"
  fi
  print_detail_text_line "$action" "$(compact_command_display "$next_command" "$value_w")" "$label_w" "$value_w" active
}

status_note_base() {
  local kind="$1"
  local -n line_ref="$2"
  local -n tone_ref="$3"
  local glyph

  case "$kind" in
    refresh)
      if usage_unicode_enabled; then
        line_ref="↻ refresh"
      else
        line_ref="refresh"
      fi
      tone_ref="accent"
      ;;
    ready)
      line_ref="ready"
      tone_ref="good"
      ;;
    blocked)
      line_ref="! blocked"
      tone_ref="bad"
      ;;
    cache)
      line_ref="cache"
      tone_ref="warn"
      ;;
    recover)
      if usage_unicode_enabled; then
        line_ref="↳ recover"
      else
        line_ref="recover"
      fi
      tone_ref="accent"
      ;;
    roll)
      line_ref="roll"
      tone_ref="warn"
      ;;
    *)
      glyph="$(usage_meta_glyph)"
      line_ref="$glyph $kind"
      ;;
  esac
}

status_note_apply_detail() {
  local kind="$1"
  local cols="$2"
  local -n line_ref="$3"
  local -n detail_ref="$4"

  case "$kind:$detail_ref" in
    "ready:already on best profile")
      if (( cols < 28 )); then
        line_ref="already best"
      else
        line_ref="already on best profile"
      fi
      detail_ref=""
      ;;
    "blocked:no ready profile")
      line_ref="! no ready profile"
      detail_ref=""
      ;;
    "blocked:choose switch/login/skip")
      line_ref="! choose row"
      detail_ref=""
      ;;
    "cache:refresh busy")
      detail_ref="busy"
      ;;
    "roll:usage limit, rotating")
      line_ref="roll auth"
      (( cols >= 32 )) && detail_ref="resume"
      ;;
  esac
}

status_note_compact_overflow() {
  local kind="$1"
  local detail="$2"
  local -n line_ref="$3"
  local compact_detail

  case "$kind:$detail" in
    "blocked:no ready profile")
      line_ref="! no ready profile"
      ;;
    "ready:already on best profile")
      line_ref="ready already best"
      ;;
    "recover:latest session")
      if usage_unicode_enabled; then
        line_ref="↳ recover latest"
      else
        line_ref="recover latest"
      fi
      ;;
    "recover:session "*)
      compact_detail="${detail#session }"
      if usage_unicode_enabled; then
        line_ref="↳ recover $compact_detail"
      else
        line_ref="recover $compact_detail"
      fi
      ;;
  esac
}

print_status_note() {
  local kind="$1"
  local detail="${2:-}"
  local cols line tone="muted"

  cols="$(terminal_width)"
  status_note_base "$kind" line tone
  status_note_apply_detail "$kind" "$cols" line detail
  [[ -n "$detail" ]] && line+=" $detail"
  if (( ${#line} > cols )); then
    status_note_compact_overflow "$kind" "$detail" line
  fi

  USAGE_COLOR_ENABLED=0
  color_enabled && USAGE_COLOR_ENABLED=1
  usage_tone_color "$tone"
  fit_text_rtrim "$line" "$cols"
  usage_tone_reset
  printf '\n'
}

profile_list_summary() {
  local count="$1"
  local active_name="$2"
  local alias_count="$3"
  local total_w="$4"
  local summary="profiles $count"
  local active_summary active_label active_short active_tiny alias_summary sep

  if [[ -n "$active_name" ]]; then
    sep="$(usage_separator)"
    active_short="$(usage_display_profile_name "$active_name" "" 6)"
    active_tiny="$(usage_display_profile_name "$active_name" "" 3)"
    for active_label in "active $active_name" "act $active_name" "act $active_short" "act $active_tiny"; do
      active_summary="$summary$sep$active_label"
      if (( ${#active_summary} <= total_w )); then
        summary="$active_summary"
        break
      fi
    done
  fi
  if (( alias_count > 0 )); then
    alias_summary="$summary$(usage_separator)aliases $alias_count"
    if (( ${#alias_summary} <= total_w )); then
      summary="$alias_summary"
    fi
  fi

  printf '%s' "$summary"
}

profile_list_note_account() {
  local name="$1"
  local hint="$2"
  local -n account_count_ref="$3"
  local -n account_primary_ref="$4"
  local -n alias_count_ref="$5"

  [[ -n "$hint" ]] || return 0
  account_count_ref["$hint"]=$(( ${account_count_ref["$hint"]:-0} + 1 ))
  if (( account_count_ref["$hint"] > 1 )); then
    alias_count_ref=$((alias_count_ref + 1))
  fi
  if [[ -z "${account_primary_ref["$hint"]:-}" || ( "${account_primary_ref["$hint"]:-}" == "current" && "$name" != "current" ) ]]; then
    account_primary_ref["$hint"]="$name"
  fi
}

profile_list_alias_of() {
  local hint="$1"
  local name="$2"
  local -n account_count_ref="$3"
  local -n account_primary_ref="$4"

  if [[ -n "$hint" && "${account_count_ref["$hint"]:-0}" -gt 1 && "$name" != "${account_primary_ref["$hint"]:-}" ]]; then
    printf '%s' "${account_primary_ref["$hint"]}"
  fi
}

profile_list_row_action() {
  local active_name="$1"
  local name="$2"
  local alias_of="$3"
  local active_fp="$4"
  local fp="$5"

  if [[ -n "$active_name" && "$name" == "$active_name" ]]; then
    printf 'stay'
  elif [[ -n "$alias_of" ]]; then
    printf 'alias'
  elif [[ -n "$active_fp" && "$fp" == "$active_fp" ]]; then
    printf 'alias'
  else
    printf 'use'
  fi
}

current_profile_summary() {
  local matched="$1"
  local mode="$2"
  local hint="$3"
  local account_display="$4"
  local total_w="$5"
  local mode_display="$6"
  local mode_summary_display="$mode_display"
  local matched_display summary

  if (( total_w < 24 )); then
    mode_summary_display="$(profile_list_mode_label "$mode" 4)"
  fi
  matched_display="$matched"
  if [[ -n "$matched_display" && "$total_w" -lt 22 ]]; then
    matched_display="$(usage_display_profile_name "$matched_display" "" 6)"
  fi
  if [[ -n "$matched" ]]; then
    summary="active $matched_display$(usage_separator)$mode_summary_display"
  elif (( total_w < 22 )); then
    summary="unsaved$(usage_separator)$mode_summary_display"
  else
    summary="active unsaved$(usage_separator)$mode_summary_display"
  fi
  if [[ -n "$hint" ]] && (( ${#summary} + ${#account_display} + 11 <= total_w )); then
    summary+="$(usage_separator)account $account_display"
  fi
  printf '%s' "$summary"
}

current_codex_status() {
  local mode_display="$1"
  local value_w="$2"
  local codex_cli status_text

  codex_cli="$(codex_bin || true)"
  [[ -n "$codex_cli" ]] || return 0
  codex_launcher_ready "$codex_cli" || return 0
  status_text="$(CODEX_AUTH_RUNNER=1 "$codex_cli" login status 2>&1 || true)"
  status_text="$(printf '%s\n' "$status_text" | sed '/^WARNING: proceeding, even though we could not update PATH:/d' | tr '\n\t' '  ' | sed 's/  */ /g; s/^ //; s/ $//')"
  status_text="$(compact_codex_status "$status_text" "$value_w")"
  if [[ -n "$status_text" && "$status_text" != "$mode_display" ]]; then
    printf '%s' "$status_text"
  fi
}

parse_list_args() {
  local -n list_verbose_ref="$1"
  shift

  while (( $# > 0 )); do
    case "$1" in
      --verbose|-v)
        list_verbose_ref=1
        shift
        ;;
      *)
        die "usage: codex-auth list [-v]"
        ;;
    esac
  done
}

profile_list_load_metadata() {
  local -n files_ref="$1"
  local -n active_fp_ref="$2"
  local -n profile_mode_ref="$3"
  local -n profile_hint_ref="$4"
  local -n profile_fp_ref="$5"
  local fp meta_path mode hint secret name

  while IFS=$'\037' read -r meta_path mode hint secret; do
    [[ -n "$meta_path" ]] || continue
    fp="$(auth_record_fingerprint "$secret")"
    if [[ "$meta_path" == "$AUTH_FILE" ]]; then
      active_fp_ref="$fp"
    else
      name="$(basename "$meta_path" .json)"
      profile_mode_ref["$name"]="$mode"
      profile_hint_ref["$name"]="$hint"
      profile_fp_ref["$name"]="$fp"
    fi
  done < <(auth_metadata_records "${files_ref[@]}")
}

profile_list_scan_profiles() {
  local active_fp="$1"
  local account_count_var="$6"
  local account_primary_var="$7"
  local alias_count_var="${10}"
  local -n profiles_ref="$2"
  local -n profile_mode_ref="$3"
  local -n profile_hint_ref="$4"
  local -n profile_fp_ref="$5"
  local -n account_count_ref="$account_count_var"
  local -n account_primary_ref="$account_primary_var"
  local -n active_name_ref="$8"
  local -n count_ref="$9"
  local -n alias_count_ref="$alias_count_var"
  local path name mode hint fp

  PROFILE_LIST_WIDTH_HINT=12
  for path in "${profiles_ref[@]}"; do
    name="$(basename "$path" .json)"
    (( ${#name} > PROFILE_LIST_WIDTH_HINT )) && PROFILE_LIST_WIDTH_HINT="${#name}"
    mode="${profile_mode_ref["$name"]:-unknown}"
    hint="${profile_hint_ref["$name"]:-}"
    fp="${profile_fp_ref["$name"]:-}"
    if [[ -z "$active_name_ref" && -n "$active_fp" && "$fp" == "$active_fp" ]]; then
      active_name_ref="$name"
    fi
    profile_list_note_account "$name" "$hint" "$account_count_var" "$account_primary_var" "$alias_count_var"
    count_ref=$((count_ref + 1))
  done
}

print_profile_list_header() {
  local count="$1"
  local active_name="$2"
  local alias_count="$3"
  local role_w="$4"
  local profile_w="$5"
  local mode_w="$6"
  local account_w="$7"
  local total_w summary role_header profile_header

  total_w=$((role_w + 1 + profile_w + 1 + mode_w + 1 + account_w))
  summary="$(profile_list_summary "$count" "$active_name" "$alias_count" "$total_w")"
  print_palette_summary_header "Auth" "Saved profiles" "$summary" "$total_w"
  role_header="$(compact_width_choice "$role_w" 2 "" "act")"
  profile_header="$(compact_width_choice "$profile_w" 7 "prof" "profile")"
  print_profile_list_line "$role_header" "$profile_header" "auth" "account" "$role_w" "$profile_w" "$mode_w" "$account_w"
}

print_profile_list_rows() {
  local active_name="$1"
  local active_fp="$2"
  local list_verbose="$3"
  local role_w="$4"
  local profile_w="$5"
  local mode_w="$6"
  local account_w="$7"
  local account_count_var="${12}"
  local account_primary_var="${13}"
  local -n profiles_ref="$8"
  local -n profile_mode_ref="$9"
  local -n profile_hint_ref="${10}"
  local -n profile_fp_ref="${11}"
  local -n account_count_ref="$account_count_var"
  local -n account_primary_ref="$account_primary_var"
  local path name mode hint fp action alias_of account_display account_base

  for path in "${profiles_ref[@]}"; do
    name="$(basename "$path" .json)"
    mode="${profile_mode_ref["$name"]:-unknown}"
    hint="${profile_hint_ref["$name"]:-}"
    fp="${profile_fp_ref["$name"]:-}"
    alias_of="$(profile_list_alias_of "$hint" "$name" "$account_count_var" "$account_primary_var")"
    action="$(profile_list_row_action "$active_name" "$name" "$alias_of" "$active_fp" "$fp")"
    if [[ -n "$alias_of" ]]; then
      account_display="$(profile_account_alias_display "$hint" "$account_w" "$list_verbose" "$alias_of")"
    elif [[ -n "$hint" ]]; then
      if (( list_verbose )); then
        account_base="$(verbose_account_hint "$hint" "$account_w")"
      else
        account_base="$(short_account_hint "$hint" "$account_w")"
      fi
      account_display="$(fit_text "$account_base" "$account_w")"
    else
      account_display=""
    fi
    print_profile_list_line "$(profile_list_action_label "$action" "$role_w")" "$name" "$mode" "$account_display" "$role_w" "$profile_w" "$mode_w" "$account_w"
  done
}

cmd_list() {
  ensure_dirs
  local list_verbose=0
  parse_list_args list_verbose "$@"

  shopt -s nullglob
  local profiles=("$PROFILE_DIR"/*.json)
  if (( ${#profiles[@]} == 0 )); then
    print_empty_profiles
    return 0
  fi

  local active_fp=""
  local active_name="" count=0
  local alias_count=0
  local meta_files=()
  local -A account_primary=()
  local -A account_count=()
  local -A profile_mode=()
  local -A profile_hint=()
  local -A profile_fp=()

  [[ -f "$AUTH_FILE" ]] && meta_files+=("$AUTH_FILE")
  meta_files+=("${profiles[@]}")
  profile_list_load_metadata meta_files active_fp profile_mode profile_hint profile_fp
  profile_list_scan_profiles "$active_fp" profiles profile_mode profile_hint profile_fp account_count account_primary active_name count alias_count

  local cols role_w profile_w mode_w account_w
  cols="$(terminal_width)"
  USAGE_COLOR_ENABLED=0
  color_enabled && USAGE_COLOR_ENABLED=1
  USAGE_VERBOSE="$list_verbose"
  IFS=$'\t' read -r role_w profile_w mode_w account_w <<<"$(profile_list_widths "$cols")"

  print_profile_list_header "$count" "$active_name" "$alias_count" "$role_w" "$profile_w" "$mode_w" "$account_w"
  print_profile_list_rows "$active_name" "$active_fp" "$list_verbose" "$role_w" "$profile_w" "$mode_w" "$account_w" profiles profile_mode profile_hint profile_fp account_count account_primary
}

current_meta_files_into() {
  local -n files_ref="$1"
  local path

  shopt -s nullglob
  files_ref+=("$AUTH_FILE")
  for path in "$PROFILE_DIR"/*.json; do
    files_ref+=("$path")
  done
}

current_load_metadata() {
  local -n files_ref="$1"
  local -n fp_map_ref="$2"
  local -n active_fp_ref="$3"
  local -n active_mode_ref="$4"
  local -n active_hint_ref="$5"
  local fp meta_path secret meta_mode meta_hint

  while IFS=$'\037' read -r meta_path meta_mode meta_hint secret; do
    [[ -n "$meta_path" ]] || continue
    fp="$(auth_record_fingerprint "$secret")"
    fp_map_ref["$meta_path"]="$fp"
    if [[ "$meta_path" == "$AUTH_FILE" ]]; then
      active_fp_ref="$fp"
      active_mode_ref="${meta_mode:-unknown}"
      active_hint_ref="${meta_hint:-}"
    fi
  done < <(auth_metadata_records "${files_ref[@]}")
}

current_matched_profile() {
  local active_fp="$1"
  local -n fp_map_ref="$2"
  local path fp

  [[ -n "$active_fp" ]] || return 0
  shopt -s nullglob
  for path in "$PROFILE_DIR"/*.json; do
    fp="${fp_map_ref["$path"]:-}"
    if [[ "$fp" == "$active_fp" ]]; then
      basename "$path" .json
      return 0
    fi
  done
}

cmd_current() {
  ensure_dirs
  local cols label_w value_w total_w status_text
  cols="$(terminal_width)"
  IFS=$'\t' read -r label_w value_w <<<"$(detail_widths "$cols")"
  if (( cols < 68 )); then
    label_w=7
    value_w=$((cols - label_w - 1))
    (( value_w < 10 )) && value_w=10
  fi
  total_w=$((label_w + 1 + value_w))
  USAGE_COLOR_ENABLED=0
  color_enabled && USAGE_COLOR_ENABLED=1

  if [[ ! -f "$AUTH_FILE" ]]; then
    print_no_active_auth
    return 0
  fi
  if ! auth_file_is_valid "$AUTH_FILE"; then
    print_bad_active_auth
    return 0
  fi

  local active_fp="" mode mode_display matched hint account_display summary
  local active_mode="" active_hint=""
  local meta_files=()
  local -A meta_fp=()

  current_meta_files_into meta_files
  current_load_metadata meta_files meta_fp active_fp active_mode active_hint
  mode="${active_mode:-unknown}"
  mode_display="$(auth_mode_display_label "$mode")"
  hint="${active_hint:-}"
  active_fp="${active_fp:-}"
  account_display="$(short_account_hint "$hint" "$value_w")"
  matched="$(current_matched_profile "$active_fp" meta_fp)"
  summary="$(current_profile_summary "$matched" "$mode" "$hint" "$account_display" "$total_w" "$mode_display")"

  print_palette_summary_header "Auth" "Active profile" "$summary" "$total_w" flat 0
  if [[ -n "$hint" && "$summary" != *"account "* ]]; then
    print_detail_line "account" "$account_display" "$label_w" "$value_w"
  fi
  status_text="$(current_codex_status "$mode_display" "$value_w")"
  if [[ -n "$status_text" ]]; then
    print_detail_text_line "codex" "$status_text" "$label_w" "$value_w"
  fi
}

cmd_save() {
  local name="$1"
  local source="${2:-$AUTH_FILE}"
  local summary="${3:-saved $name}"
  require_name "$name"
  ensure_dirs
  acquire_mutation_lock
  if [[ "$source" == "$AUTH_FILE" && ! -f "$source" ]]; then
    die "no active auth to save"
  fi
  require_auth_file "$source"

  local dest
  dest="$(profile_path "$name")"
  copy_auth_file_atomic "$source" "$dest"
  print_result_block "$summary" \
    "profile"$'\t'"$(display_path "$dest")"$'\t'"active" \
    "source"$'\t'"$(display_path "$source")"$'\t'"muted"
}

cmd_import() {
  local name="$1"
  local source="$2"
  cmd_save "$name" "$source" "imported $name"
}

cmd_use() {
  local name="$1"
  require_name "$name"
  ensure_dirs
  acquire_mutation_lock

  local source source_fp="" active_fp=""
  source="$(profile_path "$name")"
  [[ -f "$source" ]] || die "profile not found: $name"
  require_auth_file "$source"

  source_fp="$(credential_fingerprint "$source" || true)"
  if [[ -f "$AUTH_FILE" ]]; then
    active_fp="$(credential_fingerprint "$AUTH_FILE" || true)"
  fi
  if [[ -n "$source_fp" && -n "$active_fp" && "$source_fp" == "$active_fp" ]]; then
    print_result_block "active $name" \
      "auth"$'\t'"$(display_path "$AUTH_FILE")"$'\t'"active" \
      "profile"$'\t'"$(display_path "$source")"$'\t'"muted" \
      "active"$'\t'"already active"$'\t'"active"
    return 0
  fi

  local backup=""
  backup="$(backup_current "pre-use-$name" || true)"
  copy_auth_file_atomic "$source" "$AUTH_FILE"

  if [[ -n "$backup" ]]; then
    print_result_block "active $name" \
      "auth"$'\t'"$(display_path "$AUTH_FILE")"$'\t'"active" \
      "profile"$'\t'"$(display_path "$source")"$'\t'"muted" \
      "backup"$'\t'"$(display_path "$backup")"$'\t'"muted"
  else
    print_result_block "active $name" \
      "auth"$'\t'"$(display_path "$AUTH_FILE")"$'\t'"active" \
      "profile"$'\t'"$(display_path "$source")"$'\t'"muted"
  fi
}

login_fail_with_restore() {
  local hidden_auth="$1"
  local restored_message="$2"
  local plain_message="$3"
  local message="$plain_message"

  if restore_hidden_auth "$hidden_auth"; then
    message="$restored_message"
  fi
  print_error "$message"
  exit 1
}

hide_active_auth_for_login() {
  local name="$1" hidden_auth=""

  [[ -f "$AUTH_FILE" ]] || return 0
  hidden_auth="$(reserve_unique_backup_path "hidden-for-login-$name")"
  mv "$AUTH_FILE" "$hidden_auth" || { rm -f "$hidden_auth"; die "could not hide active auth for login"; }
  chmod 600 "$hidden_auth"
  printf '%s' "$hidden_auth"
}

cmd_login() {
  local name="$1"
  shift || true
  require_name "$name"
  [[ -t 0 && -t 1 ]] || die "login needs tty"
  local codex_cli
  codex_cli="$(codex_bin)" || die "codex command not found"
  require_codex_launcher "$codex_cli"
  ensure_dirs
  acquire_mutation_lock

  backup_current "pre-login-$name" >/dev/null || true

  local hidden_auth="$(hide_active_auth_for_login "$name")"

  CODEX_AUTH_RUNNER=1 "$codex_cli" login "$@" || login_fail_with_restore "$hidden_auth" "login failed; restored previous auth" "login failed"

  auth_file_is_valid "$AUTH_FILE" || login_fail_with_restore "$hidden_auth" "login did not produce valid auth; restored previous auth" "login did not produce valid auth"

  cmd_save "$name" "$AUTH_FILE" "login $name"
  rm -f "$hidden_auth"
}

parse_add_positional_arg() {
  local arg="$1"
  local -n add_source_ref="$2"
  local -n add_source_seen_ref="$3"
  local -n add_login_args_ref="$4"

  if [[ -f "$arg" && -z "$add_source_ref" ]]; then
    add_source_ref="$arg"
    add_source_seen_ref=1
  else
    add_login_args_ref+=("$arg")
  fi
}

parse_add_args() {
  local source_var="$1"
  local source_seen_var="$2"
  local login_args_var="$3"
  local -n source_ref="$source_var"
  local -n source_seen_ref="$source_seen_var"
  local -n login_args_ref="$login_args_var"
  shift 3

  while (( $# > 0 )); do
    case "$1" in
      --current)
        (( source_seen_ref == 0 )) || die "add accepts one source: --current or --file"
        source_ref="$AUTH_FILE"
        source_seen_ref=1
        shift
        ;;
      --file|--from)
        [[ -n "${2:-}" ]] || die "usage: codex-auth add <name> --file <file>"
        (( source_seen_ref == 0 )) || die "add accepts one source: --current or --file"
        source_ref="$2"
        source_seen_ref=1
        shift 2
        ;;
      --)
        shift
        login_args_ref+=("$@")
        break
        ;;
      *)
        parse_add_positional_arg "$1" "$source_var" "$source_seen_var" "$login_args_var"
        shift
        ;;
    esac
  done
}

cmd_add() {
  local name="${1:-}"
  [[ -n "$name" ]] || die "usage: codex-auth add <name> [--current | --file <file> | codex login args...]"
  shift || true
  require_name "$name"

  local source=""
  local source_seen=0
  local login_args=()

  parse_add_args source source_seen login_args "$@"

  if [[ -n "$source" ]]; then
    (( ${#login_args[@]} == 0 )) || die "add cannot mix --file/--current with login args"
    cmd_save "$name" "$source"
    return 0
  fi

  cmd_login "$name" "${login_args[@]}"
}

cmd_export() {
  local name="$1"
  local dest="$2"
  require_name "$name"
  ensure_dirs

  local source dest_dir
  source="$(profile_path "$name")"
  [[ -f "$source" ]] || die "profile not found: $name"
  require_auth_file "$source"
  dest_dir="$(dirname "$dest")"
  [[ -d "$dest_dir" ]] || die "export dir missing: $dest_dir"
  [[ ! -d "$dest" ]] || die "export path is a directory: $dest"
  copy_auth_file_atomic "$source" "$dest"
  print_result_block "export $name" \
    "dest"$'\t'"$(display_path "$dest")"$'\t'"active" \
    "source"$'\t'"$(display_path "$source")"$'\t'"muted"
}

now_epoch() {
  date +%s
}

window_label() {
  local mins="${1:-}"
  if [[ ! "$mins" =~ ^[0-9]+$ || "$mins" == "0" ]]; then
    printf 'short'
  elif (( mins % 1440 == 0 )); then
    printf '%dd' "$((mins / 1440))"
  elif (( mins >= 60 && mins % 60 >= 55 )); then
    printf '%dh' "$(((mins + 59) / 60))"
  elif (( mins % 60 == 0 )); then
    printf '%dh' "$((mins / 60))"
  else
    printf '%dm' "$mins"
  fi
}

color_enabled() {
  [[ -t 1 && -z "${NO_COLOR:-}" ]]
}

usage_color_active() {
  [[ "${USAGE_COLOR_ENABLED:-0}" == "1" ]]
}

terminal_width() {
  local cols
  cols="${COLUMNS:-}"
  if [[ ! "$cols" =~ ^[0-9]+$ ]]; then
    cols="$(tput cols 2>/dev/null || true)"
  fi
  [[ "$cols" =~ ^[0-9]+$ ]] || cols=100
  (( cols < 20 )) && cols=20
  printf '%s\n' "$cols"
}

repeat_glyph() {
  local glyph="$1"
  local width="${2:-0}"
  local i

  for ((i = 0; i < width; i++)); do
    printf '%s' "$glyph"
  done
}

usage_unicode_enabled() {
  [[ "${CODEX_AUTH_ASCII:-0}" != "1" ]]
}

usage_glyph() {
  local unicode="$1"
  local ascii="${2:-}"

  if usage_unicode_enabled; then
    printf '%s' "$unicode"
  else
    printf '%s' "$ascii"
  fi
}

usage_rule_glyph() {
  usage_glyph '─' '-'
}

usage_meta_glyph() {
  usage_glyph '·' '.'
}

usage_active_glyph() {
  usage_glyph '●' '*'
}

usage_reset_glyph() {
  usage_glyph '↺'
}

usage_separator() {
  usage_glyph ' · ' ' | '
}

usage_trunc_glyph() {
  usage_glyph '…' '~'
}

fit_text() {
  local text="$1"
  local width="$2"
  local length=${#text}
  local trunc_glyph

  if (( width <= 0 )); then
    return 0
  fi
  trunc_glyph="$(usage_trunc_glyph)"
  if (( length <= width )); then
    printf '%-*s' "$width" "$text"
  elif (( width == 1 )); then
    printf '%s' "$trunc_glyph"
  else
    printf '%s%s' "${text:0:width-1}" "$trunc_glyph"
  fi
}

rtrim_spaces() {
  local text="$1"

  while [[ "$text" == *" " ]]; do
    text="${text% }"
  done
  printf '%s' "$text"
}

fit_text_rtrim() {
  local rendered

  rendered="$(fit_text "$1" "$2")"
  rtrim_spaces "$rendered"
}

fit_text_center() {
  local text="$1"
  local width="$2"
  local rendered left right

  if (( width <= 0 )); then
    return 0
  fi

  rendered="$(fit_text_rtrim "$text" "$width")"
  left=$(((width - ${#rendered} + 1) / 2))
  right=$((width - ${#rendered} - left))
  (( left > 0 )) && printf '%*s' "$left" ''
  printf '%s' "$rendered"
  (( right > 0 )) && printf '%*s' "$right" ''
  return 0
}

fit_profile_text() {
  local text="$1"
  local width="$2"
  local length=${#text}
  local trunc_glyph left right rendered pad

  if (( width <= 0 )); then
    return 0
  fi
  if (( length <= width || width < 3 )); then
    fit_text "$text" "$width"
    return 0
  fi

  trunc_glyph="$(usage_trunc_glyph)"
  if (( width <= 5 )); then
    left=2
  elif (( width <= 8 )); then
    left=3
  else
    left=$(((width - 1) / 2))
  fi
  right=$((width - left - 1))
  (( right < 1 )) && right=1
  (( left + right + 1 > width )) && left=$((width - right - 1))

  rendered="${text:0:left}${trunc_glyph}${text:length-right:right}"
  printf '%s' "$rendered"
  pad=$((width - ${#rendered}))
  (( pad > 0 )) && printf '%*s' "$pad" ''
  return 0
}

fit_profile_text_rtrim() {
  local rendered

  rendered="$(fit_profile_text "$1" "$2")"
  rtrim_spaces "$rendered"
}

usage_tone_code() {
  local mode="$1"
  local tone="${2:-}"
  local color=""

  usage_color_active || return 0
  case "$tone" in
    good) color="166;227;161" ;;
    warn|accent) color="250;178;131" ;;
    active|secondary) color="157;124;216" ;;
    bad) color="224;108;117" ;;
    track_edge) color="16;16;16" ;;
  esac
  case "$mode:$tone" in
    38:border) color="50;50;50" ;;
    38:muted) color="128;128;128" ;;
    48:track) color="35;35;35" ;;
  esac
  [[ -n "$color" ]] && printf '\033[%s;2;%sm' "$mode" "$color"
  return 0
}

usage_tone_color() {
  usage_tone_code 38 "${1:-}"
}

usage_tone_reset() {
  usage_color_active && printf '\033[0m'
  return 0
}

usage_tone_bg() {
  usage_tone_code 48 "${1:-}"
}

usage_limit_tone() {
  local percent="${1:-}"
  local value

  percent="${percent%\%}"
  if [[ ! "$percent" =~ ^-?[0-9]+$ ]]; then
    printf 'muted'
    return 0
  fi

  value="$percent"
  if (( value <= 0 )); then
    printf 'bad'
  elif (( value < 25 )); then
    printf 'bad'
  elif (( value < 50 )); then
    printf 'warn'
  else
    printf 'good'
  fi
}

usage_role_tone() {
  case "${1:-}" in
    best|b|◆|+)
      printf 'accent'
      ;;
    active|stay|s|●|\*)
      printf 'active'
      ;;
    use|u)
      printf 'good'
      ;;
    same|a)
      printf 'muted'
      ;;
    cap|c)
      printf 'bad'
      ;;
    login|l)
      printf 'warn'
      ;;
    *)
      printf 'muted'
      ;;
  esac
}

usage_status_tone() {
  local status="${1:-}"
  local valid="${2:-0}"

  if [[ "$status" == "offline" || "$status" == "refresh timeout" || "$status" == "refresh unavailable" ]]; then
    printf 'warn'
  elif [[ "$valid" != "0" || "$status" == "login" ]]; then
    printf 'muted'
  elif [[ "$status" == stale* ]]; then
    printf 'warn'
  elif [[ "$status" == "ok" ]]; then
    printf 'good'
  elif [[ "$status" == *cap* ]]; then
    printf 'bad'
  else
    printf 'bad'
  fi
}

print_toned_fit() {
  local text="$1"
  local width="$2"
  local tone="${3:-}"

  usage_tone_color "$tone"
  fit_text "$text" "$width"
  usage_tone_reset
}

print_toned_fit_rtrim() {
  local text="$1"
  local width="$2"
  local tone="${3:-}"

  usage_tone_color "$tone"
  fit_text_rtrim "$text" "$width"
  usage_tone_reset
}

print_toned_fit_center() {
  local text="$1"
  local width="$2"
  local tone="${3:-}"

  usage_tone_color "$tone"
  fit_text_center "$text" "$width"
  usage_tone_reset
}

usage_record_group() {
  local valid="${1:-0}"
  local status="${2:-}"

  if [[ "$status" == "offline" ]]; then
    printf 'offline'
  elif [[ "$status" == "login" ]]; then
    printf 'login'
  elif [[ "$valid" != "0" || "$status" == "no data" || "$status" == "no usage" ]]; then
    printf 'unavailable'
  elif [[ "$status" == stale* ]]; then
    printf 'stale'
  elif [[ "$status" == "ok" ]]; then
    printf 'ready'
  else
    printf 'limited'
  fi
}

usage_section_rule() {
  local width="$1"
  local label="${2:-}"
  local text rule_glyph
  rule_glyph="$(usage_rule_glyph)"

  if [[ -n "$label" ]]; then
    case "$label" in
      limited) text="limits" ;;
      login) text="auth" ;;
      stale) text="stale cache" ;;
      unavailable) text="no data" ;;
      *) text="$label" ;;
    esac
    printf '%s' "$text"
  else
    repeat_glyph "$rule_glyph" "$width"
  fi
}

print_usage_section_rule() {
  local width="$1"
  local label="${2:-}"
  local tone="muted"

  case "$label" in
    limited|cap) tone="bad" ;;
    login|offline) tone="warn" ;;
    ready) tone="good" ;;
  esac
  usage_tone_color "$tone"
  usage_section_rule "$width" "$label"
  usage_tone_reset
  printf '\n'
}

usage_bar() {
  local percent="${1:-}"
  local width="${2:-8}"
  local value units max_units full partial empty_count
  local filled_glyph="█"
  local empty_glyph="░"
  local partial_glyphs=("" "▏" "▎" "▍" "▌" "▋" "▊" "▉")
  local ascii_single_glyphs=("." "+" "#")

  [[ "${CODEX_AUTH_ASCII:-0}" == "1" ]] && empty_glyph="."
  if ! value="$(usage_clamped_percent "$percent")"; then
    repeat_glyph "$empty_glyph" "$width"
    return 0
  fi

  if [[ "${CODEX_AUTH_ASCII:-0}" == "1" ]]; then
    if (( width == 1 )); then
      printf '%s' "${ascii_single_glyphs[$(( value <= 0 ? 0 : value >= 100 ? 2 : 1 ))]}"
      return 0
    fi
    full=$(((value * width + 50) / 100))
    full="$(clamp_int_between "$full" 0 "$width")"
    repeat_glyph "#" "$full"
    repeat_glyph "$empty_glyph" "$((width - full))"
    return 0
  fi

  units=$(((value * width * 8 + 50) / 100))
  max_units=$((width * 8))
  units="$(clamp_int_between "$units" 0 "$max_units")"
  full=$((units / 8))
  partial=$((units % 8))
  empty_count=$((width - full))
  (( partial > 0 && empty_count > 0 )) && empty_count=$((empty_count - 1))

  repeat_glyph "$filled_glyph" "$full"
  printf '%s' "${partial_glyphs[$partial]}"
  repeat_glyph "$empty_glyph" "$empty_count"
}

usage_bar_rail() {
  local percent="$1"
  local width="$2"
  local tone="${3:-}"
  local inner_w left_rail right_rail

  if (( width < 3 )); then
    usage_tone_color "$tone"
    usage_bar "$percent" "$width"
    usage_tone_reset
    return 0
  fi

  inner_w=$((width - 2))
  if usage_unicode_enabled; then
    left_rail="▕"
    right_rail="▐"
  else
    left_rail="["
    right_rail="]"
  fi

  usage_tone_color muted
  printf '%s' "$left_rail"
  usage_tone_reset
  usage_tone_color "$tone"
  usage_bar "$percent" "$inner_w"
  usage_tone_reset
  usage_tone_color muted
  printf '%s' "$right_rail"
  usage_tone_reset
}

usage_render_total_width() {
  local role_w="$1"
  local profile_w="$2"
  local cell_w="$3"
  local status_w="$4"
  local role_profile_gap status_gap

  role_profile_gap=$((1 + (role_w > 1)))
  status_gap="$role_profile_gap"
  if (( status_w > 0 )); then
    printf '%s' "$((role_w + role_profile_gap + profile_w + 1 + cell_w + 1 + cell_w + status_gap + status_w))"
  else
    printf '%s' "$((role_w + role_profile_gap + profile_w + 1 + cell_w + 1 + cell_w))"
  fi
}

clamp_int_between() {
  local value="$1"
  local min="$2"
  local max="$3"

  if (( value < min )); then
    printf '%s' "$min"
  elif (( value > max )); then
    printf '%s' "$max"
  else
    printf '%s' "$value"
  fi
}

usage_profile_width_hint() {
  local cols="$1"
  local wanted="$2"
  local verbose="${3:-0}"
  local row row_verbose threshold min_w max_w
  local rows=(
    "1 112 18 28"
    "1 94 14 24"
    "1 0 12 24"
    "0 112 20 30"
    "0 94 18 28"
    "0 72 14 24"
    "0 0 12 24"
  )

  if [[ ! "$wanted" =~ ^[0-9]+$ ]]; then
    wanted=12
  fi

  for row in "${rows[@]}"; do
    read -r row_verbose threshold min_w max_w <<<"$row"
    if (( verbose == row_verbose && cols >= threshold )); then
      clamp_int_between "$wanted" "$min_w" "$max_w"
      return 0
    fi
  done
}

usage_width_row_matches() {
  local row="$1"
  local cols="$2"
  local verbose="$3"
  local row_min row_max row_verbose

  read -r row_min row_max row_verbose _ <<<"$row"
  (( cols >= row_min && cols <= row_max )) || return 1
  (( row_verbose < 0 || row_verbose == verbose ))
}

usage_width_apply_status_defaults() {
  local cols="$1"
  local verbose="$2"
  local -n mode_ref="$3"
  local -n role_w_ref="$4"
  local -n status_min_ref="$5"
  local -n label_w_ref="$6"
  local -n max_bar_w_ref="$7"

  if (( verbose && cols >= 68 )) && [[ "$mode_ref" == "tight" ]]; then
    status_min_ref=12
  fi
  if (( ! verbose )); then
    if (( cols >= 61 )); then
      role_w_ref=5
      status_min_ref=12
    else
      role_w_ref=1
    fi
    return 0
  fi
  case "$mode_ref" in
    pico|nano|micro|tiny|tight)
      return 0
      ;;
  esac
  label_w_ref=6
  max_bar_w_ref=12
  if (( cols >= 112 )); then
    max_bar_w_ref=20
  elif (( cols >= 94 )); then
    max_bar_w_ref=14
  fi
  return 0
}

usage_width_mode_defaults() {
  local cols="$1"
  local verbose="${2:-0}"
  local row
  local mode role_w profile_min status_min reset_w label_w min_bar_w max_bar_w
  local rows=(
    "0 25 -1 pico 1 4 3 0 4 0 0"
    "26 39 -1 nano 1 5 3 0 4 0 0"
    "40 49 -1 micro 1 8 5 0 4 3 8"
    "50 59 -1 tiny 1 8 5 5 4 3 8"
    "60 71 -1 tight 6 8 7 5 4 4 8"
    "72 93 1 compact 6 8 12 5 4 5 12"
    "72 93 0 normal 6 8 12 11 4 4 16"
    "94 111 1 normal 7 8 12 11 4 4 18"
    "94 111 0 normal 7 8 12 11 4 4 20"
    "112 9999 1 wide 7 8 12 11 4 4 18"
    "112 9999 0 wide 7 8 12 11 4 4 22"
  )

  for row in "${rows[@]}"; do
    usage_width_row_matches "$row" "$cols" "$verbose" || continue
    read -r _ _ _ mode role_w profile_min status_min reset_w label_w min_bar_w max_bar_w <<<"$row"
    break
  done

  usage_width_apply_status_defaults "$cols" "$verbose" mode role_w status_min label_w max_bar_w

  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$mode" "$role_w" "$profile_min" "$status_min" "$reset_w" "$label_w" "$min_bar_w" "$max_bar_w"
}

usage_mode_is_pico_or_nano() {
  case "$1" in
    pico|nano)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

usage_mode_shows_used_percent_label() {
  case "$1" in
    pico|nano|micro|tiny|tight)
      return 1
      ;;
    *)
      return 0
      ;;
  esac
}

usage_limit_cell_reset_label() {
  local mode="$1"
  local reset_label="$2"

  if [[ "$mode" == "micro" || "$mode" == "nano" ]]; then
    reset_label=""
  elif [[ ( "$mode" == "compact" || "$mode" == "tight" || "$mode" == "tiny" ) && "$reset_label" == *" "* ]]; then
    reset_label="${reset_label##* }"
  fi
  (( USAGE_VERBOSE )) || reset_label=""

  printf '%s' "$reset_label"
}

usage_limit_cell_set_labels() {
  local percent="$1"
  local mode="$2"
  local used_percent="${3:-}"
  local -n percent_label_ref="$4"
  local -n reset_label_ref="$5"
  local -n reset_prefix_ref="$6"
  local -n label_w_ref="$7"

  if [[ "$percent" == "-" ]]; then
    percent_label_ref="$(usage_meta_glyph)"
    [[ "$mode" == "micro" || "$mode" == "nano" ]] || reset_label_ref="$(usage_meta_glyph)"
  elif (( USAGE_VERBOSE )) && usage_mode_shows_used_percent_label "$mode" && [[ "$used_percent" =~ ^[0-9]+$ ]]; then
    percent_label_ref="${percent%\%}/${used_percent}%"
    label_w_ref=6
  elif (( ! USAGE_VERBOSE )); then
    percent_label_ref="${percent%\%}"
  elif [[ -n "$reset_label_ref" ]]; then
    reset_prefix_ref="$(usage_reset_glyph)"
  fi
  if [[ -n "$reset_label_ref" && -z "$reset_prefix_ref" && "$percent" != "-" ]]; then
    reset_prefix_ref="$(usage_reset_glyph)"
  fi
}

usage_print_limit_cell_reset() {
  local reset_label="$1"
  local reset_prefix="$2"
  local -n visible_ref="$3"

  [[ -n "$reset_label" ]] || return 0
  usage_tone_color muted
  if [[ -n "$reset_prefix" ]]; then
    printf ' %s%s' "$reset_prefix" "$reset_label"
    visible_ref=$((visible_ref + 1 + ${#reset_prefix} + ${#reset_label}))
  else
    printf ' %s' "$reset_label"
    visible_ref=$((visible_ref + 1 + ${#reset_label}))
  fi
  usage_tone_reset
  return 0
}

usage_print_limit_empty_cell() {
  local percent_label="$1"
  local reset_label="$2"
  local label_w="$3"
  local cell_w="$4"
  local tone="$5"
  local visible pad

  usage_tone_color "$tone"
  printf "%${label_w}s" "$percent_label"
  usage_tone_reset
  visible="$label_w"
  usage_print_limit_cell_reset "$reset_label" "" visible
  pad=$((cell_w - visible))
  (( pad > 0 )) && printf '%*s' "$pad" ''
  return 0
}

usage_print_limit_bar_cell() {
  local percent="$1"
  local percent_label="$2"
  local reset_label="$3"
  local reset_prefix="$4"
  local label_w="$5"
  local bar_width="$6"
  local cell_w="$7"
  local tone="$8"
  local visible pad

  usage_tone_color "$tone"
  printf "%${label_w}s " "$percent_label"
  usage_tone_reset
  usage_bar_rail "$percent" "$bar_width" "$tone"
  visible=$((label_w + 1 + bar_width))
  usage_print_limit_cell_reset "$reset_label" "$reset_prefix" visible
  pad=$((cell_w - visible))
  (( pad > 0 )) && printf '%*s' "$pad" ''
  return 0
}

print_usage_limit_cell() {
  local percent="$1"
  local reset_time="$2"
  local mode="$3"
  local bar_width="$4"
  local cell_w="$5"
  local used_percent="${6:-}"
  local reset_label="$reset_time"
  local percent_label="$percent"
  local reset_prefix=""
  local label_w=4
  local tone

  reset_label="$(usage_limit_cell_reset_label "$mode" "$reset_label")"
  usage_limit_cell_set_labels "$percent" "$mode" "$used_percent" percent_label reset_label reset_prefix label_w
  tone="$(usage_limit_tone "$percent")"
  if usage_mode_is_pico_or_nano "$mode"; then
    [[ "$percent" == "-" ]] && percent_label="$(usage_meta_glyph)"
    usage_tone_color "$tone"
    fit_text_center "$percent_label" "$cell_w"
    usage_tone_reset
    return 0
  fi

  if [[ "$percent" == "-" ]]; then
    usage_print_limit_empty_cell "$percent_label" "$reset_label" "$label_w" "$cell_w" "$tone"
    return 0
  fi

  usage_print_limit_bar_cell "$percent" "$percent_label" "$reset_label" "$reset_prefix" "$label_w" "$bar_width" "$cell_w" "$tone"
  return 0
}

usage_reset_prefix_width() {
  local reset_w="$1"

  if (( reset_w > 0 )) && usage_unicode_enabled; then
    printf '1'
  else
    printf '0'
  fi
}

usage_cell_overhead() {
  local mode="$1"
  local label_w="$2"
  local reset_w="$3"
  local reset_prefix_w="$4"

  if [[ "$mode" == "pico" ]]; then
    printf '%s' "$label_w"
  elif (( reset_w > 0 )); then
    printf '%s' "$((label_w + 2 + reset_w + reset_prefix_w))"
  else
    printf '%s' "$((label_w + 1))"
  fi
}

usage_max_profile_width() {
  local cols="$1"
  local role_w="$2"
  local status_min="$3"
  local cell_overhead="$4"
  local min_bar_w="$5"
  local gap_w="$6"

  printf '%s' "$(( cols - role_w - status_min - (2 * (cell_overhead + min_bar_w)) - gap_w ))"
}

usage_tight_width_fallback() {
  local cols="$1"
  local role_w="$2"
  local status_min="$3"
  local min_bar_w="$4"
  local gap_w="$5"
  local mode="tight"
  local reset_w=5
  local label_w=4
  local reset_prefix_w cell_overhead max_profile_w

  reset_prefix_w="$(usage_reset_prefix_width "$reset_w")"
  cell_overhead="$(usage_cell_overhead "$mode" "$label_w" "$reset_w" "$reset_prefix_w")"
  max_profile_w="$(usage_max_profile_width "$cols" "$role_w" "$status_min" "$cell_overhead" "$min_bar_w" "$gap_w")"
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$mode" "$reset_w" "$label_w" "$reset_prefix_w" "$cell_overhead" "$max_profile_w"
}

usage_initial_metric_widths() {
  local cols="$1"
  local role_w="$2"
  local profile_w="$3"
  local status_min="$4"
  local gap_w="$5"
  local cell_overhead="$6"
  local min_bar_w="$7"
  local max_bar_w="$8"
  local available cell_w bar_width status_w

  available=$(( cols - role_w - profile_w - status_min - gap_w ))
  cell_w=$(( available / 2 ))
  bar_width=$(( cell_w - cell_overhead ))
  bar_width="$(clamp_int_between "$bar_width" "$min_bar_w" "$max_bar_w")"
  cell_w=$(( bar_width + cell_overhead ))
  status_w=$(( cols - role_w - profile_w - cell_w - cell_w - gap_w ))
  printf '%s\t%s\t%s\n' "$cell_w" "$bar_width" "$status_w"
}

usage_fit_status_widths() {
  local -n profile_w_ref="$1"
  local -n cell_w_ref="$2"
  local -n bar_width_ref="$3"
  local -n status_w_ref="$4"
  local cols="$5"
  local role_w="$6"
  local profile_min="$7"
  local status_min="$8"
  local gap_w="$9"
  local cell_overhead="${10}"
  local min_bar_w="${11}"

  while (( status_w_ref < status_min && bar_width_ref > min_bar_w )); do
    bar_width_ref=$((bar_width_ref - 1))
    cell_w_ref=$(( bar_width_ref + cell_overhead ))
    status_w_ref=$(( cols - role_w - profile_w_ref - cell_w_ref - cell_w_ref - gap_w ))
  done
  while (( status_w_ref < status_min && profile_w_ref > profile_min )); do
    profile_w_ref=$((profile_w_ref - 1))
    status_w_ref=$(( cols - role_w - profile_w_ref - cell_w_ref - cell_w_ref - gap_w ))
  done
  (( status_w_ref < status_min )) && status_w_ref="$status_min"
  return 0
}

usage_status_max_width() {
  local cols="$1"
  local row row_verbose threshold max_w
  local rows=(
    "1 94 16"
    "1 72 14"
    "0 60 13"
    "0 50 9"
  )

  for row in "${rows[@]}"; do
    read -r row_verbose threshold max_w <<<"$row"
    if (( USAGE_VERBOSE == row_verbose && cols >= threshold )); then
      printf '%s' "$max_w"
      return 0
    fi
  done
  printf '0'
}

usage_render_status_width() {
  local show_status="$1"
  local cols="$2"
  local status_w="$3"
  local status_max

  if [[ "$show_status" != "1" ]]; then
    printf '0'
    return 0
  fi
  status_max="$(usage_status_max_width "$cols")"
  if (( status_max > 0 && status_w > status_max )); then
    status_w="$status_max"
  fi
  printf '%s' "$status_w"
}

usage_render_widths() {
  local cols="$1"
  local mode role_w
  local show_status="${CODEX_AUTH_USAGE_STATUS:-0}"
  local profile_w
  local wanted_profile_w="${USAGE_PROFILE_WIDTH_HINT:-12}"
  local profile_min status_min reset_w label_w min_bar_w max_bar_w
  local cell_overhead reset_prefix_w=0
  local cell_w status_w status_max bar_width available max_profile_w
  local role_profile_gap=1 status_gap=1 gap_w=4

  wanted_profile_w="$(usage_profile_width_hint "$cols" "$wanted_profile_w" "$USAGE_VERBOSE")"
  IFS=$'\t' read -r mode role_w profile_min status_min reset_w label_w min_bar_w max_bar_w <<<"$(usage_width_mode_defaults "$cols" "$USAGE_VERBOSE")"
  role_profile_gap=$((1 + (role_w > 1)))
  status_gap="$role_profile_gap"
  if [[ "$show_status" != "1" ]]; then
    status_min=0
    status_gap=0
  fi
  gap_w=$((role_profile_gap + 2 + status_gap))
  if (( ! USAGE_VERBOSE )); then
    reset_w=0
  fi
  reset_prefix_w="$(usage_reset_prefix_width "$reset_w")"
  cell_overhead="$(usage_cell_overhead "$mode" "$label_w" "$reset_w" "$reset_prefix_w")"

  max_profile_w="$(usage_max_profile_width "$cols" "$role_w" "$status_min" "$cell_overhead" "$min_bar_w" "$gap_w")"
  if (( max_profile_w < 12 && reset_w > 5 )); then
    IFS=$'\t' read -r mode reset_w label_w reset_prefix_w cell_overhead max_profile_w <<<"$(usage_tight_width_fallback "$cols" "$role_w" "$status_min" "$min_bar_w" "$gap_w")"
  fi

  profile_w="$(clamp_int_between "$wanted_profile_w" "$profile_min" "$max_profile_w")"
  IFS=$'\t' read -r cell_w bar_width status_w <<<"$(usage_initial_metric_widths "$cols" "$role_w" "$profile_w" "$status_min" "$gap_w" "$cell_overhead" "$min_bar_w" "$max_bar_w")"
  usage_fit_status_widths profile_w cell_w bar_width status_w "$cols" "$role_w" "$profile_min" "$status_min" "$gap_w" "$cell_overhead" "$min_bar_w"
  status_w="$(usage_render_status_width "$show_status" "$cols" "$status_w")"

  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$mode" "$role_w" "$profile_w" "$cell_w" "$status_w" "$bar_width"
}

usage_role_label() {
  local mark="$1"
  local profile="$2"
  local default_profile="$3"
  local mode="${4:-normal}"
  local valid="${5:-0}"
  local status="${6:-}"
  local role_w="${7:-1}"
  local action

  action="$(usage_role_action "$mark" "$profile" "$default_profile" "$valid" "$status")"
  if (( role_w <= 1 )); then
    usage_role_narrow_label "$action"
    return 0
  fi

  printf '%s' "$action"
}

usage_role_action() {
  local mark="$1"
  local profile="$2"
  local default_profile="$3"
  local valid="$4"
  local status="$5"

  if [[ "$mark" == "*" ]]; then
    printf 'stay'
  elif [[ "$mark" == "=" ]]; then
    printf 'same'
  elif [[ -n "$default_profile" && "$profile" == "$default_profile" ]]; then
    printf 'use'
  elif [[ "$status" == *cap* ]]; then
    printf 'cap'
  elif [[ "$status" == "login" ]]; then
    printf 'login'
  elif [[ "$valid" == "0" && "$status" == "ok" ]]; then
    printf 'use'
  fi
}

usage_role_narrow_label() {
  case "$1" in
    stay)
      printf 's'
      ;;
    same)
      printf 'a'
      ;;
    use)
      printf 'u'
      ;;
    cap)
      printf 'c'
      ;;
    login)
      printf 'l'
      ;;
  esac
}

usage_status_is_exact_cap() {
  case "$1" in
    "week+5h cap"|"week cap"|"5h cap")
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

usage_stale_ok_label() {
  local stale_age="$1"
  local aged_format="${2:-old}"

  if [[ -n "$stale_age" && "$stale_age" != "now" ]]; then
    printf "$aged_format" "$stale_age"
  else
    printf 'stale'
  fi
}

usage_display_stale_status() {
  local status="$1"
  local mode="$2"
  local stale_age="$3"

  if usage_mode_is_pico_or_nano "$mode"; then
    if [[ "$status" == *cap ]]; then
      printf 'cap'
    else
      printf 'old'
    fi
  elif [[ "$mode" == "micro" || "$mode" == "tiny" ]]; then
    if [[ "$status" == "ok" ]]; then
      usage_stale_ok_label "$stale_age"
    elif usage_status_is_exact_cap "$status"; then
      printf 'cap'
    else
      printf 'stale'
    fi
  elif [[ "$status" == "ok" ]]; then
    usage_stale_ok_label "$stale_age" 'old %s'
  elif usage_status_is_exact_cap "$status"; then
    printf 'old cap'
  else
    printf 'stale'
  fi
}

usage_display_pico_status() {
  case "$1" in
    ok)
      printf 'ok'
      ;;
    stale\ *\ cap)
      printf 'old'
      ;;
    login)
      printf 'auth'
      ;;
    no\ usage|no\ data)
      printf 'n/a'
      ;;
    *)
      printf '%s' "$1"
      ;;
  esac
}

usage_display_micro_status() {
  case "$1" in
    ok)
      printf 'ready'
      ;;
    stale\ *\ cap)
      printf 'stale'
      ;;
    login)
      printf 'auth'
      ;;
    *)
      printf '%s' "$1"
      ;;
  esac
}

usage_display_normal_status() {
  case "$1" in
    ok)
      printf 'ready'
      ;;
    offline)
      printf 'offline'
      ;;
    login)
      printf 'login'
      ;;
    *)
      printf '%s' "$1"
      ;;
  esac
}

usage_display_status() {
  local status="$1"
  local mode="${2:-normal}"
  local stale_status=0
  local stale_age=""

  if [[ "$status" == stale\ * ]]; then
    stale_status=1
    status="${status#stale }"
    if [[ "$status" =~ ^(now|[0-9]+[mhd])[[:space:]]+(.+)$ ]]; then
      stale_age="${BASH_REMATCH[1]}"
      status="${BASH_REMATCH[2]}"
    fi
  fi

  if (( stale_status )); then
    usage_display_stale_status "$status" "$mode" "$stale_age"
    return 0
  fi

  if usage_status_is_exact_cap "$status"; then
    printf 'cap'
    return 0
  fi

  if usage_mode_is_pico_or_nano "$mode"; then
    usage_display_pico_status "$status"
    return 0
  fi

  if [[ "$mode" == "micro" || "$mode" == "tiny" ]]; then
    usage_display_micro_status "$status"
    return 0
  fi

  usage_display_normal_status "$status"
}

usage_display_layth_number_profile() {
  local profile="$1"
  local width="$2"
  local suffix compact

  [[ "$profile" =~ ^Layth([0-9]+)$ ]] || return 1
  suffix="${BASH_REMATCH[1]}"
  compact="L$suffix"
  if (( ${#compact} <= width )); then
    printf '%s' "$compact"
  else
    printf '%s' "${suffix:0:width}"
  fi
}

usage_display_layth_suffix_profile() {
  local profile="$1"
  local width="$2"
  local suffix

  [[ "$profile" == Layth.* ]] || return 1
  suffix="${profile#Layth.}"
  if (( ${#suffix} <= width )); then
    printf '%s' "$suffix"
  elif (( width <= 5 )); then
    printf '%s' "${suffix:0:width}"
  else
    printf '%s' "$profile"
  fi
}

usage_display_compact_profile_name() {
  local profile="$1"
  local width="$2"

  if usage_display_layth_number_profile "$profile" "$width"; then
    return 0
  fi
  if usage_display_layth_suffix_profile "$profile" "$width"; then
    return 0
  fi
  if (( width <= 5 )); then
    fit_profile_text "$profile" "$width"
  else
    printf '%s' "$profile"
  fi
}

usage_display_profile_name() {
  local profile="$1"
  local role="${2:-}"
  local width="${3:-0}"

  if [[ "$profile" == "current" && "$role" != "active" && "$role" != "●" && "$role" != "*" ]]; then
    if [[ "$width" =~ ^[0-9]+$ && "$width" -gt 0 && "$width" -lt 7 ]]; then
      printf 'cur'
    else
      printf 'current'
    fi
  elif [[ "$profile" == "Layth" && "$width" =~ ^[0-9]+$ && "$width" -gt 0 && "$width" -lt 5 ]]; then
    printf 'Lay'
  elif [[ "$width" =~ ^[0-9]+$ && "$width" -gt 0 && ${#profile} -gt width ]]; then
    usage_display_compact_profile_name "$profile" "$width"
  else
    printf '%s' "$profile"
  fi
}

usage_header_profile() {
  local mode="${1:-normal}"
  if usage_mode_is_pico_or_nano "$mode"; then
    printf 'name'
  else
    printf 'profile'
  fi
}

usage_header_percent_label() {
  local mode="$1"
  local label="$2"
  local nano_label="$3"

  if usage_mode_is_pico_or_nano "$mode"; then
    printf '%s%%' "$nano_label"
  else
    printf '%s%%' "$label"
  fi
}

usage_header_verbose_label() {
  local mode="$1"
  local label="$2"
  local nano_label="$3"
  local reset_glyph="${4:-}"

  case "$mode" in
    pico|nano)
      printf '%s%%' "$nano_label"
      ;;
    micro)
      printf '%s%%' "$label"
      ;;
    tiny)
      if [[ -n "$reset_glyph" ]]; then
        printf '%s%%%s' "$label" "$reset_glyph"
      else
        printf '%s%% reset' "$label"
      fi
      ;;
    tight)
      if [[ -n "$reset_glyph" ]]; then
        printf '%s left%s' "$label" "$reset_glyph"
      else
        printf '%s left reset' "$label"
      fi
      ;;
    compact)
      if [[ -n "$reset_glyph" ]]; then
        printf '%s left/used%s' "$label" "$reset_glyph"
      else
        printf '%s used/reset' "$label"
      fi
      ;;
    *)
      if [[ -n "$reset_glyph" ]]; then
        printf '%s left/used %s reset' "$label" "$reset_glyph"
      else
        printf '%s left/used reset' "$label"
      fi
      ;;
  esac
}

usage_header_week() {
  local mode="${1:-normal}"
  local reset_glyph
  reset_glyph="$(usage_reset_glyph)"

  if (( ! USAGE_VERBOSE )); then
    usage_header_percent_label "$mode" "week" "wk"
    return 0
  fi

  usage_header_verbose_label "$mode" "week" "wk" "$reset_glyph"
}

usage_header_short() {
  local mode="${1:-normal}"
  local label="${USAGE_SHORT_LABEL:-5h}"
  local nano_label
  local reset_glyph

  if [[ "$label" == "short" ]] && usage_mode_is_pico_or_nano "$mode"; then
    label="5h"
  fi
  nano_label="${label:0:2}"
  reset_glyph="$(usage_reset_glyph)"

  if (( ! USAGE_VERBOSE )); then
    usage_header_percent_label "$mode" "$label" "$nano_label"
    return 0
  fi

  usage_header_verbose_label "$mode" "$label" "$nano_label" "$reset_glyph"
}

usage_header_state() {
  local mode="${1:-normal}"
  if usage_mode_is_pico_or_nano "$mode"; then
    printf 'st'
  elif [[ "$mode" == "micro" || "$mode" == "tiny" ]]; then
    printf 'state'
  else
    printf 'status'
  fi
}

usage_fit_header_label() {
  local text="$1"
  local width="$2"
  local compact="$text"

  if [[ "$width" =~ ^[0-9]+$ && "$width" -gt 0 && ${#text} -gt width ]]; then
    case "$text" in
      "weekly left/used ↺ reset")
        compact="week left/used ↺ reset"
        ;;
      "weekly left/used reset")
        compact="week left/used reset"
        ;;
      "weekly left/used "*)
        compact="${text/weekly/week}"
        ;;
    esac
  fi

  if [[ "$width" =~ ^[0-9]+$ && "$width" -gt 0 && ${#compact} -le width ]]; then
    printf '%s' "$compact"
  else
    printf '%s' "$text"
  fi
}

usage_metric_header_cell() {
  local text="$1"
  local width="$2"
  local force_compact="${4:-0}"
  local display="$text"

  if (( USAGE_VERBOSE > force_compact )); then
    usage_fit_header_label "$text" "$width"
    return 0
  fi

  [[ "$display" == "week%" ]] && display="wk%"
  if (( ${#display} > width )); then
    if (( width <= 1 )); then
      display="${display:0:width}"
    elif [[ "$display" == *% ]]; then
      display="${display:0:width-1}%"
    else
      display="${display:0:width}"
    fi
  fi

  fit_text_center "$display" "$width"
  return 0
}

print_usage_render_line() {
  local role="$1"
  local profile="$2"
  local weekly_cell="$3"
  local short_cell="$4"
  local status="$5"
  local role_w="$6"
  local profile_w="$7"
  local cell_w="$8"
  local status_w="$9"
  local prefix="${10:-}"
  local reset="${11:-}"
  local role_profile_gap status_gap

  role_profile_gap=$((1 + (role_w > 1)))
  status_gap="$role_profile_gap"
  printf '%s' "$prefix"
  fit_text "$role" "$role_w"
  printf '%*s' "$role_profile_gap" ''
  fit_text "$profile" "$profile_w"
  printf ' '
  fit_text "$weekly_cell" "$cell_w"
  printf ' '
  fit_text "$short_cell" "$cell_w"
  if (( status_w > 0 )); then
    printf '%*s' "$status_gap" ''
    fit_text "$status" "$status_w"
  fi
  printf '%s\n' "$reset"
}

print_usage_render_header() {
  local role="$1"
  local profile="$2"
  local weekly_cell="$3"
  local short_cell="$4"
  local status="$5"
  local role_w="$6"
  local profile_w="$7"
  local cell_w="$8"
  local status_w="$9"
  local mode="${10:-normal}"
  local reset=""

  weekly_cell="$(usage_metric_header_cell "$weekly_cell" "$cell_w" "$mode")"
  short_cell="$(usage_metric_header_cell "$short_cell" "$cell_w" "$mode")"
  if (( status_w > 0 )); then
    status="$(fit_text_center "$status" "$status_w")"
  else
    status=""
  fi
  usage_color_active && reset=$'\033[0m'
  usage_tone_color muted
  print_usage_render_line "$role" "$profile" "$weekly_cell" "$short_cell" "$status" "$role_w" "$profile_w" "$cell_w" "$status_w" "" "$reset"
}

usage_unavailable_status_cell() {
  local raw_status="$1"
  local display_status="$2"
  local status_w="${3:-0}"
  local status cutoff text

  while IFS=$'\t' read -r status cutoff text; do
    [[ "$raw_status" == "$status" ]] || continue
    (( status_w < cutoff )) || continue
    printf '%s' "$text"
    return 0
  done <<'EOF'
login	4	log
login	6	auth
login	12	login
login	100000	login needed
no data	3	na
no data	7	n/a
no data	100000	no data
no usage	3	na
no usage	8	n/a
no usage	100000	no usage
offline	3	of
offline	7	off
offline	100000	offline
EOF
  printf '%s' "$display_status"
}

print_usage_placeholder_limit_cell() {
  local mode="$1"
  local cell_w="$2"
  local glyph label_w=4 pad

  (( cell_w <= 0 )) && return 0
  glyph="-"
  if [[ "$mode" == "pico" ]]; then
    label_w="$cell_w"
  elif (( USAGE_VERBOSE )) && usage_mode_shows_used_percent_label "$mode"; then
    label_w=6
  fi
  (( label_w > cell_w )) && label_w="$cell_w"

  usage_tone_color muted
  if usage_mode_is_pico_or_nano "$mode"; then
    fit_text_center "$glyph" "$cell_w"
    usage_tone_reset
    return 0
  fi
  printf "%${label_w}s" "$glyph"
  usage_tone_reset
  pad=$((cell_w - label_w))
  (( pad > 0 )) && printf '%*s' "$pad" ''
  return 0
}

print_usage_render_data_line() {
  local role="$1"
  local profile="$2"
  local weekly="$3"
  local weekly_reset="$4"
  local short="$5"
  local short_reset="$6"
  local display_status="$7"
  local raw_status="$8"
  local valid="$9"
  local weekly_used="${10}"
  local short_used="${11}"
  local role_w="${12}"
  local profile_w="${13}"
  local cell_w="${14}"
  local status_w="${15}"
  local bar_width="${16}"
  local mode="${17}"
  local unavailable_text role_profile_gap status_gap

  print_toned_fit "$role" "$role_w" "$(usage_role_tone "$role")"
  role_profile_gap=$((1 + (role_w > 1)))
  status_gap="$role_profile_gap"
  printf '%*s' "$role_profile_gap" ''
  fit_profile_text "$(usage_display_profile_name "$profile" "$role" "$profile_w")" "$profile_w"
  printf ' '
  if [[ "$valid" != "0" ]]; then
    unavailable_text="$(usage_unavailable_status_cell "$raw_status" "$display_status" "$status_w")"
    print_usage_placeholder_limit_cell "$mode" "$cell_w"
    printf ' '
    print_usage_placeholder_limit_cell "$mode" "$cell_w"
    if (( status_w > 0 )); then
      printf '%*s' "$status_gap" ''
      print_toned_fit_center "$unavailable_text" "$status_w" "$(usage_status_tone "$raw_status" "$valid")"
    fi
    printf '\n'
    return 0
  fi

  print_usage_limit_cell "$weekly" "$weekly_reset" "$mode" "$bar_width" "$cell_w" "$weekly_used"
  printf ' '
  print_usage_limit_cell "$short" "$short_reset" "$mode" "$bar_width" "$cell_w" "$short_used"
  if (( status_w > 0 )); then
    printf '%*s' "$status_gap" ''
    print_toned_fit_center "$display_status" "$status_w" "$(usage_status_tone "$raw_status" "$valid")"
  fi
  printf '\n'
}

usage_summary_try_append() {
  local -n line_ref="$1"
  local -n show_ref="$2"
  local part="$3"
  local width="$4"

  if (( ! show_ref )); then
    return 0
  fi
  if (( ${#line_ref} + ${#part} <= width )); then
    line_ref+="$part"
  else
    show_ref=0
  fi
}

usage_summary_note_active_record() {
  local valid="$1"
  local mark="$2"
  local profile="$3"
  local weekly="$4"
  local short="$5"
  local short_label="$6"
  local -n active_profile_ref="$7"
  local -n active_short_ref="$8"
  local -n active_weekly_ref="$9"
  local -n active_label_ref="${10}"
  local -n active_has_usage_ref="${11}"

  [[ "$mark" == "*" ]] || return 0
  active_profile_ref="$profile"
  active_short_ref="$short"
  active_weekly_ref="$weekly"
  if [[ "$valid" == "0" && -n "$short" && "$short" != "-" ]]; then
    [[ -n "$short_label" ]] && active_label_ref="$short_label"
    active_has_usage_ref=1
  elif [[ "$valid" == "0" && -n "$weekly" && "$weekly" != "-" ]]; then
    active_short_ref="$weekly"
    active_label_ref="wk"
    active_has_usage_ref=1
  fi
}

usage_summary_count_record_status() {
  local valid="$1"
  local status="$2"
  local -n caps_ref="$3"
  local -n login_ref="$4"
  local -n unavailable_ref="$5"
  local -n offline_ref="$6"
  local -n stale_ref="$7"
  local -n ready_ref="$8"

  [[ "$status" == stale* ]] && stale_ref=$((stale_ref + 1))
  if [[ "$status" == "offline" ]]; then
    offline_ref=$((offline_ref + 1))
  elif [[ "$status" == "login" ]]; then
    login_ref=$((login_ref + 1))
  elif [[ "$valid" != "0" || "$status" == "no data" || "$status" == "no usage" ]]; then
    unavailable_ref=$((unavailable_ref + 1))
  elif [[ "$status" == *cap* ]]; then
    caps_ref=$((caps_ref + 1))
  elif [[ "$status" == "ok" ]]; then
    ready_ref=$((ready_ref + 1))
  fi
}

usage_summary_note_cache_age() {
  local cache_age="$1"
  local -n cache_age_max_ref="$2"

  if [[ "$cache_age" =~ ^[0-9]+$ ]] && (( cache_age > cache_age_max_ref )); then
    cache_age_max_ref="$cache_age"
  fi
}

usage_summary_scan_record() {
  local record="$1"
  local -n best_profile_out="$2"
  local -n active_profile_out="$3"
  local -n active_short_out="$4"
  local -n active_weekly_out="$5"
  local -n active_label_out="$6"
  local -n active_has_usage_out="$7"
  local -n caps_out="$8"
  local -n login_out="$9"
  local -n unavailable_out="${10}"
  local -n offline_out="${11}"
  local -n stale_out="${12}"
  local -n ready_out="${13}"
  local -n cache_age_max_out="${14}"
  local valid weekly_used short_used mark profile plan weekly short status short_label weekly_reset short_reset cache_age

  IFS=$'\t' read -r valid weekly_used short_used mark profile plan weekly short status short_label weekly_reset short_reset cache_age <<<"$record"
  [[ -n "$profile" ]] || return 0
  usage_summary_note_cache_age "$cache_age" cache_age_max_out
  usage_summary_note_active_record "$valid" "$mark" "$profile" "$weekly" "$short" "$short_label" \
    active_profile_out active_short_out active_weekly_out active_label_out active_has_usage_out
  [[ -z "$best_profile_out" && "$status" == "ok" ]] && best_profile_out="$profile"
  usage_summary_count_record_status "$valid" "$status" caps_out login_out unavailable_out offline_out stale_out ready_out
}

usage_summary_normalize_scan() {
  local -n active_profile_ref="$1"
  local -n active_short_ref="$2"
  local -n active_weekly_ref="$3"
  local -n best_profile_ref="$4"
  local -n has_best_ref="$5"
  local -n has_active_ref="$6"
  local -n old_summary_ref="$7"
  local cache_age_max="$8"
  local stale="$9"
  local ready="${10}"
  local -n cache_age_label_ref="${11}"

  if [[ -n "$best_profile_ref" ]]; then
    has_best_ref=1
  else
    best_profile_ref="none"
  fi
  if [[ -n "$active_profile_ref" ]]; then
    has_active_ref=1
  else
    active_profile_ref="none"
  fi
  [[ -n "$active_short_ref" && "$active_short_ref" != "-" ]] || active_short_ref="n/a"
  [[ -n "$active_weekly_ref" && "$active_weekly_ref" != "-" ]] || active_weekly_ref="n/a"
  if (( cache_age_max >= 0 )); then
    cache_age_label_ref="$(format_cache_age "$cache_age_max")"
  fi
  (( stale > 0 && ready == 0 && has_active_ref )) && old_summary_ref=1
}

usage_summary_scan_records() {
  local default_profile="${1:-}"
  shift || true
  local record
  local active_profile="" active_short="" active_weekly="" active_label="5h"
  local best_profile="$default_profile"
  local caps=0 login=0 unavailable=0 offline=0 stale=0 ready=0
  local cache_age_max=-1 cache_age_label=""
  local cache_age_out
  local has_best=0 has_active=0 active_has_usage=0 old_summary=0

  for record in "$@"; do
    usage_summary_scan_record "$record" best_profile active_profile active_short active_weekly active_label active_has_usage \
      caps login unavailable offline stale ready cache_age_max
  done

  usage_summary_normalize_scan active_profile active_short active_weekly best_profile has_best has_active old_summary \
    "$cache_age_max" "$stale" "$ready" cache_age_label
  cache_age_out="$cache_age_label"
  [[ -n "$cache_age_out" ]] || cache_age_out="__none__"
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
    "$active_profile" "$active_short" "$active_weekly" "$active_label" "$best_profile" \
    "$has_best" "$has_active" "$active_has_usage" "$caps" "$login" "$unavailable" \
    "$offline" "$stale" "$ready" "$cache_age_out" "$old_summary"
}

print_usage_summary_compact_line() {
  local width="$1"
  local has_active="$2"
  local active_has_usage="$3"
  local active_profile="$4"
  local active_label="$5"
  local active_short="$6"
  local caps="$7"
  local ready="$8"
  local has_best="$9"
  local old_summary="${10}"
  local sep="${11}"
  local compact_lines=()
  local compact_active_profile line

  compact_active_profile="$(usage_display_profile_name "$active_profile" "" 6)"
  if (( old_summary )); then
    compact_lines+=(
      "old $compact_active_profile ${active_label} $active_short"
      "old $active_profile ${active_label} $active_short"
      "old $compact_active_profile"
      "old $active_profile"
    )
  fi
  if (( has_active )); then
    if (( active_has_usage )); then
      if (( caps > 0 )); then
        compact_lines+=(
          "active $compact_active_profile ${active_label} $active_short${sep}cap $caps"
          "act $compact_active_profile ${active_label} $active_short${sep}cap $caps"
        )
      fi
      compact_lines+=(
        "active $compact_active_profile ${active_label} $active_short"
        "act $compact_active_profile ${active_label} $active_short"
        "active $active_profile ${active_label} $active_short"
        "active $compact_active_profile"
        "active $active_profile"
        "${active_label} $active_short"
      )
    else
      compact_lines+=(
        "no fresh ready${sep}active $compact_active_profile"
        "no fresh ready${sep}active $active_profile"
        "active $compact_active_profile"
        "active $active_profile"
        "no fresh ready"
      )
    fi
  elif (( has_best )); then
    compact_lines+=(
      "ready $ready${sep}no active"
      "ready $ready"
      "no active"
    )
  else
    compact_lines+=(
      "no fresh ready${sep}no active"
      "no active"
    )
  fi

  for line in "${compact_lines[@]}"; do
    if (( ${#line} <= width )); then
      printf '%s\n' "$line"
      return 0
    fi
  done
  fit_text_rtrim "${compact_lines[-1]}" "$width"
  printf '\n'
}

usage_summary_initial_line() {
  local active_summary="$1"
  local old_summary="$2"
  local has_active="$3"
  local has_best="$4"
  local ready="$5"
  local sep="$6"
  local active_profile="$7"
  local active_label="$8"
  local active_short="$9"

  if (( old_summary )); then
    printf 'old active %s %s %s' "$active_profile" "$active_label" "$active_short"
  elif (( has_active )); then
    printf '%s' "$active_summary"
  elif (( has_best )); then
    if (( ready > 0 )); then
      printf 'ready %s%sno active' "$ready" "$sep"
    else
      printf 'no active'
    fi
  else
    printf 'no fresh ready%sno active' "$sep"
  fi
}

usage_summary_fallback_line() {
  local width="$1"
  local old_summary="$2"
  local has_active="$3"
  local active_has_usage="$4"
  local has_best="$5"
  local ready="$6"
  local caps="$7"
  local sep="$8"
  local active_profile="$9"
  local active_label="${10}"
  local active_short="${11}"
  local line cap_label="capped"
  local show_ready=0 show_caps=0

  if (( old_summary )); then
    line="old active $active_profile ${active_label} $active_short"
  elif (( has_active )); then
    if (( active_has_usage )); then
      line="active $active_profile ${active_label} $active_short"
    else
      line="active $active_profile"
    fi
  elif (( has_best )); then
    if (( ready > 0 )); then
      line="ready $ready${sep}no active"
    else
      line="no active"
    fi
  else
    line="no active"
  fi

  if (( caps > 0 && ${#line} + 8 <= width )); then
    cap_label="cap"
    line+="${sep}$cap_label $caps"
    show_caps=1
  elif (( ready > 0 && ${#line} + 10 <= width )); then
    line+="${sep}ready $ready"
    show_ready=1
  fi

  printf '%s\t%s\t%s\t%s\n' "$line" "$show_ready" "$show_caps" "$cap_label"
}

print_usage_summary_colored_pair() {
  local show="$1"
  local prefix="$2"
  local value="$3"
  local value_tone="$4"

  (( show )) || return 0
  usage_tone_color muted; printf '%s' "$prefix"; usage_tone_reset
  usage_tone_color "$value_tone"; printf '%s' "$value"; usage_tone_reset
}

print_usage_summary_colored_line() {
  local sep="$1"
  local old_summary="$2"
  local has_active="$3"
  local has_best="$4"
  local ready="$5"
  local active_profile="$6"
  local active_label="$7"
  local active_short="$8"
  local show_week="$9"
  local active_weekly="${10}"
  local show_ready="${11}"
  local show_caps="${12}"
  local cap_label="${13}"
  local caps="${14}"
  local show_login="${15}"
  local login="${16}"
  local show_unavailable="${17}"
  local unavailable="${18}"
  local show_offline="${19}"
  local offline="${20}"
  local show_stale="${21}"
  local stale="${22}"
  local show_cache="${23}"
  local cache_age_label="${24}"
  local active_has_usage="${25}"

  if (( old_summary )); then
    usage_tone_color muted; printf 'old active '; usage_tone_reset
    usage_tone_color active; printf '%s' "$active_profile"; usage_tone_reset
  elif (( has_active )); then
    usage_tone_color muted; printf 'active '; usage_tone_reset
    usage_tone_color active; printf '%s' "$active_profile"; usage_tone_reset
  elif (( has_best )); then
    if (( ready > 0 )); then
      usage_tone_color good; printf 'ready '; usage_tone_reset
      usage_tone_color good; printf '%s' "$ready"; usage_tone_reset
      usage_tone_color muted; printf '%sno active' "$sep"; usage_tone_reset
    else
      usage_tone_color muted; printf 'no active'; usage_tone_reset
    fi
  else
    usage_tone_color muted; printf 'no fresh ready'; usage_tone_reset
    usage_tone_color muted; printf '%sno active' "$sep"; usage_tone_reset
  fi
  print_usage_summary_colored_pair "$((has_active * active_has_usage))" " $active_label " "$active_short" "$(usage_limit_tone "$active_short")"
  print_usage_summary_colored_pair "$show_week" ' wk ' "$active_weekly" "$(usage_limit_tone "$active_weekly")"
  print_usage_summary_colored_pair "$show_ready" "${sep}ready " "$ready" good
  print_usage_summary_colored_pair "$show_caps" "${sep}${cap_label} " "$caps" bad
  print_usage_summary_colored_pair "$show_login" "${sep}login " "$login" muted
  print_usage_summary_colored_pair "$show_unavailable" "${sep}no data " "$unavailable" muted
  print_usage_summary_colored_pair "$show_offline" "${sep}offline " "$offline" warn
  print_usage_summary_colored_pair "$show_stale" "${sep}stale " "$stale" warn
  if (( show_cache )); then
    usage_tone_color muted; printf '%s' "${sep}cache $cache_age_label"; usage_tone_reset
  fi
  printf '\n'
}

usage_summary_visibility_flags() {
  local width="$1"
  local ready="$2"
  local caps="$3"
  local login="$4"
  local unavailable="$5"
  local offline="$6"
  local -n show_ready_out="$7"
  local -n show_caps_out="$8"
  local -n show_login_out="$9"
  local -n show_unavailable_out="${10}"
  local -n show_offline_out="${11}"

  (( width >= 70 && login > 0 )) && show_login_out=1
  (( width >= 70 && unavailable > 0 )) && show_unavailable_out=1
  (( width >= 70 && offline > 0 )) && show_offline_out=1
  if (( ready > 0 && (width >= 70 || caps == 0) )); then
    show_ready_out=1
  fi
  (( caps > 0 )) && show_caps_out=1
  return 0
}

usage_summary_append_optional_parts() {
  local -n line_out="$1"
  local -n show_week_out="$2"
  local -n show_ready_out="$3"
  local -n show_caps_out="$4"
  local -n show_login_out="$5"
  local -n show_unavailable_out="$6"
  local -n show_offline_out="$7"
  local -n show_stale_out="$8"
  local -n show_cache_out="$9"
  local width="${10}"
  local sep="${11}"
  local active_weekly="${12}"
  local ready="${13}"
  local cap_label="${14}"
  local caps="${15}"
  local login="${16}"
  local unavailable="${17}"
  local offline="${18}"
  local stale="${19}"
  local cache_age_label="${20}"

  usage_summary_try_append line_out show_week_out " wk $active_weekly" "$width"
  usage_summary_try_append line_out show_ready_out "${sep}ready $ready" "$width"
  usage_summary_try_append line_out show_caps_out "${sep}$cap_label $caps" "$width"
  usage_summary_try_append line_out show_login_out "${sep}login $login" "$width"
  usage_summary_try_append line_out show_unavailable_out "${sep}no data $unavailable" "$width"
  usage_summary_try_append line_out show_offline_out "${sep}offline $offline" "$width"
  if (( stale > 0 )); then
    show_stale_out=1
    usage_summary_try_append line_out show_stale_out "${sep}stale $stale" "$width"
  fi
  if [[ -n "$cache_age_label" ]]; then
    show_cache_out=1
    usage_summary_try_append line_out show_cache_out "${sep}cache $cache_age_label" "$width"
  fi
  return 0
}

usage_summary_clear_optional_flags() {
  local -n show_week_out="$1"
  local -n show_login_out="$2"
  local -n show_unavailable_out="$3"
  local -n show_offline_out="$4"
  local -n show_stale_out="$5"
  local -n show_cache_out="$6"

  show_week_out=0
  show_login_out=0
  show_unavailable_out=0
  show_offline_out=0
  show_stale_out=0
  show_cache_out=0
}

usage_summary_apply_fallback() {
  local -n line_out="$1"
  local -n show_ready_out="$2"
  local -n show_caps_out="$3"
  local -n cap_label_out="$4"
  local -n fallback_used_out="$5"
  local width="$6"
  local old_summary="$7"
  local has_active="$8"
  local active_has_usage="$9"
  local has_best="${10}"
  local ready="${11}"
  local caps="${12}"
  local sep="${13}"
  local active_profile="${14}"
  local active_label="${15}"
  local active_short="${16}"

  (( ${#line_out} > width )) || return 0
  IFS=$'\t' read -r line_out show_ready_out show_caps_out cap_label_out \
    <<<"$(usage_summary_fallback_line "$width" "$old_summary" "$has_active" "$active_has_usage" "$has_best" "$ready" "$caps" "$sep" "$active_profile" "$active_label" "$active_short")"
  fallback_used_out=1
}

print_usage_summary_rendered_line() {
  local line="$1"
  local width="$2"
  shift 2

  if (( ${#line} > width )); then
    fit_text_rtrim "$line" "$width"
    printf '\n'
    return 0
  fi
  if usage_color_active; then
    print_usage_summary_colored_line "$@"
  else
    printf '%s\n' "$line"
  fi
}

print_usage_summary_line() {
  local width="$1"
  local default_profile="${2:-}"
  shift 2
  local active_profile active_short active_weekly active_label best_profile
  local has_best has_active active_has_usage caps login unavailable offline stale ready cache_age_label old_summary
  local show_cache=0
  local line show_week=0 show_login=0 show_unavailable=0 show_offline=0 show_ready=0 show_caps=0 show_stale=0
  local active_summary
  local cap_label="capped"
  local fallback_used=0
  local sep
  sep="$(usage_separator)"

  IFS=$'\t' read -r active_profile active_short active_weekly active_label best_profile \
    has_best has_active active_has_usage caps login unavailable offline stale ready cache_age_label old_summary \
    <<<"$(usage_summary_scan_records "$default_profile" "$@")"
  [[ "$cache_age_label" != "__none__" ]] || cache_age_label=""

  active_summary="active $active_profile"
  (( active_has_usage )) && active_summary+=" ${active_label} $active_short"
  usage_summary_visibility_flags "$width" "$ready" "$caps" "$login" "$unavailable" "$offline" \
    show_ready show_caps show_login show_unavailable show_offline

  if (( width < 40 )); then
    print_usage_summary_compact_line "$width" "$has_active" "$active_has_usage" "$active_profile" "$active_label" "$active_short" "$caps" "$ready" "$has_best" "$old_summary" "$sep"
    return 0
  fi

  line="$(usage_summary_initial_line "$active_summary" "$old_summary" "$has_active" "$has_best" "$ready" "$sep" "$active_profile" "$active_label" "$active_short")"
  if (( ! has_active && has_best )); then
    show_ready=0
  fi
  usage_summary_append_optional_parts line show_week show_ready show_caps show_login show_unavailable show_offline show_stale show_cache \
    "$width" "$sep" "$active_weekly" "$ready" "$cap_label" "$caps" "$login" "$unavailable" "$offline" "$stale" "$cache_age_label"

  usage_summary_apply_fallback line show_ready show_caps cap_label fallback_used \
    "$width" "$old_summary" "$has_active" "$active_has_usage" "$has_best" "$ready" "$caps" "$sep" "$active_profile" "$active_label" "$active_short"
  (( ! fallback_used )) || usage_summary_clear_optional_flags show_week show_login show_unavailable show_offline show_stale show_cache

  print_usage_summary_rendered_line "$line" "$width" \
    "$sep" "$old_summary" "$has_active" "$has_best" "$ready" "$active_profile" "$active_label" "$active_short" \
    "$show_week" "$active_weekly" "$show_ready" "$show_caps" "$cap_label" "$caps" "$show_login" "$login" \
    "$show_unavailable" "$unavailable" "$show_offline" "$offline" "$show_stale" "$stale" "$show_cache" "$cache_age_label" "$active_has_usage"
}

state_payload_for_profile() {
  local profile_name="$1"
  local fingerprint="$2"
  local now
  now="$(now_epoch)"

  [[ -f "$STATE_FILE" ]] || return 1
  jq -c --arg name "$profile_name" --arg fp "$fingerprint" --argjson now "$now" '
    (.profiles[$name] // null) as $profile
    | select($profile != null and $profile.fingerprint == $fp)
    | ($profile.payload + {
        _codexAuthAgeSec: (if $profile.updated_at == null
          then null
          else ($now - ($profile.updated_at | tonumber))
        end)
      })
  ' "$STATE_FILE" 2>/dev/null | tail -n 1
}

state_payload_records() {
  local map_file="$1"
  local now

  [[ -f "$STATE_FILE" && -s "$map_file" ]] || return 0
  now="$(now_epoch)"
  jq -r --rawfile requested "$map_file" --argjson now "$now" '
    . as $state
    | $requested
    | split("\n")[]
    | select(length > 0)
    | split("\u001f") as $item
    | {
        path: ($item[0] // ""),
        name: ($item[1] // ""),
        fp: ($item[2] // "")
      } as $req
    | ($state.profiles[$req.name] // null) as $profile
    | select($profile != null and $profile.fingerprint == $req.fp)
    | [
        $req.path,
        $req.name,
        (($profile.payload + {
          _codexAuthAgeSec: (if $profile.updated_at == null
            then null
            else ($now - ($profile.updated_at | tonumber))
          end)
        }) | @json)
      ]
    | join("\u001f")
  ' "$STATE_FILE" 2>/dev/null
}

state_age_for_profile() {
  local profile_name="$1"
  local fingerprint="$2"
  local now
  now="$(now_epoch)"

  [[ -f "$STATE_FILE" ]] || { printf '999999999\n'; return 0; }
  jq -r --arg name "$profile_name" --arg fp "$fingerprint" --argjson now "$now" '
    (.profiles[$name] // null) as $profile
    | if $profile == null or $profile.fingerprint != $fp or $profile.updated_at == null
      then 999999999
      else ($now - ($profile.updated_at | tonumber))
      end
  ' "$STATE_FILE" 2>/dev/null || printf '999999999\n'
}

state_update_profile() {
  local profile_name="$1"
  local fingerprint="$2"
  local payload="$3"
  local updated tmp source

  updated="$(now_epoch)"
  if ! jq -e . >/dev/null 2>&1 <<<"$payload"; then
    payload='{"error":{"message":"invalid usage payload"}}'
  fi

  tmp="$(mktemp "$CODEX_HOME/.tmp/auth-state.XXXXXX")"
  if [[ -f "$STATE_FILE" ]] && jq -e . "$STATE_FILE" >/dev/null 2>&1; then
    source="$STATE_FILE"
  else
    source="/dev/null"
  fi

  {
    flock -x 9
    if [[ "$source" == "/dev/null" ]]; then
      printf '{}\n'
    else
      cat "$source"
    fi | jq -c \
      --arg name "$profile_name" \
      --arg fp "$fingerprint" \
      --argjson updated "$updated" \
      --argjson payload "$payload" '
        .version = 1
        | .updated_at = $updated
        | .profiles = (.profiles // {})
        | .profiles[$name] = {
            updated_at: $updated,
            fingerprint: $fp,
            payload: $payload
          }
      ' > "$tmp"
    chmod 600 "$tmp"
    mv "$tmp" "$STATE_FILE"
  } 9>"$CODEX_HOME/.tmp/codex-auth-state.lock"
}

mark_stale_payload() {
  local payload="$1"

  jq -c '. + {_codexAuthStale: true}' <<<"$payload" 2>/dev/null || printf '%s\n' "$payload"
}

format_cache_age() {
  local seconds="${1:-}"
  local mins hours days

  [[ "$seconds" =~ ^[0-9]+$ ]] || return 0
  if (( seconds < 60 )); then
    printf 'now'
  elif (( seconds < 3600 )); then
    mins=$(((seconds + 30) / 60))
    (( mins < 1 )) && mins=1
    printf '%dm' "$mins"
  elif (( seconds < 86400 )); then
    hours=$(((seconds + 1800) / 3600))
    (( hours < 1 )) && hours=1
    printf '%dh' "$hours"
  else
    days=$(((seconds + 43200) / 86400))
    (( days < 1 )) && days=1
    printf '%dd' "$days"
  fi
}

usage_payload_still_blocked() {
  local payload="$1"
  local now

  now="$(now_epoch)"
  jq -e --argjson now "$now" '
    if .error? != null then
      ((.error.message // .error.data.message // .error.data.error.message // .error // "")
        | tostring
        | test("token has been invalidated|token_invalidated|invalidated oauth token|token_revoked"; "i"))
    else
      (.rateLimitsByLimitId.codex // .rateLimits // null) as $r
      | if $r == null then
          false
        else
          (($r.secondary.usedPercent // 0) >= 100 and ((($r.secondary.resetsAt // 0) | tonumber? // 0) > $now))
          or (($r.primary.usedPercent // 0) >= 100 and ((($r.primary.resetsAt // 0) | tonumber? // 0) > $now))
        end
    end
  ' <<<"$payload" >/dev/null 2>&1
}

usage_payload_transient_error() {
  local payload="$1"

  jq -e '
    (.error.message // .error.data.message // .error.data.error.message // .error // "")
    | tostring
    | test("^(refresh (timeout|unavailable)|no response)$")
  ' <<<"$payload" >/dev/null 2>&1
}

usage_payload_print_transient_fallback() {
  local payload="$1"
  local cached_payload="$2"

  [[ -n "$payload" && "$payload" != "null" ]] || return 1
  usage_payload_transient_error "$payload" || return 1
  if [[ -n "$cached_payload" ]]; then
    if [[ "$USAGE_REFRESH" == "1" && "${CODEX_AUTH_REFRESH_FALLBACK_CACHE:-1}" == "1" ]]; then
      mark_stale_payload "$cached_payload"
    else
      printf '%s\n' "$cached_payload"
    fi
  else
    printf '%s\n' "$payload"
  fi
}

usage_payload_print_empty_fallback() {
  local payload="$1"
  local cached_payload="$2"

  [[ -z "$payload" || "$payload" == "null" ]] || return 1
  if [[ -n "$cached_payload" ]]; then
    if [[ "$USAGE_REFRESH" == "1" ]]; then
      if [[ "${CODEX_AUTH_REFRESH_FALLBACK_CACHE:-1}" == "1" ]]; then
        mark_stale_payload "$cached_payload"
      else
        printf '%s\n' '{"error":{"message":"no response"}}'
      fi
    else
      printf '%s\n' "$cached_payload"
    fi
  else
    printf '%s\n' '{"error":{"message":"no response"}}'
  fi
}

usage_payload_print_blocked_cache() {
  local cached_payload="$1"

  [[ "$USAGE_REFRESH" == "1" && "${CODEX_AUTH_REFRESH_BLOCKED:-0}" == "1" && -n "$cached_payload" ]] || return 1
  usage_payload_still_blocked "$cached_payload" || return 1
  printf '%s\n' "$cached_payload"
}

usage_payload_print_cache_hit() {
  local profile_name="$1"
  local fingerprint="$2"
  local cached_payload="$3"
  local age

  if [[ -n "$fingerprint" && "$USAGE_REFRESH" != "1" ]]; then
    if [[ -n "$cached_payload" ]]; then
      age="$(state_age_for_profile "$profile_name" "$fingerprint")"
      if [[ "$USAGE_CACHED" == "1" ]]; then
        printf '%s\n' "$cached_payload"
        return 0
      fi
      if [[ "$age" =~ ^[0-9]+$ ]] && (( age <= CACHE_TTL )); then
        printf '%s\n' "$cached_payload"
        return 0
      fi
    elif [[ "$USAGE_CACHED" == "1" ]]; then
      printf 'null\n'
      return 0
    fi
  elif [[ "$USAGE_CACHED" == "1" ]]; then
    printf 'null\n'
    return 0
  fi
  return 1
}

usage_payload_for_profile() {
  local profile_file="$1"
  local fingerprint="${2:-}"
  local profile_name payload cached_payload

  profile_name="$(basename "$profile_file" .json)"
  [[ -n "$fingerprint" ]] || fingerprint="$(credential_fingerprint "$profile_file" || true)"
  cached_payload=""
  [[ -n "$fingerprint" ]] && cached_payload="$(state_payload_for_profile "$profile_name" "$fingerprint" || true)"

  if usage_payload_print_blocked_cache "$cached_payload"; then
    return 0
  fi
  if usage_payload_print_cache_hit "$profile_name" "$fingerprint" "$cached_payload"; then
    return 0
  fi

  payload="$(usage_json_for_profile "$profile_file")"
  if usage_payload_print_transient_fallback "$payload" "$cached_payload"; then
    return 0
  fi
  if usage_payload_print_empty_fallback "$payload" "$cached_payload"; then
    return 0
  fi

  if [[ -n "$fingerprint" ]] && ! jq -e '.error? != null' >/dev/null 2>&1 <<<"$payload"; then
    state_update_profile "$profile_name" "$fingerprint" "$payload"
  fi
  printf '%s\n' "$payload"
}

usage_json_for_profile() {
  local profile_file="$1"
  local temp_home payload

  temp_home="$(mktemp -d "$CODEX_HOME/.tmp/auth-usage.XXXXXX")"
  copy_auth_file_atomic "$profile_file" "$temp_home/auth.json"

  payload="$(usage_json_from_home "$temp_home")"
  rm -rf "$temp_home" 2>/dev/null || true
  printf '%s\n' "$payload"
}

usage_kill_process_tree() {
  local pid="${1:-}"
  local signal="${2:-TERM}"
  local child

  [[ "$pid" =~ ^[0-9]+$ ]] || return 0
  if command -v pgrep >/dev/null 2>&1; then
    while IFS= read -r child; do
      [[ "$child" =~ ^[0-9]+$ && "$child" != "$pid" ]] || continue
      usage_kill_process_tree "$child" "$signal"
    done < <(pgrep -P "$pid" 2>/dev/null || true)
  fi
  kill "-$signal" "$pid" 2>/dev/null || true
}

usage_json_cleanup_coproc() {
  local rate_in="${1:-}"
  local rate_out="${2:-}"
  local rate_pid="${3:-}"

  [[ "$rate_in" =~ ^[0-9]+$ && -e "/proc/self/fd/$rate_in" ]] && exec {rate_in}>&- || true
  [[ "$rate_out" =~ ^[0-9]+$ && -e "/proc/self/fd/$rate_out" ]] && exec {rate_out}<&- || true
  if [[ -n "$rate_pid" ]]; then
    usage_kill_process_tree "$rate_pid"
    wait "$rate_pid" 2>/dev/null || true
  fi
}

usage_json_timeout_seconds() {
  local timeout_sec="${CODEX_AUTH_USAGE_TIMEOUT:-4}"

  [[ "$timeout_sec" =~ ^[0-9]+$ && "$timeout_sec" -gt 0 ]] || timeout_sec=4
  printf '%s' "$timeout_sec"
}

usage_json_handle_line() {
  local line="$1"
  local rate_in="$2"
  local -n requested_out="$3"
  local -n payload_out="$4"
  local -n done_out="$5"
  local line_id

  line_id="$(jq -r '.id // empty' <<<"$line" 2>/dev/null || true)"
  if [[ "$line_id" == "1" && "$requested_out" == "0" ]]; then
    printf '%s\n' '{"method":"initialized"}' 2>/dev/null >&"$rate_in" || true
    printf '%s\n' '{"id":2,"method":"account/rateLimits/read"}' 2>/dev/null >&"$rate_in" || true
    requested_out=1
  elif [[ "$line_id" == "2" ]]; then
    payload_out="$(jq -c 'if has("result") then .result else {error:.error} end' <<<"$line" 2>/dev/null || true)"
    done_out=1
  fi
  return 0
}

usage_json_check_wait() {
  local rate_pid="$1"
  local start="$2"
  local timeout_sec="$3"
  local -n payload_out="$4"
  local -n done_out="$5"
  local now

  now="$(now_epoch)"
  if (( now - start >= timeout_sec )); then
    payload_out='{"error":{"message":"refresh timeout"}}'
    done_out=1
    return 0
  fi
  if ! kill -0 "$rate_pid" 2>/dev/null; then
    payload_out='{"error":{"message":"refresh unavailable"}}'
    done_out=1
  fi
  return 0
}

usage_json_codex_bin() {
  local -n codex_cli_ref="$1"

  codex_cli_ref="$(codex_bin)" || return 1
  codex_launcher_ready "$codex_cli_ref"
}

usage_json_from_home() {
  local home_dir="$1"
  local codex_cli line payload rate_in rate_out rate_pid
  local requested=0 done=0
  local start timeout_sec

  usage_json_codex_bin codex_cli || return 0
  timeout_sec="$(usage_json_timeout_seconds)"

  if ! coproc CODEX_RATE { CODEX_AUTH_RUNNER=1 CODEX_HOME="$home_dir" "$codex_cli" app-server --listen stdio:// 2>/dev/null; }; then
    printf '%s\n' '{"error":{"message":"refresh unavailable"}}'
    return 0
  fi

  rate_out="${CODEX_RATE[0]}"
  rate_in="${CODEX_RATE[1]}"
  rate_pid="$CODEX_RATE_PID"
  start="$(now_epoch)"

  if ! printf '%s\n' '{"id":1,"method":"initialize","params":{"clientInfo":{"name":"codex-auth","title":"Codex Auth","version":"0.1.0"},"capabilities":{"experimentalApi":true,"requestAttestation":false}}}' 2>/dev/null >&"$rate_in"; then
    usage_json_cleanup_coproc "$rate_in" "$rate_out" "$rate_pid"
    printf '%s\n' '{"error":{"message":"refresh unavailable"}}'
    return 0
  fi

  while true; do
    if [[ ! "$rate_out" =~ ^[0-9]+$ || ! -e "/proc/self/fd/$rate_out" ]]; then
      payload='{"error":{"message":"refresh unavailable"}}'
      break
    fi
    if IFS= read -r -t 0.25 line 2>/dev/null <&"$rate_out"; then
      usage_json_handle_line "$line" "$rate_in" requested payload done
    else
      usage_json_check_wait "$rate_pid" "$start" "$timeout_sec" payload done
    fi
    (( done )) && break
  done

  usage_json_cleanup_coproc "$rate_in" "$rate_out" "$rate_pid"
  printf '%s\n' "$payload"
}

usage_limit_remaining_fields() {
  local used="$1"
  local window="$2"
  local reset="$3"
  local left reset_text

  if [[ -z "$window" || "$window" == "-" || "$window" == "0" ]]; then
    printf '0\t-\t-\n'
    return 0
  fi

  left=$((100 - used))
  (( left < 0 )) && left=0
  reset_text="-"
  if [[ -n "$reset" && "$reset" != "-" && "$reset" != "null" && "$reset" != "0" ]]; then
    reset_text="$(TZ="${TZ:-America/Chicago}" date -d "@$reset" '+%m-%d %H:%M' 2>/dev/null || printf '-')"
  fi
  printf '%s\t%s%%\t%s\n' "$used" "$left" "$reset_text"
}

usage_record_error_status() {
  local err="$1"

  if [[ "$err" == *"token has been invalidated"* || "$err" == *"token_invalidated"* || "$err" == *"invalidated oauth token"* || "$err" == *"token_revoked"* ]]; then
    printf 'login'
  elif [[ "$err" == "refresh timeout" || "$err" == "refresh unavailable" || "$err" == "no response" ]]; then
    printf 'offline'
  else
    printf '%s' "$err"
  fi
}

usage_record_limit_status() {
  local weekly_used="$1"
  local short_used="$2"
  local short_label="$3"
  local reached="$4"
  local stale="$5"
  local cache_age="$6"
  local status="ok"
  local stale_age_label

  if (( weekly_used >= 100 && short_used >= 100 )); then
    status="week+5h cap"
  elif (( weekly_used >= 100 )); then
    status="week cap"
  elif (( short_used >= 100 )); then
    status="${short_label} cap"
  elif [[ -n "$reached" ]]; then
    status="$reached"
  fi
  if [[ "$stale" == "true" ]]; then
    stale_age_label="$(format_cache_age "$cache_age")"
    if [[ -n "$stale_age_label" ]]; then
      status="stale $stale_age_label $status"
    else
      status="stale $status"
    fi
  fi

  printf '%s' "$status"
}

usage_record_for_profile() {
  local profile_name="$1"
  local profile_file="$2"
  local payload="$3"
  local active_fp="$4"
  local profile_fp="${5:-}"
  local mark=" "

  if [[ -n "$active_fp" ]]; then
    [[ -n "$profile_fp" ]] || profile_fp="$(credential_fingerprint "$profile_file" || true)"
  fi
  if [[ -n "$active_fp" && "$profile_fp" == "$active_fp" ]]; then
    mark="*"
  fi

  if [[ -z "$payload" || "$payload" == "null" ]]; then
    printf '1\t-1\t-1\t%s\t%s\t-\t-\t-\tno data\t5h\t-\t-\t\n' "$mark" "$profile_name"
    return 0
  fi

  local extracted kind err cache_age stale plan short_used short_window short_reset weekly_used weekly_window weekly_reset credits reached
  extracted="$(jq -r "$USAGE_RECORD_EXTRACT_JQ" <<<"$payload" 2>/dev/null || true)"
  IFS=$'\037' read -r kind err cache_age stale plan short_used short_window short_reset weekly_used weekly_window weekly_reset credits reached <<<"$extracted"

  if [[ "$kind" == "error" ]]; then
    err="$(usage_record_error_status "$err")"
    printf '1\t-1\t-1\t%s\t%s\t-\t-\t-\t%s\t5h\t-\t-\t%s\n' "$mark" "$profile_name" "$err" "$cache_age"
    return 0
  fi

  if [[ "$kind" != "usage" ]]; then
    printf '1\t-1\t-1\t%s\t%s\t-\t-\t-\tno usage\t5h\t-\t-\t%s\n' "$mark" "$profile_name" "$cache_age"
    return 0
  fi

  local short weekly status short_label weekly_reset_text short_reset_text stale_age_label
  short_label="$(window_label "$short_window")"
  IFS=$'\t' read -r short_used short short_reset_text <<<"$(usage_limit_remaining_fields "$short_used" "$short_window" "$short_reset")"
  IFS=$'\t' read -r weekly_used weekly weekly_reset_text <<<"$(usage_limit_remaining_fields "$weekly_used" "$weekly_window" "$weekly_reset")"
  status="$(usage_record_limit_status "$weekly_used" "$short_used" "$short_label" "$reached" "$stale" "$cache_age")"

  printf '0\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
    "$weekly_used" "$short_used" "$mark" "$profile_name" "$plan" "$weekly" "$short" "$status" "$short_label" "$weekly_reset_text" "$short_reset_text" "$cache_age"
}

canonical_usage_active_marks() {
  local seen_active=0
  local valid weekly_used short_used mark profile plan weekly short status short_label weekly_reset short_reset cache_age

  while IFS=$'\t' read -r valid weekly_used short_used mark profile plan weekly short status short_label weekly_reset short_reset cache_age; do
    [[ -n "$profile" ]] || continue
    if [[ "$mark" == "*" ]]; then
      if (( seen_active )); then
        mark="="
      else
        seen_active=1
      fi
    fi
    printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
      "$valid" "$weekly_used" "$short_used" "$mark" "$profile" "$plan" "$weekly" "$short" "$status" "$short_label" "$weekly_reset" "$short_reset" "$cache_age"
  done
}

MENU_ACTION=""
MENU_PROFILE=""

print_selector_row() {
  local action="$1"
  local profile="$2"
  local detail="$3"
  local action_w="$4"
  local profile_w="$5"
  local total_w="$6"
  local detail_w

  detail_w=$((total_w - action_w - profile_w - 2))
  (( detail_w < 1 )) && detail_w=1
  fit_text "$action" "$action_w"
  printf ' '
  fit_profile_text "$profile" "$profile_w"
  printf ' '
  fit_text_rtrim "$detail" "$detail_w"
}

print_selector_palette_primary() {
  local primary="$1"
  local width="$2"
  local action display_action profile action_w profile_w profile_render gap action_tone

  if (( width <= 0 )); then
    return 0
  fi
  action="${primary%% *}"
  if [[ "$primary" == "$action" ]]; then
    fit_profile_text "$primary" "$width"
    return 0
  fi
  profile="${primary#* }"
  case "$action" in
    best|stay|use|same|cap|login|warn)
      display_action="$action"
      [[ "$action" == "best" ]] && display_action="use"
      action_tone="$(usage_role_tone "$action")"
      [[ "$action" == "warn" ]] && action_tone="warn"
      action_w=5
      gap=2
      if (( action_w + gap >= width )); then
        usage_tone_color "$action_tone"
        fit_text "$display_action" "$width"
        usage_tone_reset
        return 0
      fi
      usage_tone_color "$action_tone"
      fit_text "$display_action" "$action_w"
      usage_tone_reset
      printf '%*s' "$gap" ''
      profile_w=$((width - action_w - gap))
      profile_render="$(usage_display_profile_name "$profile" "$action" "$profile_w")"
      fit_profile_text "$profile_render" "$profile_w"
      ;;
    *)
      fit_profile_text "$primary" "$width"
      ;;
  esac
}

selector_palette_profile_label() {
  local profile="$1"
  local total_w="${2:-0}"
  local width="${3:-0}"

  [[ "$total_w" =~ ^[0-9]+$ ]] || total_w=0
  [[ "$width" =~ ^[0-9]+$ ]] || width=0

  if (( total_w <= 30 )); then
    usage_display_profile_name "$profile" "" 6
  else
    printf '%s' "$profile"
  fi
}

selector_palette_primary_width() {
  local total_w="$1"
  local primary_w=16

  if (( total_w < 20 )); then
    primary_w=11
  elif (( total_w < 32 )); then
    primary_w=13
  elif (( total_w < 60 )); then
    primary_w=19
  elif (( total_w < 68 )); then
    primary_w=20
  elif (( total_w >= 108 )); then
    primary_w=28
  elif (( total_w >= 88 )); then
    primary_w=26
  elif (( total_w >= 68 )); then
    primary_w=22
  fi
  printf '%s' "$primary_w"
}

width_floor_value() {
  local value="$1"
  local default="$2"
  shift 2
  local row floor output

  for row in "$@"; do
    floor="${row%%:*}"
    output="${row#*:}"
    if (( value >= floor )); then
      printf '%s' "$output"
      return 0
    fi
  done
  printf '%s' "$default"
}

selector_palette_status_gap() {
  local total_w="$1"

  width_floor_value "$total_w" 1 108:8 88:6 68:4 58:3 48:2
}

selector_palette_metric_gap() {
  local total_w="$1"

  if (( total_w >= 48 )); then
    printf '2'
  else
    printf '1'
  fi
}

selector_palette_table_widths() {
  local total_w="$1"
  local primary_w week_w short_w status_w metric_w status_gap metric_gap status_max=13

  primary_w="$(selector_palette_primary_width "$total_w")"
  status_gap="$(selector_palette_status_gap "$total_w")"
  metric_gap="$(selector_palette_metric_gap "$total_w")"
  if (( total_w < 58 )); then
    status_max=12
  fi
  if (( total_w < 24 )); then
    primary_w=$((total_w - 5))
    primary_w=$(( primary_w < 11 ? 11 : primary_w ))
    week_w=0
    short_w=4
    status_w=0
  else
    metric_w="$(width_floor_value "$total_w" 5 108:23 88:19 68:13)"
    week_w="$metric_w"
    short_w=$(( total_w < 50 ? 3 : metric_w ))
    status_w=$((total_w - primary_w - 1 - week_w - metric_gap - short_w - status_gap))
    while (( status_w < 2 && metric_w > 5 )); do
      metric_w=$((metric_w - 1))
      week_w="$metric_w"
      short_w=$(( total_w < 50 ? 3 : metric_w ))
      status_w=$((total_w - primary_w - 1 - week_w - metric_gap - short_w - status_gap))
    done
    status_w=$(( status_w < 2 ? 2 : status_w > status_max ? status_max : status_w ))
  fi

  printf '%s\t%s\t%s\t%s\n' "$primary_w" "$week_w" "$short_w" "$status_w"
}

selector_palette_fzf_colors() {
  printf '%s' 'dark,fg:#eeeeee,fg+:#f4f0e8,bg:#141414,bg+:#262626,hl:#fab283,hl+:#ffd0a0,border:#323232,label:#fab283,prompt:#fab283,pointer:#fab283,header:#9a9a9a,info:#808080,gutter:#141414'
}

selector_compact_by_width() {
  local width="$1"
  local default="$2"
  shift 2
  local cutoff label

  if (( width <= 0 )); then
    printf '%s' "$default"
    return 0
  fi
  while (( $# >= 2 )); do
    cutoff="$1"
    label="$2"
    if (( width < cutoff )); then
      printf '%s' "$label"
      return 0
    fi
    shift 2
  done
  printf '%s' "$default"
}

selector_palette_status_compact() {
  local status="$1"
  local width="${2:-0}"

  case "$status" in
    "no data"|"no usage"|"n/a")
      selector_compact_by_width "$width" "$status" 3 na
      ;;
    "login needed")
      selector_compact_by_width "$width" "$status" 4 log 6 auth 13 login
      ;;
    cap)
      selector_compact_by_width "$width" "$status" 3 cp
      ;;
    "old cap"|"both cap")
      selector_compact_by_width "$width" "$status" 3 cp 7 cap
      ;;
    ready)
      selector_compact_by_width "$width" "$status" 5 ok
      ;;
    offline)
      selector_compact_by_width "$width" "$status" 3 of 7 off
      ;;
    same)
      selector_compact_by_width "$width" "$status" 4 =
      ;;
    *)
      printf '%s' "$status"
      ;;
  esac
}

selector_palette_metric_cell() {
  local percent="$1"
  local width="$2"
  local tone bar_w label label_w=4

  (( width <= 0 )) && return 0
  [[ -n "$percent" ]] || percent="-"
  label="${percent%\%}"
  tone="$(usage_limit_tone "$percent")"

  if [[ "$percent" == "-" ]]; then
    usage_tone_color muted
    if (( width < 8 )); then
      fit_text_center "-" "$width"
    else
      printf '%3s' "-"
      printf '%*s' "$((width - 3))" ''
    fi
    usage_tone_reset
    return 0
  fi

  usage_tone_color "$tone"
  if (( width < 8 )); then
    fit_text_center "$label" "$width"
    usage_tone_reset
    return 0
  fi
  if (( width >= 18 )); then
    label_w=5
  fi
  fit_text_center "$label" "$label_w"
  usage_tone_reset
  printf ' '
  bar_w=$((width - label_w - 1))
  (( bar_w < 0 )) && bar_w=0
  selector_palette_bar "$percent" "$bar_w"
}

selector_palette_table_header() {
  local total_w="$1"
  local primary_w week_w short_w status_w short_label status_label status_gap metric_gap
  local action_w=5 primary_gap=2 primary_profile_w profile_label

  IFS=$'\t' read -r primary_w week_w short_w status_w <<<"$(selector_palette_table_widths "$total_w")"
  status_gap="$(selector_palette_status_gap "$total_w")"
  metric_gap="$(selector_palette_metric_gap "$total_w")"
  short_label="${USAGE_SHORT_LABEL:-5h}"
  [[ -n "$short_label" && "$short_label" != "short" ]] || short_label="5h"
  short_label="${short_label}%"
  status_label="status"
  if (( status_w > 0 && status_w < 7 )); then
    status_label="st"
  fi

  primary_profile_w=$((primary_w - action_w - primary_gap))
  (( primary_profile_w < 1 )) && primary_profile_w=1
  if (( primary_profile_w <= 6 )); then
    profile_label="name"
  else
    profile_label="profile"
  fi
  print_toned_fit_center "act" "$action_w" muted
  printf '%*s' "$primary_gap" ''
  print_toned_fit_center "$profile_label" "$primary_profile_w" muted
  printf ' '
  if (( week_w > 0 )); then
    usage_tone_color muted
    usage_metric_header_cell "week%" "$week_w" normal 1
    usage_tone_reset
    printf '%*s' "$metric_gap" ''
  fi
  usage_tone_color muted
  usage_metric_header_cell "$short_label" "$short_w" normal 1
  usage_tone_reset
  if (( status_w > 0 )); then
    printf '%*s' "$status_gap" ''
    print_toned_fit_center "$status_label" "$status_w" muted
  fi
  printf '\n'
}

print_selector_palette_table_row() {
  local primary="$1"
  local weekly="$2"
  local short="$3"
  local status="$4"
  local raw_status="$5"
  local valid="$6"
  local total_w="$7"
  local primary_w week_w short_w status_w compact_status status_gap metric_gap

  IFS=$'\t' read -r primary_w week_w short_w status_w <<<"$(selector_palette_table_widths "$total_w")"
  status_gap="$(selector_palette_status_gap "$total_w")"
  metric_gap="$(selector_palette_metric_gap "$total_w")"
  print_selector_palette_primary "$primary" "$primary_w"
  printf ' '

  if (( week_w == 0 )); then
    if [[ "$valid" == "0" ]]; then
      selector_palette_metric_cell "$short" "$short_w"
    else
      compact_status="$(selector_palette_status_compact "$status" "$short_w")"
      print_toned_fit_center "$compact_status" "$short_w" "$(usage_status_tone "$raw_status" "$valid")"
    fi
    return 0
  fi

  compact_status="$(selector_palette_status_compact "$status" "$status_w")"
  if [[ "$valid" == "0" ]]; then
    selector_palette_metric_cell "$weekly" "$week_w"
    printf '%*s' "$metric_gap" ''
    selector_palette_metric_cell "$short" "$short_w"
  else
    selector_palette_metric_cell "-" "$week_w"
    printf '%*s' "$metric_gap" ''
    selector_palette_metric_cell "-" "$short_w"
  fi
  printf '%*s' "$status_gap" ''
  print_toned_fit "$compact_status" "$status_w" "$(usage_status_tone "$raw_status" "$valid")"
}

usage_clamped_percent() {
  local percent="$1"
  local value

  percent="${percent%\%}"
  [[ "$percent" =~ ^-?[0-9]+$ ]] || return 1
  value="$percent"
  (( value < 0 )) && value=0
  (( value > 100 )) && value=100
  printf '%s' "$value"
}

selector_palette_bar_bg_segments() {
  local tone="$1"
  local width="$2"
  local used="$3"
  local bar_border_glyph="$4"

  if (( used > 0 )); then
    usage_tone_bg "$tone"
    usage_tone_color track_edge
    repeat_glyph "$bar_border_glyph" "$used"
    usage_tone_reset
  fi
  if (( width > used )); then
    usage_tone_bg track
    usage_tone_color track_edge
    repeat_glyph "$bar_border_glyph" "$((width - used))"
    usage_tone_reset
  fi
  return 0
}

selector_palette_bar_unicode() {
  local value="$1"
  local width="$2"
  local tone="$3"
  local bg_style="$4"
  local bar_border_glyph="$5"
  local units full partial used
  local partial_glyphs=("" "▏" "▎" "▍" "▌" "▋" "▊" "▉")

  units=$(((value * width * 8 + 50) / 100))
  full=$((units / 8))
  partial=$((units % 8))
  if (( full >= width )); then
    full="$width"
    partial=0
  fi
  used="$full"
  (( partial > 0 && used < width )) && used=$((used + 1))
  if usage_color_active && [[ "$bg_style" == "bg" ]]; then
    selector_palette_bar_bg_segments "$tone" "$width" "$used" "$bar_border_glyph"
  else
    usage_tone_color "$tone"
    repeat_glyph "█" "$full"
    (( partial > 0 && full < width )) && printf '%s' "${partial_glyphs[$partial]}"
    usage_tone_reset
    (( width > used )) && printf '%*s' "$((width - used))" ''
  fi
  return 0
}

selector_palette_bar_ascii() {
  local value="$1"
  local width="$2"
  local tone="$3"
  local bg_style="$4"
  local bar_border_glyph="$5"
  local full

  full=$(((value * width + 50) / 100))
  (( full > width )) && full="$width"
  if usage_color_active && [[ "$bg_style" == "bg" ]]; then
    selector_palette_bar_bg_segments "$tone" "$width" "$full" "$bar_border_glyph"
  else
    usage_tone_color "$tone"
    repeat_glyph "#" "$full"
    usage_tone_reset
    (( width > full )) && printf '%*s' "$((width - full))" ''
  fi
  return 0
}

selector_palette_bar() {
  local percent="$1"
  local width="$2"
  local tone value bg_style
  local bar_border_glyph="▁"

  tone="$(usage_limit_tone "$percent")"
  bg_style="${CODEX_AUTH_SELECTOR_BAR_STYLE:-bg}"
  if value="$(usage_clamped_percent "$percent")"; then
    if usage_unicode_enabled; then
      selector_palette_bar_unicode "$value" "$width" "$tone" "$bg_style" "$bar_border_glyph"
    else
      selector_palette_bar_ascii "$value" "$width" "$tone" "$bg_style" "$bar_border_glyph"
    fi
  elif usage_color_active && [[ "$bg_style" == "bg" ]]; then
    usage_tone_bg track
    usage_tone_color track_edge
    repeat_glyph "$bar_border_glyph" "$width"
    usage_tone_reset
  else
    printf '%*s' "$width" ''
  fi
}

selector_action_role() {
  local action="$1"
  local role_w="$2"

  if (( role_w <= 1 )); then
    case "$action" in
      switch) printf ' ' ;;
      best) printf 'u' ;;
      cap) printf 'c' ;;
      login) printf 'l' ;;
      stay) usage_active_glyph ;;
      *) usage_meta_glyph ;;
    esac
  elif (( role_w < 6 )); then
    case "$action" in
      best|switch) printf 'use' ;;
      cap) printf 'cap' ;;
      same) printf 'same' ;;
      login) printf 'login' ;;
      *) printf 'stay' ;;
    esac
  else
    case "$action" in
      switch|best) printf 'use' ;;
      same) printf 'same' ;;
      *) printf '%s' "$action" ;;
    esac
  fi
}

selector_header_action() {
  local role_w="$1"

  if (( role_w <= 1 )); then
    printf ' '
  elif (( role_w < 6 )); then
    printf 'act'
  else
    printf 'action'
  fi
}

usage_metadata_summary_line() {
  local render_w="$1"
  shift
  local summary_w=$((render_w * 2))
  local line sep record valid weekly_used short_used mark profile plan weekly short status short_label weekly_reset short_reset cache_age
  local old_color="${USAGE_COLOR_ENABLED:-0}"
  local cache_age_max=-1 cache_age_label

  if (( render_w < 40 )); then
    summary_w="$render_w"
  else
    summary_w="$(clamp_int_between "$summary_w" 64 132)"
  fi
  USAGE_COLOR_ENABLED=0
  line="$(print_usage_summary_line "$summary_w" "$@")"
  USAGE_COLOR_ENABLED="$old_color"
  sep="$(usage_separator)"

  if [[ "$line" != cache\ * && "$line" != *"${sep}cache "* ]]; then
    for record in "$@"; do
      IFS=$'\t' read -r valid weekly_used short_used mark profile plan weekly short status short_label weekly_reset short_reset cache_age <<<"$record"
      if [[ "$cache_age" =~ ^[0-9]+$ ]] && (( cache_age > cache_age_max )); then
        cache_age_max="$cache_age"
      fi
    done
    if (( cache_age_max >= 0 )); then
      cache_age_label="$(format_cache_age "$cache_age_max")"
      [[ -n "$cache_age_label" ]] && line+="${sep}cache $cache_age_label"
    fi
  fi

  printf '%s' "$line"
}

selector_header_spaced_text() {
  local text="$1"
  local sep
  sep="$(usage_separator)"

  text="${text//capped /cap }"
  while [[ "$text" == *"$sep"* ]]; do
    printf '%s   ' "${text%%"$sep"*}"
    text="${text#*"$sep"}"
  done
  printf '%s' "$text"
}

selector_header_identity_text() {
  local text="$1"
  local value_w="$2"
  local name detail name_w detail_w

  IFS=' ' read -r name detail <<<"$text"
  if [[ -z "$detail" || ! "$value_w" =~ ^[0-9]+$ || "$value_w" -lt 18 ]]; then
    printf '%s' "$text"
    return 0
  fi

  name_w=12
  (( value_w < 34 )) && name_w=10
  (( value_w < 26 )) && name_w=8
  if (( name_w > value_w - 8 )); then
    name_w=$((value_w - 8))
  fi
  if (( name_w < 6 )); then
    printf '%s' "$text"
    return 0
  fi

  detail_w=$((value_w - name_w - 2))
  (( detail_w < 1 )) && detail_w=1
  fit_profile_text "$name" "$name_w"
  printf '  '
  fit_text "$detail" "$detail_w"
}

selector_header_meta_line() {
  local label="$1"
  local text="$2"
  local total_w="$3"
  local label_w="$4"
  local frame="${5:-0}"
  local outer_w="${6:-$total_w}"
  local value_w value label_tone="muted" tl tr bl br vl vr glyph

  (( label_w < 1 )) && label_w=1
  value_w=$((total_w - label_w - 2))
  (( value_w < 1 )) && value_w=1
  case "$label" in
    best|active|old|status)
      value="$(selector_header_identity_text "$text" "$value_w")"
      ;;
    *)
      value="$(selector_header_spaced_text "$text")"
      ;;
  esac
  case "$label" in
    best) label_tone="accent" ;;
    active) label_tone="active" ;;
    old) label_tone="warn" ;;
  esac

  if (( frame )); then
    IFS=$'\t' read -r tl tr bl br vl vr glyph <<<"$(usage_frame_chars)"
    usage_tone_color muted
    printf '%s ' "$vl"
    usage_tone_reset
  fi
  print_toned_fit "$label" "$label_w" "$label_tone"
  printf '  '
  fit_text "$value" "$value_w"
  if (( frame )); then
    usage_tone_color muted
    printf ' %s' "$vr"
    usage_tone_reset
  fi
  printf '\n'
}

selector_header_primary_line() {
  local text="$1"
  local total_w="$2"
  local label_w="$3"
  local frame="${4:-0}"
  local outer_w="${5:-$total_w}"
  local label="status"
  local value="$text"

  if [[ "$text" == "best "* ]]; then
    label="best"
    value="${text#best }"
  elif [[ "$text" == "active "* ]]; then
    label="active"
    value="${text#active }"
  elif [[ "$text" == "old "* ]]; then
    label="old"
    value="${text#old }"
  fi

  selector_header_meta_line "$label" "$value" "$total_w" "$label_w" "$frame" "$outer_w"
}

print_usage_title_line() {
  local title="$1"
  local total_w="$2"
  local title_w rule_w glyph

  [[ -n "$title" ]] || return 0
  (( total_w >= 40 )) || return 0

  title_w=${#title}
  if (( title_w + 2 >= total_w )); then
    fit_text "$title" "$total_w"
    printf '\n'
    return 0
  fi

  glyph="$(usage_rule_glyph)"
  rule_w=$((total_w - title_w - 1))
  usage_tone_color accent
  printf '%s' "$title"
  usage_tone_reset
  printf ' '
  usage_tone_color muted
  repeat_glyph "$glyph" "$rule_w"
  usage_tone_reset
  printf '\n'
}

usage_frame_chars() {
  if usage_unicode_enabled; then
    printf '╭\t╮\t╰\t╯\t│\t│\t─\n'
  else
    printf '+\t+\t+\t+\t|\t|\t-\n'
  fi
}

print_usage_frame_top() {
  local title="$1"
  local width="$2"
  local tl tr bl br vl vr glyph label rule_w
  IFS=$'\t' read -r tl tr bl br vl vr glyph <<<"$(usage_frame_chars)"

  label=" $title "
  rule_w=$((width - 2 - ${#label}))
  (( rule_w < 0 )) && rule_w=0
  usage_tone_color muted
  printf '%s' "$tl"
  usage_tone_reset
  usage_tone_color accent
  printf '%s' "$label"
  usage_tone_reset
  usage_tone_color muted
  repeat_glyph "$glyph" "$rule_w"
  printf '%s\n' "$tr"
  usage_tone_reset
}

print_usage_frame_bottom() {
  local width="$1"
  local tl tr bl br vl vr glyph
  IFS=$'\t' read -r tl tr bl br vl vr glyph <<<"$(usage_frame_chars)"

  usage_tone_color muted
  printf '%s' "$bl"
  repeat_glyph "$glyph" "$((width - 2))"
  printf '%s\n' "$br"
  usage_tone_reset
}

usage_summary_split_once() {
  local text="$1"
  local sep="$2"

  if [[ "$text" == *"$sep"* ]]; then
    printf '%s\t%s\n' "${text%%"$sep"*}" "${text#*"$sep"}"
  else
    printf '%s\t\n' "$text"
  fi
}

usage_summary_extend_best_head() {
  local -n first_ref="$1"
  local -n rest_ref="$2"
  local sep="$3"
  local next_part

  case "$first_ref" in
    best|"best active"|"best is active")
      if [[ -n "$rest_ref" ]]; then
        IFS=$'\t' read -r next_part rest_ref <<<"$(usage_summary_split_once "$rest_ref" "$sep")"
        first_ref="$first_ref $next_part"
      fi
      ;;
  esac
  return 0
}

usage_summary_normalize_best_active() {
  local -n first_ref="$1"
  local best_subject

  if [[ "$first_ref" == "best active "* ]]; then
    best_subject="${first_ref#best active }"
    first_ref="best $best_subject"
  elif [[ "$first_ref" == "best is active "* ]]; then
    best_subject="${first_ref#best is active }"
    first_ref="best $best_subject"
  fi
  return 0
}

usage_summary_take_active_part() {
  local -n active_ref="$1"
  local -n pool_ref="$2"
  local sep="$3"
  local pool_head next_part

  active_ref=""
  if [[ -n "$pool_ref" ]]; then
    IFS=$'\t' read -r pool_head next_part <<<"$(usage_summary_split_once "$pool_ref" "$sep")"
    if [[ "$pool_head" == "active "* || "$pool_head" == "no active" ]]; then
      active_ref="$pool_head"
      pool_ref="$next_part"
    fi
  fi
  return 0
}

usage_summary_merge_pool_subject() {
  local -n first_ref="$1"
  local -n active_ref="$2"
  local -n pool_ref="$3"
  local total_w="$4"
  local sep="$5"
  local pool_head next_part candidate value_candidate

  [[ -n "$pool_ref" && -z "$active_ref" ]] || return 0
  IFS=$'\t' read -r pool_head next_part <<<"$(usage_summary_split_once "$pool_ref" "$sep")"
  case "$pool_head" in
    ready*|capped*|cap*|login*|"no data"*|offline*|stale*|cache*)
      return 0
      ;;
  esac

  candidate="$first_ref $pool_head"
  value_candidate="$candidate"
  [[ "$candidate" == "best "* ]] && value_candidate="${candidate#best }"
  if (( ${#value_candidate} <= total_w - 7 )); then
    first_ref="$candidate"
    pool_ref="$next_part"
  fi
  return 0
}

usage_summary_parts() {
  local summary="$1"
  local total_w="$2"
  local -n first_ref="$3"
  local -n active_ref="$4"
  local -n pool_ref="$5"
  local sep

  sep="$(usage_separator)"
  IFS=$'\t' read -r first_ref pool_ref <<<"$(usage_summary_split_once "$summary" "$sep")"
  usage_summary_extend_best_head first_ref pool_ref "$sep"
  usage_summary_normalize_best_active first_ref
  usage_summary_take_active_part active_ref pool_ref "$sep"
  usage_summary_merge_pool_subject first_ref active_ref pool_ref "$total_w" "$sep"
}

print_usage_summary_body() {
  local first="$1"
  local active_part="$2"
  local pool_part="$3"
  local body_w="$4"
  local frame="$5"
  local total_w="$6"
  local label_w=5 show_active=0 show_pool=0 blank_after=0

  if (( body_w >= 64 )); then
    label_w=7
    show_active=1
    show_pool=1
    blank_after=1
  elif (( body_w >= 40 )); then
    label_w=6
    show_active=1
    blank_after=1
  fi

  selector_header_primary_line "$first" "$body_w" "$label_w" "$frame" "$total_w"
  if (( show_active )) && [[ -n "$active_part" ]]; then
    selector_header_primary_line "$active_part" "$body_w" "$label_w" "$frame" "$total_w"
  fi
  if (( show_pool )) && [[ -n "$pool_part" ]]; then
    selector_header_meta_line "stats" "$pool_part" "$body_w" "$label_w" "$frame" "$total_w"
  fi
  (( frame )) && print_usage_frame_bottom "$total_w"
  (( blank_after )) && printf '\n'
  return 0
}

print_usage_summary_block() {
  local summary="$1"
  local total_w="$2"
  local title="${3:-}"
  local first active_part pool_part
  local frame=0 body_w="$total_w"

  usage_summary_parts "$summary" "$total_w" first active_part pool_part
  if [[ -n "$title" ]] && (( total_w >= 42 )); then
    frame=1
    body_w=$((total_w - 4))
    print_usage_frame_top "$title" "$total_w"
  else
    print_usage_title_line "$title" "$total_w"
  fi
  print_usage_summary_body "$first" "$active_part" "$pool_part" "$body_w" "$frame" "$total_w"
  return 0
}

selector_header_text() {
  local summary="$1"
  local controls="$2"
  local role_w="$3"
  local profile_w="$4"
  local cell_w="$5"
  local status_w="$6"
  local total_w="$7"
  local mode="$8"
  local title="${9:-}"

  print_usage_summary_block "$summary" "$total_w" "$title"
  print_usage_render_header "$(selector_header_action "$role_w")" "$(usage_header_profile "$mode")" "$(usage_header_week "$mode")" "$(usage_header_short "$mode")" "$(usage_header_state "$mode")" \
    "$role_w" "$profile_w" "$cell_w" "$status_w" "$mode"
  repeat_glyph "$(usage_rule_glyph)" "$total_w"
  printf '\n'
  fit_text_rtrim "$controls" "$total_w"
}

selector_palette_header_text() {
  local summary="$1"
  local controls="$2"
  local total_w="$3"

  selector_palette_controls_line "$controls" "$total_w"
  printf '\n'
  if [[ "${CODEX_AUTH_SELECTOR_CONTEXT:-0}" == "1" ]]; then
    selector_palette_context_line "$summary" "$total_w"
  fi
  selector_palette_table_header "$total_w"
}

selector_palette_take_short_limit() {
  local text="$1"
  local name label value

  IFS=$'\t' read -r name _ label value <<<"$(selector_palette_limit_parts "$text")"
  if [[ -n "$label" && -n "$value" ]]; then
    printf '%s %s %s' "$name" "$label" "$value"
  else
    printf '%s' "$text"
  fi
}

selector_palette_compact_active_limit() {
  local text="$1"
  local compact_name value

  IFS=$'\t' read -r _ compact_name _ value <<<"$(selector_palette_limit_parts "$text")"
  if [[ -n "$value" ]]; then
    printf 'act %s %s' "$compact_name" "$value"
  elif [[ -n "$compact_name" ]]; then
    printf 'act %s' "$compact_name"
  fi
}

selector_palette_limit_parts() {
  local text="$1"
  local name="" compact_name="" label="" value="" token
  local parts=()
  local i

  read -r -a parts <<<"$text"
  if (( ${#parts[@]} > 0 )); then
    name="${parts[0]}"
    compact_name="$(usage_display_profile_name "$name" "" 6)"
  fi
  for ((i = 1; i < ${#parts[@]} - 1; i++)); do
    token="${parts[$i]}"
    case "$token" in
      5h|short|wk)
        label="$token"
        value="${parts[$((i + 1))]}"
        break
        ;;
    esac
  done
  printf '%s\t%s\t%s\t%s\n' "$name" "$compact_name" "$label" "$value"
}

selector_palette_keyword_tone() {
  case "${1:-}" in
    best)
      printf 'accent'
      ;;
    active|act)
      printf 'active'
      ;;
    ready)
      printf 'good'
      ;;
    cap)
      printf 'bad'
      ;;
    login)
      printf 'warn'
      ;;
    *)
      return 1
      ;;
  esac
}

selector_palette_context_word_tone() {
  local word="$1"
  local section="${2:-}"

  if [[ "$word" == *% ]]; then
    usage_limit_tone "$word"
    return 0
  fi
  if selector_palette_keyword_tone "$word"; then
    return 0
  fi
  if selector_palette_keyword_tone "$section"; then
    return 0
  fi
  printf 'muted'
}

print_selector_palette_context_line() {
  local line="$1"
  local total_w="$2"
  local rest spaces word section="" tone

  if (( ${#line} > total_w )); then
    fit_text_rtrim "$line" "$total_w"
    printf '\n'
    return 0
  fi
  if ! usage_color_active; then
    fit_text_rtrim "$line" "$total_w"
    printf '\n'
    return 0
  fi

  rest="$line"
  while [[ -n "$rest" ]]; do
    if [[ "$rest" =~ ^([[:space:]]*)([^[:space:]]+)(.*)$ ]]; then
      spaces="${BASH_REMATCH[1]}"
      word="${BASH_REMATCH[2]}"
      rest="${BASH_REMATCH[3]}"
      printf '%s' "$spaces"
      tone="$(selector_palette_context_word_tone "$word" "$section")"
      usage_tone_color "$tone"
      printf '%s' "$word"
      usage_tone_reset
      case "$word" in
        best|active|act|ready|cap|login)
          section="$word"
          ;;
      esac
    else
      printf '%s' "$rest"
      break
    fi
  done
  printf '\n'
}

selector_palette_context_compact_best() {
  local best_value="$1"
  local best_parts=()

  if [[ "$best_value" == best\ * ]]; then
    read -r -a best_parts <<<"${best_value#best }"
    if (( ${#best_parts[@]} > 0 )); then
      printf 'best %s' "${best_parts[0]}"
      return 0
    fi
  fi
  printf '%s' "$best_value"
}

selector_palette_context_add_active() {
  local -n line_ref="$1"
  local active_part="$2"
  local best_value="$3"
  local compact_best_value="$4"
  local total_w="$5"
  local active_value compact_active_value

  [[ -n "$active_part" ]] || return 0
  active_value="$active_part"
  [[ "$active_value" == active\ * ]] && active_value="active $(selector_palette_take_short_limit "${active_value#active }")"
  if (( ${#line_ref} + ${#active_value} + 3 <= total_w )); then
    line_ref+="   $active_value"
    return 0
  fi
  compact_active_value="$(selector_palette_compact_active_limit "${active_part#active }")"
  if [[ -n "$compact_active_value" ]] && (( ${#line_ref} + ${#compact_active_value} + 3 <= total_w )); then
    line_ref+="   $compact_active_value"
  elif [[ -n "$compact_active_value" && "$compact_best_value" != "$best_value" ]] \
    && (( ${#compact_best_value} + ${#compact_active_value} + 3 <= total_w )); then
    line_ref="$compact_best_value   $compact_active_value"
  fi
}

selector_palette_context_add_stats() {
  local -n line_ref="$1"
  local stats_part="$2"
  local sep="$3"
  local total_w="$4"
  local stat_token next_part prefix added_stats=0

  while [[ -n "$stats_part" ]]; do
    IFS=$'\t' read -r stat_token next_part <<<"$(usage_summary_split_once "$stats_part" "$sep")"
    stats_part="$next_part"
    stat_token="${stat_token//capped /cap }"
    [[ "$stat_token" == cache\ * ]] && continue
    [[ -n "$stat_token" ]] || continue
    if (( added_stats )); then
      prefix=" "
    else
      prefix="   "
    fi
    if (( ${#line_ref} + ${#stat_token} + ${#prefix} <= total_w )); then
      line_ref+="$prefix$stat_token"
      added_stats=1
    else
      break
    fi
  done
}

selector_palette_context_line() {
  local summary="$1"
  local total_w="$2"
  local sep first rest active_part="" stats_part line best_value compact_best_value

  sep="$(usage_separator)"
  IFS=$'\t' read -r first rest <<<"$(usage_summary_split_once "$summary" "$sep")"
  usage_summary_extend_best_head first rest "$sep"
  usage_summary_normalize_best_active first
  stats_part="$rest"
  usage_summary_take_active_part active_part stats_part "$sep"
  best_value="$first"
  [[ "$best_value" == best\ * ]] && best_value="best $(selector_palette_take_short_limit "${best_value#best }")"
  compact_best_value="$(selector_palette_context_compact_best "$best_value")"
  line="$best_value"
  selector_palette_context_add_active line "$active_part" "$best_value" "$compact_best_value" "$total_w"
  selector_palette_context_add_stats line "$stats_part" "$sep" "$total_w"
  print_selector_palette_context_line "$line" "$total_w"
}

selector_palette_controls_line() {
  local fallback="$1"
  local total_w="$2"
  local left left_compact left_short left_tiny right compact sep tiny_controls tiny_line
  local control_pair candidate_left candidate_right selected=0

  sep="$(usage_separator)"
  left="Auth${sep}Codex profiles"
  left_compact="Auth${sep}profiles"
  left_short="Auth${sep}prof"
  left_tiny="Auth"
  right="enter select${sep}esc stay"
  compact="enter${sep}esc"
  case "$fallback" in
    number*|num*|[0-9]*)
      right="$fallback"
      compact="$fallback"
      ;;
  esac

  for control_pair in "$left"$'\t'"$right" "$left_compact"$'\t'"$compact" "$left_short"$'\t'"$compact" "$left_tiny"$'\t'"$compact"; do
    IFS=$'\t' read -r candidate_left candidate_right <<<"$control_pair"
    if (( ${#candidate_left} + ${#candidate_right} + 3 <= total_w )); then
      left="$candidate_left"
      right="$candidate_right"
      selected=1
      break
    fi
  done

  if (( ! selected )); then
    tiny_controls="$compact"
    tiny_controls="${tiny_controls//$sep/ }"
    if (( ${#left_tiny} + ${#tiny_controls} + 3 > total_w )); then
      tiny_controls="${tiny_controls/ q stay/ q}"
    fi
    tiny_line="$left_tiny$sep$tiny_controls"
    fit_text_rtrim "$tiny_line" "$total_w"
    return 0
  fi

  if usage_color_active; then
    usage_tone_color accent
    printf '%s' "$left"
    usage_tone_reset
    printf '   '
    usage_tone_color muted
    printf '%s' "$right"
    usage_tone_reset
  else
    printf '%s   %s' "$left" "$right"
  fi
}

summary_token_by_prefix() {
  local summary="$1"
  local prefix="$2"
  local sep token

  sep="$(usage_separator)"
  while [[ -n "$summary" ]]; do
    IFS=$'\t' read -r token summary <<<"$(usage_summary_split_once "$summary" "$sep")"
    token="${token//capped /cap }"
    if [[ "$token" == "$prefix "* ]]; then
      printf '%s' "$token"
      return 0
    fi
  done
  return 1
}

print_palette_title_line() {
  local namespace="$1"
  local label="$2"
  local right="$3"
  local total_w="$4"
  local sep left compact_label compact_left gap

  sep="$(usage_separator)"
  left="$namespace$sep$label"
  if (( ${#left} > total_w || ( ${#right} > 0 && ${#left} + ${#right} + 2 > total_w ) )); then
    case "$label" in
      Codex\ profiles|Saved\ profiles) compact_label="Profiles" ;;
      Active\ profile) compact_label="Active" ;;
      Removed\ profile) compact_label="Removed" ;;
      *) compact_label="$label" ;;
    esac
    compact_left="$namespace$sep$compact_label"
    if (( ${#compact_left} < ${#left} )); then
      left="$compact_left"
    fi
  fi
  if (( ${#right} > 0 && ${#left} + ${#right} + 2 <= total_w )); then
    usage_tone_color accent
    printf '%s' "$left"
    usage_tone_reset
    gap=$((total_w - ${#left} - ${#right}))
    printf '%*s' "$gap" ''
    usage_tone_color muted
    printf '%s' "$right"
    usage_tone_reset
    printf '\n'
    return 0
  fi

  usage_tone_color accent
  fit_text_rtrim "$left" "$total_w"
  usage_tone_reset
  printf '\n'
}

print_flat_context_line() {
  local summary="$1"
  local total_w="$2"
  local text sep token parts=()

  sep="$(usage_separator)"
  while [[ -n "$summary" ]]; do
    IFS=$'\t' read -r token summary <<<"$(usage_summary_split_once "$summary" "$sep")"
    token="${token//capped /cap }"
    [[ "$token" == cache\ * ]] && continue
    [[ -n "$token" ]] && parts+=("$token")
  done

  if (( ${#parts[@]} == 0 )); then
    text=""
  else
    text="${parts[0]}"
    local i
    for ((i = 1; i < ${#parts[@]}; i++)); do
      text+="   ${parts[$i]}"
    done
  fi
  print_selector_palette_context_line "$text" "$total_w"
}

print_palette_summary_header() {
  local namespace="$1"
  local label="$2"
  local summary="$3"
  local total_w="$4"
  local mode="${5:-flat}"
  local gap="${6:-1}"
  local right=""

  right="$(summary_token_by_prefix "$summary" cache || true)"
  print_palette_title_line "$namespace" "$label" "$right" "$total_w"
  if [[ "$mode" == "usage" && "${CODEX_AUTH_USAGE_CONTEXT:-0}" == "1" ]]; then
    selector_palette_context_line "$summary" "$total_w"
  elif [[ "$mode" == "usage" ]]; then
    :
  else
    print_flat_context_line "$summary" "$total_w"
  fi
  if (( gap )); then
    printf '\n'
  fi
}

selector_fzf_base_height() {
  local row_count="$1"
  local fzf_height=$((row_count + 8))
  local term_lines max_height

  (( fzf_height < 12 )) && fzf_height=12
  term_lines="${LINES:-}"
  [[ "$term_lines" =~ ^[0-9]+$ ]] || term_lines="$(tput lines 2>/dev/null || true)"
  if [[ "$term_lines" =~ ^[0-9]+$ ]]; then
    max_height=$((term_lines - 2))
    (( max_height < 12 )) && max_height=12
    (( fzf_height > max_height )) && fzf_height="$max_height"
  elif (( fzf_height > 24 )); then
    fzf_height=24
  fi

  printf '%s\t%s\n' "$fzf_height" "$term_lines"
}

selector_fzf_theme_color() {
  local selector_palette_mode="$1"
  local color_arg=""
  local opencode_theme=0

  if [[ -n "${CODEX_AUTH_FZF_THEME:-}" ]]; then
    if [[ "$CODEX_AUTH_FZF_THEME" == "codex" || "$CODEX_AUTH_FZF_THEME" == "1" ]]; then
      color_arg="$(selector_palette_fzf_colors)"
      opencode_theme=1
    else
      color_arg="$CODEX_AUTH_FZF_THEME"
    fi
  elif (( selector_palette_mode )); then
    if usage_color_active; then
      color_arg="$(selector_palette_fzf_colors)"
    else
      color_arg="bw"
    fi
    opencode_theme=1
  fi

  printf '%s\t%s\n' "$color_arg" "$opencode_theme"
}

selector_fzf_controls() {
  local total_w="$1"
  local fzf_prompt fzf_pointer selector_control_sep selector_controls

  selector_control_sep="$(usage_separator)"
  if usage_unicode_enabled; then
    fzf_prompt='filter ▸ '
    fzf_pointer='▸'
  else
    fzf_prompt='filter > '
    fzf_pointer='>'
  fi
  if (( total_w < 32 )); then
    selector_controls="enter${selector_control_sep}esc stay${selector_control_sep}filter"
  else
    selector_controls="enter select${selector_control_sep}esc stay${selector_control_sep}type filter"
  fi

  printf '%s\t%s\t%s\n' "$fzf_prompt" "$fzf_pointer" "$selector_controls"
}

selector_fzf_apply_frame() {
  local fzf_opencode_theme="$1"
  local total_w="$2"
  local -n fzf_prompt_ref="$3"
  local -n fzf_pointer_ref="$4"
  local -n fzf_border_args_ref="$5"
  local -n fzf_margin_args_ref="$6"

  if (( fzf_opencode_theme )); then
    local palette_effective_w right_margin terminal_w primary_w week_w short_w status_w status_gap metric_gap
    fzf_pointer_ref=' '
    fzf_prompt_ref='filter '
    terminal_w="$(terminal_width)"
    IFS=$'\t' read -r primary_w week_w short_w status_w <<<"$(selector_palette_table_widths "$total_w")"
    status_gap="$(selector_palette_status_gap "$total_w")"
    metric_gap="$(selector_palette_metric_gap "$total_w")"
    if (( week_w == 0 )); then
      palette_effective_w=$((primary_w + 1 + short_w))
    else
      palette_effective_w=$((primary_w + 1 + week_w + metric_gap + short_w))
      if (( status_w > 0 )); then
        palette_effective_w=$((palette_effective_w + status_gap + status_w))
      fi
    fi
    right_margin=$((terminal_w - palette_effective_w - 4))
    if (( right_margin > 0 )); then
      fzf_margin_args_ref+=(--margin="0,$right_margin,0,0")
    fi
    fzf_border_args_ref+=(--border=none)
  else
    fzf_border_args_ref+=(--border=rounded --border-label=' auth profiles ' --border-label-pos=3)
  fi
}

selector_fzf_palette_height() {
  local row_count="$1"
  local header_count="$2"
  local term_lines="$3"
  local height max_height vertical_padding=0

  height=$((row_count + header_count + 1))
  if [[ "$term_lines" =~ ^[0-9]+$ ]]; then
    max_height=$((term_lines - 2))
    max_height=$(( max_height < 6 ? 6 : max_height ))
    if (( height + 2 <= max_height )); then
      height=$((height + 2))
      vertical_padding=1
    fi
    height=$(( height > max_height ? max_height : height ))
  elif (( height < 22 )); then
    height=$((height + 2))
    vertical_padding=1
  fi
  printf '%s\t%s\n' "$height" "$vertical_padding"
}

selector_fzf_prepare_header() {
  local -n header_rows_ref="$1"
  local summary_text="$2"
  local selector_controls="$3"
  local total_w="$4"
  local role_w="$5"
  local profile_w="$6"
  local cell_w="$7"
  local status_w="$8"
  local mode="$9"
  local fzf_opencode_theme="${10}"
  local term_lines="${11}"
  local -n fzf_header_ref="${12}"
  local -n fzf_height_ref="${13}"
  local -n fzf_height_arg_ref="${14}"
  local -n fzf_outer_top_padding_ref="${15}"
  local -n fzf_header_line_count_ref="${16}"
  local -n fzf_padding_args_ref="${17}"
  local -n fzf_header_args_ref="${18}"
  local fzf_vertical_padding=0 fzf_header_line

  if (( fzf_opencode_theme )); then
    fzf_header_ref="$(selector_palette_header_text "$summary_text" "$selector_controls" "$total_w")"
    fzf_header_line_count_ref=0
    while IFS= read -r fzf_header_line; do
      fzf_header_line_count_ref=$((fzf_header_line_count_ref + 1))
    done <<<"$fzf_header_ref"
    (( fzf_header_line_count_ref < 1 )) && fzf_header_line_count_ref=1
    IFS=$'\t' read -r fzf_height_ref fzf_vertical_padding <<<"$(selector_fzf_palette_height "${#header_rows_ref[@]}" "$fzf_header_line_count_ref" "$term_lines")"
    if (( fzf_vertical_padding )); then
      fzf_padding_args_ref+=(--padding=1,0,1,0)
    fi
    if [[ "${CODEX_AUTH_SELECTOR_CENTER:-0}" == "1" && "$term_lines" =~ ^[0-9]+$ ]] && (( term_lines > fzf_height_ref + 1 )); then
      fzf_outer_top_padding_ref=$(((term_lines - fzf_height_ref) / 2))
    fi
    fzf_height_arg_ref="~$fzf_height_ref"
    fzf_header_args_ref+=(--header-lines="$fzf_header_line_count_ref" --header-first)
  else
    fzf_header_ref="$(selector_header_text "$summary_text" "$selector_controls" "$role_w" "$profile_w" "$cell_w" "$status_w" "$total_w" "$mode")"
    fzf_header_args_ref+=(--header="$fzf_header_ref")
  fi
}

selector_fzf_menu() {
  local -n rows_ref="$1"
  local summary_text="$2"
  local total_w="$3"
  local role_w="$4"
  local profile_w="$5"
  local cell_w="$6"
  local status_w="$7"
  local mode="$8"
  local selector_palette_mode="$9"
  local fzf_height fzf_height_arg choice kind action profile_choice fzf_prompt fzf_pointer fzf_header term_lines
  local fzf_outer_top_padding=0
  local fzf_pad_i=0
  local fzf_header_line_count=1
  local fzf_color_args=()
  local fzf_border_args=()
  local fzf_margin_args=()
  local fzf_padding_args=()
  local fzf_ellipsis_args=()
  local fzf_header_args=()
  local fzf_layout_args=(--layout=reverse)
  local fzf_opencode_theme=0
  local selector_controls
  local fzf_color_arg

  IFS=$'\t' read -r fzf_height term_lines <<<"$(selector_fzf_base_height "${#rows_ref[@]}")"
  IFS=$'\t' read -r fzf_color_arg fzf_opencode_theme <<<"$(selector_fzf_theme_color "$selector_palette_mode")"
  [[ -n "$fzf_color_arg" ]] && fzf_color_args+=(--color="$fzf_color_arg")
  fzf_height_arg="~$fzf_height"
  fzf_ellipsis_args+=(--ellipsis='')
  IFS=$'\t' read -r fzf_prompt fzf_pointer selector_controls <<<"$(selector_fzf_controls "$total_w")"
  selector_fzf_apply_frame "$fzf_opencode_theme" "$total_w" fzf_prompt fzf_pointer fzf_border_args fzf_margin_args
  selector_fzf_prepare_header rows_ref "$summary_text" "$selector_controls" "$total_w" "$role_w" "$profile_w" "$cell_w" "$status_w" "$mode" \
    "$fzf_opencode_theme" "$term_lines" fzf_header fzf_height fzf_height_arg fzf_outer_top_padding fzf_header_line_count fzf_padding_args fzf_header_args

  for ((fzf_pad_i = 0; fzf_pad_i < fzf_outer_top_padding; fzf_pad_i++)); do
    printf '\n'
  done

  choice="$(
    {
      if (( fzf_opencode_theme )); then
        while IFS= read -r fzf_header_line; do
          printf 'header\tnoop\t-\t%s\n' "$fzf_header_line"
        done <<<"$fzf_header"
      fi
      printf '%s\n' "${rows_ref[@]}"
    } | fzf \
      --ansi \
      --no-sort \
      "${fzf_layout_args[@]}" \
      --height="$fzf_height_arg" \
      "${fzf_border_args[@]}" \
      "${fzf_margin_args[@]}" \
      "${fzf_padding_args[@]}" \
      --prompt="$fzf_prompt" \
      --pointer="$fzf_pointer" \
      --marker=' ' \
      --info=hidden \
      --no-scrollbar \
      --no-separator \
      "${fzf_ellipsis_args[@]}" \
      "${fzf_header_args[@]}" \
      --delimiter=$'\t' \
      --with-nth=4.. \
      --bind='esc:abort,ctrl-q:abort' \
      --no-multi \
      --cycle \
      --tiebreak=index \
      "${fzf_color_args[@]}"
  )" || {
    MENU_ACTION="skip"
    MENU_PROFILE=""
    return 0
  }

  IFS=$'\t' read -r kind action profile_choice display <<<"$choice"
  [[ "$profile_choice" == "-" ]] && profile_choice=""
  if [[ "$action" == "switch" || "$action" == "login" || "$action" == "skip" ]]; then
    MENU_ACTION="$action"
    MENU_PROFILE="$profile_choice"
  else
    MENU_ACTION="blocked"
    MENU_PROFILE=""
  fi
}

selector_numbered_top_padding() {
  local row_count="$1"
  local term_lines="$2"
  local fallback_height

  if [[ "${CODEX_AUTH_SELECTOR_CENTER:-0}" == "1" && "$term_lines" =~ ^[0-9]+$ ]]; then
    fallback_height=$((3 + row_count + 1))
    if (( term_lines > fallback_height + 1 )); then
      printf '%s' $(((term_lines - fallback_height) / 2))
      return 0
    fi
  fi
  printf '0'
}

selector_numbered_header() {
  local selector_palette_mode="$1"
  local selector_controls="$2"
  local summary_text="$3"
  local total_w="$4"
  local role_w="$5"
  local profile_w="$6"
  local cell_w="$7"
  local status_w="$8"
  local mode="$9"

  if (( selector_palette_mode )); then
    printf '%*s' 4 ''
    selector_palette_controls_line "$selector_controls" "$total_w"
    printf '\n'
    if [[ "${CODEX_AUTH_SELECTOR_CONTEXT:-0}" == "1" ]]; then
      printf '%*s' 4 ''
      selector_palette_context_line "$summary_text" "$total_w"
    fi
    printf '%*s' 4 ''
    selector_palette_table_header "$total_w"
  else
    selector_header_text "$summary_text" "$selector_controls" "$role_w" "$profile_w" "$cell_w" "$status_w" "$total_w" "$mode" "auth profiles"
    printf '\n'
  fi
}

selector_numbered_print_display() {
  local display="$1"
  local line_w="$2"
  local plain

  if [[ "$display" == *$'\033'* ]]; then
    plain="$(LC_ALL=C sed $'s/\033\\[[0-9;]*m//g' <<<"$display")"
    if (( ${#plain} <= line_w )); then
      printf '%s' "$display"
    else
      fit_text_rtrim "$plain" "$line_w"
    fi
  else
    fit_text_rtrim "$display" "$line_w"
  fi
}

selector_numbered_print_row() {
  local row="$1"
  local cols="$2"
  local -n action_count_ref="$3"
  local -n fallback_actions_ref="$4"
  local -n fallback_profiles_ref="$5"
  local kind action profile_choice display line_w prefix

  IFS=$'\t' read -r kind action profile_choice display <<<"$row"
  [[ "$profile_choice" == "-" ]] && profile_choice=""
  if [[ "$kind" == "action" ]]; then
    fallback_actions_ref+=("$action")
    fallback_profiles_ref+=("$profile_choice")
    action_count_ref=$((action_count_ref + 1))
    prefix="$(printf '%2d. ' "$action_count_ref")"
    line_w=$((cols - ${#prefix}))
  else
    prefix=''
    line_w="$cols"
  fi
  (( line_w < 1 )) && line_w=1
  printf '%s' "$prefix"
  selector_numbered_print_display "$display" "$line_w"
  printf '\n'
}

selector_numbered_read_choice() {
  local choice="$1"
  local fallback_count="$2"
  local -n selected_ref="$3"

  if [[ -z "$choice" ]]; then
    selected_ref=0
  elif [[ "$choice" == "q" || "$choice" == "Q" ]]; then
    MENU_ACTION="skip"
    MENU_PROFILE=""
    return 1
  elif [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= fallback_count )); then
    selected_ref=$((choice - 1))
  else
    MENU_ACTION="skip"
    MENU_PROFILE=""
    return 1
  fi
}

selector_numbered_menu() {
  local -n rows_ref="$1"
  local summary_text="$2"
  local total_w="$3"
  local role_w="$4"
  local profile_w="$5"
  local cell_w="$6"
  local status_w="$7"
  local mode="$8"
  local selector_palette_mode="$9"
  local choice i action_count=0 cols
  local term_lines fallback_top_padding=0 fallback_pad_i
  local selector_controls sep
  local selected=0
  local fallback_actions=()
  local fallback_profiles=()

  cols="$(terminal_width)"
  term_lines="${LINES:-}"
  [[ "$term_lines" =~ ^[0-9]+$ ]] || term_lines="$(tput lines 2>/dev/null || true)"
  sep="$(usage_separator)"
  if (( cols < 36 )); then
    selector_controls="1-${#rows_ref[@]}${sep}q stay"
  else
    selector_controls="1-${#rows_ref[@]} select${sep}q stay"
  fi
  fallback_top_padding="$(selector_numbered_top_padding "${#rows_ref[@]}" "$term_lines")"
  for ((fallback_pad_i = 0; fallback_pad_i < fallback_top_padding; fallback_pad_i++)); do
    printf '\n'
  done

  selector_numbered_header "$selector_palette_mode" "$selector_controls" "$summary_text" "$total_w" "$role_w" "$profile_w" "$cell_w" "$status_w" "$mode"
  for i in "${!rows_ref[@]}"; do
    selector_numbered_print_row "${rows_ref[$i]}" "$cols" action_count fallback_actions fallback_profiles
  done
  if usage_unicode_enabled; then
    printf '› '
  else
    printf '> '
  fi
  IFS= read -r choice < /dev/tty || return 0
  selector_numbered_read_choice "$choice" "${#fallback_actions[@]}" selected || return 0

  MENU_ACTION="${fallback_actions[$selected]}"
  MENU_PROFILE="${fallback_profiles[$selected]}"
}

selector_valid_palette_role() {
  local default_profile="$1"
  local profile="$2"
  local mark="$3"
  local display_status="$4"

  if [[ "$mark" == "*" ]]; then
    printf 'stay'
  elif [[ "$mark" == "=" ]]; then
    printf 'same'
  else
    case "$display_status" in
      ready|ok)
        if [[ -n "$default_profile" && "$profile" == "$default_profile" ]]; then
          printf 'best'
        else
          printf 'use'
        fi
        ;;
      cap|old\ cap|both\ cap)
        printf 'cap'
        ;;
      *)
        printf 'warn'
        ;;
    esac
  fi
}

selector_valid_plain_role() {
  local default_profile="$1"
  local profile="$2"
  local mark="$3"
  local display_status="$4"
  local role_w="$5"

  if [[ "$mark" == "*" ]]; then
    selector_action_role "stay" "$role_w"
  elif [[ "$mark" == "=" ]]; then
    selector_action_role "same" "$role_w"
  elif [[ "$display_status" == "cap" || "$display_status" == "old cap" || "$display_status" == "both cap" ]]; then
    selector_action_role "cap" "$role_w"
  elif [[ -n "$default_profile" && "$profile" == "$default_profile" ]]; then
    selector_action_role "best" "$role_w"
  else
    selector_action_role "switch" "$role_w"
  fi
}

selector_invalid_role() {
  local mark="$1"
  local palette_mode="$2"

  case "$mark:$palette_mode" in
    "*:1") printf 'stay' ;;
    "=:1"|"=:0") printf 'same' ;;
    *) printf 'use' ;;
  esac
}

selector_menu_row_for_record() {
  local default_profile="$1"
  local selector_palette_mode="$2"
  local mode="$3"
  local role_w="$4"
  local profile_w="$5"
  local cell_w="$6"
  local status_w="$7"
  local bar_width="$8"
  local total_w="$9"
  local selector_profile_w="${10}"
  local action_w="${11}"
  local record="${12}"
  local valid weekly_used short_used mark profile plan weekly short status short_label weekly_reset short_reset cache_age
  local display display_status palette_profile detail action_role row_action row_profile_field active_row=0

  IFS=$'\t' read -r valid weekly_used short_used mark profile plan weekly short status short_label weekly_reset short_reset cache_age <<<"$record"
  [[ -n "$profile" ]] || return 1
  row_action="switch"
  row_profile_field="$profile"

  if [[ "$valid" != "0" && "$status" == "login" ]]; then
    if (( selector_palette_mode )); then
      palette_profile="$(selector_palette_profile_label "$profile" "$total_w" "$selector_profile_w")"
      display="$(print_selector_palette_table_row "login $palette_profile" "-" "-" "login needed" "$status" "$valid" "$total_w")"
    else
      detail="needed"
      display="$(print_selector_row "login" "$(usage_display_profile_name "$profile" "" "$selector_profile_w")" "$detail" "$action_w" "$selector_profile_w" "$total_w")"
    fi
    row_action="login"
  elif [[ "$valid" == "0" ]]; then
    if (( selector_palette_mode )); then
      display_status="$(usage_display_status "$status" "normal")"
      palette_profile="$(selector_palette_profile_label "$profile" "$total_w" "$selector_profile_w")"
      action_role="$(selector_valid_palette_role "$default_profile" "$profile" "$mark" "$display_status")"
      display="$(print_selector_palette_table_row "$action_role $palette_profile" "$weekly" "$short" "$display_status" "$status" "$valid" "$total_w")"
    else
      display_status="$(usage_display_status "$status" "$mode")"
      action_role="$(selector_valid_plain_role "$default_profile" "$profile" "$mark" "$display_status" "$role_w")"
      display="$(print_usage_render_data_line "$action_role" "$profile" "$weekly" "$weekly_reset" "$short" "$short_reset" \
        "$display_status" "$status" "$valid" "$weekly_used" "$short_used" "$role_w" "$profile_w" "$cell_w" "$status_w" "$bar_width" "$mode")"
    fi
  else
    if (( selector_palette_mode )); then
      display_status="$(usage_display_status "$status" "normal")"
      palette_profile="$(selector_palette_profile_label "$profile" "$total_w" "$selector_profile_w")"
      action_role="$(selector_invalid_role "$mark" 1)"
      display="$(print_selector_palette_table_row "$action_role $palette_profile" "-" "-" "$display_status" "$status" "$valid" "$total_w")"
    else
      display_status="$(usage_display_status "$status" "$mode")"
      action_role="$(selector_invalid_role "$mark" 0)"
      display="$(print_selector_row "$action_role" "$(usage_display_profile_name "$profile" "" "$selector_profile_w")" "$display_status" "$action_w" "$selector_profile_w" "$total_w")"
    fi
  fi
  if [[ "$row_action" == "switch" && ( "$mark" == "*" || "$mark" == "=" ) ]]; then
    active_row=1
    row_action="skip"
    row_profile_field="-"
  fi

  printf '%s\037action\037%s\037%s\037%s\n' "$active_row" "$row_action" "$row_profile_field" "$display"
}

selector_current_menu_row() {
  local selector_palette_mode="$1"
  local total_w="$2"
  local selector_profile_w="$3"
  local action_w="$4"
  local display palette_profile

  if (( selector_palette_mode )); then
    palette_profile="$(selector_palette_profile_label "current" "$total_w" "$selector_profile_w")"
    display="$(print_selector_palette_table_row "stay $palette_profile" "-" "-" "same" "ok" "1" "$total_w")"
  else
    display="$(print_selector_row "stay" "current" "same" "$action_w" "$selector_profile_w" "$total_w")"
  fi
  printf 'action\tskip\t-\t%s\n' "$display"
}

selector_palette_mode_for_fzf() {
  local use_fzf="$1"

  if (( ! use_fzf )); then
    printf '1'
    return 0
  fi
  case "${CODEX_AUTH_FZF_THEME:-}" in
    codex|1|'')
      printf '1'
      ;;
    *)
      printf '0'
      ;;
  esac
}

selector_render_columns() {
  local use_fzf="$1"
  local selector_palette_mode="$2"
  local render_cols="$3"

  if (( use_fzf && selector_palette_mode )); then
    render_cols=$((render_cols - 3))
    (( render_cols < 20 )) && render_cols=20
  elif (( ! use_fzf )); then
    render_cols=$((render_cols - 4))
    (( render_cols < 16 )) && render_cols=16
  fi
  printf '%s' "$render_cols"
}

selector_menu_rows() {
  local -n rows_ref="$1"
  local -n has_active_ref="$2"
  local default_profile="$3"
  local selector_palette_mode="$4"
  local mode="$5"
  local role_w="$6"
  local profile_w="$7"
  local cell_w="$8"
  local status_w="$9"
  local bar_width="${10}"
  local total_w="${11}"
  local selector_profile_w="${12}"
  local action_w="${13}"
  shift 13
  local record row active_row row_kind row_action row_profile_field row_display

  for record in "$@"; do
    row="$(selector_menu_row_for_record "$default_profile" "$selector_palette_mode" "$mode" "$role_w" "$profile_w" "$cell_w" "$status_w" "$bar_width" "$total_w" "$selector_profile_w" "$action_w" "$record")" || continue
    IFS=$'\037' read -r active_row row_kind row_action row_profile_field row_display <<<"$row"
    (( active_row )) && has_active_ref=1
    rows_ref+=("$row_kind"$'\t'"$row_action"$'\t'"$row_profile_field"$'\t'"$row_display")
  done
  return 0
}

arrow_action_menu() {
  local default_profile="${1:-}"
  shift
  local records=("$@")

  MENU_ACTION="skip"
  MENU_PROFILE=""

  [[ "${CODEX_AUTH_NO_PROMPT:-}" != "1" && -t 0 && -t 1 && -r /dev/tty ]] || return 0

  local mode role_w profile_w cell_w status_w bar_width total_w
  local rows=()
  local summary_text action_w selector_profile_w
  local has_active_row=0
  local use_fzf=0
  local selector_palette_mode=0
  local render_cols

  if command -v fzf >/dev/null 2>&1 && [[ "${CODEX_AUTH_NO_FZF:-}" != "1" ]]; then
    use_fzf=1
  fi
  render_cols="$(terminal_width)"
  if (( render_cols < 32 )); then
    use_fzf=0
  fi

  selector_palette_mode="$(selector_palette_mode_for_fzf "$use_fzf")"
  USAGE_COLOR_ENABLED=0
  if (( use_fzf || selector_palette_mode )) && color_enabled; then
    USAGE_COLOR_ENABLED=1
  fi
  render_cols="$(selector_render_columns "$use_fzf" "$selector_palette_mode" "$render_cols")"
  IFS=$'\t' read -r mode role_w profile_w cell_w status_w bar_width <<<"$(usage_render_widths "$render_cols")"
  total_w="$(usage_render_total_width "$role_w" "$profile_w" "$cell_w" "$status_w")"
  total_w="$(clamp_int_between "$total_w" 0 "$render_cols")"
  summary_text="$(usage_metadata_summary_line "$total_w" "$default_profile" "${records[@]}")"
  action_w=5
  selector_profile_w="$profile_w"
  (( selector_profile_w < 10 )) && selector_profile_w=10

  selector_menu_rows rows has_active_row "$default_profile" "$selector_palette_mode" "$mode" "$role_w" "$profile_w" "$cell_w" "$status_w" "$bar_width" "$total_w" "$selector_profile_w" "$action_w" "${records[@]}"
  if (( ! has_active_row )) && [[ -f "$AUTH_FILE" ]]; then
    rows+=("$(selector_current_menu_row "$selector_palette_mode" "$total_w" "$selector_profile_w" "$action_w")")
  fi

  if (( use_fzf )); then
    selector_fzf_menu rows "$summary_text" "$total_w" "$role_w" "$profile_w" "$cell_w" "$status_w" "$mode" "$selector_palette_mode"
    return 0
  fi

  selector_numbered_menu rows "$summary_text" "$total_w" "$role_w" "$profile_w" "$cell_w" "$status_w" "$mode" "$selector_palette_mode"
}

usage_refresh_job_count() {
  local profile_count="$1"
  local max_jobs="${CODEX_AUTH_REFRESH_JOBS:-2}"
  local max_jobs_cap="${CODEX_AUTH_REFRESH_JOBS_MAX:-4}"

  [[ "$max_jobs" =~ ^[0-9]+$ && "$max_jobs" -gt 0 ]] || max_jobs=2
  [[ "$max_jobs_cap" =~ ^[0-9]+$ && "$max_jobs_cap" -gt 0 ]] || max_jobs_cap=4
  (( max_jobs > max_jobs_cap )) && max_jobs="$max_jobs_cap"
  (( max_jobs > profile_count )) && max_jobs="$profile_count"
  (( max_jobs < 1 )) && max_jobs=1
  printf '%s' "$max_jobs"
}

collect_usage_record_file() {
  local active_fp="$1"
  local output_file="$2"
  local profile_file="$3"
  local profile_name payload fingerprint

  require_auth_file "$profile_file"
  profile_name="$(basename "$profile_file" .json)"
  fingerprint="$(credential_fingerprint "$profile_file" || true)"
  payload="$(usage_payload_for_profile "$profile_file" "$fingerprint")"
  usage_record_for_profile "$profile_name" "$profile_file" "$payload" "$active_fp" "$fingerprint" > "$output_file"
}

usage_wait_for_refresh_slot() {
  local -n active_jobs_ref="$1"

  wait -n || true
  active_jobs_ref=$((active_jobs_ref - 1))
}

collect_usage_records() {
  local active_fp="$1"
  shift
  local profile_files=("$@")
  local records_dir profile_file i
  local max_jobs active_jobs=0

  max_jobs="$(usage_refresh_job_count "${#profile_files[@]}")"
  records_dir="$(mktemp -d "$CODEX_HOME/.tmp/auth-records.XXXXXX")"

  for i in "${!profile_files[@]}"; do
    profile_file="${profile_files[$i]}"
    collect_usage_record_file "$active_fp" "$records_dir/$i.record" "$profile_file" &
    active_jobs=$((active_jobs + 1))
    if (( active_jobs >= max_jobs )); then
      usage_wait_for_refresh_slot active_jobs
    fi
  done

  while (( active_jobs > 0 )); do
    usage_wait_for_refresh_slot active_jobs
  done

  for i in "${!profile_files[@]}"; do
    [[ -f "$records_dir/$i.record" ]] && cat "$records_dir/$i.record"
  done | canonical_usage_active_marks
  rm -rf "$records_dir" 2>/dev/null || true
  return 0
}

collect_usage_records_cached() {
  local active_fp="$1"
  shift
  local profile_files=("$@")
  local map_file profile_file profile_name meta_path mode hint secret fp payload
  local -A profile_fp=()
  local -A payload_by_path=()

  map_file="$(mktemp "$CODEX_HOME/.tmp/auth-cache-map.XXXXXX")"

  while IFS=$'\037' read -r meta_path mode hint secret; do
    [[ -n "$meta_path" ]] || continue
    fp="$(auth_record_fingerprint "$secret")"
    profile_name="$(basename "$meta_path" .json)"
    profile_fp["$meta_path"]="$fp"
    printf '%s\037%s\037%s\n' "$meta_path" "$profile_name" "$fp" >> "$map_file"
  done < <(auth_metadata_records "${profile_files[@]}")

  while IFS=$'\037' read -r meta_path profile_name payload; do
    [[ -n "$meta_path" ]] || continue
    payload_by_path["$meta_path"]="$payload"
  done < <(state_payload_records "$map_file")

  for profile_file in "${profile_files[@]}"; do
    profile_name="$(basename "$profile_file" .json)"
    fp="${profile_fp["$profile_file"]:-}"
    payload="${payload_by_path["$profile_file"]:-null}"
    usage_record_for_profile "$profile_name" "$profile_file" "$payload" "$active_fp" "$fp"
  done | canonical_usage_active_marks

  rm -f "$map_file" 2>/dev/null || true
  return 0
}

usage_blocked_cache_payload() {
  local profile_name="$1"
  local fingerprint="$2"
  local payload=""

  if [[ "${CODEX_AUTH_REFRESH_BLOCKED:-0}" == "1" && -n "$fingerprint" ]]; then
    payload="$(state_payload_for_profile "$profile_name" "$fingerprint" || true)"
    if [[ -n "$payload" ]] && ! usage_payload_still_blocked "$payload"; then
      payload=""
    fi
  fi
  printf '%s' "$payload"
}

usage_refresh_state_fallback_payload() {
  local profile_name="$1"
  local fingerprint="$2"
  local payload=""

  [[ -n "$fingerprint" ]] && payload="$(state_payload_for_profile "$profile_name" "$fingerprint" || true)"
  if [[ -n "$payload" && "${CODEX_AUTH_REFRESH_FALLBACK_CACHE:-1}" == "1" ]]; then
    mark_stale_payload "$payload"
  else
    printf '%s' '{"error":{"message":"no response"}}'
  fi
}

usage_refresh_payload_or_cache() {
  local profile_name="$1"
  local profile_file="$2"
  local fingerprint="$3"
  local payload

  payload="$(usage_blocked_cache_payload "$profile_name" "$fingerprint")"
  [[ -n "$payload" ]] && printf '%s' "$payload" && return 0

  payload="$(usage_json_for_profile "$profile_file")"
  if [[ -n "$payload" && "$payload" != "null" ]] && usage_payload_transient_error "$payload"; then
    payload=""
  fi
  if [[ -z "$payload" || "$payload" == "null" ]]; then
    payload="$(usage_refresh_state_fallback_payload "$profile_name" "$fingerprint")"
  elif [[ -n "$fingerprint" ]]; then
    state_update_profile "$profile_name" "$fingerprint" "$payload"
  fi
  printf '%s' "$payload"
}

collect_usage_record_synced() {
  local active_fp="$1"
  local profile_file="$2"
  local profile_name fingerprint payload

  require_auth_file "$profile_file"
  profile_name="$(basename "$profile_file" .json)"
  fingerprint="$(credential_fingerprint "$profile_file" || true)"
  payload="$(usage_refresh_payload_or_cache "$profile_name" "$profile_file" "$fingerprint")"
  usage_record_for_profile "$profile_name" "$profile_file" "$payload" "$active_fp" "$fingerprint"
}

collect_usage_records_synced() {
  local active_fp="$1"
  shift
  local profile_files=("$@")
  local records=""
  local profile_file

  for profile_file in "${profile_files[@]}"; do
    records+="$(collect_usage_record_synced "$active_fp" "$profile_file")"$'\n'
  done

  printf '%s' "$records" | canonical_usage_active_marks
}

refresh_active_profile_state() {
  local profile_name="$1"
  local profile_file fingerprint payload

  profile_file="$(profile_path "$profile_name")"
  require_auth_file "$profile_file"
  fingerprint="$(credential_fingerprint "$profile_file" || true)"
  payload="$(usage_json_from_home "$CODEX_HOME")"

  if [[ -n "$payload" && "$payload" != "null" && -n "$fingerprint" ]] \
    && ! usage_payload_transient_error "$payload" \
    && ! jq -e '.error? != null' >/dev/null 2>&1 <<<"$payload"; then
    state_update_profile "$profile_name" "$fingerprint" "$payload"
    return 0
  fi

  return 1
}

usage_limit_coverage_rank() {
  local weekly="$1"
  local short="$2"

  if [[ -n "$weekly" && "$weekly" != "-" && -n "$short" && "$short" != "-" ]]; then
    printf '0'
  elif [[ -n "$short" && "$short" != "-" ]]; then
    printf '1'
  elif [[ -n "$weekly" && "$weekly" != "-" ]]; then
    printf '2'
  else
    printf '9'
  fi
}

usage_limit_sort_score() {
  local used="$1"
  local display="$2"

  if [[ -n "$display" && "$display" != "-" && "$used" =~ ^[0-9]+$ ]]; then
    printf '%s' "$used"
  else
    printf '101'
  fi
}

usage_record_is_best_candidate() {
  local valid="$1"
  local weekly_used="$2"
  local short_used="$3"
  local status="$4"

  [[ "$valid" == "0" && "$status" == "ok" ]] || return 1
  (( weekly_used < 100 && short_used < 100 ))
}

usage_best_candidate_scores() {
  local weekly_used="$1"
  local short_used="$2"
  local weekly="$3"
  local short="$4"
  local coverage_rank

  coverage_rank="$(usage_limit_coverage_rank "$weekly" "$short")"
  (( coverage_rank < 9 )) || return 1
  printf '%s\t%s\t%s\n' "$coverage_rank" "$(usage_limit_sort_score "$short_used" "$short")" "$(usage_limit_sort_score "$weekly_used" "$weekly")"
}

usage_best_candidate_wins() {
  local include_active="$1"
  local mark="$2"
  local coverage_rank="$3"
  local short_score="$4"
  local week_score="$5"
  local best_mark="$6"
  local best_coverage="$7"
  local best_short="$8"
  local best_week="$9"

  if (( coverage_rank < best_coverage )); then
    return 0
  fi
  if (( coverage_rank == best_coverage && short_score < best_short )); then
    return 0
  fi
  if (( coverage_rank == best_coverage && short_score == best_short && week_score < best_week )); then
    return 0
  fi
  [[ "$include_active" == "1" && "$mark" == "*" && "$best_mark" != "*" && "$coverage_rank" == "$best_coverage" && "$short_score" == "$best_short" && "$week_score" == "$best_week" ]]
}

find_best_ok_profile() {
  local records="$1"
  local include_active="${2:-0}"
  local best_week=101
  local best_short=101
  local best_coverage=99
  local best_profile=""
  local best_mark=""
  local valid weekly_used short_used mark profile plan weekly short status short_label
  local coverage_rank short_score week_score scores

  while IFS=$'\t' read -r valid weekly_used short_used mark profile plan weekly short status short_label; do
    [[ -n "$profile" ]] || continue
    usage_record_is_best_candidate "$valid" "$weekly_used" "$short_used" "$status" || continue
    [[ "$include_active" != "1" && ( "$mark" == "*" || "$mark" == "=" ) ]] && continue
    scores="$(usage_best_candidate_scores "$weekly_used" "$short_used" "$weekly" "$short")" || continue
    IFS=$'\t' read -r coverage_rank short_score week_score <<<"$scores"
    if usage_best_candidate_wins "$include_active" "$mark" "$coverage_rank" "$short_score" "$week_score" "$best_mark" "$best_coverage" "$best_short" "$best_week"; then
      best_profile="$profile"
      best_mark="$mark"
      best_coverage="$coverage_rank"
      best_week="$week_score"
      best_short="$short_score"
    fi
  done < <(printf '%s\n' "$records" | sed '/^[[:space:]]*$/d')

  if [[ -n "$best_profile" ]]; then
    printf '%s\t%s\t%s\t%s\n' "$best_profile" "$best_mark" "$best_week" "$best_short"
  else
    printf '\n'
  fi
}

usage_ok_record_sort_rank() {
  local default_profile="$1" mark="$2" profile="$3"

  if [[ -n "$default_profile" && "$profile" == "$default_profile" ]]; then
    printf '0'
    return 0
  fi
  case "$mark" in
    '*') printf '1' ;;
    '=') printf '4' ;;
    *) printf '2' ;;
  esac
}

usage_non_ok_record_sort_rank() {
  local mark="$1" status="$2"

  case "$status:$mark" in
    stale*) printf '3' ;;
    *:'*') printf '4' ;;
    *cap*:*) printf '5' ;;
    *) printf '6' ;;
  esac
}

usage_record_sort_rank() {
  local default_profile="$1" valid="$2" mark="$3" profile="$4" status="$5"

  case "$status" in
    offline) printf '7'; return 0 ;;
    login) printf '8'; return 0 ;;
  esac
  if [[ "$valid" != "0" ]]; then
    printf '9'
  elif [[ "$status" == "ok" ]]; then
    usage_ok_record_sort_rank "$default_profile" "$mark" "$profile"
  else
    usage_non_ok_record_sort_rank "$mark" "$status"
  fi
}

usage_record_sort_line() {
  local default_profile="$1"
  local record="$2"
  local valid weekly_used short_used mark profile plan weekly short status short_label weekly_reset short_reset cache_age
  local rank coverage_rank short_score week_score

  IFS=$'\t' read -r valid weekly_used short_used mark profile plan weekly short status short_label weekly_reset short_reset cache_age <<<"$record"
  rank="$(usage_record_sort_rank "$default_profile" "$valid" "$mark" "$profile" "$status")"
  coverage_rank="$(usage_limit_coverage_rank "$weekly" "$short")"
  short_score="$(usage_limit_sort_score "$short_used" "$short")"
  week_score="$(usage_limit_sort_score "$weekly_used" "$weekly")"
  printf '%s\t%s\t%03d\t%03d\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
    "$rank" "$coverage_rank" "$short_score" "$week_score" "$profile" \
    "$valid" "$weekly_used" "$short_used" "$mark" "$profile" "$plan" "$weekly" "$short" "$status" "$short_label" "$weekly_reset" "$short_reset" "$cache_age"
}

usage_prepare_record_hints() {
  local -n sorted_records_ref="$1"
  local record valid weekly_used short_used mark profile plan weekly short status record_short_label weekly_reset short_reset cache_age

  USAGE_SHORT_LABEL="5h"
  USAGE_PROFILE_WIDTH_HINT=12
  for record in "${sorted_records_ref[@]}"; do
    IFS=$'\t' read -r valid weekly_used short_used mark profile plan weekly short status record_short_label weekly_reset short_reset cache_age <<<"$record"
    if (( ${#profile} > USAGE_PROFILE_WIDTH_HINT )); then
      USAGE_PROFILE_WIDTH_HINT="${#profile}"
    fi
    if [[ -n "$record_short_label" && "$record_short_label" != "short" && "$record_short_label" != "5h" ]]; then
      USAGE_SHORT_LABEL="$record_short_label"
    fi
  done
}

prepare_usage_records() {
  local records="$1"
  local default_profile="${2:-}"
  local sorted_records=()

  mapfile -t sorted_records < <(
    printf '%s\n' "$records" \
      | sed '/^[[:space:]]*$/d' \
      | while IFS= read -r record; do
          usage_record_sort_line "$default_profile" "$record"
        done \
      | sort -t $'\t' -k1,1n -k2,2n -k3,3n -k4,4n -k5,5 \
      | cut -f6-
  )

  usage_prepare_record_hints sorted_records
  SORTED_USAGE_RECORDS=("${sorted_records[@]}")
}

render_usage_records() {
  local records="$1"
  local default_profile="$2"
  local active_is_best="$3"

  prepare_usage_records "$records" "$default_profile"

  local mode role_w profile_w cell_w status_w bar_width
  local display_role display_status total_w group previous_group=""
  local render_cols max_cols header_role
  USAGE_COLOR_ENABLED=0
  color_enabled && USAGE_COLOR_ENABLED=1
  max_cols=$((120 + USAGE_VERBOSE * 12))
  render_cols="$(clamp_int_between "$(terminal_width)" 0 "$max_cols")"
  IFS=$'\t' read -r mode role_w profile_w cell_w status_w bar_width <<<"$(usage_render_widths "$render_cols")"
  total_w="$(usage_render_total_width "$role_w" "$profile_w" "$cell_w" "$status_w")"

  print_palette_summary_header "Auth" "Codex profiles" "$(usage_metadata_summary_line "$total_w" "$default_profile" "${SORTED_USAGE_RECORDS[@]}")" "$total_w" usage 0
  if [[ "${CODEX_AUTH_USAGE_HEADER:-0}" == "1" ]]; then
    header_role="act"
    (( role_w <= 1 )) && header_role=""
    print_usage_render_header "$header_role" "$(usage_header_profile "$mode")" "$(usage_header_week "$mode")" "$(usage_header_short "$mode")" "$(usage_header_state "$mode")" \
      "$role_w" "$profile_w" "$cell_w" "$status_w" "$mode"
  fi

  for record in "${SORTED_USAGE_RECORDS[@]}"; do
    IFS=$'\t' read -r valid weekly_used short_used mark profile plan weekly short status record_short_label weekly_reset short_reset cache_age <<<"$record"
	    group="$(usage_record_group "$valid" "$status")"
    if [[ -z "$previous_group" ]]; then
      if [[ "$group" != "ready" && "$group" != "limited" ]]; then
        print_usage_section_rule "$total_w" "$group"
      fi
    elif [[ "$group" != "$previous_group" && "$group" != "ready" && "$group" != "limited" ]]; then
      print_usage_section_rule "$total_w" "$group"
    fi
    previous_group="$group"

    display_role="$(usage_role_label "$mark" "$profile" "$default_profile" "$mode" "$valid" "$status" "$role_w")"
    display_status="$(usage_display_status "$status" "$mode")"
    print_usage_render_data_line "$display_role" "$profile" "$weekly" "$weekly_reset" "$short" "$short_reset" \
      "$display_status" "$status" "$valid" "$weekly_used" "$short_used" "$role_w" "$profile_w" "$cell_w" "$status_w" "$bar_width" "$mode"
  done
}

parse_usage_args() {
  local -n auto_switch_ref="$1"
  local -n args_ref="$2"
  shift 2

  while (( $# > 0 )); do
    if parse_usage_simple_option "$1" auto_switch_ref; then
      shift
      continue
    fi
    if [[ "$1" == "--ttl" ]]; then
      [[ "${2:-}" =~ ^[0-9]+$ ]] || die "usage: --ttl seconds"
      CACHE_TTL="$2"
      shift 2
    elif [[ "$1" == "--" ]]; then
      shift
      args_ref+=("$@")
      break
    elif [[ "$1" == -* ]]; then
      die "unknown usage option: $1"
    else
      args_ref+=("$1")
      shift
    fi
  done
}

parse_usage_simple_option() {
  local option="$1"
  local -n auto_switch_target_ref="$2"

  case "$option" in
    --auto)
      auto_switch_target_ref=1
      ;;
    --cached)
      USAGE_CACHED=1
      ;;
    --refresh)
      USAGE_REFRESH=1
      ;;
    --fast)
      USAGE_FAST_REFRESH=1
      ;;
    --sync)
      USAGE_FAST_REFRESH=0
      ;;
    --quiet|-q)
      USAGE_QUIET=1
      ;;
    --verbose|-v)
      USAGE_VERBOSE=1
      ;;
    --select|--menu)
      USAGE_SELECT=1
      ;;
    *)
      return 1
      ;;
  esac
}

profile_files_for_args_into() {
  local -n profile_files_ref="$1"
  local quiet_missing="$2"
  shift 2
  local name profile_file

  profile_files_ref=()
  if (( $# > 0 )); then
    for name in "$@"; do
      require_name "$name"
      profile_file="$(profile_path "$name")"
      if [[ ! -f "$profile_file" ]]; then
        [[ "$quiet_missing" == "1" && "$USAGE_QUIET" == "1" ]] && return 1
        die "profile not found: $name"
      fi
      profile_files_ref+=("$profile_file")
    done
  else
    shopt -s nullglob
    profile_files_ref=("$PROFILE_DIR"/*.json)
    shopt -u nullglob
  fi
}

usage_profile_files_for_args_into() {
  local profile_files_var="$1" quiet_missing="$2"; shift 2
  local -n profile_files_ref="$profile_files_var"

  profile_files_for_args_into "$profile_files_var" "$quiet_missing" "$@" || return 1
  (( ${#profile_files_ref[@]} > 0 )) && return 0
  [[ "$USAGE_QUIET" == "1" ]] || print_empty_profiles; return 1
}

active_auth_fingerprint() {
  local active_meta=()

  [[ -f "$AUTH_FILE" ]] || return 0
  mapfile -t active_meta < <(auth_metadata "$AUTH_FILE" || true)
  printf '%s' "${active_meta[2]:-}"
}

usage_maybe_acquire_refresh_lock() {
  local profile_count="$1"
  local -n refresh_lock_held_ref="$2"
  local refresh_lock_wait

  if [[ "$USAGE_REFRESH" == "1" && "$USAGE_QUIET" != "1" && -t 2 ]]; then
    print_status_note refresh "$profile_count profiles" >&2
  fi
  if [[ "$USAGE_REFRESH" == "1" ]]; then
    exec 8>"$CODEX_HOME/.tmp/codex-auth-refresh.lock"
    refresh_lock_wait="${CODEX_AUTH_REFRESH_LOCK_WAIT:-1}"
    [[ "$refresh_lock_wait" =~ ^[0-9]+$ ]] || refresh_lock_wait=1
    if ! flock -w "$refresh_lock_wait" 8; then
      [[ "$USAGE_QUIET" == "1" ]] || print_status_note cache "refresh busy" >&2
      USAGE_REFRESH=0
      USAGE_CACHED=1
    else
      refresh_lock_held_ref=1
    fi
  fi
}

usage_collect_records_for_mode() {
  local active_fp="$1"
  shift

  if [[ "$USAGE_CACHED" == "1" && "$USAGE_REFRESH" != "1" ]]; then
    collect_usage_records_cached "$active_fp" "$@"
  elif [[ "$USAGE_REFRESH" == "1" && "$USAGE_FAST_REFRESH" != "1" ]]; then
    collect_usage_records_synced "$active_fp" "$@"
  else
    collect_usage_records "$active_fp" "$@"
  fi
}

usage_best_selection_into() {
  local records="$1"
  local -n default_profile_ref="$2"
  local -n active_is_best_ref="$3"
  local best_profile best_mark best_week best_short

  IFS=$'\t' read -r best_profile best_mark best_week best_short <<<"$(find_best_ok_profile "$records" 1)"
  default_profile_ref=""
  active_is_best_ref=0
  if [[ -n "$best_profile" ]]; then
    if [[ "$best_mark" == "*" ]]; then
      active_is_best_ref=1
    else
      default_profile_ref="$best_profile"
    fi
  fi
}

usage_render_or_prepare() {
  local records="$1"
  local default_profile="$2"
  local active_is_best="$3"
  local -n rendered_output_ref="$4"

  rendered_output_ref=0
  if [[ "$USAGE_SELECT" == "1" ]]; then
    prepare_usage_records "$records" "$default_profile"
  elif [[ "$USAGE_QUIET" != "1" ]]; then
    render_usage_records "$records" "$default_profile" "$active_is_best"
    rendered_output_ref=1
  fi
}

usage_auto_switch_result() {
  local rendered_output="$1"
  local default_profile="$2"
  local active_is_best="$3"

  if (( rendered_output )); then
    printf '\n'
  fi
  if [[ -n "$default_profile" ]]; then
    cmd_use "$default_profile"
  elif [[ "$active_is_best" == "1" && "$USAGE_QUIET" != "1" ]]; then
    print_status_note ready "already on best profile"
  elif [[ "$USAGE_QUIET" != "1" ]]; then
    print_status_note blocked "no ready profile"
  fi
}

usage_handle_menu_action() {
  case "$MENU_ACTION" in
    login)
      local refreshed_profile="$MENU_PROFILE"
      cmd_login "$refreshed_profile"
      printf '\n'
      print_status_note refresh "$refreshed_profile"
      refresh_active_profile_state "$refreshed_profile" || true
      USAGE_REFRESH=0
      USAGE_CACHED=1
      return 1
      ;;
    blocked)
      print_status_note blocked "choose switch/login/skip"
      return 0
      ;;
    switch)
      cmd_use "$MENU_PROFILE"
      return 0
      ;;
    skip|*)
      return 0
      ;;
  esac
}

cmd_usage() {
  ensure_dirs
  command -v jq >/dev/null 2>&1 || die "jq is required for usage output"

  local auto_switch=0
  local args=()
  local refresh_lock_held=0
  USAGE_QUIET=0
  USAGE_CACHED=0
  USAGE_REFRESH=0
  USAGE_SELECT=0
  USAGE_FAST_REFRESH=1
  parse_usage_args auto_switch args "$@"
  set -- "${args[@]}"

  local profile_files=()
  usage_profile_files_for_args_into profile_files 0 "$@" || return 0
  usage_maybe_acquire_refresh_lock "${#profile_files[@]}" refresh_lock_held

  while true; do
    local active_fp
    active_fp="$(active_auth_fingerprint)"

    local records=""
    records="$(usage_collect_records_for_mode "$active_fp" "${profile_files[@]}")"
    if (( refresh_lock_held )); then
      flock -u 8 2>/dev/null || true
      refresh_lock_held=0
    fi

    local default_profile active_is_best
    usage_best_selection_into "$records" default_profile active_is_best

    local rendered_output=0
    usage_render_or_prepare "$records" "$default_profile" "$active_is_best" rendered_output

    case "$auto_switch:$USAGE_SELECT" in
      1:*) usage_auto_switch_result "$rendered_output" "$default_profile" "$active_is_best"; return 0 ;;
      0:1)
        arrow_action_menu "$default_profile" "${SORTED_USAGE_RECORDS[@]}"
        usage_handle_menu_action && return 0
        ;;
      *) return 0 ;;
    esac
  done
}

cache_stale_profile_names() {
  local profile_file profile_name fingerprint payload age

  for profile_file in "$@"; do
    profile_name="$(basename "$profile_file" .json)"
    fingerprint="$(credential_fingerprint "$profile_file" || true)"
    payload=""
    [[ -n "$fingerprint" ]] && payload="$(state_payload_for_profile "$profile_name" "$fingerprint" || true)"
    age="999999999"
    [[ -n "$fingerprint" ]] && age="$(state_age_for_profile "$profile_name" "$fingerprint")"
    if [[ -z "$payload" || ! "$age" =~ ^[0-9]+$ || "$age" -gt "$CACHE_TTL" ]]; then
      printf '%s\n' "$profile_name"
    fi
  done
}

background_refresh_profiles() {
  local script="${BASH_SOURCE[0]}"
  local background_jobs="${CODEX_AUTH_BACKGROUND_REFRESH_JOBS:-1}"
  (( USAGE_BACKGROUND )) || return 0
  [[ "${CODEX_AUTH_NO_BACKGROUND:-}" == "1" ]] && return 0
  (( $# > 0 )) || return 0
  [[ "$background_jobs" =~ ^[0-9]+$ && "$background_jobs" -gt 0 ]] || background_jobs=1

  nohup env CODEX_AUTH_REFRESH_LOCK=try CODEX_AUTH_NO_BACKGROUND=1 CODEX_AUTH_REFRESH_BLOCKED=1 CODEX_AUTH_REFRESH_FALLBACK_CACHE=1 CODEX_AUTH_REFRESH_JOBS="$background_jobs" "$script" refresh --quiet --fast "$@" >/dev/null 2>&1 &
}

parse_refresh_args() {
  local -n args_ref="$1"
  shift

  while (( $# > 0 )); do
    case "$1" in
      --quiet|-q)
        USAGE_QUIET=1
        shift
        ;;
      --fast)
        USAGE_FAST_REFRESH=1
        shift
        ;;
      --sync)
        USAGE_FAST_REFRESH=0
        shift
        ;;
      --)
        shift
        args_ref+=("$@")
        break
        ;;
      *)
        args_ref+=("$1")
        shift
        ;;
    esac
  done
}

acquire_refresh_command_lock() {
  if [[ "${CODEX_AUTH_REFRESH_LOCK:-}" == "try" ]]; then
    exec 9>"$CODEX_HOME/.tmp/codex-auth-refresh.lock"
    flock -n 9 || return 1
    return 0
  fi

  exec 9>"$CODEX_HOME/.tmp/codex-auth-refresh.lock"
  local refresh_lock_wait
  refresh_lock_wait="${CODEX_AUTH_REFRESH_LOCK_WAIT:-1}"
  [[ "$refresh_lock_wait" =~ ^[0-9]+$ ]] || refresh_lock_wait=1
  if ! flock -w "$refresh_lock_wait" 9; then
    [[ "$USAGE_QUIET" == "1" ]] || print_status_note cache "refresh busy" >&2
    return 1
  fi
}

cmd_refresh() {
  ensure_dirs
  command -v jq >/dev/null 2>&1 || die "jq is required for usage refresh"

  USAGE_QUIET=0
  USAGE_CACHED=0
  USAGE_REFRESH=1
  USAGE_BACKGROUND=0
  USAGE_FAST_REFRESH=1

  local args=()
  parse_refresh_args args "$@"
  set -- "${args[@]}"

  acquire_refresh_command_lock || return 0

  local profile_files=()
  profile_files_for_args_into profile_files 0 "$@"

  if (( ${#profile_files[@]} == 0 )); then
    [[ "$USAGE_QUIET" == "1" ]] || print_empty_profiles
    return 0
  fi
  if [[ "$USAGE_QUIET" != "1" && -t 2 ]]; then
    print_status_note refresh "${#profile_files[@]} profiles" >&2
  fi

  local active_fp
  active_fp="$(active_auth_fingerprint)"

  local records default_profile active_is_best
  if [[ "$USAGE_FAST_REFRESH" == "1" ]]; then
    records="$(collect_usage_records "$active_fp" "${profile_files[@]}")"
  else
    records="$(collect_usage_records_synced "$active_fp" "${profile_files[@]}")"
  fi
  usage_best_selection_into "$records" default_profile active_is_best

  [[ "$USAGE_QUIET" == "1" ]] || render_usage_records "$records" "$default_profile" "$active_is_best"
}

parse_auto_args() {
  local -n args_ref="$1"
  shift

  while (( $# > 0 )); do
    case "$1" in
      --quiet|-q)
        USAGE_QUIET=1
        shift
        ;;
      --ttl)
        [[ "${2:-}" =~ ^[0-9]+$ ]] || return 1
        CACHE_TTL="$2"
        USAGE_CACHED=0
        shift 2
        ;;
      --no-background)
        USAGE_BACKGROUND=0
        shift
        ;;
      --)
        shift
        args_ref+=("$@")
        break
        ;;
      *)
        args_ref+=("$1")
        shift
        ;;
    esac
  done
}

auto_apply_selection() {
  local rendered_output="$1"
  local default_profile="$2"
  local active_is_best="$3"

  if [[ -n "$default_profile" ]]; then
    (( rendered_output )) && printf '\n'
    if [[ "$USAGE_QUIET" == "1" ]]; then
      cmd_use "$default_profile" >/dev/null
    else
      cmd_use "$default_profile"
    fi
  elif [[ "$USAGE_QUIET" != "1" ]]; then
    (( rendered_output )) && printf '\n'
    if [[ "$active_is_best" == "1" ]]; then
      print_status_note ready "already on best profile"
    else
      print_status_note blocked "no ready profile"
    fi
  fi
}

cmd_auto() {
  ensure_dirs
  command -v jq >/dev/null 2>&1 || return 0

  USAGE_QUIET=0
  USAGE_CACHED=1
  USAGE_REFRESH=0
  USAGE_BACKGROUND=1

  local args=()
  parse_auto_args args "$@" || return 0
  set -- "${args[@]}"

  local profile_files=()
  usage_profile_files_for_args_into profile_files 1 "$@" || return 0

  local active_fp
  active_fp="$(active_auth_fingerprint)"

  local records default_profile active_is_best
  records="$(collect_usage_records "$active_fp" "${profile_files[@]}")"
  usage_best_selection_into "$records" default_profile active_is_best

  local rendered_output=0
  if [[ "$USAGE_QUIET" != "1" ]]; then
    render_usage_records "$records" "$default_profile" "$active_is_best"
    rendered_output=1
  fi

  auto_apply_selection "$rendered_output" "$default_profile" "$active_is_best"

  local stale_names=()
  mapfile -t stale_names < <(cache_stale_profile_names "${profile_files[@]}")
  if (( ${#stale_names[@]} > 0 )); then
    background_refresh_profiles "${stale_names[@]}"
  fi
}

PATCH_CODEX_PATCH_VERSION=1

patch_codex_root() {
  printf '%s\n' "${CODEX_AUTH_PATCH_CODEX_DIR:-$CODEX_HOME/patched-codex}"
}

patch_codex_bin_path() {
  printf '%s/bin/codex\n' "$(patch_codex_root)"
}

patch_codex_marker_path() {
  printf '%s/current.env\n' "$(patch_codex_root)"
}

patch_codex_log_path() {
  printf '%s/build.log\n' "$(patch_codex_root)"
}

patch_codex_stock_bin() {
  if [[ -n "${CODEX_AUTH_STOCK_CODEX_BIN:-}" && -x "${CODEX_AUTH_STOCK_CODEX_BIN:-}" ]]; then
    printf '%s\n' "$CODEX_AUTH_STOCK_CODEX_BIN"
    return 0
  fi
  codex_bin
}

patch_codex_stock_info() {
  local stock_bin="$1"
  local version hash key

  version="$("$stock_bin" --version 2>/dev/null | sed -n '1s/[[:space:]]*$//p' || true)"
  [[ -n "$version" ]] || version="unknown"
  if command -v sha256sum >/dev/null 2>&1 && [[ -f "$stock_bin" ]]; then
    hash="$(sha256sum "$stock_bin" | awk '{print $1}')"
  else
    hash="$(printf '%s' "$stock_bin" | cksum | awk '{print $1 "-" $2}')"
  fi
  if command -v sha256sum >/dev/null 2>&1; then
    key="$(printf '%s\037%s\n' "$version" "$hash" | sha256sum | awk '{print $1}')"
  else
    key="$(printf '%s\037%s\n' "$version" "$hash" | cksum | awk '{print $1 "-" $2}')"
  fi
  printf '%s\t%s\t%s\n' "$version" "$hash" "$key"
}

patch_codex_marker_value() {
  local key="$1"
  local marker="${2:-$(patch_codex_marker_path)}"

  [[ -f "$marker" ]] || return 1
  awk -F= -v key="$key" '$1 == key { sub(/^[^=]*=/, ""); print; exit }' "$marker"
}

patch_codex_ready_for_key() {
  local stock_key="$1"
  local patched_bin marker_key marker_patch_version

  patched_bin="$(patch_codex_bin_path)"
  [[ -x "$patched_bin" ]] || return 1
  marker_key="$(patch_codex_marker_value stock_key || true)"
  marker_patch_version="$(patch_codex_marker_value patch_version || true)"
  [[ "$marker_key" == "$stock_key" && "$marker_patch_version" == "$PATCH_CODEX_PATCH_VERSION" ]]
}

patch_codex_extract_package_version() {
  local stock_version="$1"
  local candidate

  candidate="${stock_version##* }"
  if [[ "$candidate" =~ ^[0-9]+\.[0-9]+\.[0-9]+(-[0-9A-Za-z.-]+)?(\+[0-9A-Za-z.-]+)?$ ]]; then
    printf '%s' "$candidate"
  else
    printf '0.0.0'
  fi
}

patch_codex_local_package_version() {
  local base="$1"
  local suffix="${CODEX_AUTH_PATCH_VERSION_SUFFIX:-local}"

  if [[ -z "$suffix" || "$suffix" == "0" ]]; then
    printf '%s' "$base"
  elif [[ "$base" == *+* ]]; then
    printf '%s.%s' "$base" "$suffix"
  else
    printf '%s+%s' "$base" "$suffix"
  fi
}

patch_codex_set_workspace_version() {
  local source_dir="$1"
  local package_version="$2"
  local cargo_toml="$source_dir/codex-rs/Cargo.toml"
  local tmp

  [[ -f "$cargo_toml" ]] || die "missing $cargo_toml"
  tmp="$(mktemp "$(patch_codex_root)/.tmp/Cargo.toml.XXXXXX")"
  awk -v package_version="$package_version" '
    BEGIN { in_workspace_package = 0; done = 0 }
    /^\[workspace\.package\]$/ { in_workspace_package = 1 }
    /^\[/ && $0 != "[workspace.package]" { in_workspace_package = 0 }
    in_workspace_package && !done && /^version = "/ {
      print "version = \"" package_version "\""
      done = 1
      next
    }
    { print }
    END { if (!done) exit 1 }
  ' "$cargo_toml" > "$tmp" || {
    rm -f "$tmp"
    die "could not set Codex package version"
  }
  mv "$tmp" "$cargo_toml"
}

