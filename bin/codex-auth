patch_codex_apply_source_patch() {
  local source_dir="$1"
  local manager_file="$source_dir/codex-rs/login/src/auth/manager.rs"
  local patch_file

  [[ -f "$manager_file" ]] || die "missing $manager_file"
  if grep -Fq 'CODEX_AUTH_ROLLING_ENV_VAR' "$manager_file"; then
    return 0
  fi

  patch_file="$(mktemp "$(patch_codex_root)/.tmp/codex-source.XXXXXX.patch")"
  patch_codex_write_source_patch "$patch_file"
  git -C "$source_dir" apply "$patch_file"
  rm -f "$patch_file"
}

patch_codex_prepare_source() {
  local source_dir="$1"
  local ref="$2"
  local no_fetch="$3"
  local repo_url="${CODEX_AUTH_PATCH_REPO_URL:-https://github.com/openai/codex.git}"
  local clone_tmp

  if [[ -d "$source_dir/.git" ]] \
    && ! git -C "$source_dir" rev-parse --verify HEAD >/dev/null 2>&1 \
    && [[ ! -f "$source_dir/codex-rs/login/src/auth/manager.rs" ]]; then
    rm -rf "$source_dir"
  fi
  if [[ ! -d "$source_dir/.git" ]]; then
    if [[ -e "$source_dir" ]]; then
      die "source exists but is not a git repo: $source_dir"
    fi
    mkdir -p "$(dirname "$source_dir")"
    clone_tmp="$(mktemp -d "$(dirname "$source_dir")/.clone.XXXXXX")"
    git clone "$repo_url" "$clone_tmp"
    mv "$clone_tmp" "$source_dir"
  fi

  if [[ -f "$source_dir/codex-rs/login/src/auth/manager.rs" ]] \
    && grep -Fq 'CODEX_AUTH_ROLLING_ENV_VAR' "$source_dir/codex-rs/login/src/auth/manager.rs"; then
    return 0
  fi

  if [[ "$no_fetch" != "1" ]]; then
    git -C "$source_dir" fetch origin
  fi

  git -C "$source_dir" checkout --detach "$ref"
}

patch_codex_built_binary_path() {
  local source_dir="$1"
  local profile="$2"
  local target_dir="${CARGO_TARGET_DIR:-$source_dir/codex-rs/target}"

  if [[ "$profile" == "release" ]]; then
    printf '%s/release/codex\n' "$target_dir"
  else
    printf '%s/debug/codex\n' "$target_dir"
  fi
}

patch_codex_run_build() {
  local source_dir="$1"
  local profile="$2"
  local check_login="$3"
  local args=()

  [[ "$profile" == "release" ]] && args=(--release)
  if [[ "$check_login" == "1" ]]; then
    (cd "$source_dir/codex-rs" && cargo check -p codex-login)
  fi
  (cd "$source_dir/codex-rs" && cargo build -p codex-cli --bin codex "${args[@]}")
}

patch_codex_write_marker() {
  local stock_key="$1"
  local stock_version="$2"
  local stock_hash="$3"
  local source_commit="$4"
  local package_version="$5"
  local profile="$6"
  local marker tmp

  marker="$(patch_codex_marker_path)"
  tmp="$(mktemp "$(patch_codex_root)/.tmp/current.env.XXXXXX")"
  {
    printf 'patch_version=%s\n' "$PATCH_CODEX_PATCH_VERSION"
    printf 'stock_key=%s\n' "$stock_key"
    printf 'stock_version=%s\n' "$stock_version"
    printf 'stock_hash=%s\n' "$stock_hash"
    printf 'source_commit=%s\n' "$source_commit"
    printf 'package_version=%s\n' "$package_version"
    printf 'profile=%s\n' "$profile"
    printf 'built_at=%s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  } > "$tmp"
  mv "$tmp" "$marker"
}

patch_codex_install_binary() {
  local built_bin="$1"
  local stock_key="$2"
  local stock_version="$3"
  local stock_hash="$4"
  local source_commit="$5"
  local package_version="$6"
  local profile="$7"
  local target_bin tmp_bin

  [[ -x "$built_bin" ]] || die "build did not produce $built_bin"
  target_bin="$(patch_codex_bin_path)"
  mkdir -p "$(dirname "$target_bin")"
  tmp_bin="$(mktemp "$(patch_codex_root)/.tmp/codex.XXXXXX")"
  install -m 0755 "$built_bin" "$tmp_bin"
  "$tmp_bin" --version >/dev/null 2>&1 || die "patched codex smoke failed"
  mv "$tmp_bin" "$target_bin"
  patch_codex_write_marker "$stock_key" "$stock_version" "$stock_hash" "$source_commit" "$package_version" "$profile"
}

patch_codex_status() {
  local stock_bin="$1"
  local stock_version="$2"
  local stock_hash="$3"
  local stock_key="$4"
  local marker_key marker_version package_version source_commit state

  marker_key="$(patch_codex_marker_value stock_key || true)"
  marker_version="$(patch_codex_marker_value stock_version || true)"
  package_version="$(patch_codex_marker_value package_version || true)"
  source_commit="$(patch_codex_marker_value source_commit || true)"
  state="stale"
  patch_codex_ready_for_key "$stock_key" && state="ready"

  printf 'patched codex: %s\n' "$state"
  printf 'stock bin: %s\n' "$stock_bin"
  printf 'stock version: %s\n' "$stock_version"
  printf 'stock hash: %s\n' "$stock_hash"
  printf 'patched bin: %s\n' "$(patch_codex_bin_path)"
  [[ -n "$marker_version" ]] && printf 'patched stock version: %s\n' "$marker_version"
  [[ -n "$package_version" ]] && printf 'patched package version: %s\n' "$package_version"
  [[ -n "$source_commit" ]] && printf 'source commit: %s\n' "$source_commit"
  [[ -n "$marker_key" && "$marker_key" != "$stock_key" ]] && printf 'reason: stock key changed\n'
  return 0
}

patch_codex_background() {
  local stock_bin="$1"
  local quiet="$2"
  local self log

  self="$(realpath "${BASH_SOURCE[0]}" 2>/dev/null || printf '%s\n' "${BASH_SOURCE[0]}")"
  log="$(patch_codex_log_path)"
  mkdir -p "$(dirname "$log")" "$(patch_codex_root)/.tmp"
  nohup env CODEX_AUTH_STOCK_CODEX_BIN="$stock_bin" CODEX_AUTH_PATCH_BACKGROUND_CHILD=1 "$self" patch-codex --quiet --foreground >"$log" 2>&1 &
  [[ "$quiet" == "1" ]] || print_status_note patch "background build started"
}

patch_codex_parse_args() {
  local -n background_ref="$1"
  local -n quiet_ref="$2"
  local -n status_ref="$3"
  local -n print_bin_ref="$4"
  local -n print_key_ref="$5"
  local -n force_ref="$6"
  local -n no_fetch_ref="$7"
  local -n check_login_ref="$8"
  local -n profile_ref="$9"
  local -n ref_ref="${10}"
  local -n source_dir_ref="${11}"
  shift 11

  while (( $# > 0 )); do
    case "$1" in
      --background)
        background_ref=1
        ;;
      --foreground)
        background_ref=0
        ;;
      --quiet|-q)
        quiet_ref=1
        ;;
      --status)
        status_ref=1
        ;;
      --print-bin)
        print_bin_ref=1
        ;;
      --print-key)
        print_key_ref=1
        ;;
      --force)
        force_ref=1
        ;;
      --no-fetch)
        no_fetch_ref=1
        ;;
      --check-login)
        check_login_ref=1
        ;;
      --debug)
        profile_ref=debug
        ;;
      --release)
        profile_ref=release
        ;;
      --ref)
        [[ -n "${2:-}" ]] || die "usage: codex-auth patch-codex --ref <git-ref>"
        ref_ref="$2"
        shift
        ;;
      --source-dir)
        [[ -n "${2:-}" ]] || die "usage: codex-auth patch-codex --source-dir <dir>"
        source_dir_ref="$2"
        shift
        ;;
      *)
        die "usage: codex-auth patch-codex [--background|--status|--force|--debug|--release]"
        ;;
    esac
    shift
  done
}

cmd_patch_codex() {
  ensure_dirs

  local background=0 quiet=0 status=0 print_bin=0 print_key=0 force=0 no_fetch=0 check_login=0
  local profile="${CODEX_AUTH_PATCH_PROFILE:-release}"
  local ref="${CODEX_AUTH_PATCH_REF:-origin/main}"
  local source_dir=""
  patch_codex_parse_args background quiet status print_bin print_key force no_fetch check_login profile ref source_dir "$@"
  [[ "$profile" == "release" || "$profile" == "debug" ]] || profile=release

  local stock_bin stock_version stock_hash stock_key
  stock_bin="$(patch_codex_stock_bin)" || die "codex command not found"
  require_codex_launcher "$stock_bin"
  IFS=$'\t' read -r stock_version stock_hash stock_key <<<"$(patch_codex_stock_info "$stock_bin")"

  if (( print_key )); then
    printf '%s\n' "$stock_key"
    return 0
  fi
  if (( print_bin )); then
    patch_codex_ready_for_key "$stock_key" || return 1
    patch_codex_bin_path
    return 0
  fi
  if (( status )); then
    patch_codex_status "$stock_bin" "$stock_version" "$stock_hash" "$stock_key"
    return 0
  fi
  if (( ! force )) && patch_codex_ready_for_key "$stock_key"; then
    [[ "$quiet" == "1" ]] || patch_codex_status "$stock_bin" "$stock_version" "$stock_hash" "$stock_key"
    return 0
  fi
  if (( background )); then
    patch_codex_background "$stock_bin" "$quiet"
    return 0
  fi

  command -v git >/dev/null 2>&1 || die "git is required for patch-codex"
  command -v cargo >/dev/null 2>&1 || die "cargo is required for patch-codex"

  local lock_wait lock_fd source_commit package_base package_version built_bin
  lock_wait="${CODEX_AUTH_PATCH_LOCK_WAIT:-0}"
  [[ "$lock_wait" =~ ^[0-9]+$ ]] || lock_wait=0
  exec {lock_fd}>"$(patch_codex_root)/build.lock"
  if [[ "${CODEX_AUTH_PATCH_BACKGROUND_CHILD:-}" == "1" || "$lock_wait" == "0" ]]; then
    flock -n "$lock_fd" || return 0
  else
    flock -w "$lock_wait" "$lock_fd" || die "patched Codex build already running"
  fi

  if (( ! force )) && patch_codex_ready_for_key "$stock_key"; then
    return 0
  fi

  [[ -n "$source_dir" ]] || source_dir="$(patch_codex_root)/sources/$stock_key/source"
  package_base="$(patch_codex_extract_package_version "$stock_version")"
  package_version="$(patch_codex_local_package_version "$package_base")"

  [[ "$quiet" == "1" ]] || print_status_note patch "source $ref"
  patch_codex_prepare_source "$source_dir" "$ref" "$no_fetch"
  source_commit="$(git -C "$source_dir" rev-parse HEAD)"
  patch_codex_apply_source_patch "$source_dir"
  patch_codex_set_workspace_version "$source_dir" "$package_version"

  [[ "$quiet" == "1" ]] || print_status_note patch "build $profile"
  patch_codex_run_build "$source_dir" "$profile" "$check_login"
  built_bin="$(patch_codex_built_binary_path "$source_dir" "$profile")"
  patch_codex_install_binary "$built_bin" "$stock_key" "$stock_version" "$stock_hash" "$source_commit" "$package_version" "$profile"

  [[ "$quiet" == "1" ]] || patch_codex_status "$stock_bin" "$stock_version" "$stock_hash" "$stock_key"
}

codex_run_limit_detected() {
  local log_file="$1"
  local scan_bytes="${CODEX_AUTH_ROLL_LOG_SCAN_BYTES:-1048576}"

  [[ -s "$log_file" ]] || return 1
  [[ "$scan_bytes" =~ ^[1-9][0-9]*$ ]] || scan_bytes=1048576
  if command -v tail >/dev/null 2>&1; then
    LC_ALL=C tail -c "$scan_bytes" "$log_file" 2>/dev/null | grep -aEiq \
      'usage limit|rate limit|rate.?limit reached|limit reached|reached[^[:alnum:]]+limit|exceeded[^[:alnum:]]+limit|too many requests|429|rateLimitReached|5h cap|weekly cap|week cap|quota'
  else
    LC_ALL=C grep -aEiq \
      'usage limit|rate limit|rate.?limit reached|limit reached|reached[^[:alnum:]]+limit|exceeded[^[:alnum:]]+limit|too many requests|429|rateLimitReached|5h cap|weekly cap|week cap|quota' \
      "$log_file"
  fi
}

codex_run_resume_option_takes_value() {
  case "$1" in
    -c|--config|--enable|--disable|--remote|--remote-auth-token-env|-i|--image|-m|--model|-p|--profile|--profile-v2|-s|--sandbox|-a|--ask-for-approval|-C|--cd|--cwd)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

codex_run_resume_flag_option() {
  case "$1" in
    --dangerously-bypass-approvals-and-sandbox|--yolo|--oss|--strict-config|--dangerously-auto-approve-everything)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

codex_run_make_resume_args() {
  CODEX_RUN_RESUME_ARGS=()

  while (( $# > 0 )); do
    if [[ "$1" == "--" ]]; then
      shift
      break
    fi
    if codex_run_resume_option_takes_value "$1"; then
      CODEX_RUN_RESUME_ARGS+=("$1")
      shift
      if (( $# > 0 )); then
        CODEX_RUN_RESUME_ARGS+=("$1")
        shift
      fi
    elif codex_run_resume_flag_option "$1" || [[ "$1" == -* ]]; then
      CODEX_RUN_RESUME_ARGS+=("$1")
      shift
    else
      break
    fi
  done

  if [[ "${1:-}" == "resume" ]]; then
    shift
    if [[ "${1:-}" == "--last" ]]; then
      CODEX_RUN_RESUME_ARGS+=(resume --last)
    elif [[ -n "${1:-}" && "${1:-}" != -* ]]; then
      CODEX_RUN_RESUME_ARGS+=(resume "$1")
    else
      CODEX_RUN_RESUME_ARGS+=(resume --last)
    fi
  else
    CODEX_RUN_RESUME_ARGS+=(resume --last)
  fi
}

codex_run_write_launcher() {
  local run_file="$1"
  local codex_cli="$2"
  shift 2
  local arg

  {
    printf '#!/usr/bin/env bash\n'
    printf 'set -euo pipefail\n'
    printf 'export CODEX_AUTH_RUNNER=1\n'
    printf 'exec %q' "$codex_cli"
    for arg in "$@"; do
      printf ' %q' "$arg"
    done
    printf '\n'
  } > "$run_file"
  chmod 700 "$run_file"
}

codex_run_watch_loop() {
  local auto_ttl="$1"
  local interval="${CODEX_AUTH_ROLL_INTERVAL:-60}"

  [[ "$interval" =~ ^[1-9][0-9]*$ ]] || interval=60
  while true; do
    sleep "$interval" || exit 0
    codex_run_auto_select 1 "$auto_ttl"
  done
}

codex_run_auto_args() {
  local auto_ttl="${1:-}"

  CODEX_RUN_AUTO_ARGS=(--quiet --no-background)
  if [[ "$auto_ttl" =~ ^[0-9]+$ ]]; then
    CODEX_RUN_AUTO_ARGS+=(--ttl "$auto_ttl")
  fi
  return 0
}

codex_run_auto_select() {
  local run_auto="${1:-1}"
  local auto_ttl="${2:-}"

  [[ "$run_auto" != "0" && "${CODEX_AUTH_AUTO:-1}" != "0" ]] || return 0
  codex_run_auto_args "$auto_ttl"
  CODEX_AUTH_NO_BACKGROUND=1 cmd_auto "${CODEX_RUN_AUTO_ARGS[@]}" || true
}

codex_run_start_watch_if_enabled() {
  local run_auto="${1:-1}"
  local watch_enabled="${2:-0}"
  local auto_ttl="${3:-}"

  CODEX_RUN_WATCH_PID=""
  if [[ "$run_auto" != "0" && "$watch_enabled" != "0" && "${CODEX_AUTH_AUTO:-1}" != "0" ]]; then
    codex_run_watch_loop "$auto_ttl" &
    CODEX_RUN_WATCH_PID=$!
  fi
}

codex_run_script_child_matches() {
  local child="$1"
  local run_file="$2"
  local log_file="$3"
  local cmd

  [[ "$child" =~ ^[0-9]+$ && "$child" != "${BASHPID:-}" && -r "/proc/$child/cmdline" ]] || return 1
  cmd="$(tr '\0' ' ' <"/proc/$child/cmdline" 2>/dev/null || true)"
  [[ "$cmd" == *"script "* && "$cmd" == *"$run_file"* && "$cmd" == *"$log_file"* ]]
}

codex_run_kill_script_for_log() {
  local parent_pid="$1"
  local run_file="$2"
  local log_file="$3"
  local signal="${4:-TERM}"
  local child grandchild killed_child

  [[ "$parent_pid" =~ ^[0-9]+$ ]] || return 0
  if ! command -v pgrep >/dev/null 2>&1; then
    return 0
  fi

  while IFS= read -r child; do
    codex_run_script_child_matches "$child" "$run_file" "$log_file" || continue
    killed_child=0
    while IFS= read -r grandchild; do
      [[ "$grandchild" =~ ^[0-9]+$ ]] || continue
      usage_kill_process_tree "$grandchild" "$signal"
      killed_child=1
    done < <(pgrep -P "$child" 2>/dev/null)
    if (( killed_child == 0 )); then
      usage_kill_process_tree "$child" "$signal"
    fi
  done < <(pgrep -P "$parent_pid" 2>/dev/null)
}

codex_run_limit_monitor_loop() {
  local log_file="$1"
  local target_pid="$2"
  local parent_pid="${3:-}"
  local run_file="${4:-}"
  local interval="${CODEX_AUTH_ROLL_MONITOR_INTERVAL:-2}"
  local watched_pid="$target_pid"

  [[ "$interval" =~ ^[1-9][0-9]*$ ]] || interval=2
  [[ "$watched_pid" =~ ^[0-9]+$ ]] || watched_pid="$parent_pid"
  [[ "$watched_pid" =~ ^[0-9]+$ ]] || return 0

  while true; do
    kill -0 "$watched_pid" 2>/dev/null || return 0

    if codex_run_limit_detected "$log_file"; then
      if [[ "$target_pid" =~ ^[0-9]+$ ]]; then
        usage_kill_process_tree "$target_pid" TERM
      else
        codex_run_kill_script_for_log "$parent_pid" "$run_file" "$log_file" TERM
      fi
      sleep 1 || true
      if [[ "$target_pid" =~ ^[0-9]+$ ]]; then
        kill -0 "$target_pid" 2>/dev/null && usage_kill_process_tree "$target_pid" KILL
      else
        codex_run_kill_script_for_log "$parent_pid" "$run_file" "$log_file" KILL
      fi
      return 0
    fi
    sleep "$interval" || return 0
  done
}

codex_run_start_limit_monitor() {
  local log_file="$1"
  local target_pid="$2"
  local parent_pid="${3:-}"
  local run_file="${4:-}"

  CODEX_RUN_LIMIT_MONITOR_PID=""
  if [[ "${CODEX_AUTH_ROLL_LIVE_MONITOR:-1}" == "0" || -z "$log_file" ]]; then
    return 0
  fi
  codex_run_limit_monitor_loop "$log_file" "$target_pid" "$parent_pid" "$run_file" &
  CODEX_RUN_LIMIT_MONITOR_PID=$!
}

codex_run_cleanup() {
  local watch_pid="${1:-}"
  local monitor_pid="${2:-}"
  local run_file="${3:-}"
  local log_file="${4:-}"
  local keep_log="${5:-0}"

  if [[ "$monitor_pid" =~ ^[0-9]+$ ]]; then
    kill "$monitor_pid" 2>/dev/null || true
    wait "$monitor_pid" 2>/dev/null || true
  fi
  if [[ "$watch_pid" =~ ^[0-9]+$ ]]; then
    kill "$watch_pid" 2>/dev/null || true
    wait "$watch_pid" 2>/dev/null || true
  fi
  [[ -n "$run_file" ]] && rm -f "$run_file" 2>/dev/null || true
  if [[ "$keep_log" != "1" && -n "$log_file" ]]; then
    rm -f "$log_file" 2>/dev/null || true
  fi
}

parse_run_args() {
  local -n max_attempts_ref="$1"
  local -n run_auto_ref="$2"
  local -n log_enabled_ref="$3"
  local -n args_ref="$4"
  shift 4

  while (( $# > 0 )); do
    case "$1" in
      --attempts)
        [[ "${2:-}" =~ ^[1-9][0-9]*$ ]] || die "usage: codex-auth run [--attempts n] -- <codex args>"
        max_attempts_ref="$2"
        shift 2
        ;;
      --no-auto)
        run_auto_ref=0
        shift
        ;;
      --no-log)
        log_enabled_ref=0
        shift
        ;;
      --)
        shift
        args_ref+=("$@")
        break
        ;;
      *)
        args_ref+=("$1")
        shift
        ;;
    esac
  done
}

codex_run_execute_attempt() {
  local codex_cli="$1"
  local log_enabled="$2"
  local -n run_args_ref="$3"
  local -n status_ref="$4"
  local -n log_file_ref="$5"
  local -n run_file_ref="$6"
  local -n watch_pid_ref="$7"
  local -n monitor_pid_ref="$8"
  local -n target_pid_ref="$9"

  log_file_ref=""
  run_file_ref=""
  monitor_pid_ref=""
  if [[ "$log_enabled" != "0" ]]; then
    log_file_ref="$(mktemp "$CODEX_HOME/.tmp/codex-run.XXXXXX.log")"
  fi

  status_ref=0
  if [[ "$log_enabled" != "0" && -n "$log_file_ref" && -t 0 && -t 1 && -r /dev/tty ]] && command -v script >/dev/null 2>&1; then
    run_file_ref="$(mktemp "$CODEX_HOME/.tmp/codex-run.XXXXXX.sh")"
    codex_run_write_launcher "$run_file_ref" "$codex_cli" "${run_args_ref[@]}"
    set +e
    codex_run_start_limit_monitor "$log_file_ref" "" "$$" "$run_file_ref"
    monitor_pid_ref="$CODEX_RUN_LIMIT_MONITOR_PID"
    script -qefc "$run_file_ref" "$log_file_ref"
    status_ref=$?
  elif [[ "$log_enabled" != "0" && -n "$log_file_ref" && ! -t 1 ]]; then
    set +e
    CODEX_AUTH_RUNNER=1 "$codex_cli" "${run_args_ref[@]}" > >(tee "$log_file_ref") 2> >(tee -a "$log_file_ref" >&2) &
    target_pid_ref=$!
    codex_run_start_limit_monitor "$log_file_ref" "$target_pid_ref"
    monitor_pid_ref="$CODEX_RUN_LIMIT_MONITOR_PID"
    wait "$target_pid_ref"
    status_ref=$?
  else
    set +e
    CODEX_AUTH_RUNNER=1 "$codex_cli" "${run_args_ref[@]}"
    status_ref=$?
    [[ -n "$log_file_ref" ]] && : > "$log_file_ref"
  fi
  set -e
  codex_run_cleanup "$watch_pid_ref" "$monitor_pid_ref" "$run_file_ref" "" 1
  watch_pid_ref=""
  monitor_pid_ref=""
  run_file_ref=""
}

cmd_run() {
  ensure_dirs

  local max_attempts="${CODEX_AUTH_ROLL_ATTEMPTS:-5}"
  local auto_ttl="${CODEX_AUTH_ROLL_AUTO_TTL:-}"
  local run_auto="${CODEX_AUTH_RUN_AUTO:-1}"
  local watch_enabled="${CODEX_AUTH_ROLL_WATCH:-0}"
  local keep_log="${CODEX_AUTH_KEEP_RUN_LOG:-0}"
  local log_enabled="${CODEX_AUTH_ROLL_LOG:-1}"
  local args=()
  local codex_cli attempt status log_file run_file watch_pid monitor_pid target_pid

  [[ "$max_attempts" =~ ^[1-9][0-9]*$ ]] || max_attempts=5
  [[ -z "$auto_ttl" || "$auto_ttl" =~ ^[0-9]+$ ]] || auto_ttl=""

  parse_run_args max_attempts run_auto log_enabled args "$@"

  codex_cli="$(codex_bin)" || die "codex command not found"
  require_codex_launcher "$codex_cli"

  local run_args=("${args[@]}")
  CODEX_RUN_RESUME_ARGS=()
  attempt=1
  log_file=""
  run_file=""
  watch_pid=""
  monitor_pid=""
  target_pid=""
  trap 'codex_run_cleanup "${watch_pid:-}" "${monitor_pid:-}" "${run_file:-}" "${log_file:-}" "${keep_log:-0}"' EXIT
  trap 'codex_run_cleanup "${watch_pid:-}" "${monitor_pid:-}" "${run_file:-}" "${log_file:-}" "${keep_log:-0}"; exit 130' HUP INT TERM

  while true; do
    codex_run_auto_select "$run_auto" "$auto_ttl"

    codex_run_start_watch_if_enabled "$run_auto" "$watch_enabled" "$auto_ttl"
    watch_pid="$CODEX_RUN_WATCH_PID"

    codex_run_execute_attempt "$codex_cli" "$log_enabled" run_args status log_file run_file watch_pid monitor_pid target_pid

    if (( status != 0 && attempt < max_attempts )) && [[ -n "$log_file" ]] && codex_run_limit_detected "$log_file"; then
      [[ "$keep_log" == "1" ]] || rm -f "$log_file" 2>/dev/null || true
      log_file=""
      print_status_note roll "usage limit, rotating" >&2
      codex_run_make_resume_args "${run_args[@]}"
      run_args=("${CODEX_RUN_RESUME_ARGS[@]}")
      attempt=$((attempt + 1))
      continue
    fi

    codex_run_cleanup "$watch_pid" "$monitor_pid" "$run_file" "$log_file" "$keep_log"
    trap - EXIT HUP INT TERM
    return "$status"
  done
}

cmd_recover() {
  ensure_dirs
  [[ -t 0 && -t 1 ]] || die "recover needs tty"
  command -v jq >/dev/null 2>&1 || die "jq is required for recovery"

  local codex_cli
  codex_cli="$(codex_bin)" || die "codex command not found"
  require_codex_launcher "$codex_cli"

  cmd_auto --quiet --no-background

  export CODEX_AUTH_RUNNER=1
  if (( $# == 0 )); then
    print_status_note recover "latest session"
    exec "$codex_cli" resume --last
  fi

  print_status_note recover "session $*"
  exec "$codex_cli" resume "$@"
}

first_profile_name_for_fingerprint() {
  local fingerprint="$1"
  local other other_fp

  shopt -s nullglob
  for other in "$PROFILE_DIR"/*.json; do
    other_fp="$(credential_fingerprint "$other" || true)"
    if [[ -n "$other_fp" && "$other_fp" == "$fingerprint" ]]; then
      basename "$other" .json
      return 0
    fi
  done
  return 1
}

profile_removal_matches_active() {
  local name="$1"
  local path="$2"
  local -n active_fp_ref="$3"
  local profile_fp active_name

  active_fp_ref=""
  [[ -f "$AUTH_FILE" ]] || return 1
  active_fp_ref="$(credential_fingerprint "$AUTH_FILE" || true)"
  profile_fp="$(credential_fingerprint "$path" || true)"
  [[ -n "$active_fp_ref" && "$active_fp_ref" == "$profile_fp" ]] || return 1
  active_name="$(first_profile_name_for_fingerprint "$active_fp_ref" || true)"
  [[ "$active_name" == "$name" ]]
}

print_removed_active_profile() {
  local name="$1"
  local path="$2"
  local remaining_name="$3"
  local active_value="unsaved auth"

  [[ -n "$remaining_name" ]] && active_value="saved $remaining_name"
  print_result_block "removed active $name" \
    "profile"$'\t'"$(display_path "$path")"$'\t'"bad" \
    "active"$'\t'"$active_value"$'\t'"active"
}

print_removed_profile() {
  local name="$1"
  local path="$2"

  print_result_block "removed $name" \
    "profile"$'\t'"$(display_path "$path")"$'\t'"bad"
}

cmd_remove() {
  local name="$1"
  local yes="${2:-}"
  require_name "$name"
  [[ "$yes" == "--yes" ]] || die "refusing to remove without --yes"
  ensure_dirs
  acquire_mutation_lock

  local path active_matches=0 active_fp="" remaining_name=""
  path="$(profile_path "$name")"
  [[ -f "$path" ]] || die "profile not found: $name"
  profile_removal_matches_active "$name" "$path" active_fp && active_matches=1

  rm -f "$path"
  if (( active_matches )); then
    remaining_name="$(first_profile_name_for_fingerprint "$active_fp" || true)"
    print_removed_active_profile "$name" "$path" "$remaining_name"
    return 0
  fi
  print_removed_profile "$name" "$path"
}

doctor_ps_rows() {
  if [[ -n "${CODEX_AUTH_DOCTOR_PS_FILE:-}" ]]; then
    cat "$CODEX_AUTH_DOCTOR_PS_FILE"
  else
    ps -eo pid=,ppid=,pgid=,sid=,tty=,stat=,etime=,args=
  fi
}

doctor_is_legacy_codex() {
  local args="$1"

  [[ "$args" == *"codex-auth run"* ]] && return 0
  [[ "$args" == *"/.bun/bin/codex --yolo"* ]] && return 0
  [[ "$args" == *"/codex/codex --yolo"* ]] && return 0
  return 1
}

doctor_is_sidecar() {
  local args="$1"

  case "$args" in
    *"/outlook-mcp/"*|*"/webex-mcp/"*|*"/drfirst-mcp/"*|*"/gemini_ui_mcp.mjs"*|*"/run_event_mcp.py"*|*"claude-runner-mcp"*|*"playwright-repl-mcp"*)
      return 0
      ;;
  esac
  return 1
}

doctor_parse_args() {
  local -n kill_sidecars_ref="$1"
  local -n yes_ref="$2"
  shift 2

  while (( $# > 0 )); do
    case "$1" in
      --kill-sidecars)
        kill_sidecars_ref=1
        ;;
      --yes)
        yes_ref=1
        ;;
      *)
        die "usage: codex-auth doctor [--kill-sidecars --yes]"
        ;;
    esac
    shift
  done
  return 0
}

doctor_collect_legacy_rows() {
  local -n rows_ref="$1"
  local -n legacy_pid_ref="$2"
  local -n root_count_ref="$3"
  local pid ppid pgid sid tty stat etime args row

  while read -r pid ppid pgid sid tty stat etime args; do
    [[ "$pid" =~ ^[0-9]+$ ]] || continue
    args="${args:-}"
    row="$pid"$'\t'"$ppid"$'\t'"$pgid"$'\t'"$tty"$'\t'"$etime"$'\t'"$args"
    rows_ref+=("$row")
    if doctor_is_legacy_codex "$args"; then
      legacy_pid_ref["$pid"]=1
      root_count_ref=$((root_count_ref + 1))
    fi
  done < <(doctor_ps_rows)
  return 0
}

doctor_collect_sidecars() {
  local -n rows_ref="$1"
  local -n legacy_pid_ref="$2"
  local -n sidecar_by_parent_ref="$3"
  local -n sidecar_args_by_pid_ref="$4"
  local -n sidecar_count_ref="$5"
  local row pid ppid pgid tty etime args

  for row in "${rows_ref[@]}"; do
    IFS=$'\t' read -r pid ppid pgid tty etime args <<<"$row"
    if [[ -n "${legacy_pid_ref["$ppid"]:-}" ]] && doctor_is_sidecar "$args"; then
      sidecar_count_ref=$((sidecar_count_ref + 1))
      sidecar_by_parent_ref["$ppid"]="${sidecar_by_parent_ref["$ppid"]:-} $pid"
      sidecar_args_by_pid_ref["$pid"]="$args"
    fi
  done
  return 0
}

doctor_sidecar_total() {
  local sidecars="$1"

  if [[ -n "$sidecars" ]]; then
    wc -w <<<"$sidecars" | tr -d ' '
  else
    printf '0'
  fi
}

doctor_print_legacy_rows() {
  local -n rows_ref="$1"
  local -n legacy_pid_ref="$2"
  local -n sidecar_by_parent_ref="$3"
  local root_count="$4"
  local row pid ppid pgid tty etime args sidecars sidecar_total

  (( root_count > 0 )) || return 0
  printf '\n'
  printf 'pid\tppid\tpgid\ttty\tetime\tsidecars\tcommand\n'
  for row in "${rows_ref[@]}"; do
    IFS=$'\t' read -r pid ppid pgid tty etime args <<<"$row"
    [[ -n "${legacy_pid_ref["$pid"]:-}" ]] || continue
    sidecars="${sidecar_by_parent_ref["$pid"]:-}"
    sidecar_total="$(doctor_sidecar_total "$sidecars")"
    printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$pid" "$ppid" "$pgid" "$tty" "$etime" "$sidecar_total" "$args"
  done
}

doctor_kill_sidecars() {
  local -n sidecar_args_by_pid_ref="$1"
  local pid kill_count=0

  for pid in "${!sidecar_args_by_pid_ref[@]}"; do
    if kill "$pid" 2>/dev/null; then
      kill_count=$((kill_count + 1))
    fi
  done
  printf '%s' "$kill_count"
}

doctor_print_sidecar_action() {
  local kill_sidecars="$1"
  local sidecar_count="$2"
  local -n sidecar_args_by_pid_ref="$3"
  local kill_count

  if (( kill_sidecars )); then
    kill_count="$(doctor_kill_sidecars sidecar_args_by_pid_ref)"
    printf '\nterminated sidecars: %s\n' "$kill_count"
  elif (( sidecar_count > 0 )); then
    printf '\nrun: codex-auth doctor --kill-sidecars --yes\n'
  fi
  return 0
}

cmd_doctor() {
  local kill_sidecars=0 yes=0
  doctor_parse_args kill_sidecars yes "$@"
  if (( kill_sidecars && ! yes )); then
    die "refusing to kill sidecars without --yes"
  fi

  local root_count=0 sidecar_count=0
  local -A legacy_pid=()
  local -A sidecar_by_parent=()
  local -A sidecar_args_by_pid=()
  local -a rows=()

  doctor_collect_legacy_rows rows legacy_pid root_count
  doctor_collect_sidecars rows legacy_pid sidecar_by_parent sidecar_args_by_pid sidecar_count

  printf 'legacy codex processes: %s\n' "$root_count"
  printf 'direct sidecars under legacy codex: %s\n' "$sidecar_count"

  doctor_print_legacy_rows rows legacy_pid sidecar_by_parent "$root_count"
  doctor_print_sidecar_action "$kill_sidecars" "$sidecar_count" sidecar_args_by_pid
}

cmd_paths() {
  ensure_dirs
  local cols role_w target_w path_w total_w home_label
  cols="$(terminal_width)"
  IFS=$'\t' read -r role_w target_w path_w <<<"$(path_row_widths "$cols")"
  if (( target_w > 0 )); then
    total_w=$((role_w + 1 + target_w + 1 + path_w))
  else
    total_w=$((role_w + 1 + path_w))
  fi
  USAGE_COLOR_ENABLED=0
  color_enabled && USAGE_COLOR_ENABLED=1

  home_label="home $(compact_display_path "$CODEX_HOME" "$path_w")"
  print_palette_summary_header "Auth" "Paths" "$home_label" "$total_w"
  print_path_line "live" "auth" "$AUTH_FILE" "$role_w" "$target_w" "$path_w" active
  print_path_line "saved" "profiles" "$PROFILE_DIR" "$role_w" "$target_w" "$path_w" good
  print_path_line "undo" "backups" "$BACKUP_DIR" "$role_w" "$target_w" "$path_w" warn
  print_path_line "cache" "usage" "$STATE_FILE" "$role_w" "$target_w" "$path_w" muted
}

main() {
  local command="${1:-}"
  shift || true

  case "$command" in
    add) cmd_add "$@" ;;
    usage|limits) cmd_usage "$@" ;;
    list|ls) cmd_list "$@" ;;
    current|status) cmd_current "$@" ;;
    save) require_arg_count_between "$#" 1 2 "usage: codex-auth save <name> [file]"; cmd_save "$@" ;;
    import) require_arg_count_between "$#" 2 2 "usage: codex-auth import <name> <file>"; cmd_import "$1" "$2" ;;
    use|switch) require_arg_count_between "$#" 1 1 "usage: codex-auth use <name>"; cmd_use "$1" ;;
    login) require_arg_count_between "$#" 1 999999 "usage: codex-auth login <name> [codex login args...]"; cmd_login "$@" ;;
    auto) cmd_auto "$@" ;;
    patch-codex) cmd_patch_codex "$@" ;;
    run|wrap) cmd_run "$@" ;;
    recover) cmd_recover "$@" ;;
    refresh) cmd_refresh "$@" ;;
    doctor) cmd_doctor "$@" ;;
    export) require_arg_count_between "$#" 2 2 "usage: codex-auth export <name> <file>"; cmd_export "$@" ;;
    remove|rm) require_arg_count_between "$#" 1 2 "usage: codex-auth remove <name> --yes"; cmd_remove "$@" ;;
    paths) cmd_paths ;;
    -h|--help|help|'') usage ;;
    *) die "unknown command: $command. Use: codex-auth help" ;;
  esac
}

main "$@"
