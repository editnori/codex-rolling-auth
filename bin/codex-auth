#!/usr/bin/env bash
set -euo pipefail

umask 077

CODEX_HOME="${CODEX_HOME:-$HOME/.codex}"
AUTH_FILE="$CODEX_HOME/auth.json"
PROFILE_DIR="${CODEX_AUTH_PROFILES_DIR:-$CODEX_HOME/auth-profiles}"
BACKUP_DIR="$CODEX_HOME/auth-backups"
STATE_FILE="${CODEX_AUTH_STATE_FILE:-$CODEX_HOME/auth-state.json}"
CACHE_TTL="${CODEX_AUTH_CACHE_TTL:-900}"
CODEX_BIN="${CODEX_AUTH_CODEX_BIN:-}"
USAGE_VERBOSE=0
USAGE_QUIET=0
USAGE_CACHED=0
USAGE_REFRESH=0
USAGE_BACKGROUND=1
USAGE_SELECT=0
USAGE_FAST_REFRESH=0
MUTATION_LOCK_HELD=0
MUTATION_LOCK_FD=""

usage() {
  local width
  width="$(terminal_width)"
  USAGE_COLOR_ENABLED=0
  color_enabled && USAGE_COLOR_ENABLED=1
  print_help_summary "$width"
  print_help_section "daily" "$width"
  print_help_item "usage --refresh --select" "Refresh and select" "$width"
  print_help_item "usage --cached" "Cached usage" "$width"
  print_help_item "usage --refresh -v" "Wide usage" "$width"
  print_help_item "add <name>" "Browser login" "$width"
  print_help_section "lookup" "$width"
  print_help_item "current" "Active auth" "$width"
  print_help_item "list [-v]" "Saved profiles" "$width"
  print_help_item "paths" "Auth paths" "$width"
  print_help_section "switch" "$width"
  print_help_item "use <name>" "Select profile" "$width"
  print_help_item "add <name> --current" "Save current auth" "$width"
  print_help_item "add <name> --file <file>" "Import auth file" "$width"
  print_help_item "login <name>" "Login profile" "$width"
  print_help_section "maintenance" "$width"
  print_help_item "refresh" "Refresh usage" "$width"
  print_help_item "auto" "Select best profile" "$width"
  print_help_item "recover [session]" "Resume with best" "$width"
  print_help_item "run -- <args>" "Rolling session" "$width"
  print_help_item "remove <name> --yes" "Delete profile" "$width"
  print_help_item "doctor" "Process audit" "$width"
  print_help_section "advanced" "$width"
  print_help_item "save <name> [file]" "Save auth file" "$width"
  print_help_item "import <name> <file>" "Import profile" "$width"
  print_help_item "export <name> <file>" "Export auth file" "$width"
  printf '\n'
}

print_help_summary() {
  local width="$1"
  local path path_w

  if (( width < 32 )); then
    if (( width < 22 )); then
      print_palette_title_line "Auth" "Commands" "" "$width"
      return 0
    fi
    path="profiles auth-profiles"
  else
    path_w=$((width - 9))
    (( path_w < 1 )) && path_w=1
    path="$(compact_display_path "$PROFILE_DIR" "$path_w")"
    path="profiles $path"
  fi

  print_palette_title_line "Auth" "Commands" "" "$width"
  print_flat_context_line "$path" "$width"
}

print_help_section() {
  local label="$1"
  local width="$2"
  printf '\n'
  print_toned_fit_rtrim "$label" "$width" muted
  printf '\n'
}

print_help_item() {
  local cmd="$1"
  local desc="$2"
  local width="$3"
  local action action_w command_w desc_w line gap

  action="$(help_item_action "$cmd" "$desc")"
  action_w=7
  (( width < 56 )) && action_w=6

  if (( width < 56 )); then
    print_help_compact_command "$action" "$cmd" "$width" "$action_w"
    return 0
  fi

  command_w=27
  (( width >= 72 )) && command_w=31
  (( width >= 96 )) && command_w=34
  if (( command_w > width - action_w - 19 )); then
    command_w=$((width - action_w - 19))
  fi
  (( command_w < 14 )) && command_w=14
  desc_w=$((width - action_w - command_w - 3))
  (( desc_w < 1 )) && desc_w=1
  print_toned_fit "$action" "$action_w" "$(help_action_tone "$action")"
  printf ' '
  print_toned_fit "$cmd" "$command_w" accent
  gap=2
  printf '%*s' "$gap" ''
  print_toned_fit_rtrim "$desc" "$desc_w" muted
  printf '\n'
}

print_help_compact_command() {
  local action="$1"
  local cmd="$2"
  local width="$3"
  local action_w="$4"
  local command_w token line="" first=1
  local tokens=()

  command_w=$((width - action_w - 1))
  (( command_w < 1 )) && command_w=1
  read -r -a tokens <<<"$cmd"

  for token in "${tokens[@]}"; do
    if [[ -z "$line" ]]; then
      line="$token"
    elif (( ${#line} + 1 + ${#token} <= command_w )); then
      line+=" $token"
    else
      print_help_compact_line "$action" "$line" "$action_w" "$command_w" "$first"
      first=0
      line="$token"
    fi
  done

  if [[ -n "$line" ]]; then
    print_help_compact_line "$action" "$line" "$action_w" "$command_w" "$first"
  fi
}

print_help_compact_line() {
  local action="$1"
  local cmd="$2"
  local action_w="$3"
  local command_w="$4"
  local first="${5:-0}"

  if (( first )); then
    print_toned_fit "$action" "$action_w" "$(help_action_tone "$action")"
  else
    printf '%*s' "$action_w" ''
  fi
  printf ' '
  print_toned_fit_rtrim "$cmd" "$command_w" accent
  printf '\n'
}

help_item_action() {
  local cmd="$1"
  local desc="$2"

  case "$cmd" in
    "usage --refresh --select")
      printf 'select'
      ;;
    "usage --cached")
      printf 'cache'
      ;;
    "usage --refresh -v")
      printf 'wide'
      ;;
    "add <name>")
      printf 'new'
      ;;
    current|list*|paths)
      printf 'view'
      ;;
    "use <name>")
      printf 'use'
      ;;
    "add <name> --current")
      printf 'save'
      ;;
    save*)
      printf 'copy'
      ;;
    "add <name> --file <file>")
      printf 'import'
      ;;
    import*)
      printf 'load'
      ;;
    "login <name>")
      printf 'auth'
      ;;
    refresh)
      printf 'sync'
      ;;
    auto)
      printf 'best'
      ;;
    recover*)
      printf 'resume'
      ;;
    "run -- <args>")
      printf 'roll'
      ;;
    remove*)
      printf 'delete'
      ;;
    doctor)
      printf 'audit'
      ;;
    export*)
      printf 'write'
      ;;
    *)
      printf '%s' "${desc%% *}"
      ;;
  esac
}

help_action_tone() {
  case "${1:-}" in
    select|best)
      printf 'accent'
      ;;
    use|save|view|cache|export|new|copy|load|write)
      printf 'good'
      ;;
    auth|login|import|wide|refresh|resume|roll|audit)
      printf 'warn'
      ;;
    delete|remove)
      printf 'bad'
      ;;
    *)
      printf 'muted'
      ;;
  esac
}

display_path() {
  local path="$1"
  local home_prefix="${HOME%/}/"

  if [[ -n "${HOME:-}" && "$path" == "$HOME" ]]; then
    printf '~'
  elif [[ -n "${HOME:-}" && "$path" == "$home_prefix"* ]]; then
    printf '~/%s' "${path#$home_prefix}"
  else
    printf '%s' "$path"
  fi
}

compact_display_path() {
  local path="$1"
  local width="${2:-0}"
  local rendered base prefix candidate

  rendered="$(display_path "$path")"
  if [[ "$width" =~ ^[0-9]+$ && "$width" -gt 0 && ${#rendered} -gt width && "$rendered" == */* ]]; then
    base="${rendered##*/}"
    if usage_unicode_enabled; then
      prefix="…/"
    else
      prefix=".../"
    fi
    candidate="$prefix$base"
    fit_profile_text_rtrim "$candidate" "$width"
    return 0
  fi
  printf '%s' "$rendered"
}

compact_codex_status() {
  local status="$1"
  local width="${2:-0}"

  if [[ "$status" == "Logged in using "* ]]; then
    printf '%s' "${status#Logged in using }"
  else
    printf '%s' "$status"
  fi
}

print_help_footer() {
  local width="$1"
  local path path_w

  if (( width < 32 )); then
    path_w=$((width - 5))
    (( path_w < 1 )) && path_w=1
    path="$(compact_display_path "$PROFILE_DIR" "$path_w")"
    fit_text_rtrim "prof $path" "$width"
  elif (( width < 42 )); then
    path_w=$((width - 9))
    (( path_w < 1 )) && path_w=1
    path="$(compact_display_path "$PROFILE_DIR" "$path_w")"
    fit_text_rtrim "profiles $path" "$width"
  else
    path="$(display_path "$PROFILE_DIR")"
    fit_text_rtrim "profiles live under $path" "$width"
  fi
}

die() {
  print_error "$*"
  exit 1
}

codex_bin() {
  if [[ -n "$CODEX_BIN" && -x "$CODEX_BIN" ]]; then
    printf '%s\n' "$CODEX_BIN"
  elif [[ -x "$HOME/.bun/bin/codex-real" ]]; then
    printf '%s\n' "$HOME/.bun/bin/codex-real"
  elif [[ -x "$HOME/.bun/bin/codex" ]]; then
    printf '%s\n' "$HOME/.bun/bin/codex"
  else
    command -v codex 2>/dev/null || return 1
  fi
}

codex_launcher_needs_node() {
  local codex_cli="$1"
  local first_line=""

  [[ -r "$codex_cli" ]] || return 1
  IFS= read -r first_line < "$codex_cli" || return 1
  [[ "$first_line" == "#!"*"env node"* ]]
}

codex_launcher_ready() {
  local codex_cli="$1"

  if codex_launcher_needs_node "$codex_cli"; then
    command -v node >/dev/null 2>&1 || return 1
  fi
  return 0
}

require_codex_launcher() {
  local codex_cli="$1"

  if codex_launcher_needs_node "$codex_cli" && ! command -v node >/dev/null 2>&1; then
    die "node needed for codex"
  fi
}

ensure_dirs() {
  mkdir -p "$CODEX_HOME" "$PROFILE_DIR" "$BACKUP_DIR" "$CODEX_HOME/.tmp"
  chmod 700 "$CODEX_HOME" "$PROFILE_DIR" "$BACKUP_DIR" "$CODEX_HOME/.tmp" 2>/dev/null || true
}

acquire_mutation_lock() {
  local wait
  if (( MUTATION_LOCK_HELD )); then
    return 0
  fi

  ensure_dirs
  wait="${CODEX_AUTH_MUTATION_LOCK_WAIT:-30}"
  [[ "$wait" =~ ^[0-9]+$ ]] || wait=30
  exec {MUTATION_LOCK_FD}>"$CODEX_HOME/.tmp/codex-auth-mutation.lock"
  flock -w "$wait" "$MUTATION_LOCK_FD" || die "auth change already running"
  MUTATION_LOCK_HELD=1
}

require_name() {
  local name="${1:-}"
  [[ -n "$name" ]] || die "missing profile name"
  [[ "$name" =~ ^[A-Za-z0-9._-]+$ ]] || die "profile names may only use letters, numbers, dot, underscore, and dash"
}

profile_path() {
  local name="$1"
  printf '%s/%s.json\n' "$PROFILE_DIR" "$name"
}

require_auth_file() {
  local path="$1"
  [[ -f "$path" ]] || die "auth file not found: $path"
  [[ -s "$path" ]] || die "auth file is empty: $path"
  if command -v jq >/dev/null 2>&1; then
    jq -e 'has("OPENAI_API_KEY") or has("tokens")' "$path" >/dev/null 2>&1 \
      || die "not a Codex auth.json with OPENAI_API_KEY or tokens: $path"
  fi
}

auth_file_is_valid() {
  local path="$1"
  [[ -f "$path" && -s "$path" ]] || return 1
  if command -v jq >/dev/null 2>&1; then
    jq -e 'has("OPENAI_API_KEY") or has("tokens")' "$path" >/dev/null 2>&1 || return 1
  fi
}

copy_auth_file_atomic() {
  local source="$1"
  local dest="$2"
  local dest_dir dest_base tmp

  dest_dir="$(dirname "$dest")"
  dest_base="$(basename "$dest")"
  tmp="$(mktemp "$dest_dir/.${dest_base}.tmp.XXXXXX")"
  if ! cp -p "$source" "$tmp"; then
    rm -f "$tmp"
    return 1
  fi
  if ! chmod 600 "$tmp"; then
    rm -f "$tmp"
    return 1
  fi
  if ! mv -f "$tmp" "$dest"; then
    rm -f "$tmp"
    return 1
  fi
}

restore_hidden_auth() {
  local hidden_auth="${1:-}"
  [[ -n "$hidden_auth" && -f "$hidden_auth" ]] || return 1
  rm -f "$AUTH_FILE"
  mv "$hidden_auth" "$AUTH_FILE"
  chmod 600 "$AUTH_FILE"
}

credential_fingerprint() {
  local path="$1"
  [[ -f "$path" ]] || return 1
  if command -v jq >/dev/null 2>&1; then
    jq -r 'if .OPENAI_API_KEY then "api:" + .OPENAI_API_KEY elif .tokens.refresh_token then "chatgpt:" + .tokens.refresh_token elif .tokens.access_token then "chatgpt-access:" + .tokens.access_token else empty end' "$path" \
      | sha256sum \
      | awk '{print $1}'
  else
    sha256sum "$path" | awk '{print $1}'
  fi
}

fingerprint_secret() {
  local secret="${1:-}"
  if [[ -n "$secret" ]]; then
    printf '%s\n' "$secret" | sha256sum | awk '{print $1}'
  else
    printf '' | sha256sum | awk '{print $1}'
  fi
}

auth_metadata() {
  local path="$1"
  local mode="unknown"
  local hint=""
  local secret=""
  local fp=""
  local fields=()

  [[ -f "$path" ]] || return 1
  if command -v jq >/dev/null 2>&1; then
    mapfile -t fields < <(
      jq -r '
        if .OPENAI_API_KEY then
          "api_key",
          "",
          ("api:" + .OPENAI_API_KEY)
        elif .tokens then
          "chatgpt",
          ((.tokens.account_id // "") | tostring | gsub("[[:space:]]"; "")),
          (if .tokens.refresh_token then
             "chatgpt:" + .tokens.refresh_token
           elif .tokens.access_token then
             "chatgpt-access:" + .tokens.access_token
           else
             ""
           end)
        else
          "unknown",
          "",
          ""
        end
      ' "$path" 2>/dev/null || true
    )
    mode="${fields[0]:-unknown}"
    hint="${fields[1]:-}"
    secret="${fields[2]:-}"
    fp="$(fingerprint_secret "$secret")"
  else
    fp="$(sha256sum "$path" | awk '{print $1}')"
  fi

  printf '%s\n%s\n%s\n' "$mode" "$hint" "$fp"
}

auth_metadata_records() {
  if (( $# == 0 )); then
    return 0
  fi

  if command -v jq >/dev/null 2>&1; then
    jq -r '
      def clean: tostring | gsub("[[:space:]]"; "");
      if .OPENAI_API_KEY then
        [input_filename, "api_key", "", ("api:" + .OPENAI_API_KEY)]
      elif .tokens then
        [input_filename,
         "chatgpt",
         ((.tokens.account_id // "") | clean),
         (if .tokens.refresh_token then
            "chatgpt:" + .tokens.refresh_token
          elif .tokens.access_token then
            "chatgpt-access:" + .tokens.access_token
          else
            ""
          end)]
      else
        [input_filename, "unknown", "", ""]
      end
      | join("\u001f")
    ' "$@" 2>/dev/null
  else
    local path
    for path in "$@"; do
      [[ -f "$path" ]] || continue
      printf '%s\037unknown\037\037%s\n' "$path" "$(sha256sum "$path" | awk '{print $1}')"
    done
  fi
}

auth_mode() {
  local path="$1"
  if command -v jq >/dev/null 2>&1; then
    jq -r 'if .OPENAI_API_KEY then "api_key" elif .tokens then "chatgpt" else "unknown" end' "$path" 2>/dev/null || printf 'unknown\n'
  else
    printf 'unknown\n'
  fi
}

account_hint() {
  local path="$1"
  if command -v jq >/dev/null 2>&1; then
    jq -r '.tokens.account_id // empty' "$path" 2>/dev/null | sed 's/[[:space:]]//g'
  fi
}

reserve_unique_backup_path() {
  local label="$1"
  local stamp base candidate suffix=0

  stamp="$(date +%Y%m%d_%H%M%S)"
  base="$BACKUP_DIR/auth.json.$stamp.$label"
  while true; do
    candidate="$base"
    (( suffix > 0 )) && candidate="$base.$suffix"
    if ( set -o noclobber; : > "$candidate" ) 2>/dev/null; then
      chmod 600 "$candidate"
      printf '%s\n' "$candidate"
      return 0
    fi
    suffix=$((suffix + 1))
  done
}

backup_current() {
  local label="${1:-switch}"
  ensure_dirs
  if [[ ! -f "$AUTH_FILE" ]]; then
    return 0
  fi
  local backup
  backup="$(reserve_unique_backup_path "$label")"
  if ! copy_auth_file_atomic "$AUTH_FILE" "$backup"; then
    rm -f "$backup"
    return 1
  fi
  printf '%s\n' "$backup"
}

short_account_hint() {
  local hint="$1"
  local width="${2:-13}"
  local length=${#hint}
  if [[ -z "$hint" ]]; then
    usage_meta_glyph
  elif (( width < 13 && length > width )); then
    fit_profile_text "$hint" "$width"
  elif (( length > 13 )); then
    printf '%s%s%s' "${hint:0:8}" "$(usage_trunc_glyph)" "${hint:length-4:4}"
  else
    printf '%s' "$hint"
  fi
}

verbose_account_hint() {
  local hint="$1"
  local width="${2:-13}"
  local clean length right left

  if [[ -z "$hint" ]]; then
    usage_meta_glyph
    return 0
  fi
  if (( ${#hint} <= width )); then
    printf '%s' "$hint"
    return 0
  fi

  clean="${hint//-/}"
  if [[ "$hint" =~ ^[0-9a-fA-F-]+$ && ${#clean} -gt 12 ]]; then
    if (( width >= 13 )); then
      right=$((width - 9))
      (( right < 4 )) && right=4
      printf '%s%s%s' "${clean:0:8}" "$(usage_trunc_glyph)" "${clean:${#clean}-right:right}"
    elif (( width >= 8 )); then
      right=4
      left=$((width - right - 1))
      (( left < 3 )) && left=3
      printf '%s%s%s' "${clean:0:left}" "$(usage_trunc_glyph)" "${clean:${#clean}-right:right}"
    else
      fit_profile_text "$clean" "$width"
    fi
  else
    fit_profile_text "$hint" "$width"
  fi
}

profile_list_widths() {
  local cols="$1"
  local role_w=5
  local profile_w
  local wanted_profile_w
  local mode_w=7
  local account_min=10
  local max_profile_w account_w

  wanted_profile_w="${PROFILE_LIST_WIDTH_HINT:-12}"
  wanted_profile_w="$(usage_profile_width_hint "$cols" "$wanted_profile_w" "$USAGE_VERBOSE")"

  if (( cols < 34 )); then
    role_w=1
    mode_w=4
    account_min=8
  elif (( cols < 40 )); then
    role_w=1
    mode_w=7
    account_min=10
  fi

  max_profile_w=$((cols - role_w - mode_w - account_min - 3))
  profile_w="$wanted_profile_w"
  (( profile_w > max_profile_w )) && profile_w="$max_profile_w"
  if (( cols < 23 )); then
    (( profile_w < 4 )) && profile_w=4
  else
    (( profile_w < 5 )) && profile_w=5
  fi
  account_w=$((cols - role_w - profile_w - mode_w - 3))
  (( account_w < account_min )) && account_w="$account_min"

  printf '%s\t%s\t%s\t%s\n' "$role_w" "$profile_w" "$mode_w" "$account_w"
}

profile_list_mode_label() {
  local mode="$1"
  local width="$2"

  if (( width <= 4 )); then
    case "$mode" in
      chatgpt)
        printf 'chat'
        ;;
      api_key)
        printf 'api'
        ;;
      unknown|"")
        printf 'n/a'
        ;;
      *)
        fit_text "$mode" "$width"
        ;;
    esac
  else
    fit_text "$(auth_mode_display_label "$mode")" "$width"
  fi
}

auth_mode_display_label() {
  local mode="$1"

  case "$mode" in
    chatgpt)
      printf 'ChatGPT'
      ;;
    api_key)
      printf 'API key'
      ;;
    unknown|"")
      printf 'n/a'
      ;;
    *)
      printf '%s' "$mode"
      ;;
  esac
}

profile_account_display() {
  local hint="$1"
  local width="$2"
  local verbose="${3:-0}"
  local alias_of="${4:-}"
  local base alias_label alias_text compact_alias

  if [[ -n "$alias_of" ]]; then
    alias_label="$(usage_display_profile_name "$alias_of" "" "$width")"
    if (( verbose )) && [[ -n "$hint" ]]; then
      base="$hint"
    else
      base="$(short_account_hint "$hint" 13)"
    fi
    if usage_unicode_enabled; then
      alias_text="$base ↔ $alias_label"
      compact_alias="↔ $alias_label"
    else
      alias_text="$base = $alias_label"
      compact_alias="= $alias_label"
    fi
    if (( ${#alias_text} > width )) && (( verbose )); then
      base="$(short_account_hint "$hint" 13)"
      if usage_unicode_enabled; then
        alias_text="$base ↔ $alias_label"
      else
        alias_text="$base = $alias_label"
      fi
    fi
    if (( ${#alias_text} <= width )); then
      printf '%s' "$alias_text"
    elif (( ${#compact_alias} <= width )); then
      printf '%s' "$compact_alias"
    elif (( width >= 5 )); then
      alias_label="$(usage_display_profile_name "$alias_of" "" "$((width - 2))")"
      if usage_unicode_enabled; then
        compact_alias="↔ $alias_label"
      else
        compact_alias="= $alias_label"
      fi
      if (( ${#compact_alias} <= width )); then
        printf '%s' "$compact_alias"
      elif usage_unicode_enabled; then
        printf '↔'
        fit_profile_text "$alias_label" "$((width - 1))"
      else
        printf '='
        fit_profile_text "$alias_label" "$((width - 1))"
      fi
    elif usage_unicode_enabled && (( width >= 2 )); then
      printf '↔'
      fit_profile_text "$alias_label" "$((width - 1))"
    elif (( width >= 2 )); then
      printf '='
      fit_profile_text "$alias_label" "$((width - 1))"
    else
      fit_text "$(short_account_hint "$hint" "$width")" "$width"
    fi
    return 0
  fi

  if [[ -z "$hint" ]]; then
    return 0
  fi

  if (( verbose )); then
    base="$(verbose_account_hint "$hint" "$width")"
  else
    base="$(short_account_hint "$hint" "$width")"
  fi
  fit_text "$base" "$width"
}

print_profile_list_line() {
  local role="$1"
  local profile="$2"
  local mode="$3"
  local account="$4"
  local role_w="$5"
  local profile_w="$6"
  local mode_w="$7"
  local account_w="$8"
  local role_tone="muted"

  if [[ "$role" == "$(usage_active_glyph)" || "$role" == "active" || "$role" == "stay" || "$role" == "s" || "$role" == "*" ]]; then
    role_tone="active"
  fi
  case "$role" in
    use|u)
      role_tone="good"
      ;;
    alias|a|=)
      role_tone="warn"
      ;;
  esac
  print_toned_fit "$role" "$role_w" "$role_tone"
  printf ' '
  fit_profile_text "$(usage_display_profile_name "$profile" "$role" "$profile_w")" "$profile_w"
  printf ' '
  profile_list_mode_label "$mode" "$mode_w"
  printf ' '
  fit_profile_text_rtrim "$account" "$account_w"
  printf '\n'
}

profile_list_action_label() {
  local role="$1"
  local width="$2"

  if (( width <= 1 )); then
    case "$role" in
      stay)
        printf 's'
        ;;
      alias)
        printf 'a'
        ;;
      use)
        printf 'u'
        ;;
      *)
        printf ''
        ;;
    esac
    return 0
  fi

  case "$role" in
    stay)
      printf 'stay'
      ;;
    alias)
      printf 'alias'
      ;;
    use)
      printf 'use'
      ;;
    *)
      printf ''
      ;;
  esac
}

detail_widths() {
  local cols="$1"
  local label_w=8
  local value_w

  if (( cols < 39 )); then
    label_w=8
  elif (( cols >= 72 )); then
    label_w=10
  fi
  value_w=$((cols - label_w - 1))
  (( value_w < 10 )) && value_w=10

  printf '%s\t%s\n' "$label_w" "$value_w"
}

print_detail_line() {
  local label="$1"
  local value="$2"
  local label_w="$3"
  local value_w="$4"
  local tone="${5:-muted}"

  print_toned_fit "$label" "$label_w" "$tone"
  printf ' '
  fit_profile_text_rtrim "$value" "$value_w"
  printf '\n'
}

print_detail_text_line() {
  local label="$1"
  local value="$2"
  local label_w="$3"
  local value_w="$4"
  local tone="${5:-muted}"

  print_toned_fit "$label" "$label_w" "$tone"
  printf ' '
  fit_text_rtrim "$value" "$value_w"
  printf '\n'
}

path_row_widths() {
  local cols="$1"
  local role_w=5
  local target_w=8
  local path_w

  if (( cols < 22 )); then
    role_w=5
    target_w=0
  elif (( cols < 39 )); then
    role_w=5
    target_w=0
  elif (( cols >= 72 )); then
    role_w=6
    target_w=9
  fi
  if (( target_w <= 0 )); then
    path_w=$((cols - role_w - 1))
  else
    path_w=$((cols - role_w - target_w - 2))
  fi
  (( path_w < 8 )) && path_w=8
  printf '%s\t%s\t%s\n' "$role_w" "$target_w" "$path_w"
}

path_role_label() {
  local role="$1"
  local width="$2"

  if (( width <= 4 )); then
    case "$role" in
      saved)
        printf 'save'
        ;;
      cache)
        printf 'cach'
        ;;
      *)
        fit_text "$role" "$width"
        ;;
    esac
  else
    fit_text "$role" "$width"
  fi
}

path_target_label() {
  local target="$1"
  local width="$2"

  if (( width <= 4 )); then
    case "$target" in
      profiles)
        printf 'prof'
        ;;
      backups)
        printf 'back'
        ;;
      usage)
        printf 'usg'
        ;;
      *)
        fit_text "$target" "$width"
        ;;
    esac
  else
    fit_text "$target" "$width"
  fi
}

print_path_line() {
  local role="$1"
  local target="$2"
  local path="$3"
  local role_w="$4"
  local target_w="$5"
  local path_w="$6"
  local tone="${7:-muted}"
  local rendered base

  rendered="$(compact_display_path "$path" "$path_w")"
  if (( target_w <= 0 && path_w < 24 )) && [[ "$target" != "auth" && "$path" == */* ]]; then
    base="${path##*/}"
    if (( ${#base} <= path_w )); then
      rendered="$base"
    fi
  fi
  if (( target_w <= 0 )) && [[ "$rendered" == "…/"* || "$rendered" == "*/"* ]]; then
    base="${path##*/}"
    if (( ${#base} <= path_w )); then
      rendered="$base"
    fi
  fi
  if (( ${#rendered} > path_w )) && [[ "$path" == */* ]]; then
    base="${path##*/}"
    if (( ${#base} <= path_w )); then
      rendered="$base"
    fi
  fi
  if (( target_w <= 0 )) && [[ "$target" == "usage" && "$path_w" -lt 15 ]]; then
    base="state.json"
    if (( ${#base} <= path_w )); then
      rendered="$base"
    fi
  fi
  print_toned_fit "$(path_role_label "$role" "$role_w")" "$role_w" "$tone"
  printf ' '
  if (( target_w > 0 )); then
    path_target_label "$target" "$target_w"
    printf ' '
  fi
  fit_profile_text_rtrim "$rendered" "$path_w"
  printf '\n'
}

compact_command_display() {
  local command="$1"
  local width="$2"

  if (( ${#command} > width )) && [[ "$command" == codex-auth\ * ]]; then
    command="${command#codex-auth }"
  fi
  if (( ${#command} > width )) && [[ "$command" == "add current --current" ]]; then
    command="save current"
  fi
  if (( ${#command} > width )) && [[ "$command" == "save current" ]]; then
    command="current"
  fi
  printf '%s' "$command"
}

print_detail_summary() {
  local summary="$1"
  local width="$2"

  if (( width >= 40 )); then
    print_usage_title_line "$summary" "$width"
    return 0
  fi

  fit_text_rtrim "$summary" "$width"
  printf '\n'
  repeat_glyph "$(usage_rule_glyph)" "$width"
  printf '\n'
}

print_summary_kv_line() {
  local label="$1"
  local value="$2"
  local width="$3"
  local label_w="${4:-8}"
  local value_w

  value_w=$((width - label_w - 2))
  (( value_w < 1 )) && value_w=1
  fit_text "$label" "$label_w"
  printf '  '
  fit_text_rtrim "$value" "$value_w"
  printf '\n'
}

result_title_for_summary() {
  local summary="$1"

  case "$summary" in
    active\ *|using\ profile\ *)
      printf 'Active profile'
      ;;
    saved\ *|login\ *|imported\ *|saved\ profile\ *|logged\ in\ profile\ *|imported\ profile\ *)
      printf 'Saved profile'
      ;;
    export\ *|exported\ profile\ *)
      printf 'Export'
      ;;
    removed\ active\ *|removed\ *|removed\ active\ profile\ *|removed\ profile\ *)
      printf 'Removed profile'
      ;;
    *)
      printf 'Result'
      ;;
  esac
}

result_detail_label() {
  local label="$1"
  local summary="${2:-}"

  case "$label" in
    auth)
      printf 'live'
      ;;
    profile)
      if [[ "$summary" == removed* ]]; then
        printf 'gone'
      else
        printf 'saved'
      fi
      ;;
    source)
      printf 'from'
      ;;
    dest)
      printf 'out'
      ;;
    backup)
      printf 'undo'
      ;;
    active)
      printf 'state'
      ;;
    *)
      printf '%s' "$label"
      ;;
  esac
}

result_value_path() {
  local path="$1"
  local width="$2"
  local base

  if [[ "$path" == */* ]] && (( width < 18 )); then
    base="${path##*/}"
    fit_profile_text_rtrim "$base" "$width"
    return 0
  fi
  compact_display_path "$path" "$width"
}

result_summary_display() {
  local summary="$1"
  local width="$2"

  if (( width < 24 )) && [[ "$summary" == removed\ active\ * ]]; then
    printf 'removed %s' "${summary#removed active }"
  else
    printf '%s' "$summary"
  fi
}

print_result_block() {
  local summary="$1"
  shift
  local cols label_w value_w total_w row label value tone title display_label display_summary

  cols="$(terminal_width)"
  IFS=$'\t' read -r label_w value_w <<<"$(detail_widths "$cols")"
  total_w=$((label_w + 1 + value_w))
  USAGE_COLOR_ENABLED=0
  color_enabled && USAGE_COLOR_ENABLED=1

  title="$(result_title_for_summary "$summary")"
  display_summary="$(result_summary_display "$summary" "$total_w")"
  print_palette_summary_header "Auth" "$title" "$display_summary" "$total_w"
  for row in "$@"; do
    IFS=$'\t' read -r label value tone <<<"$row"
    [[ -n "$tone" ]] || tone="muted"
    case "$label" in
      backup)
        if [[ "$value" == */* ]]; then
          if [[ "${CODEX_AUTH_SHOW_BACKUP_PATH:-0}" != "1" ]]; then
            value="created"
          elif (( value_w < 46 )); then
            value="created"
          else
            value="$(compact_display_path "$value" "$value_w")"
          fi
        fi
        ;;
      active|profile|source|dest|dir|auth|profiles|backups|state)
        if [[ "$value" == */* ]]; then
          value="$(result_value_path "$value" "$value_w")"
        fi
        ;;
    esac
    if [[ "$label" == "active" && "$value" == "unsaved auth" && "$value_w" -lt 12 ]]; then
      value="unsaved"
    fi
    if [[ "$label" == "active" && "$value" == "already active" && "$value_w" -lt 14 ]]; then
      value="already"
    fi
    if [[ "$label" == "active" && "$value" == saved\ * && "$value_w" -lt 12 ]]; then
      value="saved"
    fi
    display_label="$(result_detail_label "$label" "$summary")"
    print_detail_line "$display_label" "$value" "$label_w" "$value_w" "$tone"
  done
}

compact_width_choice() {
  local cols="$1"
  local cutoff="$2"
  local short="$3"
  local wide="$4"

  if (( cols < cutoff )); then
    printf '%s' "$short"
  else
    printf '%s' "$wide"
  fi
}

compact_value_choice() {
  local cols="$1"
  local cutoff="$2"
  local short_format="$3"
  local wide_format="$4"
  local value="$5"

  if (( cols < cutoff )); then
    printf "$short_format" "$value"
  else
    printf "$wide_format" "$value"
  fi
}

compact_missing_dir_message() {
  local cols="$1"
  local base="$2"

  if (( cols < 24 )); then
    printf 'missing dir'
  elif (( cols < 28 )); then
    printf 'missing dir %s' "$base"
  else
    printf 'missing dir: %s' "$base"
  fi
}

compact_error_static_message() {
  local cols="$1"
  local message="$2"
  local source cutoff short wide

  while IFS=$'\t' read -r source cutoff short wide; do
    [[ -n "$source" ]] || continue
    if [[ "$message" == "$source" ]]; then
      if [[ "$cutoff" == "-" ]]; then
        printf '%s' "$short"
      else
        compact_width_choice "$cols" "$cutoff" "$short" "$wide"
      fi
      return 0
    fi
  done <<'EOF'
refusing to remove without --yes	-	remove needs --yes
usage: --ttl seconds	-	ttl needs seconds
usage: codex-auth add <name> --file <file>	28	add needs file	add needs --file <file>
usage: codex-auth add <name> [--current | --file <file> | codex login args...]	28	add needs name	usage: add <name>
add accepts one source: --current or --file	40	choose one source	choose --current or --file
add cannot mix --file/--current with login args	40	file + login args	cannot mix file and login args
no active auth to save	-	no active auth
jq is required for usage output	24	jq needed	jq needed for usage
jq is required for usage refresh	24	jq needed	jq needed for refresh
jq is required for recovery	24	jq needed	jq needed for recover
node needed for codex	24	node needed	node needed for codex
codex command not found	32	codex missing	codex command not found
auth change already running	32	auth busy	auth change busy
could not hide active auth for login	32	hide auth failed	could not hide active auth
login failed; restored previous auth	32	login failed; restored	login failed; auth restored
login did not produce valid auth; restored previous auth	32	bad login auth; restored	login auth invalid; restored
login did not produce valid auth	32	bad login auth	login auth invalid
profile names may only use letters, numbers, dot, underscore, and dash	28	bad profile name	bad name: A-Z 0-9 . _ -
usage: codex-auth list [-v]	-	usage: list [-v]
usage: codex-auth remove <name> --yes	28	remove name --yes	usage: remove <name> --yes
usage: codex-auth import <name> <file>	34	import name file	usage: import <name> <file>
usage: codex-auth export <name> <file>	34	export name file	usage: export <name> <file>
usage: codex-auth save <name> [file]	34	save name file	usage: save <name> [file]
usage: codex-auth use <name>	34	use name	usage: use <name>
usage: codex-auth login <name> [codex login args...]	28	login needs name	usage: login <name>
EOF
  return 1
}

compact_error_message() {
  local message="$1"
  local cols="$2"
  local tail command option base

  if (( cols < 68 )); then
    if compact_error_static_message "$cols" "$message"; then
      return 0
    fi
    case "$message" in
      auth\ file\ not\ found:\ *)
        tail="${message#auth file not found: }"
        base="${tail##*/}"
        compact_value_choice "$cols" 28 'missing %s' 'missing file: %s' "$base"
        return 0
        ;;
      auth\ file\ is\ empty:\ *)
        tail="${message#auth file is empty: }"
        base="${tail##*/}"
        compact_value_choice "$cols" 28 'empty %s' 'empty file: %s' "$base"
        return 0
        ;;
      not\ a\ Codex\ auth.json\ with\ OPENAI_API_KEY\ or\ tokens:\ *)
        tail="${message#not a Codex auth.json with OPENAI_API_KEY or tokens: }"
        base="${tail##*/}"
        compact_value_choice "$cols" 28 'bad auth %s' 'bad auth file: %s' "$base"
        return 0
        ;;
      export\ dir\ missing:\ *)
        tail="${message#export dir missing: }"
        base="${tail##*/}"
        compact_missing_dir_message "$cols" "$base"
        return 0
        ;;
      export\ path\ is\ a\ directory:\ *)
        tail="${message#export path is a directory: }"
        base="${tail##*/}"
        compact_value_choice "$cols" 60 'export path is dir' 'export path is dir: %s' "$base"
        return 0
        ;;
      unknown\ command:\ *.\ Use:\ codex-auth\ help)
        command="${message#unknown command: }"
        command="${command%. Use: codex-auth help}"
        compact_value_choice "$cols" 28 'unknown %s' 'unknown %s; help' "$command"
        return 0
        ;;
      unknown\ usage\ option:\ *)
        option="${message#unknown usage option: }"
        compact_value_choice "$cols" 28 'bad opt %s' 'unknown option %s' "$option"
        return 0
        ;;
      profile\ not\ found:\ *)
        tail="${message#profile not found: }"
        if (( cols < 40 )); then
          tail="$(fit_profile_text_rtrim "$tail" "$((cols - 15))")"
          printf 'missing %s' "$tail"
        else
          printf 'not found: %s' "$tail"
        fi
        return 0
        ;;
    esac
  fi

  if (( cols < 32 )); then
    case "$message" in
      usage:\ codex-auth\ *)
        printf 'usage:%s' "${message#usage: codex-auth}"
        return 0
        ;;
    esac
  fi

  printf '%s' "$message"
}

print_error() {
  local message="$*"
  local cols prefix indent current word candidate rendered line_prefix line_width
  local wrote_line=0
  local words=()

  cols="$(terminal_width)"
  message="$(compact_error_message "$message" "$cols")"
  if usage_unicode_enabled || (( cols < 30 )); then
    prefix="! "
  else
    prefix="error: "
  fi
  indent="$(printf '%*s' "${#prefix}" '')"
  current="$prefix"
  read -r -a words <<<"$message"

  for word in "${words[@]}"; do
    if (( ${#current} == ${#prefix} || ${#current} == ${#indent} )); then
      candidate="${current}${word}"
    else
      candidate="$current $word"
    fi

    if (( ${#candidate} <= cols )); then
      current="$candidate"
      continue
    fi

    if [[ "$current" != "$prefix" && "$current" != "$indent" ]]; then
      rendered="$(fit_text_rtrim "$current" "$cols")"
      printf '%s\n' "$rendered" >&2
      wrote_line=1
    fi

    if (( ${#prefix} + ${#word} > cols )); then
      if (( wrote_line )); then
        line_prefix="$indent"
      else
        line_prefix="$prefix"
      fi
      line_width=$((cols - ${#line_prefix}))
      (( line_width < 1 )) && line_width=1
      rendered="$(fit_profile_text_rtrim "$word" "$line_width")"
      printf '%s%s\n' "$line_prefix" "$rendered" >&2
      wrote_line=1
      current="$indent"
    else
      current="${indent}${word}"
    fi
  done

  if [[ "$current" != "$prefix" && "$current" != "$indent" ]]; then
    rendered="$(fit_text_rtrim "$current" "$cols")"
    printf '%s\n' "$rendered" >&2
  fi
}

print_empty_profiles() {
  local cols label_w value_w total_w command action saved_path

  cols="$(terminal_width)"
  IFS=$'\t' read -r label_w value_w <<<"$(detail_widths "$cols")"
  total_w=$((label_w + 1 + value_w))
  USAGE_COLOR_ENABLED=0
  color_enabled && USAGE_COLOR_ENABLED=1

  print_palette_summary_header "Auth" "Profiles" "no saved profiles" "$total_w"
  if [[ -f "$AUTH_FILE" ]]; then
    if (( total_w < 32 )); then
      command="current"
    else
      command="codex-auth add current --current"
    fi
    action="save"
  else
    command="codex-auth add <name>"
    action="login"
  fi
  print_detail_text_line "$action" "$(compact_command_display "$command" "$value_w")" "$label_w" "$value_w" active
  if (( value_w < 13 )); then
    saved_path="profiles"
  elif (( value_w < 18 )); then
    saved_path="$(basename "$PROFILE_DIR")"
  else
    saved_path="$(compact_display_path "$PROFILE_DIR" "$value_w")"
  fi
  print_detail_line "saved" "$saved_path" "$label_w" "$value_w" good
}

print_no_active_auth() {
  local cols label_w value_w total_w first_profile next_command action

  cols="$(terminal_width)"
  IFS=$'\t' read -r label_w value_w <<<"$(detail_widths "$cols")"
  total_w=$((label_w + 1 + value_w))
  USAGE_COLOR_ENABLED=0
  color_enabled && USAGE_COLOR_ENABLED=1

  shopt -s nullglob
  local profiles=("$PROFILE_DIR"/*.json)
  shopt -u nullglob

  print_palette_summary_header "Auth" "Active profile" "no active auth" "$total_w"
  if (( ${#profiles[@]} > 0 )); then
    first_profile="$(basename "${profiles[0]}" .json)"
    next_command="$first_profile"
    action="use"
  else
    next_command="codex-auth add <name>"
    action="login"
  fi
  print_detail_text_line "$action" "$(compact_command_display "$next_command" "$value_w")" "$label_w" "$value_w" active
  print_detail_line "live" "$(compact_display_path "$AUTH_FILE" "$value_w")" "$label_w" "$value_w" bad
}

print_bad_active_auth() {
  local cols label_w value_w total_w first_profile next_command action

  cols="$(terminal_width)"
  IFS=$'\t' read -r label_w value_w <<<"$(detail_widths "$cols")"
  total_w=$((label_w + 1 + value_w))
  USAGE_COLOR_ENABLED=0
  color_enabled && USAGE_COLOR_ENABLED=1

  shopt -s nullglob
  local profiles=("$PROFILE_DIR"/*.json)
  shopt -u nullglob

  print_palette_summary_header "Auth" "Active profile" "bad active auth" "$total_w"
  print_detail_line "live" "$(compact_display_path "$AUTH_FILE" "$value_w")" "$label_w" "$value_w" bad
  if (( ${#profiles[@]} > 0 )); then
    first_profile="$(basename "${profiles[0]}" .json)"
    next_command="$first_profile"
    action="use"
  else
    if (( total_w < 24 )); then
      next_command="login"
    else
      next_command="codex-auth login <name>"
    fi
    action="fix"
  fi
  print_detail_text_line "$action" "$(compact_command_display "$next_command" "$value_w")" "$label_w" "$value_w" active
}

print_status_note() {
  local kind="$1"
  local detail="${2:-}"
  local cols line glyph tone="muted" compact_detail

  cols="$(terminal_width)"
  case "$kind" in
    refresh)
      if usage_unicode_enabled; then
        line="↻ refresh"
      else
        line="refresh"
      fi
      tone="accent"
      ;;
    ready)
      line="ready"
      tone="good"
      ;;
    blocked)
      if usage_unicode_enabled; then
        glyph="!"
      else
        glyph="!"
      fi
      line="$glyph blocked"
      tone="bad"
      ;;
    cache)
      line="cache"
      tone="warn"
      ;;
    recover)
      if usage_unicode_enabled; then
        line="↳ recover"
      else
        line="recover"
      fi
      tone="accent"
      ;;
    roll)
      line="roll"
      tone="warn"
      ;;
    *)
      glyph="$(usage_meta_glyph)"
      line="$glyph $kind"
      ;;
  esac
  case "$kind:$detail" in
    "ready:already on best profile")
      if (( cols < 28 )); then
        line="already best"
      else
        line="already on best profile"
      fi
      detail=""
      ;;
    "blocked:no ready profile")
      line="! no ready profile"
      detail=""
      ;;
    "blocked:choose switch/login/skip")
      line="! choose row"
      detail=""
      ;;
    "cache:refresh busy")
      detail="busy"
      ;;
    "roll:usage limit, rotating")
      if (( cols < 32 )); then
        line="roll auth"
      else
        line="roll auth"
        detail="resume"
      fi
      ;;
  esac
  [[ -n "$detail" ]] && line+=" $detail"
  if (( ${#line} > cols )); then
    case "$kind:$detail" in
      "blocked:no ready profile")
        line="! no ready profile"
        ;;
      "ready:already on best profile")
        line="ready already best"
        ;;
      "recover:latest session")
        if usage_unicode_enabled; then
          line="↳ recover latest"
        else
          line="recover latest"
        fi
        ;;
      "recover:session "*)
        compact_detail="${detail#session }"
        if usage_unicode_enabled; then
          line="↳ recover $compact_detail"
        else
          line="recover $compact_detail"
        fi
        ;;
    esac
  fi

  USAGE_COLOR_ENABLED=0
  color_enabled && USAGE_COLOR_ENABLED=1
  usage_tone_color "$tone"
  fit_text_rtrim "$line" "$cols"
  usage_tone_reset
  printf '\n'
}

profile_list_summary() {
  local count="$1"
  local active_name="$2"
  local alias_count="$3"
  local total_w="$4"
  local summary="profiles $count"
  local active_summary active_label active_short active_tiny alias_summary sep

  if [[ -n "$active_name" ]]; then
    sep="$(usage_separator)"
    active_short="$(usage_display_profile_name "$active_name" "" 6)"
    active_tiny="$(usage_display_profile_name "$active_name" "" 3)"
    for active_label in "active $active_name" "act $active_name" "act $active_short" "act $active_tiny"; do
      active_summary="$summary$sep$active_label"
      if (( ${#active_summary} <= total_w )); then
        summary="$active_summary"
        break
      fi
    done
  fi
  if (( alias_count > 0 )); then
    alias_summary="$summary$(usage_separator)aliases $alias_count"
    if (( ${#alias_summary} <= total_w )); then
      summary="$alias_summary"
    fi
  fi

  printf '%s' "$summary"
}

cmd_list() {
  ensure_dirs
  local list_verbose=0
  while (( $# > 0 )); do
    case "$1" in
      --verbose|-v)
        list_verbose=1
        shift
        ;;
      *)
        die "usage: codex-auth list [-v]"
        ;;
    esac
  done

  shopt -s nullglob
  local profiles=("$PROFILE_DIR"/*.json)
  if (( ${#profiles[@]} == 0 )); then
    print_empty_profiles
    return 0
  fi

  local active_fp=""
  local path name mode hint fp action active_name="" count=0
  local alias_count=0
  local meta_path secret
  local meta_files=()
  local -A account_primary=()
  local -A account_count=()
  local -A profile_mode=()
  local -A profile_hint=()
  local -A profile_fp=()

  [[ -f "$AUTH_FILE" ]] && meta_files+=("$AUTH_FILE")
  meta_files+=("${profiles[@]}")
  while IFS=$'\037' read -r meta_path mode hint secret; do
    [[ -n "$meta_path" ]] || continue
    if [[ -n "$secret" && ! "$secret" =~ ^[0-9a-f]{64}$ ]]; then
      fp="$(fingerprint_secret "$secret")"
    elif [[ -n "$secret" ]]; then
      fp="$secret"
    else
      fp="$(fingerprint_secret "")"
    fi
    if [[ "$meta_path" == "$AUTH_FILE" ]]; then
      active_fp="$fp"
    else
      name="$(basename "$meta_path" .json)"
      profile_mode["$name"]="$mode"
      profile_hint["$name"]="$hint"
      profile_fp["$name"]="$fp"
    fi
  done < <(auth_metadata_records "${meta_files[@]}")

  PROFILE_LIST_WIDTH_HINT=12
  for path in "${profiles[@]}"; do
    name="$(basename "$path" .json)"
    (( ${#name} > PROFILE_LIST_WIDTH_HINT )) && PROFILE_LIST_WIDTH_HINT="${#name}"
    mode="${profile_mode["$name"]:-unknown}"
    hint="${profile_hint["$name"]:-}"
    fp="${profile_fp["$name"]:-}"
    if [[ -z "$active_name" && -n "$active_fp" && "$fp" == "$active_fp" ]]; then
      active_name="$name"
    fi
    if [[ -n "$hint" ]]; then
      account_count["$hint"]=$(( ${account_count["$hint"]:-0} + 1 ))
      if (( account_count["$hint"] > 1 )); then
        alias_count=$((alias_count + 1))
      fi
      if [[ -z "${account_primary["$hint"]:-}" || ( "${account_primary["$hint"]:-}" == "current" && "$name" != "current" ) ]]; then
        account_primary["$hint"]="$name"
      fi
    fi
    count=$((count + 1))
  done

  local cols role_w profile_w mode_w account_w total_w summary account_display alias_of
  cols="$(terminal_width)"
  USAGE_COLOR_ENABLED=0
  color_enabled && USAGE_COLOR_ENABLED=1
  USAGE_VERBOSE="$list_verbose"
  IFS=$'\t' read -r role_w profile_w mode_w account_w <<<"$(profile_list_widths "$cols")"
  total_w=$((role_w + 1 + profile_w + 1 + mode_w + 1 + account_w))

  summary="$(profile_list_summary "$count" "$active_name" "$alias_count" "$total_w")"
  print_palette_summary_header "Auth" "Saved profiles" "$summary" "$total_w"
  local role_header profile_header
  role_header="$(compact_width_choice "$role_w" 2 "" "act")"
  profile_header="$(compact_width_choice "$profile_w" 7 "prof" "profile")"
  print_profile_list_line "$role_header" "$profile_header" "auth" "account" "$role_w" "$profile_w" "$mode_w" "$account_w"

  for path in "${profiles[@]}"; do
    name="$(basename "$path" .json)"
    mode="${profile_mode["$name"]:-unknown}"
    hint="${profile_hint["$name"]:-}"
    fp="${profile_fp["$name"]:-}"
    alias_of=""
    if [[ -n "$hint" && "${account_count["$hint"]:-0}" -gt 1 && "$name" != "${account_primary["$hint"]:-}" ]]; then
      alias_of="${account_primary["$hint"]}"
    fi
    action="use"
    if [[ -n "$active_name" && "$name" == "$active_name" ]]; then
      action="stay"
    elif [[ -n "$alias_of" ]]; then
      action="alias"
    elif [[ -n "$active_fp" && "$fp" == "$active_fp" ]]; then
      action="alias"
    fi
    account_display="$(profile_account_display "$hint" "$account_w" "$list_verbose" "$alias_of")"
    print_profile_list_line "$(profile_list_action_label "$action" "$role_w")" "$name" "$mode" "$account_display" "$role_w" "$profile_w" "$mode_w" "$account_w"
  done
}

cmd_current() {
  ensure_dirs
  local cols label_w value_w total_w
  cols="$(terminal_width)"
  IFS=$'\t' read -r label_w value_w <<<"$(detail_widths "$cols")"
  if (( cols < 68 )); then
    label_w=7
    value_w=$((cols - label_w - 1))
    (( value_w < 10 )) && value_w=10
  fi
  total_w=$((label_w + 1 + value_w))
  USAGE_COLOR_ENABLED=0
  color_enabled && USAGE_COLOR_ENABLED=1

  if [[ ! -f "$AUTH_FILE" ]]; then
    print_no_active_auth
    return 0
  fi
  if ! auth_file_is_valid "$AUTH_FILE"; then
    print_bad_active_auth
    return 0
  fi

  local active_fp mode mode_display mode_summary_display matched matched_display hint account_display summary status_text codex_cli show_account show_codex
  local path fp meta_path secret meta_mode meta_hint active_mode="" active_hint=""
  local meta_files=()
  local -A meta_fp=()

  shopt -s nullglob
  meta_files+=("$AUTH_FILE")
  for path in "$PROFILE_DIR"/*.json; do
    meta_files+=("$path")
  done
  while IFS=$'\037' read -r meta_path meta_mode meta_hint secret; do
    [[ -n "$meta_path" ]] || continue
    if [[ -n "$secret" && ! "$secret" =~ ^[0-9a-f]{64}$ ]]; then
      fp="$(fingerprint_secret "$secret")"
    elif [[ -n "$secret" ]]; then
      fp="$secret"
    else
      fp="$(fingerprint_secret "")"
    fi
    meta_fp["$meta_path"]="$fp"
    if [[ "$meta_path" == "$AUTH_FILE" ]]; then
      active_fp="$fp"
      active_mode="${meta_mode:-unknown}"
      active_hint="${meta_hint:-}"
    fi
  done < <(auth_metadata_records "${meta_files[@]}")
  mode="${active_mode:-unknown}"
  mode_display="$(auth_mode_display_label "$mode")"
  mode_summary_display="$mode_display"
  if (( total_w < 24 )); then
    mode_summary_display="$(profile_list_mode_label "$mode" 4)"
  fi
  hint="${active_hint:-}"
  active_fp="${active_fp:-}"
  account_display="$(short_account_hint "$hint" "$value_w")"
  matched=""

  for path in "$PROFILE_DIR"/*.json; do
    fp="${meta_fp["$path"]:-}"
    if [[ -n "$active_fp" && "$fp" == "$active_fp" ]]; then
      matched="$(basename "$path" .json)"
      break
    fi
  done

  matched_display="$matched"
  if [[ -n "$matched_display" && "$total_w" -lt 22 ]]; then
    matched_display="$(usage_display_profile_name "$matched_display" "" 6)"
  fi
  if [[ -n "$matched" ]]; then
    summary="active $matched_display$(usage_separator)$mode_summary_display"
  else
    if (( total_w < 22 )); then
      summary="unsaved$(usage_separator)$mode_summary_display"
    else
      summary="active unsaved$(usage_separator)$mode_summary_display"
    fi
  fi
  if [[ -n "$hint" ]] && (( ${#summary} + ${#account_display} + 11 <= total_w )); then
    summary+="$(usage_separator)account $account_display"
  fi

  show_account=0
  show_codex=0
  [[ -n "$hint" && "$summary" != *"account "* ]] && show_account=1

  codex_cli="$(codex_bin || true)"
  if [[ -n "$codex_cli" ]] && codex_launcher_ready "$codex_cli"; then
    status_text="$(CODEX_AUTH_RUNNER=1 "$codex_cli" login status 2>&1 || true)"
    status_text="$(printf '%s\n' "$status_text" | sed '/^WARNING: proceeding, even though we could not update PATH:/d' | tr '\n\t' '  ' | sed 's/  */ /g; s/^ //; s/ $//')"
    status_text="$(compact_codex_status "$status_text" "$value_w")"
    if [[ -n "$status_text" && "$status_text" != "$mode_display" ]]; then
      show_codex=1
    fi
  fi

  print_palette_summary_header "Auth" "Active profile" "$summary" "$total_w" flat 0
  if (( show_account )); then
    print_detail_line "account" "$account_display" "$label_w" "$value_w"
  fi

  if (( show_codex )); then
    print_detail_text_line "codex" "$status_text" "$label_w" "$value_w"
  fi
}

cmd_save() {
  local name="$1"
  local source="${2:-$AUTH_FILE}"
  local summary="${3:-saved $name}"
  require_name "$name"
  ensure_dirs
  acquire_mutation_lock
  if [[ "$source" == "$AUTH_FILE" && ! -f "$source" ]]; then
    die "no active auth to save"
  fi
  require_auth_file "$source"

  local dest
  dest="$(profile_path "$name")"
  copy_auth_file_atomic "$source" "$dest"
  print_result_block "$summary" \
    "profile"$'\t'"$(display_path "$dest")"$'\t'"active" \
    "source"$'\t'"$(display_path "$source")"$'\t'"muted"
}

cmd_import() {
  local name="$1"
  local source="$2"
  cmd_save "$name" "$source" "imported $name"
}

cmd_use() {
  local name="$1"
  require_name "$name"
  ensure_dirs
  acquire_mutation_lock

  local source source_fp="" active_fp=""
  source="$(profile_path "$name")"
  [[ -f "$source" ]] || die "profile not found: $name"
  require_auth_file "$source"

  source_fp="$(credential_fingerprint "$source" || true)"
  if [[ -f "$AUTH_FILE" ]]; then
    active_fp="$(credential_fingerprint "$AUTH_FILE" || true)"
  fi
  if [[ -n "$source_fp" && -n "$active_fp" && "$source_fp" == "$active_fp" ]]; then
    print_result_block "active $name" \
      "auth"$'\t'"$(display_path "$AUTH_FILE")"$'\t'"active" \
      "profile"$'\t'"$(display_path "$source")"$'\t'"muted" \
      "active"$'\t'"already active"$'\t'"active"
    return 0
  fi

  local backup=""
  backup="$(backup_current "pre-use-$name" || true)"
  copy_auth_file_atomic "$source" "$AUTH_FILE"

  if [[ -n "$backup" ]]; then
    print_result_block "active $name" \
      "auth"$'\t'"$(display_path "$AUTH_FILE")"$'\t'"active" \
      "profile"$'\t'"$(display_path "$source")"$'\t'"muted" \
      "backup"$'\t'"$(display_path "$backup")"$'\t'"muted"
  else
    print_result_block "active $name" \
      "auth"$'\t'"$(display_path "$AUTH_FILE")"$'\t'"active" \
      "profile"$'\t'"$(display_path "$source")"$'\t'"muted"
  fi
}

cmd_login() {
  local name="$1"
  shift || true
  require_name "$name"
  [[ -t 0 && -t 1 ]] || die "login needs tty"
  local codex_cli
  codex_cli="$(codex_bin)" || die "codex command not found"
  require_codex_launcher "$codex_cli"
  ensure_dirs
  acquire_mutation_lock

  local backup=""
  backup="$(backup_current "pre-login-$name" || true)"

  local hidden_auth=""
  if [[ -f "$AUTH_FILE" ]]; then
    hidden_auth="$(reserve_unique_backup_path "hidden-for-login-$name")"
    if ! mv "$AUTH_FILE" "$hidden_auth"; then
      rm -f "$hidden_auth"
      die "could not hide active auth for login"
    fi
    chmod 600 "$hidden_auth"
  fi

  if ! CODEX_AUTH_RUNNER=1 "$codex_cli" login "$@"; then
    if restore_hidden_auth "$hidden_auth"; then
      print_error "login failed; restored previous auth"
    else
      print_error "login failed"
    fi
    exit 1
  fi

  if ! auth_file_is_valid "$AUTH_FILE"; then
    if restore_hidden_auth "$hidden_auth"; then
      print_error "login did not produce valid auth; restored previous auth"
    else
      print_error "login did not produce valid auth"
    fi
    exit 1
  fi

  cmd_save "$name" "$AUTH_FILE" "login $name"
  rm -f "$hidden_auth"
}

cmd_add() {
  local name="${1:-}"
  [[ -n "$name" ]] || die "usage: codex-auth add <name> [--current | --file <file> | codex login args...]"
  shift || true
  require_name "$name"

  local source=""
  local source_seen=0
  local login_args=()
  while (( $# > 0 )); do
    case "$1" in
      --current)
        (( source_seen == 0 )) || die "add accepts one source: --current or --file"
        source="$AUTH_FILE"
        source_seen=1
        shift
        ;;
      --file|--from)
        [[ -n "${2:-}" ]] || die "usage: codex-auth add <name> --file <file>"
        (( source_seen == 0 )) || die "add accepts one source: --current or --file"
        source="$2"
        source_seen=1
        shift 2
        ;;
      --)
        shift
        login_args+=("$@")
        break
        ;;
      *)
        if [[ -f "$1" && -z "$source" ]]; then
          source="$1"
          source_seen=1
        else
          login_args+=("$1")
        fi
        shift
        ;;
    esac
  done

  if [[ -n "$source" ]]; then
    (( ${#login_args[@]} == 0 )) || die "add cannot mix --file/--current with login args"
    cmd_save "$name" "$source"
    return 0
  fi

  cmd_login "$name" "${login_args[@]}"
}

cmd_export() {
  local name="$1"
  local dest="$2"
  require_name "$name"
  ensure_dirs

  local source dest_dir
  source="$(profile_path "$name")"
  [[ -f "$source" ]] || die "profile not found: $name"
  require_auth_file "$source"
  dest_dir="$(dirname "$dest")"
  [[ -d "$dest_dir" ]] || die "export dir missing: $dest_dir"
  [[ ! -d "$dest" ]] || die "export path is a directory: $dest"
  copy_auth_file_atomic "$source" "$dest"
  print_result_block "export $name" \
    "dest"$'\t'"$(display_path "$dest")"$'\t'"active" \
    "source"$'\t'"$(display_path "$source")"$'\t'"muted"
}

format_reset_time() {
  local epoch="${1:-}"
  if [[ -z "$epoch" || "$epoch" == "-" || "$epoch" == "null" || "$epoch" == "0" ]]; then
    printf '-'
    return 0
  fi
  TZ="${TZ:-America/Chicago}" date -d "@$epoch" '+%m-%d %H:%M' 2>/dev/null || printf '-'
}

now_epoch() {
  date +%s
}

window_label() {
  local mins="${1:-}"
  if [[ ! "$mins" =~ ^[0-9]+$ || "$mins" == "0" ]]; then
    printf 'short'
  elif (( mins % 1440 == 0 )); then
    printf '%dd' "$((mins / 1440))"
  elif (( mins >= 60 && mins % 60 >= 55 )); then
    printf '%dh' "$(((mins + 59) / 60))"
  elif (( mins % 60 == 0 )); then
    printf '%dh' "$((mins / 60))"
  else
    printf '%dm' "$mins"
  fi
}

color_enabled() {
  [[ -t 1 && -z "${NO_COLOR:-}" ]]
}

usage_color_active() {
  [[ "${USAGE_COLOR_ENABLED:-0}" == "1" ]]
}

terminal_width() {
  local cols
  cols="${COLUMNS:-}"
  if [[ ! "$cols" =~ ^[0-9]+$ ]]; then
    cols="$(tput cols 2>/dev/null || true)"
  fi
  [[ "$cols" =~ ^[0-9]+$ ]] || cols=100
  (( cols < 20 )) && cols=20
  printf '%s\n' "$cols"
}

strip_ansi() {
  LC_ALL=C sed $'s/\033\\[[0-9;]*m//g' <<<"${1:-}"
}

ansi_visible_length() {
  local plain
  plain="$(strip_ansi "${1:-}")"
  printf '%s' "${#plain}"
}

repeat_glyph() {
  local glyph="$1"
  local width="${2:-0}"
  local i

  for ((i = 0; i < width; i++)); do
    printf '%s' "$glyph"
  done
}

usage_unicode_enabled() {
  [[ "${CODEX_AUTH_ASCII:-0}" != "1" ]]
}

usage_rule_glyph() {
  if usage_unicode_enabled; then
    printf '─'
  else
    printf '-'
  fi
}

usage_meta_glyph() {
  if usage_unicode_enabled; then
    printf '·'
  else
    printf '.'
  fi
}

usage_active_glyph() {
  if usage_unicode_enabled; then
    printf '●'
  else
    printf '*'
  fi
}

usage_best_glyph() {
  if usage_unicode_enabled; then
    printf '◆'
  else
    printf '+'
  fi
}

usage_reset_glyph() {
  if usage_unicode_enabled; then
    printf '↺'
  fi
}

usage_separator() {
  if usage_unicode_enabled; then
    printf ' · '
  else
    printf ' | '
  fi
}

usage_trunc_glyph() {
  if usage_unicode_enabled; then
    printf '…'
  else
    printf '~'
  fi
}

fit_text() {
  local text="$1"
  local width="$2"
  local length=${#text}
  local trunc_glyph

  if (( width <= 0 )); then
    return 0
  fi
  trunc_glyph="$(usage_trunc_glyph)"
  if (( length <= width )); then
    printf '%-*s' "$width" "$text"
  elif (( width == 1 )); then
    printf '%s' "$trunc_glyph"
  else
    printf '%s%s' "${text:0:width-1}" "$trunc_glyph"
  fi
}

rtrim_spaces() {
  local text="$1"

  while [[ "$text" == *" " ]]; do
    text="${text% }"
  done
  printf '%s' "$text"
}

fit_text_rtrim() {
  local rendered

  rendered="$(fit_text "$1" "$2")"
  rtrim_spaces "$rendered"
}

fit_text_center() {
  local text="$1"
  local width="$2"
  local rendered left right

  if (( width <= 0 )); then
    return 0
  fi

  rendered="$(fit_text_rtrim "$text" "$width")"
  left=$(((width - ${#rendered} + 1) / 2))
  right=$((width - ${#rendered} - left))
  (( left > 0 )) && printf '%*s' "$left" ''
  printf '%s' "$rendered"
  (( right > 0 )) && printf '%*s' "$right" ''
  return 0
}

fit_profile_text() {
  local text="$1"
  local width="$2"
  local length=${#text}
  local trunc_glyph left right rendered pad

  if (( width <= 0 )); then
    return 0
  fi
  if (( length <= width || width < 3 )); then
    fit_text "$text" "$width"
    return 0
  fi

  trunc_glyph="$(usage_trunc_glyph)"
  if (( width <= 5 )); then
    left=2
  elif (( width <= 8 )); then
    left=3
  else
    left=$(((width - 1) / 2))
  fi
  right=$((width - left - 1))
  (( right < 1 )) && right=1
  (( left + right + 1 > width )) && left=$((width - right - 1))

  rendered="${text:0:left}${trunc_glyph}${text:length-right:right}"
  printf '%s' "$rendered"
  pad=$((width - ${#rendered}))
  (( pad > 0 )) && printf '%*s' "$pad" ''
  return 0
}

fit_profile_text_rtrim() {
  local rendered

  rendered="$(fit_profile_text "$1" "$2")"
  rtrim_spaces "$rendered"
}

usage_tone_color() {
  local tone="${1:-}"

  if ! usage_color_active; then
    return 0
  fi

  case "$tone" in
    good)
      printf '\033[38;2;166;227;161m'
      ;;
    warn)
      printf '\033[38;2;250;178;131m'
      ;;
    active)
      printf '\033[38;2;157;124;216m'
      ;;
    bad)
      printf '\033[38;2;224;108;117m'
      ;;
    accent)
      printf '\033[38;2;250;178;131m'
      ;;
    secondary)
      printf '\033[38;2;157;124;216m'
      ;;
    border)
      printf '\033[38;2;50;50;50m'
      ;;
    track_edge)
      printf '\033[38;2;16;16;16m'
      ;;
    muted)
      printf '\033[38;2;128;128;128m'
      ;;
  esac
  return 0
}

usage_tone_reset() {
  if usage_color_active; then
    printf '\033[0m'
  fi
  return 0
}

usage_tone_bg() {
  local tone="${1:-}"

  if ! usage_color_active; then
    return 0
  fi

  case "$tone" in
    good)
      printf '\033[48;2;166;227;161m'
      ;;
    warn)
      printf '\033[48;2;250;178;131m'
      ;;
    active)
      printf '\033[48;2;157;124;216m'
      ;;
    bad)
      printf '\033[48;2;224;108;117m'
      ;;
    accent)
      printf '\033[48;2;250;178;131m'
      ;;
    track)
      printf '\033[48;2;35;35;35m'
      ;;
    track_edge)
      printf '\033[48;2;16;16;16m'
      ;;
  esac
  return 0
}

usage_limit_tone() {
  local percent="${1:-}"
  local value

  percent="${percent%\%}"
  if [[ ! "$percent" =~ ^-?[0-9]+$ ]]; then
    printf 'muted'
    return 0
  fi

  value="$percent"
  if (( value <= 0 )); then
    printf 'bad'
  elif (( value < 25 )); then
    printf 'bad'
  elif (( value < 50 )); then
    printf 'warn'
  else
    printf 'good'
  fi
}

usage_role_tone() {
  case "${1:-}" in
    best|b|◆|+)
      printf 'accent'
      ;;
    active|stay|s|●|\*)
      printf 'active'
      ;;
    use|u)
      printf 'good'
      ;;
    same|a)
      printf 'muted'
      ;;
    cap|c)
      printf 'bad'
      ;;
    login|l)
      printf 'warn'
      ;;
    *)
      printf 'muted'
      ;;
  esac
}

usage_status_tone() {
  local status="${1:-}"
  local valid="${2:-0}"

  if [[ "$status" == "offline" || "$status" == "refresh timeout" || "$status" == "refresh unavailable" ]]; then
    printf 'warn'
  elif [[ "$valid" != "0" || "$status" == "login" ]]; then
    printf 'muted'
  elif [[ "$status" == stale* ]]; then
    printf 'warn'
  elif [[ "$status" == "ok" ]]; then
    printf 'good'
  elif [[ "$status" == *cap* ]]; then
    printf 'bad'
  else
    printf 'bad'
  fi
}

usage_group_tone() {
  case "${1:-}" in
    limited|cap)
      printf 'bad'
      ;;
    login|offline)
      printf 'warn'
      ;;
    ready)
      printf 'good'
      ;;
    *)
      printf 'muted'
      ;;
  esac
}

print_toned_fit() {
  local text="$1"
  local width="$2"
  local tone="${3:-}"

  usage_tone_color "$tone"
  fit_text "$text" "$width"
  usage_tone_reset
}

print_toned_fit_rtrim() {
  local text="$1"
  local width="$2"
  local tone="${3:-}"

  usage_tone_color "$tone"
  fit_text_rtrim "$text" "$width"
  usage_tone_reset
}

print_toned_fit_center_rtrim() {
  local text="$1"
  local width="$2"
  local tone="${3:-}"
  local rendered

  rendered="$(fit_text_center "$text" "$width")"
  usage_tone_color "$tone"
  rtrim_spaces "$rendered"
  usage_tone_reset
}

print_toned_fit_center() {
  local text="$1"
  local width="$2"
  local tone="${3:-}"

  usage_tone_color "$tone"
  fit_text_center "$text" "$width"
  usage_tone_reset
}

usage_section_label() {
  case "${1:-}" in
    limited)
      printf 'limits'
      ;;
    login)
      printf 'auth'
      ;;
    stale)
      printf 'stale cache'
      ;;
    offline)
      printf 'offline'
      ;;
    unavailable)
      printf 'no data'
      ;;
    *)
      printf '%s' "${1:-}"
      ;;
  esac
}

usage_record_group() {
  local valid="${1:-0}"
  local status="${2:-}"

  if [[ "$status" == "offline" ]]; then
    printf 'offline'
  elif [[ "$status" == "login" ]]; then
    printf 'login'
  elif [[ "$valid" != "0" || "$status" == "no data" || "$status" == "no usage" ]]; then
    printf 'unavailable'
  elif [[ "$status" == stale* ]]; then
    printf 'stale'
  elif [[ "$status" == "ok" ]]; then
    printf 'ready'
  else
    printf 'limited'
  fi
}

usage_section_rule() {
  local width="$1"
  local label="${2:-}"
  local text remaining rule_glyph
  rule_glyph="$(usage_rule_glyph)"

  if [[ -n "$label" ]]; then
    printf '%s' "$(usage_section_label "$label")"
  else
    repeat_glyph "$rule_glyph" "$width"
  fi
}

print_usage_section_rule() {
  local width="$1"
  local label="${2:-}"

  usage_tone_color "$(usage_group_tone "$label")"
  usage_section_rule "$width" "$label"
  usage_tone_reset
  printf '\n'
}

usage_show_group_label() {
  case "${1:-}" in
    ready|limited)
      return 1
      ;;
    *)
      return 0
      ;;
  esac
}

usage_bar() {
  local percent="${1:-}"
  local width="${2:-8}"
  local value units full partial empty_count i
  local filled_glyph="█"
  local empty_glyph="░"
  local partial_glyphs=("" "▏" "▎" "▍" "▌" "▋" "▊" "▉")

  if [[ "${CODEX_AUTH_ASCII:-0}" == "1" ]]; then
    percent="${percent%\%}"
    if [[ ! "$percent" =~ ^-?[0-9]+$ ]]; then
      repeat_glyph "." "$width"
      return 0
    fi
    value="$percent"
    (( value < 0 )) && value=0
    (( value > 100 )) && value=100
    if (( width == 1 )); then
      if (( value <= 0 )); then
        printf '.'
      elif (( value >= 100 )); then
        printf '#'
      else
        printf '+'
      fi
      return 0
    fi
    full=$(((value * width + 50) / 100))
    (( full > width )) && full="$width"
    repeat_glyph "#" "$full"
    repeat_glyph "." "$((width - full))"
    return 0
  fi

  percent="${percent%\%}"
  if [[ ! "$percent" =~ ^-?[0-9]+$ ]]; then
    repeat_glyph "$empty_glyph" "$width"
    return 0
  fi

  value="$percent"
  (( value < 0 )) && value=0
  (( value > 100 )) && value=100
  units=$(((value * width * 8 + 50) / 100))
  full=$((units / 8))
  partial=$((units % 8))
  if (( full >= width )); then
    full="$width"
    partial=0
  fi
  empty_count=$((width - full))
  (( partial > 0 && empty_count > 0 )) && empty_count=$((empty_count - 1))

  repeat_glyph "$filled_glyph" "$full"
  (( partial > 0 )) && printf '%s' "${partial_glyphs[$partial]}"
  repeat_glyph "$empty_glyph" "$empty_count"
}

usage_bar_rail() {
  local percent="$1"
  local width="$2"
  local tone="${3:-}"
  local inner_w left_rail right_rail

  if (( width < 3 )); then
    usage_tone_color "$tone"
    usage_bar "$percent" "$width"
    usage_tone_reset
    return 0
  fi

  inner_w=$((width - 2))
  if usage_unicode_enabled; then
    left_rail="▕"
    right_rail="▐"
  else
    left_rail="["
    right_rail="]"
  fi

  usage_tone_color muted
  printf '%s' "$left_rail"
  usage_tone_reset
  usage_tone_color "$tone"
  usage_bar "$percent" "$inner_w"
  usage_tone_reset
  usage_tone_color muted
  printf '%s' "$right_rail"
  usage_tone_reset
}

usage_role_profile_gap() {
  local role_w="${1:-0}"

  if (( role_w > 1 )); then
    printf '2'
  else
    printf '1'
  fi
}

usage_metric_status_gap() {
  local role_w="${1:-0}"

  if (( role_w > 1 )); then
    printf '2'
  else
    printf '1'
  fi
}

usage_render_total_width() {
  local role_w="$1"
  local profile_w="$2"
  local cell_w="$3"
  local status_w="$4"
  local role_profile_gap status_gap

  role_profile_gap="$(usage_role_profile_gap "$role_w")"
  status_gap="$(usage_metric_status_gap "$role_w")"
  if (( status_w > 0 )); then
    printf '%s' "$((role_w + role_profile_gap + profile_w + 1 + cell_w + 1 + cell_w + status_gap + status_w))"
  else
    printf '%s' "$((role_w + role_profile_gap + profile_w + 1 + cell_w + 1 + cell_w))"
  fi
}

usage_static_render_columns() {
  local cols
  local max_cols=120

  cols="$(terminal_width)"
  (( USAGE_VERBOSE )) && max_cols=132
  if (( cols > max_cols )); then
    cols="$max_cols"
  fi
  printf '%s' "$cols"
}

clamp_int_between() {
  local value="$1"
  local min="$2"
  local max="$3"

  if (( value < min )); then
    printf '%s' "$min"
  elif (( value > max )); then
    printf '%s' "$max"
  else
    printf '%s' "$value"
  fi
}

usage_profile_width_hint() {
  local cols="$1"
  local wanted="$2"
  local verbose="${3:-0}"
  local row row_verbose threshold min_w max_w
  local rows=(
    "1 112 18 28"
    "1 94 14 24"
    "1 0 12 24"
    "0 112 20 30"
    "0 94 18 28"
    "0 72 14 24"
    "0 0 12 24"
  )

  if [[ ! "$wanted" =~ ^[0-9]+$ ]]; then
    wanted=12
  fi

  for row in "${rows[@]}"; do
    read -r row_verbose threshold min_w max_w <<<"$row"
    if (( verbose == row_verbose && cols >= threshold )); then
      clamp_int_between "$wanted" "$min_w" "$max_w"
      return 0
    fi
  done
}

usage_width_mode_defaults() {
  local cols="$1"
  local verbose="${2:-0}"
  local row row_min row_max row_verbose
  local mode role_w profile_min status_min reset_w label_w min_bar_w max_bar_w
  local rows=(
    "0 25 -1 pico 1 4 3 0 4 0 0"
    "26 39 -1 nano 1 5 3 0 4 0 0"
    "40 49 -1 micro 1 8 5 0 4 3 8"
    "50 59 -1 tiny 1 8 5 5 4 3 8"
    "60 71 -1 tight 6 8 7 5 4 4 8"
    "72 93 1 compact 6 8 12 5 4 5 12"
    "72 93 0 normal 6 8 12 11 4 4 16"
    "94 111 1 normal 7 8 12 11 4 4 18"
    "94 111 0 normal 7 8 12 11 4 4 20"
    "112 9999 1 wide 7 8 12 11 4 4 18"
    "112 9999 0 wide 7 8 12 11 4 4 22"
  )

  for row in "${rows[@]}"; do
    read -r row_min row_max row_verbose mode role_w profile_min status_min reset_w label_w min_bar_w max_bar_w <<<"$row"
    if (( cols >= row_min && cols <= row_max )); then
      if (( row_verbose < 0 || row_verbose == verbose )); then
        break
      fi
    fi
  done

  if (( verbose && cols >= 68 )) && [[ "$mode" == "tight" ]]; then
    status_min=12
  fi
  if (( ! verbose )); then
    if (( cols >= 61 )); then
      role_w=5
      status_min=12
    else
      role_w=1
    fi
  fi
  if (( verbose )) && [[ "$mode" != "pico" && "$mode" != "nano" && "$mode" != "micro" && "$mode" != "tiny" && "$mode" != "tight" ]]; then
    label_w=6
    max_bar_w=12
    if (( cols >= 112 )); then
      max_bar_w=20
    elif (( cols >= 94 )); then
      max_bar_w=14
    fi
  fi

  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$mode" "$role_w" "$profile_min" "$status_min" "$reset_w" "$label_w" "$min_bar_w" "$max_bar_w"
}

print_usage_limit_cell() {
  local percent="$1"
  local reset_time="$2"
  local mode="$3"
  local bar_width="$4"
  local cell_w="$5"
  local used_percent="${6:-}"
  local reset_label="$reset_time"
  local percent_label="$percent"
  local reset_prefix=""
  local label_w=4
  local tone visible pad

  if [[ "$mode" == "micro" || "$mode" == "nano" ]]; then
    reset_label=""
  elif [[ ( "$mode" == "compact" || "$mode" == "tight" || "$mode" == "tiny" ) && "$reset_label" == *" "* ]]; then
    reset_label="${reset_label##* }"
  fi
  if (( ! USAGE_VERBOSE )); then
    reset_label=""
  fi

  if [[ "$percent" == "-" ]]; then
    percent_label="$(usage_meta_glyph)"
    [[ "$mode" == "micro" || "$mode" == "nano" ]] || reset_label="$(usage_meta_glyph)"
  elif (( USAGE_VERBOSE )) && [[ "$mode" != "pico" && "$mode" != "nano" && "$mode" != "micro" && "$mode" != "tiny" && "$mode" != "tight" && "$used_percent" =~ ^[0-9]+$ ]]; then
    percent_label="${percent%\%}/${used_percent}%"
    label_w=6
  elif (( ! USAGE_VERBOSE )); then
    percent_label="${percent%\%}"
  elif [[ -n "$reset_label" ]]; then
    reset_prefix="$(usage_reset_glyph)"
  fi
  if [[ -n "$reset_label" && -z "$reset_prefix" && "$percent" != "-" ]]; then
    reset_prefix="$(usage_reset_glyph)"
  fi

  tone="$(usage_limit_tone "$percent")"
  if [[ "$mode" == "pico" || "$mode" == "nano" ]]; then
    [[ "$percent" == "-" ]] && percent_label="$(usage_meta_glyph)"
    usage_tone_color "$tone"
    fit_text_center "$percent_label" "$cell_w"
    usage_tone_reset
    return 0
  fi

  if [[ "$percent" == "-" ]]; then
    usage_tone_color "$tone"
    printf "%${label_w}s" "$percent_label"
    usage_tone_reset
    visible="$label_w"
    if [[ -n "$reset_label" ]]; then
      usage_tone_color muted
      printf ' %s' "$reset_label"
      usage_tone_reset
      visible=$((visible + 1 + ${#reset_label}))
    fi
    pad=$((cell_w - visible))
    (( pad > 0 )) && printf '%*s' "$pad" ''
    return 0
  fi

  usage_tone_color "$tone"
  printf "%${label_w}s " "$percent_label"
  usage_tone_reset
  usage_bar_rail "$percent" "$bar_width" "$tone"
  visible=$((label_w + 1 + bar_width))
  if [[ -n "$reset_label" ]]; then
    usage_tone_color muted
    if [[ -n "$reset_prefix" ]]; then
      printf ' %s%s' "$reset_prefix" "$reset_label"
      visible=$((visible + 1 + ${#reset_prefix} + ${#reset_label}))
    else
      printf ' %s' "$reset_label"
      visible=$((visible + 1 + ${#reset_label}))
    fi
    usage_tone_reset
  fi

  pad=$((cell_w - visible))
  (( pad > 0 )) && printf '%*s' "$pad" ''
  return 0
}

usage_render_widths() {
  local cols="$1"
  local mode role_w
  local show_status="${CODEX_AUTH_USAGE_STATUS:-0}"
  local profile_w
  local wanted_profile_w="${USAGE_PROFILE_WIDTH_HINT:-12}"
  local profile_min status_min reset_w label_w min_bar_w max_bar_w
  local cell_overhead reset_prefix_w=0
  local cell_w status_w status_max bar_width available max_profile_w
  local role_profile_gap=1 status_gap=1 gap_w=4

  wanted_profile_w="$(usage_profile_width_hint "$cols" "$wanted_profile_w" "$USAGE_VERBOSE")"
  IFS=$'\t' read -r mode role_w profile_min status_min reset_w label_w min_bar_w max_bar_w <<<"$(usage_width_mode_defaults "$cols" "$USAGE_VERBOSE")"
  role_profile_gap="$(usage_role_profile_gap "$role_w")"
  status_gap="$(usage_metric_status_gap "$role_w")"
  if [[ "$show_status" != "1" ]]; then
    status_min=0
    status_gap=0
  fi
  gap_w=$((role_profile_gap + 2 + status_gap))
  if (( ! USAGE_VERBOSE )); then
    reset_w=0
  fi
  if (( reset_w > 0 )) && usage_unicode_enabled; then
    reset_prefix_w=1
  fi
  if [[ "$mode" == "pico" ]]; then
    cell_overhead="$label_w"
  elif (( reset_w > 0 )); then
    cell_overhead=$((label_w + 2 + reset_w + reset_prefix_w))
  else
    cell_overhead=$((label_w + 1))
  fi

  max_profile_w=$(( cols - role_w - status_min - (2 * (cell_overhead + min_bar_w)) - gap_w ))
  if (( max_profile_w < 12 && reset_w > 5 )); then
    mode="tight"
    reset_w=5
    label_w=4
    if usage_unicode_enabled; then
      reset_prefix_w=1
    else
      reset_prefix_w=0
    fi
    if (( reset_w > 0 )); then
      cell_overhead=$((label_w + 2 + reset_w + reset_prefix_w))
    else
      cell_overhead=$((label_w + 1))
    fi
    max_profile_w=$(( cols - role_w - status_min - (2 * (cell_overhead + min_bar_w)) - gap_w ))
  fi

  profile_w="$wanted_profile_w"
  (( profile_w > max_profile_w )) && profile_w="$max_profile_w"
  (( profile_w < profile_min )) && profile_w="$profile_min"

  available=$(( cols - role_w - profile_w - status_min - gap_w ))
  cell_w=$(( available / 2 ))
  bar_width=$(( cell_w - cell_overhead ))
  (( bar_width < min_bar_w )) && bar_width="$min_bar_w"
  (( bar_width > max_bar_w )) && bar_width="$max_bar_w"
  cell_w=$(( bar_width + cell_overhead ))
  status_w=$(( cols - role_w - profile_w - cell_w - cell_w - gap_w ))
  while (( status_w < status_min && bar_width > min_bar_w )); do
    bar_width=$((bar_width - 1))
    cell_w=$(( bar_width + cell_overhead ))
    status_w=$(( cols - role_w - profile_w - cell_w - cell_w - gap_w ))
  done
  while (( status_w < status_min && profile_w > profile_min )); do
    profile_w=$((profile_w - 1))
    status_w=$(( cols - role_w - profile_w - cell_w - cell_w - gap_w ))
  done
  (( status_w < status_min )) && status_w="$status_min"
  status_max=0
  if [[ "$show_status" != "1" ]]; then
    status_w=0
  elif (( USAGE_VERBOSE )); then
    if (( cols >= 94 )); then
      status_max=16
    elif (( cols >= 72 )); then
      status_max=14
    fi
  else
    if (( cols >= 60 )); then
      status_max=13
    elif (( cols >= 50 )); then
      status_max=9
    fi
  fi
  (( status_max > 0 && status_w > status_max )) && status_w="$status_max"

  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$mode" "$role_w" "$profile_w" "$cell_w" "$status_w" "$bar_width"
}

usage_role_label() {
  local mark="$1"
  local profile="$2"
  local default_profile="$3"
  local mode="${4:-normal}"
  local valid="${5:-0}"
  local status="${6:-}"
  local role_w="${7:-1}"

  if (( role_w <= 1 )); then
    if [[ "$mark" == "*" ]]; then
      printf 's'
    elif [[ "$mark" == "=" ]]; then
      printf 'a'
    elif [[ -n "$default_profile" && "$profile" == "$default_profile" ]]; then
      printf 'u'
    elif [[ "$status" == *cap* ]]; then
      printf 'c'
    elif [[ "$status" == "login" ]]; then
      printf 'l'
    elif [[ "$valid" == "0" && "$status" == "ok" ]]; then
      printf 'u'
    fi
    return 0
  fi

  if [[ "$mark" == "*" ]]; then
    printf 'stay'
  elif [[ "$mark" == "=" ]]; then
    printf 'same'
  elif [[ -n "$default_profile" && "$profile" == "$default_profile" ]]; then
    printf 'use'
  elif [[ "$status" == *cap* ]]; then
    printf 'cap'
  elif [[ "$status" == "login" ]]; then
    printf 'login'
  elif [[ "$valid" == "0" && "$status" == "ok" ]]; then
    printf 'use'
  fi
}

usage_status_is_exact_cap() {
  case "$1" in
    "week+5h cap"|"week cap"|"5h cap")
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

usage_stale_ok_label() {
  local stale_age="$1"
  local aged_format="${2:-old}"

  if [[ -n "$stale_age" && "$stale_age" != "now" ]]; then
    printf "$aged_format" "$stale_age"
  else
    printf 'stale'
  fi
}

usage_display_status() {
  local status="$1"
  local mode="${2:-normal}"
  local stale_status=0
  local stale_age=""

  if [[ "$status" == stale\ * ]]; then
    stale_status=1
    status="${status#stale }"
    if [[ "$status" =~ ^(now|[0-9]+[mhd])[[:space:]]+(.+)$ ]]; then
      stale_age="${BASH_REMATCH[1]}"
      status="${BASH_REMATCH[2]}"
    fi
  fi

  if (( stale_status )); then
    if [[ "$mode" == "pico" || "$mode" == "nano" ]]; then
      if [[ "$status" == *cap ]]; then
        printf 'cap'
      else
        printf 'old'
      fi
      return 0
    elif [[ "$mode" == "micro" || "$mode" == "tiny" ]]; then
      if [[ "$status" == "ok" ]]; then
        usage_stale_ok_label "$stale_age"
      elif usage_status_is_exact_cap "$status"; then
        printf 'cap'
      else
        printf 'stale'
      fi
      return 0
    fi
    if [[ "$status" == "ok" ]]; then
      usage_stale_ok_label "$stale_age" 'old %s'
    elif usage_status_is_exact_cap "$status"; then
      printf 'old cap'
    else
      printf 'stale'
    fi
    return 0
  fi

  if usage_status_is_exact_cap "$status"; then
    printf 'cap'
    return 0
  fi

  if [[ "$mode" == "pico" || "$mode" == "nano" ]]; then
    case "$status" in
      ok)
        printf 'ok'
        ;;
      stale\ *\ cap)
        printf 'old'
        ;;
      login)
        printf 'auth'
        ;;
      no\ usage|no\ data)
        printf 'n/a'
        ;;
      *)
        printf '%s' "$status"
        ;;
    esac
    return 0
  fi

  if [[ "$mode" == "micro" || "$mode" == "tiny" ]]; then
    case "$status" in
      ok)
        printf 'ready'
        ;;
      stale\ *\ cap)
        printf 'stale'
        ;;
      login)
        printf 'auth'
        ;;
      *)
        printf '%s' "$status"
        ;;
    esac
    return 0
  fi

  case "$status" in
    ok)
      printf 'ready'
      ;;
    offline)
      printf 'offline'
      ;;
    login)
      printf 'login'
      ;;
    *)
      printf '%s' "$status"
      ;;
  esac
}

usage_display_profile_name() {
  local profile="$1"
  local role="${2:-}"
  local width="${3:-0}"
  local suffix compact

  if [[ "$profile" == "current" && "$role" != "active" && "$role" != "●" && "$role" != "*" ]]; then
    if [[ "$width" =~ ^[0-9]+$ && "$width" -gt 0 && "$width" -lt 7 ]]; then
      printf 'cur'
    else
      printf 'current'
    fi
  elif [[ "$profile" == "Layth" && "$width" =~ ^[0-9]+$ && "$width" -gt 0 && "$width" -lt 5 ]]; then
    printf 'Lay'
  elif [[ "$width" =~ ^[0-9]+$ && "$width" -gt 0 && ${#profile} -gt width ]]; then
    if [[ "$profile" =~ ^Layth([0-9]+)$ ]]; then
      suffix="${BASH_REMATCH[1]}"
      compact="L$suffix"
      if (( ${#compact} <= width )); then
        printf '%s' "$compact"
      else
        printf '%s' "${suffix:0:width}"
      fi
    elif [[ "$profile" == Layth.* ]]; then
      suffix="${profile#Layth.}"
      if (( ${#suffix} <= width )); then
        printf '%s' "$suffix"
      elif (( width <= 5 )); then
        printf '%s' "${suffix:0:width}"
      else
        printf '%s' "$profile"
      fi
    else
      if (( width <= 5 )); then
        fit_profile_text "$profile" "$width"
      else
        printf '%s' "$profile"
      fi
    fi
  else
    printf '%s' "$profile"
  fi
}

usage_header_role() {
  local mode="${1:-normal}"
  local role_w="${2:-0}"
  if (( role_w <= 1 )); then
    printf ''
  else
    printf 'act'
  fi
}

usage_header_profile() {
  local mode="${1:-normal}"
  if [[ "$mode" == "pico" || "$mode" == "nano" ]]; then
    printf 'name'
  else
    printf 'profile'
  fi
}

usage_header_week() {
  local mode="${1:-normal}"
  local reset_glyph
  reset_glyph="$(usage_reset_glyph)"

	  if (( ! USAGE_VERBOSE )); then
	    if [[ "$mode" == "pico" || "$mode" == "nano" ]]; then
	      printf 'wk%%'
	    else
	      printf 'week%%'
	    fi
	    return 0
	  fi

  if [[ -z "$reset_glyph" ]]; then
    if [[ "$mode" == "pico" || "$mode" == "nano" ]]; then
      printf 'wk%%'
    elif [[ "$mode" == "micro" || "$mode" == "tiny" ]]; then
      if [[ "$mode" == "tiny" ]]; then
        printf 'week%% reset'
      else
        printf 'week%%'
      fi
    elif [[ "$mode" == "tight" ]]; then
      printf 'week left reset'
    elif [[ "$mode" == "compact" ]]; then
      printf 'week used/reset'
    elif (( USAGE_VERBOSE )); then
      printf 'week left/used reset'
    else
      printf 'weekly left reset'
    fi
  elif [[ "$mode" == "pico" || "$mode" == "nano" ]]; then
    printf 'wk%%'
  elif [[ "$mode" == "micro" ]]; then
    printf 'week%%'
  elif [[ "$mode" == "tiny" ]]; then
    printf 'week%%%s' "$reset_glyph"
  elif [[ "$mode" == "tight" ]]; then
    printf 'week left%s' "$reset_glyph"
  elif [[ "$mode" == "compact" ]]; then
    printf 'week left/used%s' "$reset_glyph"
  elif (( USAGE_VERBOSE )); then
    printf 'week left/used %s reset' "$reset_glyph"
  else
    printf 'weekly left %s reset' "$reset_glyph"
  fi
}

usage_header_short() {
  local mode="${1:-normal}"
  local label="${USAGE_SHORT_LABEL:-5h}"
  local reset_glyph
  reset_glyph="$(usage_reset_glyph)"
  if [[ "$label" == "short" && ( "$mode" == "pico" || "$mode" == "nano" ) ]]; then
    label="5h"
  fi

	  if (( ! USAGE_VERBOSE )); then
	    if [[ "$mode" == "pico" || "$mode" == "nano" ]]; then
	      printf '%s%%' "${label:0:2}"
	    else
	      printf '%s%%' "$label"
	    fi
	    return 0
	  fi

  if [[ -z "$reset_glyph" ]]; then
    if [[ "$mode" == "pico" || "$mode" == "nano" ]]; then
      printf '%s%%' "${label:0:2}"
    elif [[ "$mode" == "micro" || "$mode" == "tiny" ]]; then
      if [[ "$mode" == "tiny" ]]; then
        printf '%s%% reset' "$label"
      else
        printf '%s%%' "$label"
      fi
    elif [[ "$mode" == "tight" ]]; then
      printf '%s left reset' "$label"
    elif [[ "$mode" == "compact" ]]; then
      printf '%s used/reset' "$label"
    elif (( USAGE_VERBOSE )); then
      printf '%s left/used reset' "$label"
    else
      printf '%s left reset' "$label"
    fi
  elif [[ "$mode" == "pico" || "$mode" == "nano" ]]; then
    printf '%s%%' "${label:0:2}"
  elif [[ "$mode" == "micro" ]]; then
    printf '%s%%' "$label"
  elif [[ "$mode" == "tiny" ]]; then
    printf '%s%%%s' "$label" "$reset_glyph"
  elif [[ "$mode" == "tight" ]]; then
    printf '%s left%s' "$label" "$reset_glyph"
  elif [[ "$mode" == "compact" ]]; then
    printf '%s left/used%s' "$label" "$reset_glyph"
  elif (( USAGE_VERBOSE )); then
    printf '%s left/used %s reset' "$label" "$reset_glyph"
  else
    printf '%s left %s reset' "$label" "$reset_glyph"
  fi
}

usage_header_state() {
  local mode="${1:-normal}"
  if [[ "$mode" == "pico" || "$mode" == "nano" ]]; then
    printf 'st'
  elif [[ "$mode" == "micro" || "$mode" == "tiny" ]]; then
    printf 'state'
  else
    printf 'status'
  fi
}

usage_fit_header_label() {
  local text="$1"
  local width="$2"
  local compact="$text"

  if [[ "$width" =~ ^[0-9]+$ && "$width" -gt 0 && ${#text} -gt width ]]; then
    case "$text" in
      "weekly left/used ↺ reset")
        compact="week left/used ↺ reset"
        ;;
      "weekly left/used reset")
        compact="week left/used reset"
        ;;
      "weekly left/used "*)
        compact="${text/weekly/week}"
        ;;
    esac
  fi

  if [[ "$width" =~ ^[0-9]+$ && "$width" -gt 0 && ${#compact} -le width ]]; then
    printf '%s' "$compact"
  else
    printf '%s' "$text"
  fi
}

usage_metric_header_cell() {
  local text="$1"
  local width="$2"
  local mode="${3:-normal}"
  local display="$text"

  if (( USAGE_VERBOSE )); then
    usage_fit_header_label "$text" "$width"
    return 0
  fi

  [[ "$display" == "week%" ]] && display="wk%"
  if (( ${#display} > width )); then
    if (( width <= 1 )); then
      display="${display:0:width}"
    elif [[ "$display" == *% ]]; then
      display="${display:0:width-1}%"
    else
      display="${display:0:width}"
    fi
  fi

  fit_text_center "$display" "$width"
  return 0
}

print_usage_render_line() {
  local role="$1"
  local profile="$2"
  local weekly_cell="$3"
  local short_cell="$4"
  local status="$5"
  local role_w="$6"
  local profile_w="$7"
  local cell_w="$8"
  local status_w="$9"
  local prefix="${10:-}"
  local reset="${11:-}"
  local role_profile_gap status_gap

  role_profile_gap="$(usage_role_profile_gap "$role_w")"
  status_gap="$(usage_metric_status_gap "$role_w")"
  printf '%s' "$prefix"
  fit_text "$role" "$role_w"
  printf '%*s' "$role_profile_gap" ''
  fit_text "$profile" "$profile_w"
  printf ' '
  fit_text "$weekly_cell" "$cell_w"
  printf ' '
  fit_text "$short_cell" "$cell_w"
  if (( status_w > 0 )); then
    printf '%*s' "$status_gap" ''
    fit_text "$status" "$status_w"
  fi
  printf '%s\n' "$reset"
}

print_usage_render_header() {
  local role="$1"
  local profile="$2"
  local weekly_cell="$3"
  local short_cell="$4"
  local status="$5"
  local role_w="$6"
  local profile_w="$7"
  local cell_w="$8"
  local status_w="$9"
  local mode="${10:-normal}"
  local reset=""

  weekly_cell="$(usage_metric_header_cell "$weekly_cell" "$cell_w" "$mode")"
  short_cell="$(usage_metric_header_cell "$short_cell" "$cell_w" "$mode")"
  if (( status_w > 0 )); then
    status="$(fit_text_center "$status" "$status_w")"
  else
    status=""
  fi
  usage_color_active && reset=$'\033[0m'
  usage_tone_color muted
  print_usage_render_line "$role" "$profile" "$weekly_cell" "$short_cell" "$status" "$role_w" "$profile_w" "$cell_w" "$status_w" "" "$reset"
}

usage_unavailable_status_cell() {
  local raw_status="$1"
  local display_status="$2"
  local status_w="${3:-0}"

  case "$raw_status" in
    login)
      if (( status_w < 4 )); then
        printf 'log'
      elif (( status_w < 6 )); then
        printf 'auth'
      elif (( status_w < 12 )); then
        printf 'login'
      else
        printf 'login needed'
      fi
      ;;
    no\ data)
      if (( status_w < 3 )); then
        printf 'na'
      elif (( status_w < 7 )); then
        printf 'n/a'
      else
        printf 'no data'
      fi
      ;;
    no\ usage)
      if (( status_w < 3 )); then
        printf 'na'
      elif (( status_w < 8 )); then
        printf 'n/a'
      else
        printf 'no usage'
      fi
      ;;
    offline)
      if (( status_w < 3 )); then
        printf 'of'
      elif (( status_w < 7 )); then
        printf 'off'
      else
        printf 'offline'
      fi
      ;;
    *)
      printf '%s' "$display_status"
      ;;
  esac
}

print_usage_placeholder_limit_cell() {
  local mode="$1"
  local cell_w="$2"
  local glyph label_w=4 pad

  (( cell_w <= 0 )) && return 0
  glyph="-"
  if [[ "$mode" == "pico" ]]; then
    label_w="$cell_w"
  elif (( USAGE_VERBOSE )) && [[ "$mode" != "pico" && "$mode" != "nano" && "$mode" != "micro" && "$mode" != "tiny" && "$mode" != "tight" ]]; then
    label_w=6
  fi
  (( label_w > cell_w )) && label_w="$cell_w"

  usage_tone_color muted
  if [[ "$mode" == "pico" || "$mode" == "nano" ]]; then
    fit_text_center "$glyph" "$cell_w"
    usage_tone_reset
    return 0
  fi
  printf "%${label_w}s" "$glyph"
  usage_tone_reset
  pad=$((cell_w - label_w))
  (( pad > 0 )) && printf '%*s' "$pad" ''
  return 0
}

print_usage_render_data_line() {
  local role="$1"
  local profile="$2"
  local weekly="$3"
  local weekly_reset="$4"
  local short="$5"
  local short_reset="$6"
  local display_status="$7"
  local raw_status="$8"
  local valid="$9"
  local weekly_used="${10}"
  local short_used="${11}"
  local role_w="${12}"
  local profile_w="${13}"
  local cell_w="${14}"
	  local status_w="${15}"
	  local bar_width="${16}"
	  local mode="${17}"
	  local unavailable_text role_profile_gap status_gap

	  print_toned_fit "$role" "$role_w" "$(usage_role_tone "$role")"
	  role_profile_gap="$(usage_role_profile_gap "$role_w")"
	  status_gap="$(usage_metric_status_gap "$role_w")"
	  printf '%*s' "$role_profile_gap" ''
	  fit_profile_text "$(usage_display_profile_name "$profile" "$role" "$profile_w")" "$profile_w"
	  printf ' '
	  if [[ "$valid" != "0" ]]; then
	    unavailable_text="$(usage_unavailable_status_cell "$raw_status" "$display_status" "$status_w")"
    print_usage_placeholder_limit_cell "$mode" "$cell_w"
    printf ' '
    print_usage_placeholder_limit_cell "$mode" "$cell_w"
	    if (( status_w > 0 )); then
	      printf '%*s' "$status_gap" ''
	      print_toned_fit_center "$unavailable_text" "$status_w" "$(usage_status_tone "$raw_status" "$valid")"
	    fi
	    printf '\n'
	    return 0
	  fi

  print_usage_limit_cell "$weekly" "$weekly_reset" "$mode" "$bar_width" "$cell_w" "$weekly_used"
  printf ' '
  print_usage_limit_cell "$short" "$short_reset" "$mode" "$bar_width" "$cell_w" "$short_used"
  if (( status_w > 0 )); then
    printf '%*s' "$status_gap" ''
    print_toned_fit_center "$display_status" "$status_w" "$(usage_status_tone "$raw_status" "$valid")"
  fi
  printf '\n'
}

usage_summary_try_append() {
  local -n line_ref="$1"
  local -n show_ref="$2"
  local part="$3"
  local width="$4"

  if (( ! show_ref )); then
    return 0
  fi
  if (( ${#line_ref} + ${#part} <= width )); then
    line_ref+="$part"
  else
    show_ref=0
  fi
}

usage_summary_note_active_record() {
  local valid="$1"
  local mark="$2"
  local profile="$3"
  local weekly="$4"
  local short="$5"
  local short_label="$6"
  local -n active_profile_ref="$7"
  local -n active_short_ref="$8"
  local -n active_weekly_ref="$9"
  local -n active_label_ref="${10}"
  local -n active_has_usage_ref="${11}"

  [[ "$mark" == "*" ]] || return 0
  active_profile_ref="$profile"
  active_short_ref="$short"
  active_weekly_ref="$weekly"
  if [[ "$valid" == "0" && -n "$short" && "$short" != "-" ]]; then
    [[ -n "$short_label" ]] && active_label_ref="$short_label"
    active_has_usage_ref=1
  elif [[ "$valid" == "0" && -n "$weekly" && "$weekly" != "-" ]]; then
    active_short_ref="$weekly"
    active_label_ref="wk"
    active_has_usage_ref=1
  fi
}

usage_summary_count_record_status() {
  local valid="$1"
  local status="$2"
  local -n caps_ref="$3"
  local -n login_ref="$4"
  local -n unavailable_ref="$5"
  local -n offline_ref="$6"
  local -n stale_ref="$7"
  local -n ready_ref="$8"

  [[ "$status" == stale* ]] && stale_ref=$((stale_ref + 1))
  if [[ "$status" == "offline" ]]; then
    offline_ref=$((offline_ref + 1))
  elif [[ "$status" == "login" ]]; then
    login_ref=$((login_ref + 1))
  elif [[ "$valid" != "0" || "$status" == "no data" || "$status" == "no usage" ]]; then
    unavailable_ref=$((unavailable_ref + 1))
  elif [[ "$status" == *cap* ]]; then
    caps_ref=$((caps_ref + 1))
  elif [[ "$status" == "ok" ]]; then
    ready_ref=$((ready_ref + 1))
  fi
}

usage_summary_scan_records() {
  local default_profile="${1:-}"
  shift || true
  local record valid weekly_used short_used mark profile plan weekly short status short_label weekly_reset short_reset cache_age
  local active_profile="" active_short="" active_weekly="" active_label="5h"
  local best_profile="$default_profile"
  local caps=0 login=0 unavailable=0 offline=0 stale=0 ready=0
  local cache_age_max=-1 cache_age_label=""
  local cache_age_out
  local has_best=0 has_active=0 active_has_usage=0 old_summary=0

  for record in "$@"; do
    IFS=$'\t' read -r valid weekly_used short_used mark profile plan weekly short status short_label weekly_reset short_reset cache_age <<<"$record"
    [[ -n "$profile" ]] || continue
    if [[ "$cache_age" =~ ^[0-9]+$ ]] && (( cache_age > cache_age_max )); then
      cache_age_max="$cache_age"
    fi
    usage_summary_note_active_record "$valid" "$mark" "$profile" "$weekly" "$short" "$short_label" \
      active_profile active_short active_weekly active_label active_has_usage
    [[ -z "$best_profile" && "$status" == "ok" ]] && best_profile="$profile"
    usage_summary_count_record_status "$valid" "$status" caps login unavailable offline stale ready
  done

  [[ -n "$best_profile" ]] && has_best=1 || best_profile="none"
  [[ -n "$active_profile" ]] && has_active=1 || active_profile="none"
  [[ -n "$active_short" && "$active_short" != "-" ]] || active_short="n/a"
  [[ -n "$active_weekly" && "$active_weekly" != "-" ]] || active_weekly="n/a"
  if (( cache_age_max >= 0 )); then
    cache_age_label="$(format_cache_age "$cache_age_max")"
  fi
  (( stale > 0 && ready == 0 && has_active )) && old_summary=1

  cache_age_out="$cache_age_label"
  [[ -n "$cache_age_out" ]] || cache_age_out="__none__"
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
    "$active_profile" "$active_short" "$active_weekly" "$active_label" "$best_profile" \
    "$has_best" "$has_active" "$active_has_usage" "$caps" "$login" "$unavailable" \
    "$offline" "$stale" "$ready" "$cache_age_out" "$old_summary"
}

print_usage_summary_compact_line() {
  local width="$1"
  local has_active="$2"
  local active_has_usage="$3"
  local active_profile="$4"
  local active_label="$5"
  local active_short="$6"
  local caps="$7"
  local ready="$8"
  local has_best="$9"
  local old_summary="${10}"
  local sep="${11}"
  local compact_lines=()
  local compact_active_profile line

  compact_active_profile="$(usage_display_profile_name "$active_profile" "" 6)"
  if (( old_summary )); then
    compact_lines+=(
      "old $compact_active_profile ${active_label} $active_short"
      "old $active_profile ${active_label} $active_short"
      "old $compact_active_profile"
      "old $active_profile"
    )
  fi
  if (( has_active )); then
    if (( active_has_usage )); then
      if (( caps > 0 )); then
        compact_lines+=(
          "active $compact_active_profile ${active_label} $active_short${sep}cap $caps"
          "act $compact_active_profile ${active_label} $active_short${sep}cap $caps"
        )
      fi
      compact_lines+=(
        "active $compact_active_profile ${active_label} $active_short"
        "act $compact_active_profile ${active_label} $active_short"
        "active $active_profile ${active_label} $active_short"
        "active $compact_active_profile"
        "active $active_profile"
        "${active_label} $active_short"
      )
    else
      compact_lines+=(
        "no fresh ready${sep}active $compact_active_profile"
        "no fresh ready${sep}active $active_profile"
        "active $compact_active_profile"
        "active $active_profile"
        "no fresh ready"
      )
    fi
  elif (( has_best )); then
    compact_lines+=(
      "ready $ready${sep}no active"
      "ready $ready"
      "no active"
    )
  else
    compact_lines+=(
      "no fresh ready${sep}no active"
      "no active"
    )
  fi

  for line in "${compact_lines[@]}"; do
    if (( ${#line} <= width )); then
      printf '%s\n' "$line"
      return 0
    fi
  done
  fit_text_rtrim "${compact_lines[-1]}" "$width"
  printf '\n'
}

usage_summary_initial_line() {
  local active_summary="$1"
  local old_summary="$2"
  local has_active="$3"
  local has_best="$4"
  local ready="$5"
  local sep="$6"
  local active_profile="$7"
  local active_label="$8"
  local active_short="$9"

  if (( old_summary )); then
    printf 'old active %s %s %s' "$active_profile" "$active_label" "$active_short"
  elif (( has_active )); then
    printf '%s' "$active_summary"
  elif (( has_best )); then
    if (( ready > 0 )); then
      printf 'ready %s%sno active' "$ready" "$sep"
    else
      printf 'no active'
    fi
  else
    printf 'no fresh ready%sno active' "$sep"
  fi
}

usage_summary_fallback_line() {
  local width="$1"
  local old_summary="$2"
  local has_active="$3"
  local active_has_usage="$4"
  local has_best="$5"
  local ready="$6"
  local caps="$7"
  local sep="$8"
  local active_profile="$9"
  local active_label="${10}"
  local active_short="${11}"
  local line cap_label="capped"
  local show_ready=0 show_caps=0

  if (( old_summary )); then
    line="old active $active_profile ${active_label} $active_short"
  elif (( has_active )); then
    if (( active_has_usage )); then
      line="active $active_profile ${active_label} $active_short"
    else
      line="active $active_profile"
    fi
  elif (( has_best )); then
    if (( ready > 0 )); then
      line="ready $ready${sep}no active"
    else
      line="no active"
    fi
  else
    line="no active"
  fi

  if (( caps > 0 && ${#line} + 8 <= width )); then
    cap_label="cap"
    line+="${sep}$cap_label $caps"
    show_caps=1
  elif (( ready > 0 && ${#line} + 10 <= width )); then
    line+="${sep}ready $ready"
    show_ready=1
  fi

  printf '%s\t%s\t%s\t%s\n' "$line" "$show_ready" "$show_caps" "$cap_label"
}

print_usage_summary_colored_line() {
  local sep="$1"
  local old_summary="$2"
  local has_active="$3"
  local has_best="$4"
  local ready="$5"
  local active_profile="$6"
  local active_label="$7"
  local active_short="$8"
  local show_week="$9"
  local active_weekly="${10}"
  local show_ready="${11}"
  local show_caps="${12}"
  local cap_label="${13}"
  local caps="${14}"
  local show_login="${15}"
  local login="${16}"
  local show_unavailable="${17}"
  local unavailable="${18}"
  local show_offline="${19}"
  local offline="${20}"
  local show_stale="${21}"
  local stale="${22}"
  local show_cache="${23}"
  local cache_age_label="${24}"
  local active_has_usage="${25}"

  if (( old_summary )); then
    usage_tone_color muted; printf 'old active '; usage_tone_reset
    usage_tone_color active; printf '%s' "$active_profile"; usage_tone_reset
  elif (( has_active )); then
    usage_tone_color muted; printf 'active '; usage_tone_reset
    usage_tone_color active; printf '%s' "$active_profile"; usage_tone_reset
  elif (( has_best )); then
    if (( ready > 0 )); then
      usage_tone_color good; printf 'ready '; usage_tone_reset
      usage_tone_color good; printf '%s' "$ready"; usage_tone_reset
      usage_tone_color muted; printf '%sno active' "$sep"; usage_tone_reset
    else
      usage_tone_color muted; printf 'no active'; usage_tone_reset
    fi
  else
    usage_tone_color muted; printf 'no fresh ready'; usage_tone_reset
    usage_tone_color muted; printf '%sno active' "$sep"; usage_tone_reset
  fi
  if (( has_active && active_has_usage )); then
    usage_tone_color muted; printf ' %s ' "$active_label"; usage_tone_reset
    usage_tone_color "$(usage_limit_tone "$active_short")"; printf '%s' "$active_short"; usage_tone_reset
  fi
  if (( show_week )); then
    usage_tone_color muted; printf ' wk '; usage_tone_reset
    usage_tone_color "$(usage_limit_tone "$active_weekly")"; printf '%s' "$active_weekly"; usage_tone_reset
  fi
  if (( show_ready )); then
    usage_tone_color muted; printf '%sready ' "$sep"; usage_tone_reset
    usage_tone_color good; printf '%s' "$ready"; usage_tone_reset
  fi
  if (( show_caps )); then
    usage_tone_color muted; printf '%s%s ' "$sep" "$cap_label"; usage_tone_reset
    usage_tone_color bad; printf '%s' "$caps"; usage_tone_reset
  fi
  if (( show_login )); then
    usage_tone_color muted; printf '%slogin ' "$sep"; usage_tone_reset
    usage_tone_color muted; printf '%s' "$login"; usage_tone_reset
  fi
  if (( show_unavailable )); then
    usage_tone_color muted; printf '%sno data ' "$sep"; usage_tone_reset
    usage_tone_color muted; printf '%s' "$unavailable"; usage_tone_reset
  fi
  if (( show_offline )); then
    usage_tone_color muted; printf '%soffline ' "$sep"; usage_tone_reset
    usage_tone_color warn; printf '%s' "$offline"; usage_tone_reset
  fi
  if (( show_stale )); then
    usage_tone_color muted; printf '%sstale ' "$sep"; usage_tone_reset
    usage_tone_color warn; printf '%s' "$stale"; usage_tone_reset
  fi
  if (( show_cache )); then
    usage_tone_color muted; printf '%scache %s' "$sep" "$cache_age_label"; usage_tone_reset
  fi
  printf '\n'
}

print_usage_summary_line() {
  local width="$1"
  local default_profile="${2:-}"
  shift 2
  local active_profile active_short active_weekly active_label best_profile
  local has_best has_active active_has_usage caps login unavailable offline stale ready cache_age_label old_summary
  local show_cache=0
  local line show_week=0 show_login=0 show_unavailable=0 show_offline=0 show_ready=0 show_caps=0 show_stale=0
  local active_summary
  local cap_label="capped"
  local sep
  sep="$(usage_separator)"

  IFS=$'\t' read -r active_profile active_short active_weekly active_label best_profile \
    has_best has_active active_has_usage caps login unavailable offline stale ready cache_age_label old_summary \
    <<<"$(usage_summary_scan_records "$default_profile" "$@")"
  [[ "$cache_age_label" != "__none__" ]] || cache_age_label=""

  active_summary="active $active_profile"
  if (( active_has_usage )); then
    active_summary+=" ${active_label} $active_short"
  fi
  (( width >= 70 && login > 0 )) && show_login=1
  (( width >= 70 && unavailable > 0 )) && show_unavailable=1
  (( width >= 70 && offline > 0 )) && show_offline=1
  if (( ready > 0 && (width >= 70 || caps == 0) )); then
    show_ready=1
  fi
  (( caps > 0 )) && show_caps=1

  if (( width < 40 )); then
    print_usage_summary_compact_line "$width" "$has_active" "$active_has_usage" "$active_profile" "$active_label" "$active_short" "$caps" "$ready" "$has_best" "$old_summary" "$sep"
    return 0
  fi

  line="$(usage_summary_initial_line "$active_summary" "$old_summary" "$has_active" "$has_best" "$ready" "$sep" "$active_profile" "$active_label" "$active_short")"
  if (( ! has_active && has_best )); then
    show_ready=0
  fi
  usage_summary_try_append line show_week " wk $active_weekly" "$width"
  usage_summary_try_append line show_ready "${sep}ready $ready" "$width"
  usage_summary_try_append line show_caps "${sep}$cap_label $caps" "$width"
  usage_summary_try_append line show_login "${sep}login $login" "$width"
  usage_summary_try_append line show_unavailable "${sep}no data $unavailable" "$width"
  usage_summary_try_append line show_offline "${sep}offline $offline" "$width"
  if (( stale > 0 )); then
    show_stale=1
    usage_summary_try_append line show_stale "${sep}stale $stale" "$width"
  fi
  if [[ -n "$cache_age_label" ]]; then
    show_cache=1
    usage_summary_try_append line show_cache "${sep}cache $cache_age_label" "$width"
  fi

  if (( ${#line} > width )); then
    IFS=$'\t' read -r line show_ready show_caps cap_label \
      <<<"$(usage_summary_fallback_line "$width" "$old_summary" "$has_active" "$active_has_usage" "$has_best" "$ready" "$caps" "$sep" "$active_profile" "$active_label" "$active_short")"
    show_week=0
    show_login=0
    show_unavailable=0
    show_offline=0
    show_stale=0
    show_cache=0
  fi

  if (( ${#line} > width )); then
    fit_text_rtrim "$line" "$width"
    printf '\n'
    return 0
  fi

  if usage_color_active; then
    print_usage_summary_colored_line "$sep" "$old_summary" "$has_active" "$has_best" "$ready" "$active_profile" "$active_label" "$active_short" \
      "$show_week" "$active_weekly" "$show_ready" "$show_caps" "$cap_label" "$caps" "$show_login" "$login" \
      "$show_unavailable" "$unavailable" "$show_offline" "$offline" "$show_stale" "$stale" "$show_cache" "$cache_age_label" "$active_has_usage"
  else
    printf '%s\n' "$line"
  fi
}

state_payload_for_profile() {
  local profile_name="$1"
  local fingerprint="$2"
  local now
  now="$(now_epoch)"

  [[ -f "$STATE_FILE" ]] || return 1
  jq -c --arg name "$profile_name" --arg fp "$fingerprint" --argjson now "$now" '
    (.profiles[$name] // null) as $profile
    | select($profile != null and $profile.fingerprint == $fp)
    | ($profile.payload + {
        _codexAuthAgeSec: (if $profile.updated_at == null
          then null
          else ($now - ($profile.updated_at | tonumber))
        end)
      })
  ' "$STATE_FILE" 2>/dev/null | tail -n 1
}

state_payload_records() {
  local map_file="$1"
  local now

  [[ -f "$STATE_FILE" && -s "$map_file" ]] || return 0
  now="$(now_epoch)"
  jq -r --rawfile requested "$map_file" --argjson now "$now" '
    . as $state
    | $requested
    | split("\n")[]
    | select(length > 0)
    | split("\u001f") as $item
    | {
        path: ($item[0] // ""),
        name: ($item[1] // ""),
        fp: ($item[2] // "")
      } as $req
    | ($state.profiles[$req.name] // null) as $profile
    | select($profile != null and $profile.fingerprint == $req.fp)
    | [
        $req.path,
        $req.name,
        (($profile.payload + {
          _codexAuthAgeSec: (if $profile.updated_at == null
            then null
            else ($now - ($profile.updated_at | tonumber))
          end)
        }) | @json)
      ]
    | join("\u001f")
  ' "$STATE_FILE" 2>/dev/null
}

state_age_for_profile() {
  local profile_name="$1"
  local fingerprint="$2"
  local now
  now="$(now_epoch)"

  [[ -f "$STATE_FILE" ]] || { printf '999999999\n'; return 0; }
  jq -r --arg name "$profile_name" --arg fp "$fingerprint" --argjson now "$now" '
    (.profiles[$name] // null) as $profile
    | if $profile == null or $profile.fingerprint != $fp or $profile.updated_at == null
      then 999999999
      else ($now - ($profile.updated_at | tonumber))
      end
  ' "$STATE_FILE" 2>/dev/null || printf '999999999\n'
}

state_update_profile() {
  local profile_name="$1"
  local fingerprint="$2"
  local payload="$3"
  local updated tmp source

  updated="$(now_epoch)"
  if ! jq -e . >/dev/null 2>&1 <<<"$payload"; then
    payload='{"error":{"message":"invalid usage payload"}}'
  fi

  tmp="$(mktemp "$CODEX_HOME/.tmp/auth-state.XXXXXX")"
  if [[ -f "$STATE_FILE" ]] && jq -e . "$STATE_FILE" >/dev/null 2>&1; then
    source="$STATE_FILE"
  else
    source="/dev/null"
  fi

  {
    flock -x 9
    if [[ "$source" == "/dev/null" ]]; then
      printf '{}\n'
    else
      cat "$source"
    fi | jq -c \
      --arg name "$profile_name" \
      --arg fp "$fingerprint" \
      --argjson updated "$updated" \
      --argjson payload "$payload" '
        .version = 1
        | .updated_at = $updated
        | .profiles = (.profiles // {})
        | .profiles[$name] = {
            updated_at: $updated,
            fingerprint: $fp,
            payload: $payload
          }
      ' > "$tmp"
    chmod 600 "$tmp"
    mv "$tmp" "$STATE_FILE"
  } 9>"$CODEX_HOME/.tmp/codex-auth-state.lock"
}

mark_stale_payload() {
  local payload="$1"

  jq -c '. + {_codexAuthStale: true}' <<<"$payload" 2>/dev/null || printf '%s\n' "$payload"
}

format_cache_age() {
  local seconds="${1:-}"
  local mins hours days

  [[ "$seconds" =~ ^[0-9]+$ ]] || return 0
  if (( seconds < 60 )); then
    printf 'now'
  elif (( seconds < 3600 )); then
    mins=$(((seconds + 30) / 60))
    (( mins < 1 )) && mins=1
    printf '%dm' "$mins"
  elif (( seconds < 86400 )); then
    hours=$(((seconds + 1800) / 3600))
    (( hours < 1 )) && hours=1
    printf '%dh' "$hours"
  else
    days=$(((seconds + 43200) / 86400))
    (( days < 1 )) && days=1
    printf '%dd' "$days"
  fi
}

usage_payload_still_blocked() {
  local payload="$1"
  local now

  now="$(now_epoch)"
  jq -e --argjson now "$now" '
    if .error? != null then
      ((.error.message // .error.data.message // .error.data.error.message // .error // "")
        | tostring
        | test("token has been invalidated|token_invalidated|invalidated oauth token|token_revoked"; "i"))
    else
      (.rateLimitsByLimitId.codex // .rateLimits // null) as $r
      | if $r == null then
          false
        else
          (($r.secondary.usedPercent // 0) >= 100 and ((($r.secondary.resetsAt // 0) | tonumber? // 0) > $now))
          or (($r.primary.usedPercent // 0) >= 100 and ((($r.primary.resetsAt // 0) | tonumber? // 0) > $now))
        end
    end
  ' <<<"$payload" >/dev/null 2>&1
}

usage_payload_transient_error() {
  local payload="$1"

  jq -e '
    (.error.message // .error.data.message // .error.data.error.message // .error // "")
    | tostring
    | test("^(refresh (timeout|unavailable)|no response)$")
  ' <<<"$payload" >/dev/null 2>&1
}

usage_payload_for_profile() {
  local profile_file="$1"
  local fingerprint="${2:-}"
  local profile_name payload age cached_payload

  profile_name="$(basename "$profile_file" .json)"
  [[ -n "$fingerprint" ]] || fingerprint="$(credential_fingerprint "$profile_file" || true)"
  cached_payload=""
  [[ -n "$fingerprint" ]] && cached_payload="$(state_payload_for_profile "$profile_name" "$fingerprint" || true)"

  if [[ "$USAGE_REFRESH" == "1" && "${CODEX_AUTH_REFRESH_BLOCKED:-0}" == "1" && -n "$cached_payload" ]]; then
    if usage_payload_still_blocked "$cached_payload"; then
      printf '%s\n' "$cached_payload"
      return 0
    fi
  fi

  if [[ -n "$fingerprint" && "$USAGE_REFRESH" != "1" ]]; then
    payload="$cached_payload"
    if [[ -n "$payload" ]]; then
      age="$(state_age_for_profile "$profile_name" "$fingerprint")"
      if [[ "$USAGE_CACHED" == "1" ]]; then
        printf '%s\n' "$payload"
        return 0
      fi
      if [[ "$age" =~ ^[0-9]+$ ]] && (( age <= CACHE_TTL )); then
        printf '%s\n' "$payload"
        return 0
      fi
    elif [[ "$USAGE_CACHED" == "1" ]]; then
      printf 'null\n'
      return 0
    fi
  elif [[ "$USAGE_CACHED" == "1" ]]; then
    printf 'null\n'
    return 0
  fi

  payload="$(usage_json_for_profile "$profile_file")"
  if [[ -n "$payload" && "$payload" != "null" ]] && usage_payload_transient_error "$payload"; then
    if [[ -n "$cached_payload" ]]; then
      if [[ "$USAGE_REFRESH" == "1" && "${CODEX_AUTH_REFRESH_FALLBACK_CACHE:-1}" == "1" ]]; then
        mark_stale_payload "$cached_payload"
      else
        printf '%s\n' "$cached_payload"
      fi
      return 0
    fi
    printf '%s\n' "$payload"
    return 0
  fi
  if [[ -z "$payload" || "$payload" == "null" ]]; then
    if [[ -n "$cached_payload" ]]; then
      if [[ "$USAGE_REFRESH" == "1" ]]; then
        if [[ "${CODEX_AUTH_REFRESH_FALLBACK_CACHE:-1}" == "1" ]]; then
          mark_stale_payload "$cached_payload"
        else
          printf '%s\n' '{"error":{"message":"no response"}}'
        fi
        return 0
      fi
      printf '%s\n' "$cached_payload"
      return 0
    fi
    printf '%s\n' '{"error":{"message":"no response"}}'
    return 0
  fi

  if [[ -n "$fingerprint" ]] && ! jq -e '.error? != null' >/dev/null 2>&1 <<<"$payload"; then
    state_update_profile "$profile_name" "$fingerprint" "$payload"
  fi
  printf '%s\n' "$payload"
}

usage_json_for_profile() {
  local profile_file="$1"
  local temp_home payload

  temp_home="$(mktemp -d "$CODEX_HOME/.tmp/auth-usage.XXXXXX")"
  copy_auth_file_atomic "$profile_file" "$temp_home/auth.json"

  payload="$(usage_json_from_home "$temp_home")"
  rm -rf "$temp_home" 2>/dev/null || true
  printf '%s\n' "$payload"
}

usage_json_for_active_home() {
  usage_json_from_home "$CODEX_HOME"
}

usage_kill_process_tree() {
  local pid="${1:-}"
  local signal="${2:-TERM}"
  local child

  [[ "$pid" =~ ^[0-9]+$ ]] || return 0
  if command -v pgrep >/dev/null 2>&1; then
    while IFS= read -r child; do
      [[ "$child" =~ ^[0-9]+$ && "$child" != "$pid" ]] || continue
      usage_kill_process_tree "$child" "$signal"
    done < <(pgrep -P "$pid" 2>/dev/null || true)
  fi
  kill "-$signal" "$pid" 2>/dev/null || true
}

usage_json_cleanup_coproc() {
  local rate_in="${1:-}"
  local rate_out="${2:-}"
  local rate_pid="${3:-}"

  [[ "$rate_in" =~ ^[0-9]+$ && -e "/proc/self/fd/$rate_in" ]] && exec {rate_in}>&- || true
  [[ "$rate_out" =~ ^[0-9]+$ && -e "/proc/self/fd/$rate_out" ]] && exec {rate_out}<&- || true
  if [[ -n "$rate_pid" ]]; then
    usage_kill_process_tree "$rate_pid"
    wait "$rate_pid" 2>/dev/null || true
  fi
}

usage_json_from_home() {
  local home_dir="$1"
  local codex_cli line line_id payload rate_in rate_out rate_pid
  local requested=0
  local start now timeout_sec

  codex_cli="$(codex_bin)" || return 0
  codex_launcher_ready "$codex_cli" || return 0
  timeout_sec="${CODEX_AUTH_USAGE_TIMEOUT:-4}"
  [[ "$timeout_sec" =~ ^[0-9]+$ && "$timeout_sec" -gt 0 ]] || timeout_sec=4

  if ! coproc CODEX_RATE { CODEX_AUTH_RUNNER=1 CODEX_HOME="$home_dir" "$codex_cli" app-server --listen stdio:// 2>/dev/null; }; then
    printf '%s\n' '{"error":{"message":"refresh unavailable"}}'
    return 0
  fi

  rate_out="${CODEX_RATE[0]}"
  rate_in="${CODEX_RATE[1]}"
  rate_pid="$CODEX_RATE_PID"
  start="$(now_epoch)"

  if ! printf '%s\n' '{"id":1,"method":"initialize","params":{"clientInfo":{"name":"codex-auth","title":"Codex Auth","version":"0.1.0"},"capabilities":{"experimentalApi":true,"requestAttestation":false}}}' 2>/dev/null >&"$rate_in"; then
    usage_json_cleanup_coproc "$rate_in" "$rate_out" "$rate_pid"
    printf '%s\n' '{"error":{"message":"refresh unavailable"}}'
    return 0
  fi

  while true; do
    if [[ ! "$rate_out" =~ ^[0-9]+$ || ! -e "/proc/self/fd/$rate_out" ]]; then
      payload='{"error":{"message":"refresh unavailable"}}'
      break
    fi
    if IFS= read -r -t 0.25 line 2>/dev/null <&"$rate_out"; then
      line_id="$(jq -r '.id // empty' <<<"$line" 2>/dev/null || true)"
      if [[ "$line_id" == "1" && "$requested" == "0" ]]; then
        printf '%s\n' '{"method":"initialized"}' 2>/dev/null >&"$rate_in" || true
        printf '%s\n' '{"id":2,"method":"account/rateLimits/read"}' 2>/dev/null >&"$rate_in" || true
        requested=1
      elif [[ "$line_id" == "2" ]]; then
        payload="$(jq -c 'if has("result") then .result else {error:.error} end' <<<"$line" 2>/dev/null || true)"
        break
      fi
    else
      now="$(now_epoch)"
      if (( now - start >= timeout_sec )); then
        payload='{"error":{"message":"refresh timeout"}}'
        break
      fi
      if ! kill -0 "$rate_pid" 2>/dev/null; then
        payload='{"error":{"message":"refresh unavailable"}}'
        break
      fi
    fi
  done

  usage_json_cleanup_coproc "$rate_in" "$rate_out" "$rate_pid"
  printf '%s\n' "$payload"
}

usage_limit_remaining_fields() {
  local used="$1"
  local window="$2"
  local reset="$3"
  local left

  if [[ -z "$window" || "$window" == "-" || "$window" == "0" ]]; then
    printf '0\t-\t-\n'
    return 0
  fi

  left=$((100 - used))
  (( left < 0 )) && left=0
  printf '%s\t%s%%\t%s\n' "$used" "$left" "$(format_reset_time "$reset")"
}

usage_record_extract_payload() {
  local payload="$1"

  jq -r '
    (._codexAuthAgeSec // "") as $age
    | (._codexAuthStale // false) as $stale
    | if .error? != null then
        [
          "error",
          ((.error.message // .error.data.message // .error.data.error.message // .error // "error")
            | tostring
            | gsub("[\n\t]+"; " ")
            | gsub("  +"; " ")
            | gsub("^ "; "")
            | gsub(" $"; "")),
          $age,
          ($stale | tostring),
          "", "", "", "", "", "", "", "", ""
        ]
      else
        (.rateLimitsByLimitId.codex // .rateLimits // null) as $r
        | if $r == null then
            ["no_usage", "", $age, ($stale | tostring), "", "", "", "", "", "", "", "", ""]
          else
            def empty_limit:
              {
                used: 0,
                window: "-",
                window_num: 0,
                reset: "-"
              };
            def limit_row:
              {
                used: ((.usedPercent // 0) | tonumber? // 0 | floor),
                window: (.windowDurationMins // "-"),
                window_num: ((.windowDurationMins // 0) | tonumber? // 0),
                reset: (.resetsAt // "-")
              };
            [
              ($r.primary // empty),
              ($r.secondary // empty)
            ]
            | map(select(type == "object") | limit_row)
            | map(select(.window_num > 0))
            | sort_by(if .window_num == 0 then 999999999 else .window_num end) as $limits
            | if ($limits | length) == 0 then
                ["no_usage", "", $age, ($stale | tostring), "", "", "", "", "", "", "", "", ""]
              else
                (if ($limits | length) == 1 and ($limits[0].window_num >= 1440)
                 then empty_limit
                 else $limits[0]
                 end) as $shortLimit
                | (if ($limits | length) == 1 and ($limits[0].window_num < 1440)
                   then empty_limit
                   else $limits[-1]
                   end) as $weeklyLimit
                | [
                    "usage",
                    "",
                    $age,
                    ($stale | tostring),
                    ($r.planType // "-"),
                    $shortLimit.used,
                    $shortLimit.window,
                    $shortLimit.reset,
                    $weeklyLimit.used,
                    $weeklyLimit.window,
                    $weeklyLimit.reset,
                    (if $r.credits == null then "-"
                     elif $r.credits.unlimited then "unlimited"
                     elif $r.credits.hasCredits then ($r.credits.balance // "yes")
                     else "0" end),
                    ($r.rateLimitReachedType // "")
                  ]
              end
          end
      end
    | map(tostring)
    | join("\u001f")
  ' <<<"$payload" 2>/dev/null || true
}

usage_record_error_status() {
  local err="$1"

  if [[ "$err" == *"token has been invalidated"* || "$err" == *"token_invalidated"* || "$err" == *"invalidated oauth token"* || "$err" == *"token_revoked"* ]]; then
    printf 'login'
  elif [[ "$err" == "refresh timeout" || "$err" == "refresh unavailable" || "$err" == "no response" ]]; then
    printf 'offline'
  else
    printf '%s' "$err"
  fi
}

usage_record_limit_status() {
  local weekly_used="$1"
  local short_used="$2"
  local short_label="$3"
  local reached="$4"
  local stale="$5"
  local cache_age="$6"
  local status="ok"
  local stale_age_label

  if (( weekly_used >= 100 && short_used >= 100 )); then
    status="week+5h cap"
  elif (( weekly_used >= 100 )); then
    status="week cap"
  elif (( short_used >= 100 )); then
    status="${short_label} cap"
  elif [[ -n "$reached" ]]; then
    status="$reached"
  fi
  if [[ "$stale" == "true" ]]; then
    stale_age_label="$(format_cache_age "$cache_age")"
    if [[ -n "$stale_age_label" ]]; then
      status="stale $stale_age_label $status"
    else
      status="stale $status"
    fi
  fi

  printf '%s' "$status"
}

usage_record_for_profile() {
  local profile_name="$1"
  local profile_file="$2"
  local payload="$3"
  local active_fp="$4"
  local profile_fp="${5:-}"
  local mark=" "

  if [[ -n "$active_fp" ]]; then
    [[ -n "$profile_fp" ]] || profile_fp="$(credential_fingerprint "$profile_file" || true)"
  fi
  if [[ -n "$active_fp" && "$profile_fp" == "$active_fp" ]]; then
    mark="*"
  fi

  if [[ -z "$payload" || "$payload" == "null" ]]; then
    printf '1\t-1\t-1\t%s\t%s\t-\t-\t-\tno data\t5h\t-\t-\t\n' "$mark" "$profile_name"
    return 0
  fi

  local extracted kind err cache_age stale plan short_used short_window short_reset weekly_used weekly_window weekly_reset credits reached
  extracted="$(usage_record_extract_payload "$payload")"
  IFS=$'\037' read -r kind err cache_age stale plan short_used short_window short_reset weekly_used weekly_window weekly_reset credits reached <<<"$extracted"

  if [[ "$kind" == "error" ]]; then
    err="$(usage_record_error_status "$err")"
    printf '1\t-1\t-1\t%s\t%s\t-\t-\t-\t%s\t5h\t-\t-\t%s\n' "$mark" "$profile_name" "$err" "$cache_age"
    return 0
  fi

  if [[ "$kind" != "usage" ]]; then
    printf '1\t-1\t-1\t%s\t%s\t-\t-\t-\tno usage\t5h\t-\t-\t%s\n' "$mark" "$profile_name" "$cache_age"
    return 0
  fi

  local short weekly status short_label weekly_reset_text short_reset_text stale_age_label
  short_label="$(window_label "$short_window")"
  IFS=$'\t' read -r short_used short short_reset_text <<<"$(usage_limit_remaining_fields "$short_used" "$short_window" "$short_reset")"
  IFS=$'\t' read -r weekly_used weekly weekly_reset_text <<<"$(usage_limit_remaining_fields "$weekly_used" "$weekly_window" "$weekly_reset")"
  status="$(usage_record_limit_status "$weekly_used" "$short_used" "$short_label" "$reached" "$stale" "$cache_age")"

  printf '0\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
    "$weekly_used" "$short_used" "$mark" "$profile_name" "$plan" "$weekly" "$short" "$status" "$short_label" "$weekly_reset_text" "$short_reset_text" "$cache_age"
}

canonical_usage_active_marks() {
  local seen_active=0
  local valid weekly_used short_used mark profile plan weekly short status short_label weekly_reset short_reset cache_age

  while IFS=$'\t' read -r valid weekly_used short_used mark profile plan weekly short status short_label weekly_reset short_reset cache_age; do
    [[ -n "$profile" ]] || continue
    if [[ "$mark" == "*" ]]; then
      if (( seen_active )); then
        mark="="
      else
        seen_active=1
      fi
    fi
    printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
      "$valid" "$weekly_used" "$short_used" "$mark" "$profile" "$plan" "$weekly" "$short" "$status" "$short_label" "$weekly_reset" "$short_reset" "$cache_age"
  done
}

MENU_ACTION=""
MENU_PROFILE=""

usage_switch_action_label() {
  local profile="$1"
  local weekly="${2:-}"
  local short="${3:-}"
  local short_label="${4:-5h}"
  local detail

  detail="$(usage_switch_detail_label "$weekly" "$short" "$short_label")"
  if [[ -z "$detail" ]]; then
    printf '%s' "$profile"
  else
    printf '%s (%s)' "$profile" "$detail"
  fi
}

usage_switch_detail_label() {
  local weekly="${1:-}"
  local short="${2:-}"
  local short_label="${3:-5h}"
  local parts=()

  [[ -n "$short_label" && "$short_label" != "short" ]] || short_label="5h"
  if [[ -n "$weekly" && "$weekly" != "-" ]]; then
    parts+=("wk $weekly")
  fi
  if [[ -n "$short" && "$short" != "-" ]]; then
    parts+=("$short_label $short")
  fi

  if (( ${#parts[@]} == 0 )); then
    return 0
  elif (( ${#parts[@]} == 1 )); then
    printf '%s' "${parts[0]}"
  else
    printf '%s, %s' "${parts[0]}" "${parts[1]}"
  fi
}

print_selector_row() {
  local action="$1"
  local profile="$2"
  local detail="$3"
  local action_w="$4"
  local profile_w="$5"
  local total_w="$6"
  local detail_w

  detail_w=$((total_w - action_w - profile_w - 2))
  (( detail_w < 1 )) && detail_w=1
  fit_text "$action" "$action_w"
  printf ' '
  fit_profile_text "$profile" "$profile_w"
  printf ' '
  fit_text_rtrim "$detail" "$detail_w"
}

selector_palette_action_tone() {
  case "${1:-}" in
    best)
      printf 'accent'
      ;;
    stay)
      printf 'active'
      ;;
    use)
      printf 'good'
      ;;
    cap)
      printf 'bad'
      ;;
    login|warn)
      printf 'warn'
      ;;
    *)
      printf 'muted'
      ;;
  esac
}

print_selector_palette_primary() {
  local primary="$1"
  local width="$2"
  local action display_action profile action_w profile_w profile_render gap

  if (( width <= 0 )); then
    return 0
  fi
  action="${primary%% *}"
  if [[ "$primary" == "$action" ]]; then
    fit_profile_text "$primary" "$width"
    return 0
  fi
  profile="${primary#* }"
  case "$action" in
    best|stay|use|same|cap|login|warn)
      display_action="$action"
      [[ "$action" == "best" ]] && display_action="use"
      action_w=5
      gap=2
      if (( action_w + gap >= width )); then
        usage_tone_color "$(selector_palette_action_tone "$action")"
        fit_text "$display_action" "$width"
        usage_tone_reset
        return 0
      fi
      usage_tone_color "$(selector_palette_action_tone "$action")"
      fit_text "$display_action" "$action_w"
      usage_tone_reset
      printf '%*s' "$gap" ''
      profile_w=$((width - action_w - gap))
      profile_render="$(usage_display_profile_name "$profile" "$action" "$profile_w")"
      fit_profile_text "$profile_render" "$profile_w"
      ;;
    *)
      fit_profile_text "$primary" "$width"
      ;;
  esac
}

selector_palette_profile_label() {
  local profile="$1"
  local total_w="${2:-0}"
  local width="${3:-0}"

  [[ "$total_w" =~ ^[0-9]+$ ]] || total_w=0
  [[ "$width" =~ ^[0-9]+$ ]] || width=0

  if (( total_w <= 30 )); then
    usage_display_profile_name "$profile" "" 6
  else
    printf '%s' "$profile"
  fi
}

selector_palette_primary_width() {
  local total_w="$1"
  local primary_w=16

  if (( total_w < 20 )); then
    primary_w=11
  elif (( total_w < 32 )); then
    primary_w=13
  elif (( total_w < 60 )); then
    primary_w=19
  elif (( total_w < 68 )); then
    primary_w=20
  elif (( total_w >= 108 )); then
    primary_w=28
  elif (( total_w >= 88 )); then
    primary_w=26
  elif (( total_w >= 68 )); then
    primary_w=22
  fi
  printf '%s' "$primary_w"
}

selector_palette_status_gap() {
  local total_w="$1"

  if (( total_w >= 108 )); then
    printf '8'
  elif (( total_w >= 88 )); then
    printf '6'
  elif (( total_w >= 68 )); then
    printf '4'
  elif (( total_w >= 58 )); then
    printf '3'
  elif (( total_w >= 48 )); then
    printf '2'
  else
    printf '1'
  fi
}

selector_palette_metric_gap() {
  local total_w="$1"

  if (( total_w >= 48 )); then
    printf '2'
  else
    printf '1'
  fi
}

selector_palette_table_widths() {
  local total_w="$1"
  local primary_w week_w short_w status_w metric_w status_gap metric_gap status_max=13

  primary_w="$(selector_palette_primary_width "$total_w")"
  status_gap="$(selector_palette_status_gap "$total_w")"
  metric_gap="$(selector_palette_metric_gap "$total_w")"
  if (( total_w < 58 )); then
    status_max=12
  fi
  if (( total_w < 24 )); then
    primary_w=$((total_w - 5))
    (( primary_w < 11 )) && primary_w=11
    week_w=0
    short_w=4
    status_w=0
  else
    if (( total_w >= 108 )); then
      metric_w=23
    elif (( total_w >= 88 )); then
      metric_w=19
    elif (( total_w >= 68 )); then
      metric_w=13
    else
      metric_w=5
    fi
    week_w="$metric_w"
    if (( total_w < 50 )); then
      short_w=3
    else
      short_w="$metric_w"
    fi
    status_w=$((total_w - primary_w - 1 - week_w - metric_gap - short_w - status_gap))
    while (( status_w < 2 && metric_w > 5 )); do
      metric_w=$((metric_w - 1))
      week_w="$metric_w"
      if (( total_w < 50 )); then
        short_w=3
      else
        short_w="$metric_w"
      fi
      status_w=$((total_w - primary_w - 1 - week_w - metric_gap - short_w - status_gap))
    done
    if (( status_w < 2 )); then
      status_w=2
    fi
    if (( status_w > status_max )); then
      status_w="$status_max"
    fi
  fi

  printf '%s\t%s\t%s\t%s\n' "$primary_w" "$week_w" "$short_w" "$status_w"
}

selector_palette_effective_width() {
  local total_w="$1"
  local primary_w week_w short_w status_w status_gap metric_gap width

  IFS=$'\t' read -r primary_w week_w short_w status_w <<<"$(selector_palette_table_widths "$total_w")"
  status_gap="$(selector_palette_status_gap "$total_w")"
  metric_gap="$(selector_palette_metric_gap "$total_w")"
  if (( week_w == 0 )); then
    width=$((primary_w + 1 + short_w))
  else
    width=$((primary_w + 1 + week_w + metric_gap + short_w))
    if (( status_w > 0 )); then
      width=$((width + status_gap + status_w))
    fi
  fi
  printf '%s' "$width"
}

selector_palette_fzf_colors() {
  printf '%s' 'dark,fg:#eeeeee,fg+:#f4f0e8,bg:#141414,bg+:#262626,hl:#fab283,hl+:#ffd0a0,border:#323232,label:#fab283,prompt:#fab283,pointer:#fab283,header:#9a9a9a,info:#808080,gutter:#141414'
}

selector_compact_by_width() {
  local width="$1"
  local default="$2"
  shift 2
  local cutoff label

  if (( width <= 0 )); then
    printf '%s' "$default"
    return 0
  fi
  while (( $# >= 2 )); do
    cutoff="$1"
    label="$2"
    if (( width < cutoff )); then
      printf '%s' "$label"
      return 0
    fi
    shift 2
  done
  printf '%s' "$default"
}

selector_palette_status_compact() {
  local status="$1"
  local width="${2:-0}"

  case "$status" in
    "no data"|"no usage"|"n/a")
      selector_compact_by_width "$width" "$status" 3 na
      ;;
    "login needed")
      selector_compact_by_width "$width" "$status" 4 log 6 auth 13 login
      ;;
    cap)
      selector_compact_by_width "$width" "$status" 3 cp
      ;;
    "old cap"|"both cap")
      selector_compact_by_width "$width" "$status" 3 cp 7 cap
      ;;
    ready)
      selector_compact_by_width "$width" "$status" 5 ok
      ;;
    offline)
      selector_compact_by_width "$width" "$status" 3 of 7 off
      ;;
    same)
      selector_compact_by_width "$width" "$status" 4 =
      ;;
    *)
      printf '%s' "$status"
      ;;
  esac
}

selector_palette_metric_cell() {
  local percent="$1"
  local width="$2"
  local tone bar_w label label_w=4

  (( width <= 0 )) && return 0
  [[ -n "$percent" ]] || percent="-"
  label="${percent%\%}"
  tone="$(usage_limit_tone "$percent")"

  if [[ "$percent" == "-" ]]; then
    usage_tone_color muted
    if (( width < 8 )); then
      fit_text_center "-" "$width"
    else
      printf '%3s' "-"
      printf '%*s' "$((width - 3))" ''
    fi
    usage_tone_reset
    return 0
  fi

  usage_tone_color "$tone"
  if (( width < 8 )); then
    fit_text_center "$label" "$width"
    usage_tone_reset
    return 0
  fi
  if (( width >= 18 )); then
    label_w=5
  fi
  fit_text_center "$label" "$label_w"
  usage_tone_reset
  printf ' '
  bar_w=$((width - label_w - 1))
  (( bar_w < 0 )) && bar_w=0
  selector_palette_bar "$percent" "$bar_w"
}

selector_palette_primary_header() {
  local primary_w="$1"
  local action_w=5
  local gap=2
  local profile_w profile_label

  profile_w=$((primary_w - action_w - gap))
  (( profile_w < 1 )) && profile_w=1
  if (( profile_w <= 6 )); then
    profile_label="name"
  else
    profile_label="profile"
  fi

  selector_palette_center_header_cell "act" "$action_w"
  printf '%*s' "$gap" ''
  selector_palette_center_header_cell "$profile_label" "$profile_w"
}

selector_palette_header_cell() {
  local text="$1"
  local width="$2"

  (( width <= 0 )) && return 0
  usage_tone_color muted
  fit_text "$text" "$width"
  usage_tone_reset
}

selector_palette_center_header_cell() {
  local text="$1"
  local width="$2"

  (( width <= 0 )) && return 0
  usage_tone_color muted
  fit_text_center "$text" "$width"
  usage_tone_reset
}

selector_palette_metric_header_cell() {
  local text="$1"
  local width="$2"
  local display="$text"

  (( width <= 0 )) && return 0
  [[ "$display" == "week%" ]] && display="wk%"
  if (( ${#display} > width )); then
    if (( width <= 1 )); then
      display="${display:0:width}"
    elif [[ "$display" == *% ]]; then
      display="${display:0:width-1}%"
    else
      display="${display:0:width}"
    fi
  fi

  usage_tone_color muted
  fit_text_center "$display" "$width"
  usage_tone_reset
  return 0
}

selector_palette_table_header() {
  local total_w="$1"
  local primary_w week_w short_w status_w short_label status_label status_gap metric_gap

  IFS=$'\t' read -r primary_w week_w short_w status_w <<<"$(selector_palette_table_widths "$total_w")"
  status_gap="$(selector_palette_status_gap "$total_w")"
  metric_gap="$(selector_palette_metric_gap "$total_w")"
  short_label="${USAGE_SHORT_LABEL:-5h}"
  [[ -n "$short_label" && "$short_label" != "short" ]] || short_label="5h"
  short_label="${short_label}%"
  status_label="status"
  if (( status_w > 0 && status_w < 7 )); then
    status_label="st"
  fi

  selector_palette_primary_header "$primary_w"
  printf ' '
  if (( week_w > 0 )); then
    selector_palette_metric_header_cell "week%" "$week_w"
    printf '%*s' "$metric_gap" ''
  fi
  selector_palette_metric_header_cell "$short_label" "$short_w"
  if (( status_w > 0 )); then
    printf '%*s' "$status_gap" ''
    selector_palette_center_header_cell "$status_label" "$status_w"
  fi
  printf '\n'
}

print_selector_palette_table_row() {
  local primary="$1"
  local weekly="$2"
  local short="$3"
  local status="$4"
  local raw_status="$5"
  local valid="$6"
  local total_w="$7"
  local primary_w week_w short_w status_w compact_status status_gap metric_gap

  IFS=$'\t' read -r primary_w week_w short_w status_w <<<"$(selector_palette_table_widths "$total_w")"
  status_gap="$(selector_palette_status_gap "$total_w")"
  metric_gap="$(selector_palette_metric_gap "$total_w")"
  print_selector_palette_primary "$primary" "$primary_w"
  printf ' '

  if (( week_w == 0 )); then
    if [[ "$valid" == "0" ]]; then
      selector_palette_metric_cell "$short" "$short_w"
    else
      compact_status="$(selector_palette_status_compact "$status" "$short_w")"
      print_toned_fit_center "$compact_status" "$short_w" "$(usage_status_tone "$raw_status" "$valid")"
    fi
    return 0
  fi

  compact_status="$(selector_palette_status_compact "$status" "$status_w")"
  if [[ "$valid" == "0" ]]; then
    selector_palette_metric_cell "$weekly" "$week_w"
    printf '%*s' "$metric_gap" ''
    selector_palette_metric_cell "$short" "$short_w"
  else
    selector_palette_metric_cell "-" "$week_w"
    printf '%*s' "$metric_gap" ''
    selector_palette_metric_cell "-" "$short_w"
  fi
  printf '%*s' "$status_gap" ''
  print_toned_fit "$compact_status" "$status_w" "$(usage_status_tone "$raw_status" "$valid")"
}

selector_palette_bar() {
  local percent="$1"
  local width="$2"
  local tone value units full partial used inner_w bg_style
  local partial_glyphs=("" "▏" "▎" "▍" "▌" "▋" "▊" "▉")
  local bar_border_glyph="▁"

  tone="$(usage_limit_tone "$percent")"
  bg_style="${CODEX_AUTH_SELECTOR_BAR_STYLE:-bg}"
  inner_w="$width"
  percent="${percent%\%}"
  if [[ "$percent" =~ ^-?[0-9]+$ ]]; then
    value="$percent"
    (( value < 0 )) && value=0
    (( value > 100 )) && value=100
    if usage_unicode_enabled; then
      units=$(((value * inner_w * 8 + 50) / 100))
      full=$((units / 8))
      partial=$((units % 8))
      if (( full >= inner_w )); then
        full="$inner_w"
        partial=0
      fi
      used="$full"
      (( partial > 0 && used < inner_w )) && used=$((used + 1))
      if usage_color_active && [[ "$bg_style" == "bg" ]]; then
        if (( used > 0 )); then
          usage_tone_bg "$tone"
          usage_tone_color track_edge
          repeat_glyph "$bar_border_glyph" "$used"
          usage_tone_reset
        fi
        if (( inner_w > used )); then
          usage_tone_bg track
          usage_tone_color track_edge
          repeat_glyph "$bar_border_glyph" "$((inner_w - used))"
          usage_tone_reset
        fi
      else
        usage_tone_color "$tone"
        repeat_glyph "█" "$full"
        (( partial > 0 && full < inner_w )) && printf '%s' "${partial_glyphs[$partial]}"
        usage_tone_reset
        (( inner_w > used )) && printf '%*s' "$((inner_w - used))" ''
      fi
    else
      full=$(((value * inner_w + 50) / 100))
      (( full > inner_w )) && full="$inner_w"
      if usage_color_active && [[ "$bg_style" == "bg" ]]; then
        if (( full > 0 )); then
          usage_tone_bg "$tone"
          usage_tone_color track_edge
          repeat_glyph "$bar_border_glyph" "$full"
          usage_tone_reset
        fi
        if (( inner_w > full )); then
          usage_tone_bg track
          usage_tone_color track_edge
          repeat_glyph "$bar_border_glyph" "$((inner_w - full))"
          usage_tone_reset
        fi
      else
        usage_tone_color "$tone"
        repeat_glyph "#" "$full"
        usage_tone_reset
        (( inner_w > full )) && printf '%*s' "$((inner_w - full))" ''
      fi
    fi
  else
    if usage_color_active && [[ "$bg_style" == "bg" ]]; then
      usage_tone_bg track
      usage_tone_color track_edge
      repeat_glyph "$bar_border_glyph" "$inner_w"
      usage_tone_reset
    else
      printf '%*s' "$inner_w" ''
    fi
  fi
}

selector_palette_badge() {
  local label="$1"
  local tone="${2:-muted}"

  usage_tone_color "$tone"
  printf '%s' "$label"
  usage_tone_reset
}

selector_action_role() {
  local action="$1"
  local role_w="$2"

  if (( role_w <= 1 )); then
    case "$action" in
      switch)
        printf ' '
        ;;
      best)
        printf 'u'
        ;;
      cap)
        printf 'c'
        ;;
      login)
        printf 'l'
        ;;
      stay)
        usage_active_glyph
        ;;
      *)
        usage_meta_glyph
        ;;
    esac
    return 0
  fi

  if (( role_w < 6 )); then
    case "$action" in
      best)
        printf 'use'
        ;;
      cap)
        printf 'cap'
        ;;
      same)
        printf 'same'
        ;;
      switch)
        printf 'use'
        ;;
      login)
        printf 'login'
        ;;
      *)
        printf 'stay'
        ;;
    esac
    return 0
  fi

  if [[ "$action" == "switch" ]]; then
    printf 'use'
  elif [[ "$action" == "best" ]]; then
    printf 'use'
  elif [[ "$action" == "same" ]]; then
    printf 'same'
  else
    printf '%s' "$action"
  fi
}

selector_header_action() {
  local role_w="$1"

  if (( role_w <= 1 )); then
    printf ' '
  elif (( role_w < 6 )); then
    printf 'act'
  else
    printf 'action'
  fi
}

usage_plain_summary_line() {
  local old_color="${USAGE_COLOR_ENABLED:-0}"
  local line

  USAGE_COLOR_ENABLED=0
  line="$(print_usage_summary_line "$@")"
  USAGE_COLOR_ENABLED="$old_color"
  printf '%s' "$line"
}

usage_metadata_summary_line() {
  local render_w="$1"
  shift
  local summary_w=$((render_w * 2))
  local line sep record valid weekly_used short_used mark profile plan weekly short status short_label weekly_reset short_reset cache_age
  local cache_age_max=-1 cache_age_label

  if (( render_w < 40 )); then
    summary_w="$render_w"
  else
    (( summary_w < 64 )) && summary_w=64
    (( summary_w > 132 )) && summary_w=132
  fi
  line="$(usage_plain_summary_line "$summary_w" "$@")"
  sep="$(usage_separator)"

  if [[ "$line" != cache\ * && "$line" != *"${sep}cache "* ]]; then
    for record in "$@"; do
      IFS=$'\t' read -r valid weekly_used short_used mark profile plan weekly short status short_label weekly_reset short_reset cache_age <<<"$record"
      if [[ "$cache_age" =~ ^[0-9]+$ ]] && (( cache_age > cache_age_max )); then
        cache_age_max="$cache_age"
      fi
    done
    if (( cache_age_max >= 0 )); then
      cache_age_label="$(format_cache_age "$cache_age_max")"
      [[ -n "$cache_age_label" ]] && line+="${sep}cache $cache_age_label"
    fi
  fi

  printf '%s' "$line"
}

selector_header_spaced_text() {
  local text="$1"
  local sep
  sep="$(usage_separator)"

  text="${text//capped /cap }"
  while [[ "$text" == *"$sep"* ]]; do
    printf '%s   ' "${text%%"$sep"*}"
    text="${text#*"$sep"}"
  done
  printf '%s' "$text"
}

selector_header_identity_text() {
  local text="$1"
  local value_w="$2"
  local name detail name_w detail_w

  IFS=' ' read -r name detail <<<"$text"
  if [[ -z "$detail" || ! "$value_w" =~ ^[0-9]+$ || "$value_w" -lt 18 ]]; then
    printf '%s' "$text"
    return 0
  fi

  name_w=12
  (( value_w < 34 )) && name_w=10
  (( value_w < 26 )) && name_w=8
  if (( name_w > value_w - 8 )); then
    name_w=$((value_w - 8))
  fi
  if (( name_w < 6 )); then
    printf '%s' "$text"
    return 0
  fi

  detail_w=$((value_w - name_w - 2))
  (( detail_w < 1 )) && detail_w=1
  fit_profile_text "$name" "$name_w"
  printf '  '
  fit_text "$detail" "$detail_w"
}

selector_header_label_tone() {
  case "${1:-}" in
    best)
      printf 'accent'
      ;;
    active)
      printf 'active'
      ;;
    old)
      printf 'warn'
      ;;
    *)
      printf 'muted'
      ;;
  esac
}

selector_header_meta_line() {
  local label="$1"
  local text="$2"
  local total_w="$3"
  local label_w="$4"
  local frame="${5:-0}"
  local outer_w="${6:-$total_w}"
  local value_w value tl tr bl br vl vr glyph

  (( label_w < 1 )) && label_w=1
  value_w=$((total_w - label_w - 2))
  (( value_w < 1 )) && value_w=1
  case "$label" in
    best|active|old|status)
      value="$(selector_header_identity_text "$text" "$value_w")"
      ;;
    *)
      value="$(selector_header_spaced_text "$text")"
      ;;
  esac

  if (( frame )); then
    IFS=$'\t' read -r tl tr bl br vl vr glyph <<<"$(usage_frame_chars)"
    usage_tone_color muted
    printf '%s ' "$vl"
    usage_tone_reset
  fi
  print_toned_fit "$label" "$label_w" "$(selector_header_label_tone "$label")"
  printf '  '
  fit_text "$value" "$value_w"
  if (( frame )); then
    usage_tone_color muted
    printf ' %s' "$vr"
    usage_tone_reset
  fi
  printf '\n'
}

selector_header_primary_line() {
  local text="$1"
  local total_w="$2"
  local label_w="$3"
  local frame="${4:-0}"
  local outer_w="${5:-$total_w}"
  local label="status"
  local value="$text"

  if [[ "$text" == "best "* ]]; then
    label="best"
    value="${text#best }"
  elif [[ "$text" == "active "* ]]; then
    label="active"
    value="${text#active }"
  elif [[ "$text" == "old "* ]]; then
    label="old"
    value="${text#old }"
  fi

  selector_header_meta_line "$label" "$value" "$total_w" "$label_w" "$frame" "$outer_w"
}

print_usage_title_line() {
  local title="$1"
  local total_w="$2"
  local title_w rule_w glyph

  [[ -n "$title" ]] || return 0
  (( total_w >= 40 )) || return 0

  title_w=${#title}
  if (( title_w + 2 >= total_w )); then
    fit_text "$title" "$total_w"
    printf '\n'
    return 0
  fi

  glyph="$(usage_rule_glyph)"
  rule_w=$((total_w - title_w - 1))
  usage_tone_color accent
  printf '%s' "$title"
  usage_tone_reset
  printf ' '
  usage_tone_color muted
  repeat_glyph "$glyph" "$rule_w"
  usage_tone_reset
  printf '\n'
}

usage_frame_chars() {
  if usage_unicode_enabled; then
    printf '╭\t╮\t╰\t╯\t│\t│\t─\n'
  else
    printf '+\t+\t+\t+\t|\t|\t-\n'
  fi
}

print_usage_frame_top() {
  local title="$1"
  local width="$2"
  local tl tr bl br vl vr glyph label rule_w
  IFS=$'\t' read -r tl tr bl br vl vr glyph <<<"$(usage_frame_chars)"

  label=" $title "
  rule_w=$((width - 2 - ${#label}))
  (( rule_w < 0 )) && rule_w=0
  usage_tone_color muted
  printf '%s' "$tl"
  usage_tone_reset
  usage_tone_color accent
  printf '%s' "$label"
  usage_tone_reset
  usage_tone_color muted
  repeat_glyph "$glyph" "$rule_w"
  printf '%s\n' "$tr"
  usage_tone_reset
}

print_usage_frame_bottom() {
  local width="$1"
  local tl tr bl br vl vr glyph
  IFS=$'\t' read -r tl tr bl br vl vr glyph <<<"$(usage_frame_chars)"

  usage_tone_color muted
  printf '%s' "$bl"
  repeat_glyph "$glyph" "$((width - 2))"
  printf '%s\n' "$br"
  usage_tone_reset
}

usage_summary_split_once() {
  local text="$1"
  local sep="$2"

  if [[ "$text" == *"$sep"* ]]; then
    printf '%s\t%s\n' "${text%%"$sep"*}" "${text#*"$sep"}"
  else
    printf '%s\t\n' "$text"
  fi
}

print_usage_summary_block() {
  local summary="$1"
  local total_w="$2"
  local title="${3:-}"
  local sep first rest best_subject active_part pool_part pool_head candidate value_candidate next_part
  local frame=0 body_w="$total_w"

  sep="$(usage_separator)"
  IFS=$'\t' read -r first rest <<<"$(usage_summary_split_once "$summary" "$sep")"
  case "$first" in
    best|"best active"|"best is active")
      if [[ -n "$rest" ]]; then
        IFS=$'\t' read -r next_part rest <<<"$(usage_summary_split_once "$rest" "$sep")"
        first="$first $next_part"
      fi
      ;;
  esac
  if [[ "$first" == "best active "* ]]; then
    best_subject="${first#best active }"
    first="best $best_subject"
  elif [[ "$first" == "best is active "* ]]; then
    best_subject="${first#best is active }"
    first="best $best_subject"
  fi

  active_part=""
  pool_part="$rest"
  if [[ -n "$pool_part" ]]; then
    IFS=$'\t' read -r pool_head next_part <<<"$(usage_summary_split_once "$pool_part" "$sep")"
    if [[ "$pool_head" == "active "* || "$pool_head" == "no active" ]]; then
      active_part="$pool_head"
      pool_part="$next_part"
    fi
  fi
  if [[ -n "$pool_part" && -z "$active_part" ]]; then
    IFS=$'\t' read -r pool_head next_part <<<"$(usage_summary_split_once "$pool_part" "$sep")"
    case "$pool_head" in
      ready*|capped*|cap*|login*|"no data"*|offline*|stale*|cache*)
        ;;
      *)
        candidate="$first $pool_head"
        value_candidate="$candidate"
        [[ "$candidate" == "best "* ]] && value_candidate="${candidate#best }"
        if (( ${#value_candidate} <= total_w - 7 )); then
          first="$candidate"
          pool_part="$next_part"
        fi
        ;;
    esac
  fi

  if [[ -n "$title" ]] && (( total_w >= 42 )); then
    frame=1
    body_w=$((total_w - 4))
    print_usage_frame_top "$title" "$total_w"
  else
    print_usage_title_line "$title" "$total_w"
  fi

  if (( body_w >= 64 )); then
    selector_header_primary_line "$first" "$body_w" 7 "$frame" "$total_w"
    if [[ -n "$active_part" ]]; then
      selector_header_primary_line "$active_part" "$body_w" 7 "$frame" "$total_w"
    fi
    if [[ -n "$pool_part" ]]; then
      selector_header_meta_line "stats" "$pool_part" "$body_w" 7 "$frame" "$total_w"
    fi
    (( frame )) && print_usage_frame_bottom "$total_w"
    printf '\n'
  elif (( body_w >= 40 )); then
    selector_header_primary_line "$first" "$body_w" 6 "$frame" "$total_w"
    if [[ -n "$active_part" ]]; then
      selector_header_primary_line "$active_part" "$body_w" 6 "$frame" "$total_w"
    fi
    (( frame )) && print_usage_frame_bottom "$total_w"
    printf '\n'
  else
    selector_header_primary_line "$first" "$body_w" 5 "$frame" "$total_w"
    (( frame )) && print_usage_frame_bottom "$total_w"
  fi
  return 0
}

selector_header_text() {
  local summary="$1"
  local controls="$2"
  local role_w="$3"
  local profile_w="$4"
  local cell_w="$5"
  local status_w="$6"
  local total_w="$7"
  local mode="$8"
  local title="${9:-}"

  print_usage_summary_block "$summary" "$total_w" "$title"
  print_usage_render_header "$(selector_header_action "$role_w")" "$(usage_header_profile "$mode")" "$(usage_header_week "$mode")" "$(usage_header_short "$mode")" "$(usage_header_state "$mode")" \
    "$role_w" "$profile_w" "$cell_w" "$status_w" "$mode"
  repeat_glyph "$(usage_rule_glyph)" "$total_w"
  printf '\n'
  fit_text_rtrim "$controls" "$total_w"
}

selector_palette_header_text() {
  local summary="$1"
  local controls="$2"
  local total_w="$3"

  selector_palette_controls_line "$controls" "$total_w"
  printf '\n'
  if [[ "${CODEX_AUTH_SELECTOR_CONTEXT:-0}" == "1" ]]; then
    selector_palette_context_line "$summary" "$total_w"
  fi
  selector_palette_table_header "$total_w"
}

selector_palette_take_short_limit() {
  local text="$1"
  local name="" label="" value="" token
  local parts=()
  local i

  read -r -a parts <<<"$text"
  if (( ${#parts[@]} == 0 )); then
    return 0
  fi
  name="${parts[0]}"
  for ((i = 1; i < ${#parts[@]} - 1; i++)); do
    token="${parts[$i]}"
    case "$token" in
      5h|short|wk)
        label="$token"
        value="${parts[$((i + 1))]}"
        break
        ;;
    esac
  done
  if [[ -n "$label" && -n "$value" ]]; then
    printf '%s %s %s' "$name" "$label" "$value"
  else
    printf '%s' "$text"
  fi
}

selector_palette_compact_active_limit() {
  local text="$1"
  local name="" label="" value="" token
  local parts=()
  local i

  read -r -a parts <<<"$text"
  if (( ${#parts[@]} == 0 )); then
    return 0
  fi
  name="$(usage_display_profile_name "${parts[0]}" "" 6)"
  for ((i = 1; i < ${#parts[@]} - 1; i++)); do
    token="${parts[$i]}"
    case "$token" in
      5h|short|wk)
        label="$token"
        value="${parts[$((i + 1))]}"
        break
        ;;
    esac
  done
  if [[ -n "$value" ]]; then
    printf 'act %s %s' "$name" "$value"
  else
    printf 'act %s' "$name"
  fi
}

selector_palette_context_word_tone() {
  local word="$1"
  local section="${2:-}"

  case "$word" in
    best)
      printf 'accent'
      ;;
    active|act)
      printf 'active'
      ;;
    ready)
      printf 'good'
      ;;
    cap)
      printf 'bad'
      ;;
    login)
      printf 'warn'
      ;;
    *%)
      usage_limit_tone "$word"
      ;;
    *)
      case "$section" in
        best)
          printf 'accent'
          ;;
        active|act)
          printf 'active'
          ;;
        ready)
          printf 'good'
          ;;
        cap)
          printf 'bad'
          ;;
        login)
          printf 'warn'
          ;;
        *)
          printf 'muted'
          ;;
      esac
      ;;
  esac
}

print_selector_palette_context_line() {
  local line="$1"
  local total_w="$2"
  local rest spaces word section="" tone

  if (( ${#line} > total_w )); then
    fit_text_rtrim "$line" "$total_w"
    printf '\n'
    return 0
  fi
  if ! usage_color_active; then
    fit_text_rtrim "$line" "$total_w"
    printf '\n'
    return 0
  fi

  rest="$line"
  while [[ -n "$rest" ]]; do
    if [[ "$rest" =~ ^([[:space:]]*)([^[:space:]]+)(.*)$ ]]; then
      spaces="${BASH_REMATCH[1]}"
      word="${BASH_REMATCH[2]}"
      rest="${BASH_REMATCH[3]}"
      printf '%s' "$spaces"
      tone="$(selector_palette_context_word_tone "$word" "$section")"
      usage_tone_color "$tone"
      printf '%s' "$word"
      usage_tone_reset
      case "$word" in
        best|active|act|ready|cap|login)
          section="$word"
          ;;
      esac
    else
      printf '%s' "$rest"
      break
    fi
  done
  printf '\n'
}

selector_palette_context_line() {
  local summary="$1"
  local total_w="$2"
  local sep first rest active_part stats_part stats_head line best_value active_value compact_active_value compact_best_value stat_token prefix added_stats=0
  local best_parts=()

  sep="$(usage_separator)"
  first="$summary"
  rest=""
  if [[ "$summary" == *"$sep"* ]]; then
    first="${summary%%"$sep"*}"
    rest="${summary#*"$sep"}"
  fi
  if [[ ( "$first" == "best" || "$first" == "best active" || "$first" == "best is active" ) && -n "$rest" ]]; then
    if [[ "$rest" == *"$sep"* ]]; then
      first="$first ${rest%%"$sep"*}"
      rest="${rest#*"$sep"}"
    else
      first="$first $rest"
      rest=""
    fi
  fi
  case "$first" in
    "best active "*)
      first="best ${first#best active }"
      ;;
    "best is active "*)
      first="best ${first#best is active }"
      ;;
  esac

  active_part=""
  stats_part="$rest"
  if [[ -n "$stats_part" ]]; then
    stats_head="$stats_part"
    [[ "$stats_part" == *"$sep"* ]] && stats_head="${stats_part%%"$sep"*}"
    if [[ "$stats_head" == active\ * || "$stats_head" == "no active" ]]; then
      active_part="$stats_head"
      if [[ "$stats_part" == *"$sep"* ]]; then
        stats_part="${stats_part#*"$sep"}"
      else
        stats_part=""
      fi
    fi
  fi

  best_value="$first"
  [[ "$best_value" == best\ * ]] && best_value="best $(selector_palette_take_short_limit "${best_value#best }")"
  compact_best_value="$best_value"
  if [[ "$best_value" == best\ * ]]; then
    read -r -a best_parts <<<"${best_value#best }"
    if (( ${#best_parts[@]} > 0 )); then
      compact_best_value="best ${best_parts[0]}"
    fi
  fi
  active_value="$active_part"
  [[ "$active_value" == active\ * ]] && active_value="active $(selector_palette_take_short_limit "${active_value#active }")"

  line="$best_value"
  if [[ -n "$active_value" ]]; then
    if (( ${#line} + ${#active_value} + 3 <= total_w )); then
      line+="   $active_value"
    else
      compact_active_value="$(selector_palette_compact_active_limit "${active_part#active }")"
      if [[ -n "$compact_active_value" ]] && (( ${#line} + ${#compact_active_value} + 3 <= total_w )); then
        line+="   $compact_active_value"
      elif [[ -n "$compact_active_value" && "$compact_best_value" != "$best_value" ]] \
        && (( ${#compact_best_value} + ${#compact_active_value} + 3 <= total_w )); then
        line="$compact_best_value   $compact_active_value"
      fi
    fi
  fi
  while [[ -n "$stats_part" ]]; do
    if [[ "$stats_part" == *"$sep"* ]]; then
      stat_token="${stats_part%%"$sep"*}"
      stats_part="${stats_part#*"$sep"}"
    else
      stat_token="$stats_part"
      stats_part=""
    fi
    stat_token="${stat_token//capped /cap }"
    [[ "$stat_token" == cache\ * ]] && continue
    [[ -n "$stat_token" ]] || continue
    if (( added_stats )); then
      prefix=" "
    else
      prefix="   "
    fi
    if (( ${#line} + ${#stat_token} + ${#prefix} <= total_w )); then
      line+="$prefix$stat_token"
      added_stats=1
    else
      break
    fi
  done
  print_selector_palette_context_line "$line" "$total_w"
}

selector_palette_controls_line() {
  local fallback="$1"
  local total_w="$2"
  local left left_compact left_short left_tiny right compact sep tiny_controls tiny_line

  if usage_unicode_enabled; then
    left="Auth · Codex profiles"
    left_compact="Auth · profiles"
    left_short="Auth · prof"
    left_tiny="Auth"
    right="enter select · esc stay"
    compact="enter · esc"
  else
    left="Auth | Codex profiles"
    left_compact="Auth | profiles"
    left_short="Auth | prof"
    left_tiny="Auth"
    right="enter select | esc stay"
    compact="enter | esc"
  fi
  case "$fallback" in
    number*|num*|[0-9]*)
      right="$fallback"
      compact="$fallback"
      ;;
  esac

  if (( ${#left} + ${#right} + 3 <= total_w )); then
    :
  elif (( ${#left_compact} + ${#compact} + 3 <= total_w )); then
    left="$left_compact"
    right="$compact"
  elif (( ${#left_short} + ${#compact} + 3 <= total_w )); then
    left="$left_short"
    right="$compact"
  elif (( ${#left_tiny} + ${#compact} + 3 <= total_w )); then
    left="$left_tiny"
    right="$compact"
  else
    sep="$(usage_separator)"
    tiny_controls="$compact"
    tiny_controls="${tiny_controls// | / }"
    tiny_controls="${tiny_controls// · / }"
    if (( ${#left_tiny} + ${#tiny_controls} + 3 > total_w )); then
      tiny_controls="${tiny_controls/ q stay/ q}"
    fi
    tiny_line="$left_tiny$sep$tiny_controls"
    fit_text_rtrim "$tiny_line" "$total_w"
    return 0
  fi

  if usage_color_active; then
    usage_tone_color accent
    printf '%s' "$left"
    usage_tone_reset
    printf '   '
    usage_tone_color muted
    printf '%s' "$right"
    usage_tone_reset
  else
    printf '%s   %s' "$left" "$right"
  fi
}

summary_token_by_prefix() {
  local summary="$1"
  local prefix="$2"
  local sep token

  sep="$(usage_separator)"
  while [[ -n "$summary" ]]; do
    if [[ "$summary" == *"$sep"* ]]; then
      token="${summary%%"$sep"*}"
      summary="${summary#*"$sep"}"
    else
      token="$summary"
      summary=""
    fi
    token="${token//capped /cap }"
    if [[ "$token" == "$prefix "* ]]; then
      printf '%s' "$token"
      return 0
    fi
  done
  return 1
}

palette_compact_label() {
  local label="$1"

  case "$label" in
    Codex\ profiles|Saved\ profiles)
      printf 'Profiles'
      ;;
    Active\ profile)
      printf 'Active'
      ;;
    Removed\ profile)
      printf 'Removed'
      ;;
    *)
      printf '%s' "$label"
      ;;
  esac
}

print_palette_title_line() {
  local namespace="$1"
  local label="$2"
  local right="$3"
  local total_w="$4"
  local sep left compact_label compact_left gap

  if usage_unicode_enabled; then
    sep=" · "
  else
    sep=" | "
  fi
  left="$namespace$sep$label"
  if (( ${#left} > total_w || ( ${#right} > 0 && ${#left} + ${#right} + 2 > total_w ) )); then
    compact_label="$(palette_compact_label "$label")"
    compact_left="$namespace$sep$compact_label"
    if (( ${#compact_left} < ${#left} )); then
      left="$compact_left"
    fi
  fi
  if (( ${#right} > 0 && ${#left} + ${#right} + 2 <= total_w )); then
    usage_tone_color accent
    printf '%s' "$left"
    usage_tone_reset
    gap=$((total_w - ${#left} - ${#right}))
    printf '%*s' "$gap" ''
    usage_tone_color muted
    printf '%s' "$right"
    usage_tone_reset
    printf '\n'
    return 0
  fi

  usage_tone_color accent
  fit_text_rtrim "$left" "$total_w"
  usage_tone_reset
  printf '\n'
}

print_flat_context_line() {
  local summary="$1"
  local total_w="$2"
  local text sep token parts=()

  sep="$(usage_separator)"
  while [[ -n "$summary" ]]; do
    if [[ "$summary" == *"$sep"* ]]; then
      token="${summary%%"$sep"*}"
      summary="${summary#*"$sep"}"
    else
      token="$summary"
      summary=""
    fi
    token="${token//capped /cap }"
    [[ "$token" == cache\ * ]] && continue
    [[ -n "$token" ]] && parts+=("$token")
  done

  if (( ${#parts[@]} == 0 )); then
    text=""
  else
    text="${parts[0]}"
    local i
    for ((i = 1; i < ${#parts[@]}; i++)); do
      text+="   ${parts[$i]}"
    done
  fi
  print_selector_palette_context_line "$text" "$total_w"
}

print_palette_summary_header() {
  local namespace="$1"
  local label="$2"
  local summary="$3"
  local total_w="$4"
  local mode="${5:-flat}"
  local gap="${6:-1}"
  local right=""

  right="$(summary_token_by_prefix "$summary" cache || true)"
  print_palette_title_line "$namespace" "$label" "$right" "$total_w"
  if [[ "$mode" == "usage" && "${CODEX_AUTH_USAGE_CONTEXT:-0}" == "1" ]]; then
    selector_palette_context_line "$summary" "$total_w"
  elif [[ "$mode" == "usage" ]]; then
    :
  else
    print_flat_context_line "$summary" "$total_w"
  fi
  if (( gap )); then
    printf '\n'
  fi
}

selector_fzf_base_height() {
  local row_count="$1"
  local fzf_height=$((row_count + 8))
  local term_lines max_height

  (( fzf_height < 12 )) && fzf_height=12
  term_lines="${LINES:-}"
  [[ "$term_lines" =~ ^[0-9]+$ ]] || term_lines="$(tput lines 2>/dev/null || true)"
  if [[ "$term_lines" =~ ^[0-9]+$ ]]; then
    max_height=$((term_lines - 2))
    (( max_height < 12 )) && max_height=12
    (( fzf_height > max_height )) && fzf_height="$max_height"
  elif (( fzf_height > 24 )); then
    fzf_height=24
  fi

  printf '%s\t%s\n' "$fzf_height" "$term_lines"
}

selector_fzf_theme_color() {
  local selector_palette_mode="$1"
  local color_arg=""
  local opencode_theme=0

  if [[ -n "${CODEX_AUTH_FZF_THEME:-}" ]]; then
    if [[ "$CODEX_AUTH_FZF_THEME" == "codex" || "$CODEX_AUTH_FZF_THEME" == "1" ]]; then
      color_arg="$(selector_palette_fzf_colors)"
      opencode_theme=1
    else
      color_arg="$CODEX_AUTH_FZF_THEME"
    fi
  elif (( selector_palette_mode )); then
    if usage_color_active; then
      color_arg="$(selector_palette_fzf_colors)"
    else
      color_arg="bw"
    fi
    opencode_theme=1
  fi

  printf '%s\t%s\n' "$color_arg" "$opencode_theme"
}

selector_fzf_controls() {
  local total_w="$1"
  local fzf_prompt fzf_pointer selector_control_sep selector_controls

  if usage_unicode_enabled; then
    fzf_prompt='filter ▸ '
    fzf_pointer='▸'
    selector_control_sep=' · '
  else
    fzf_prompt='filter > '
    fzf_pointer='>'
    selector_control_sep=' | '
  fi
  if (( total_w < 32 )); then
    selector_controls="enter${selector_control_sep}esc stay${selector_control_sep}filter"
  else
    selector_controls="enter select${selector_control_sep}esc stay${selector_control_sep}type filter"
  fi

  printf '%s\t%s\t%s\n' "$fzf_prompt" "$fzf_pointer" "$selector_controls"
}

selector_fzf_apply_frame() {
  local fzf_opencode_theme="$1"
  local total_w="$2"
  local -n fzf_prompt_ref="$3"
  local -n fzf_pointer_ref="$4"
  local -n fzf_border_args_ref="$5"
  local -n fzf_margin_args_ref="$6"

  if (( fzf_opencode_theme )); then
    local palette_effective_w right_margin terminal_w
    fzf_pointer_ref=' '
    fzf_prompt_ref='filter '
    terminal_w="$(terminal_width)"
    palette_effective_w="$(selector_palette_effective_width "$total_w")"
    right_margin=$((terminal_w - palette_effective_w - 4))
    if (( right_margin > 0 )); then
      fzf_margin_args_ref+=(--margin="0,$right_margin,0,0")
    fi
    fzf_border_args_ref+=(--border=none)
  else
    fzf_border_args_ref+=(--border=rounded --border-label=' auth profiles ' --border-label-pos=3)
  fi
}

selector_fzf_prepare_header() {
  local -n header_rows_ref="$1"
  local summary_text="$2"
  local selector_controls="$3"
  local total_w="$4"
  local role_w="$5"
  local profile_w="$6"
  local cell_w="$7"
  local status_w="$8"
  local mode="$9"
  local fzf_opencode_theme="${10}"
  local term_lines="${11}"
  local -n fzf_header_ref="${12}"
  local -n fzf_height_ref="${13}"
  local -n fzf_height_arg_ref="${14}"
  local -n fzf_outer_top_padding_ref="${15}"
  local -n fzf_header_line_count_ref="${16}"
  local -n fzf_padding_args_ref="${17}"
  local -n fzf_header_args_ref="${18}"
  local fzf_header_line max_height fzf_vertical_padding=0

  if (( fzf_opencode_theme )); then
    fzf_header_ref="$(selector_palette_header_text "$summary_text" "$selector_controls" "$total_w")"
    fzf_header_line_count_ref=0
    while IFS= read -r fzf_header_line; do
      fzf_header_line_count_ref=$((fzf_header_line_count_ref + 1))
    done <<<"$fzf_header_ref"
    (( fzf_header_line_count_ref < 1 )) && fzf_header_line_count_ref=1
    fzf_height_ref=$(( ${#header_rows_ref[@]} + fzf_header_line_count_ref + 1 ))
    if [[ "$term_lines" =~ ^[0-9]+$ ]]; then
      max_height=$((term_lines - 2))
      (( max_height < 6 )) && max_height=6
      if (( fzf_height_ref + 2 <= max_height )); then
        fzf_height_ref=$((fzf_height_ref + 2))
        fzf_vertical_padding=1
      fi
      (( fzf_height_ref > max_height )) && fzf_height_ref="$max_height"
    elif (( fzf_height_ref < 22 )); then
      fzf_height_ref=$((fzf_height_ref + 2))
      fzf_vertical_padding=1
    fi
    if (( fzf_vertical_padding )); then
      fzf_padding_args_ref+=(--padding=1,0,1,0)
    fi
    if [[ "${CODEX_AUTH_SELECTOR_CENTER:-0}" == "1" && "$term_lines" =~ ^[0-9]+$ ]] && (( term_lines > fzf_height_ref + 1 )); then
      fzf_outer_top_padding_ref=$(((term_lines - fzf_height_ref) / 2))
    fi
    fzf_height_arg_ref="~$fzf_height_ref"
    fzf_header_args_ref+=(--header-lines="$fzf_header_line_count_ref" --header-first)
  else
    fzf_header_ref="$(selector_header_text "$summary_text" "$selector_controls" "$role_w" "$profile_w" "$cell_w" "$status_w" "$total_w" "$mode")"
    fzf_header_args_ref+=(--header="$fzf_header_ref")
  fi
}

selector_fzf_menu() {
  local -n rows_ref="$1"
  local summary_text="$2"
  local total_w="$3"
  local role_w="$4"
  local profile_w="$5"
  local cell_w="$6"
  local status_w="$7"
  local mode="$8"
  local selector_palette_mode="$9"
  local fzf_height fzf_height_arg choice kind action profile_choice fzf_prompt fzf_pointer fzf_header term_lines
  local fzf_outer_top_padding=0
  local fzf_pad_i=0
  local fzf_header_line_count=1
  local fzf_color_args=()
  local fzf_border_args=()
  local fzf_margin_args=()
  local fzf_padding_args=()
  local fzf_ellipsis_args=()
  local fzf_header_args=()
  local fzf_layout_args=(--layout=reverse)
  local fzf_opencode_theme=0
  local selector_controls
  local fzf_color_arg

  IFS=$'\t' read -r fzf_height term_lines <<<"$(selector_fzf_base_height "${#rows_ref[@]}")"
  IFS=$'\t' read -r fzf_color_arg fzf_opencode_theme <<<"$(selector_fzf_theme_color "$selector_palette_mode")"
  [[ -n "$fzf_color_arg" ]] && fzf_color_args+=(--color="$fzf_color_arg")
  fzf_height_arg="~$fzf_height"
  fzf_ellipsis_args+=(--ellipsis='')
  IFS=$'\t' read -r fzf_prompt fzf_pointer selector_controls <<<"$(selector_fzf_controls "$total_w")"
  selector_fzf_apply_frame "$fzf_opencode_theme" "$total_w" fzf_prompt fzf_pointer fzf_border_args fzf_margin_args
  selector_fzf_prepare_header rows_ref "$summary_text" "$selector_controls" "$total_w" "$role_w" "$profile_w" "$cell_w" "$status_w" "$mode" \
    "$fzf_opencode_theme" "$term_lines" fzf_header fzf_height fzf_height_arg fzf_outer_top_padding fzf_header_line_count fzf_padding_args fzf_header_args

  for ((fzf_pad_i = 0; fzf_pad_i < fzf_outer_top_padding; fzf_pad_i++)); do
    printf '\n'
  done

  choice="$(
    {
      if (( fzf_opencode_theme )); then
        while IFS= read -r fzf_header_line; do
          printf 'header\tnoop\t-\t%s\n' "$fzf_header_line"
        done <<<"$fzf_header"
      fi
      printf '%s\n' "${rows_ref[@]}"
    } | fzf \
      --ansi \
      --no-sort \
      "${fzf_layout_args[@]}" \
      --height="$fzf_height_arg" \
      "${fzf_border_args[@]}" \
      "${fzf_margin_args[@]}" \
      "${fzf_padding_args[@]}" \
      --prompt="$fzf_prompt" \
      --pointer="$fzf_pointer" \
      --marker=' ' \
      --info=hidden \
      --no-scrollbar \
      --no-separator \
      "${fzf_ellipsis_args[@]}" \
      "${fzf_header_args[@]}" \
      --delimiter=$'\t' \
      --with-nth=4.. \
      --bind='esc:abort,ctrl-q:abort' \
      --no-multi \
      --cycle \
      --tiebreak=index \
      "${fzf_color_args[@]}"
  )" || {
    MENU_ACTION="skip"
    MENU_PROFILE=""
    return 0
  }

  IFS=$'\t' read -r kind action profile_choice display <<<"$choice"
  [[ "$profile_choice" == "-" ]] && profile_choice=""
  if [[ "$action" == "switch" || "$action" == "login" || "$action" == "skip" ]]; then
    MENU_ACTION="$action"
    MENU_PROFILE="$profile_choice"
  else
    MENU_ACTION="blocked"
    MENU_PROFILE=""
  fi
}

selector_numbered_menu() {
  local -n rows_ref="$1"
  local summary_text="$2"
  local total_w="$3"
  local role_w="$4"
  local profile_w="$5"
  local cell_w="$6"
  local status_w="$7"
  local mode="$8"
  local selector_palette_mode="$9"
  local choice i kind action profile_choice action_count=0 cols line_w prefix
  local term_lines fallback_height fallback_top_padding=0 fallback_pad_i
  local selector_controls
  local selected=0
  local fallback_actions=()
  local fallback_profiles=()

  cols="$(terminal_width)"
  term_lines="${LINES:-}"
  [[ "$term_lines" =~ ^[0-9]+$ ]] || term_lines="$(tput lines 2>/dev/null || true)"
  if usage_unicode_enabled; then
    if (( cols < 36 )); then
      selector_controls="1-${#rows_ref[@]} · q stay"
    else
      selector_controls="1-${#rows_ref[@]} select · q stay"
    fi
  else
    if (( cols < 36 )); then
      selector_controls="1-${#rows_ref[@]} | q stay"
    else
      selector_controls="1-${#rows_ref[@]} select | q stay"
    fi
  fi
  if [[ "${CODEX_AUTH_SELECTOR_CENTER:-0}" == "1" && "$term_lines" =~ ^[0-9]+$ ]]; then
    fallback_height=$((3 + ${#rows_ref[@]} + 1))
    if (( term_lines > fallback_height + 1 )); then
      fallback_top_padding=$(((term_lines - fallback_height) / 2))
    fi
  fi
  for ((fallback_pad_i = 0; fallback_pad_i < fallback_top_padding; fallback_pad_i++)); do
    printf '\n'
  done

  if (( selector_palette_mode )); then
    printf '%*s' 4 ''
    selector_palette_controls_line "$selector_controls" "$total_w"
    printf '\n'
    if [[ "${CODEX_AUTH_SELECTOR_CONTEXT:-0}" == "1" ]]; then
      printf '%*s' 4 ''
      selector_palette_context_line "$summary_text" "$total_w"
    fi
    printf '%*s' 4 ''
    selector_palette_table_header "$total_w"
  else
    selector_header_text "$summary_text" "$selector_controls" "$role_w" "$profile_w" "$cell_w" "$status_w" "$total_w" "$mode" "auth profiles"
    printf '\n'
  fi
  for i in "${!rows_ref[@]}"; do
    IFS=$'\t' read -r kind action profile_choice display <<<"${rows_ref[$i]}"
    [[ "$profile_choice" == "-" ]] && profile_choice=""
    if [[ "$kind" == "action" ]]; then
      fallback_actions+=("$action")
      fallback_profiles+=("$profile_choice")
      action_count=$((action_count + 1))
      prefix="$(printf '%2d. ' "$action_count")"
      line_w=$((cols - ${#prefix}))
      (( line_w < 1 )) && line_w=1
    else
      prefix=''
      line_w="$cols"
    fi
    (( line_w < 1 )) && line_w=1
    printf '%s' "$prefix"
    if [[ "$display" == *$'\033'* ]]; then
      if (( $(ansi_visible_length "$display") <= line_w )); then
        printf '%s' "$display"
      else
        fit_text_rtrim "$(strip_ansi "$display")" "$line_w"
      fi
    else
      fit_text_rtrim "$display" "$line_w"
    fi
    printf '\n'
  done
  if usage_unicode_enabled; then
    printf '› '
  else
    printf '> '
  fi
  IFS= read -r choice < /dev/tty || return 0
  if [[ -z "$choice" ]]; then
    selected=0
  elif [[ "$choice" == "q" || "$choice" == "Q" ]]; then
    MENU_ACTION="skip"
    MENU_PROFILE=""
    return 0
  elif [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#fallback_actions[@]} )); then
    selected=$((choice - 1))
  else
    MENU_ACTION="skip"
    MENU_PROFILE=""
    return 0
  fi

  MENU_ACTION="${fallback_actions[$selected]}"
  MENU_PROFILE="${fallback_profiles[$selected]}"
}

selector_menu_row_for_record() {
  local default_profile="$1"
  local selector_palette_mode="$2"
  local mode="$3"
  local role_w="$4"
  local profile_w="$5"
  local cell_w="$6"
  local status_w="$7"
  local bar_width="$8"
  local total_w="$9"
  local selector_profile_w="${10}"
  local action_w="${11}"
  local record="${12}"
  local valid weekly_used short_used mark profile plan weekly short status short_label weekly_reset short_reset cache_age
  local display display_status palette_profile detail action_role row_action row_profile_field active_row=0

  IFS=$'\t' read -r valid weekly_used short_used mark profile plan weekly short status short_label weekly_reset short_reset cache_age <<<"$record"
  [[ -n "$profile" ]] || return 1

  if [[ "$valid" != "0" && "$status" == "login" ]]; then
    if (( selector_palette_mode )); then
      palette_profile="$(selector_palette_profile_label "$profile" "$total_w" "$selector_profile_w")"
      display="$(print_selector_palette_table_row "login $palette_profile" "-" "-" "login needed" "$status" "$valid" "$total_w")"
    else
      detail="needed"
      display="$(print_selector_row "login" "$(usage_display_profile_name "$profile" "" "$selector_profile_w")" "$detail" "$action_w" "$selector_profile_w" "$total_w")"
    fi
    row_action="login"
    row_profile_field="$profile"
  elif [[ "$valid" == "0" ]]; then
    if (( selector_palette_mode )); then
      display_status="$(usage_display_status "$status" "normal")"
      palette_profile="$(selector_palette_profile_label "$profile" "$total_w" "$selector_profile_w")"
      if [[ "$mark" == "*" ]]; then
        display="$(print_selector_palette_table_row "stay $palette_profile" "$weekly" "$short" "$display_status" "$status" "$valid" "$total_w")"
      elif [[ "$mark" == "=" ]]; then
        display="$(print_selector_palette_table_row "same $palette_profile" "$weekly" "$short" "$display_status" "$status" "$valid" "$total_w")"
      else
        case "$display_status" in
          ready|ok)
            if [[ -n "$default_profile" && "$profile" == "$default_profile" ]]; then
              action_role="best"
            else
              action_role="use"
            fi
            ;;
          cap|old\ cap|both\ cap)
            action_role="cap"
            ;;
          *)
            action_role="warn"
            ;;
        esac
        display="$(print_selector_palette_table_row "$action_role $palette_profile" "$weekly" "$short" "$display_status" "$status" "$valid" "$total_w")"
      fi
    else
      display_status="$(usage_display_status "$status" "$mode")"
      if [[ "$mark" == "*" ]]; then
        action_role="$(selector_action_role "stay" "$role_w")"
      elif [[ "$mark" == "=" ]]; then
        action_role="$(selector_action_role "same" "$role_w")"
      elif [[ "$display_status" == "cap" || "$display_status" == "old cap" || "$display_status" == "both cap" ]]; then
        action_role="$(selector_action_role "cap" "$role_w")"
      elif [[ -n "$default_profile" && "$profile" == "$default_profile" ]]; then
        action_role="$(selector_action_role "best" "$role_w")"
      else
        action_role="$(selector_action_role "switch" "$role_w")"
      fi
      display="$(print_usage_render_data_line "$action_role" "$profile" "$weekly" "$weekly_reset" "$short" "$short_reset" \
        "$display_status" "$status" "$valid" "$weekly_used" "$short_used" "$role_w" "$profile_w" "$cell_w" "$status_w" "$bar_width" "$mode")"
    fi
    if [[ "$mark" == "*" || "$mark" == "=" ]]; then
      active_row=1
      row_action="skip"
      row_profile_field="-"
    else
      row_action="switch"
      row_profile_field="$profile"
    fi
  else
    if (( selector_palette_mode )); then
      display_status="$(usage_display_status "$status" "normal")"
      palette_profile="$(selector_palette_profile_label "$profile" "$total_w" "$selector_profile_w")"
      if [[ "$mark" == "*" ]]; then
        display="$(print_selector_palette_table_row "stay $palette_profile" "-" "-" "$display_status" "$status" "$valid" "$total_w")"
      elif [[ "$mark" == "=" ]]; then
        display="$(print_selector_palette_table_row "same $palette_profile" "-" "-" "$display_status" "$status" "$valid" "$total_w")"
      else
        display="$(print_selector_palette_table_row "use $palette_profile" "-" "-" "$display_status" "$status" "$valid" "$total_w")"
      fi
    else
      display_status="$(usage_display_status "$status" "$mode")"
      if [[ "$mark" == "=" ]]; then
        display="$(print_selector_row "same" "$(usage_display_profile_name "$profile" "" "$selector_profile_w")" "$display_status" "$action_w" "$selector_profile_w" "$total_w")"
      else
        display="$(print_selector_row "use" "$(usage_display_profile_name "$profile" "" "$selector_profile_w")" "$display_status" "$action_w" "$selector_profile_w" "$total_w")"
      fi
    fi
    if [[ "$mark" == "*" || "$mark" == "=" ]]; then
      active_row=1
      row_action="skip"
      row_profile_field="-"
    else
      row_action="switch"
      row_profile_field="$profile"
    fi
  fi

  printf '%s\037action\037%s\037%s\037%s\n' "$active_row" "$row_action" "$row_profile_field" "$display"
}

selector_current_menu_row() {
  local selector_palette_mode="$1"
  local total_w="$2"
  local selector_profile_w="$3"
  local action_w="$4"
  local display palette_profile

  if (( selector_palette_mode )); then
    palette_profile="$(selector_palette_profile_label "current" "$total_w" "$selector_profile_w")"
    display="$(print_selector_palette_table_row "stay $palette_profile" "-" "-" "same" "ok" "1" "$total_w")"
  else
    display="$(print_selector_row "stay" "current" "same" "$action_w" "$selector_profile_w" "$total_w")"
  fi
  printf 'action\tskip\t-\t%s\n' "$display"
}

arrow_action_menu() {
  local default_profile="${1:-}"
  shift
  local records=("$@")

  MENU_ACTION="skip"
  MENU_PROFILE=""

  if [[ "${CODEX_AUTH_NO_PROMPT:-}" == "1" || ! -t 0 || ! -t 1 || ! -r /dev/tty ]]; then
    return 0
  fi

  local mode role_w profile_w cell_w status_w bar_width total_w
  local rows=()
  local row active_row row_kind row_action row_profile_field row_display
  local summary_text action_w selector_profile_w
  local has_active_row=0
  local use_fzf=0
  local selector_palette_mode=0
  if command -v fzf >/dev/null 2>&1 && [[ "${CODEX_AUTH_NO_FZF:-}" != "1" ]]; then
    use_fzf=1
  fi
  USAGE_COLOR_ENABLED=0
  (( use_fzf )) && color_enabled && USAGE_COLOR_ENABLED=1
  local render_cols
  render_cols="$(terminal_width)"
  if (( render_cols < 32 )); then
    use_fzf=0
    USAGE_COLOR_ENABLED=0
  fi

  if (( use_fzf )); then
    if [[ "${CODEX_AUTH_FZF_THEME:-}" == "codex" || "${CODEX_AUTH_FZF_THEME:-}" == "1" ]]; then
      selector_palette_mode=1
    elif [[ -z "${CODEX_AUTH_FZF_THEME:-}" ]]; then
      selector_palette_mode=1
    fi
  else
    selector_palette_mode=1
  fi

  if (( use_fzf && selector_palette_mode )); then
    render_cols=$((render_cols - 3))
    (( render_cols < 20 )) && render_cols=20
  elif (( ! use_fzf )); then
    render_cols=$((render_cols - 4))
    (( render_cols < 16 )) && render_cols=16
  fi
  IFS=$'\t' read -r mode role_w profile_w cell_w status_w bar_width <<<"$(usage_render_widths "$render_cols")"
  total_w="$(usage_render_total_width "$role_w" "$profile_w" "$cell_w" "$status_w")"
  if (( total_w > render_cols )); then
    total_w="$render_cols"
  fi
  summary_text="$(usage_metadata_summary_line "$total_w" "$default_profile" "${records[@]}")"
  action_w=5
  selector_profile_w="$profile_w"
  (( selector_profile_w < 10 )) && selector_profile_w=10
  if (( selector_palette_mode )); then
    if color_enabled; then
      USAGE_COLOR_ENABLED=1
    fi
  fi

  for record in "${records[@]}"; do
    row="$(selector_menu_row_for_record "$default_profile" "$selector_palette_mode" "$mode" "$role_w" "$profile_w" "$cell_w" "$status_w" "$bar_width" "$total_w" "$selector_profile_w" "$action_w" "$record")" || continue
    IFS=$'\037' read -r active_row row_kind row_action row_profile_field row_display <<<"$row"
    (( active_row )) && has_active_row=1
    rows+=("$row_kind"$'\t'"$row_action"$'\t'"$row_profile_field"$'\t'"$row_display")
  done

  if (( ! has_active_row )) && [[ -f "$AUTH_FILE" ]]; then
    rows+=("$(selector_current_menu_row "$selector_palette_mode" "$total_w" "$selector_profile_w" "$action_w")")
  fi

  if (( use_fzf )); then
    selector_fzf_menu rows "$summary_text" "$total_w" "$role_w" "$profile_w" "$cell_w" "$status_w" "$mode" "$selector_palette_mode"
    return 0
  fi

  selector_numbered_menu rows "$summary_text" "$total_w" "$role_w" "$profile_w" "$cell_w" "$status_w" "$mode" "$selector_palette_mode"
}

collect_usage_records() {
  local active_fp="$1"
  shift
  local profile_files=("$@")
  local records_dir profile_file profile_name payload fingerprint i failed=0
  local max_jobs max_jobs_cap active_jobs=0

  max_jobs="${CODEX_AUTH_REFRESH_JOBS:-2}"
  max_jobs_cap="${CODEX_AUTH_REFRESH_JOBS_MAX:-4}"
  [[ "$max_jobs" =~ ^[0-9]+$ && "$max_jobs" -gt 0 ]] || max_jobs=2
  [[ "$max_jobs_cap" =~ ^[0-9]+$ && "$max_jobs_cap" -gt 0 ]] || max_jobs_cap=4
  (( max_jobs > max_jobs_cap )) && max_jobs="$max_jobs_cap"
  (( max_jobs > ${#profile_files[@]} )) && max_jobs="${#profile_files[@]}"
  (( max_jobs < 1 )) && max_jobs=1

  records_dir="$(mktemp -d "$CODEX_HOME/.tmp/auth-records.XXXXXX")"

  for i in "${!profile_files[@]}"; do
    profile_file="${profile_files[$i]}"
    (
      require_auth_file "$profile_file"
      profile_name="$(basename "$profile_file" .json)"
      fingerprint="$(credential_fingerprint "$profile_file" || true)"
      payload="$(usage_payload_for_profile "$profile_file" "$fingerprint")"
      usage_record_for_profile "$profile_name" "$profile_file" "$payload" "$active_fp" "$fingerprint" > "$records_dir/$i.record"
    ) &
    active_jobs=$((active_jobs + 1))
    if (( active_jobs >= max_jobs )); then
      wait -n || failed=1
      active_jobs=$((active_jobs - 1))
    fi
  done

  while (( active_jobs > 0 )); do
    wait -n || failed=1
    active_jobs=$((active_jobs - 1))
  done

  for i in "${!profile_files[@]}"; do
    [[ -f "$records_dir/$i.record" ]] && cat "$records_dir/$i.record"
  done | canonical_usage_active_marks
  rm -rf "$records_dir" 2>/dev/null || true
  return 0
}

collect_usage_records_cached() {
  local active_fp="$1"
  shift
  local profile_files=("$@")
  local map_file profile_file profile_name meta_path mode hint secret fp payload
  local -A profile_fp=()
  local -A payload_by_path=()

  map_file="$(mktemp "$CODEX_HOME/.tmp/auth-cache-map.XXXXXX")"

  while IFS=$'\037' read -r meta_path mode hint secret; do
    [[ -n "$meta_path" ]] || continue
    if [[ -n "$secret" && ! "$secret" =~ ^[0-9a-f]{64}$ ]]; then
      fp="$(fingerprint_secret "$secret")"
    elif [[ -n "$secret" ]]; then
      fp="$secret"
    else
      fp="$(fingerprint_secret "")"
    fi
    profile_name="$(basename "$meta_path" .json)"
    profile_fp["$meta_path"]="$fp"
    printf '%s\037%s\037%s\n' "$meta_path" "$profile_name" "$fp" >> "$map_file"
  done < <(auth_metadata_records "${profile_files[@]}")

  while IFS=$'\037' read -r meta_path profile_name payload; do
    [[ -n "$meta_path" ]] || continue
    payload_by_path["$meta_path"]="$payload"
  done < <(state_payload_records "$map_file")

  for profile_file in "${profile_files[@]}"; do
    profile_name="$(basename "$profile_file" .json)"
    fp="${profile_fp["$profile_file"]:-}"
    payload="${payload_by_path["$profile_file"]:-null}"
    usage_record_for_profile "$profile_name" "$profile_file" "$payload" "$active_fp" "$fp"
  done | canonical_usage_active_marks

  rm -f "$map_file" 2>/dev/null || true
  return 0
}

collect_usage_records_synced() {
  local active_fp="$1"
  shift
  local profile_files=("$@")
  local records=""
  local profile_file profile_name payload fingerprint

  for profile_file in "${profile_files[@]}"; do
    require_auth_file "$profile_file"
    profile_name="$(basename "$profile_file" .json)"
    fingerprint="$(credential_fingerprint "$profile_file" || true)"
    payload=""

    if [[ "${CODEX_AUTH_REFRESH_BLOCKED:-0}" == "1" && -n "$fingerprint" ]]; then
      payload="$(state_payload_for_profile "$profile_name" "$fingerprint" || true)"
      if [[ -n "$payload" ]] && ! usage_payload_still_blocked "$payload"; then
        payload=""
      fi
    fi

    if [[ -z "$payload" ]]; then
      payload="$(usage_json_for_profile "$profile_file")"
      if [[ -n "$payload" && "$payload" != "null" ]] && usage_payload_transient_error "$payload"; then
        payload=""
      fi
      if [[ -z "$payload" || "$payload" == "null" ]]; then
        payload=""
        [[ -n "$fingerprint" ]] && payload="$(state_payload_for_profile "$profile_name" "$fingerprint" || true)"
        if [[ -n "$payload" && "${CODEX_AUTH_REFRESH_FALLBACK_CACHE:-1}" == "1" ]]; then
          payload="$(mark_stale_payload "$payload")"
        else
          payload='{"error":{"message":"no response"}}'
        fi
      elif [[ -n "$fingerprint" ]]; then
        state_update_profile "$profile_name" "$fingerprint" "$payload"
      fi
    fi

    records+="$(
      usage_record_for_profile "$profile_name" "$profile_file" "$payload" "$active_fp" "$fingerprint"
    )"$'\n'
  done

  printf '%s' "$records" | canonical_usage_active_marks
}

refresh_active_profile_state() {
  local profile_name="$1"
  local profile_file fingerprint payload

  profile_file="$(profile_path "$profile_name")"
  require_auth_file "$profile_file"
  fingerprint="$(credential_fingerprint "$profile_file" || true)"
  payload="$(usage_json_for_active_home)"

  if [[ -n "$payload" && "$payload" != "null" && -n "$fingerprint" ]] \
    && ! usage_payload_transient_error "$payload" \
    && ! jq -e '.error? != null' >/dev/null 2>&1 <<<"$payload"; then
    state_update_profile "$profile_name" "$fingerprint" "$payload"
    return 0
  fi

  return 1
}

usage_limit_coverage_rank() {
  local weekly="$1"
  local short="$2"

  if [[ -n "$weekly" && "$weekly" != "-" && -n "$short" && "$short" != "-" ]]; then
    printf '0'
  elif [[ -n "$short" && "$short" != "-" ]]; then
    printf '1'
  elif [[ -n "$weekly" && "$weekly" != "-" ]]; then
    printf '2'
  else
    printf '9'
  fi
}

usage_limit_sort_score() {
  local used="$1"
  local display="$2"

  if [[ -n "$display" && "$display" != "-" && "$used" =~ ^[0-9]+$ ]]; then
    printf '%s' "$used"
  else
    printf '101'
  fi
}

find_best_ok_profile() {
  local records="$1"
  local include_active="${2:-0}"
  local best_week=101
  local best_short=101
  local best_coverage=99
  local best_profile=""
  local best_mark=""
  local valid weekly_used short_used mark profile plan weekly short status short_label
  local coverage_rank short_score week_score

  while IFS=$'\t' read -r valid weekly_used short_used mark profile plan weekly short status short_label; do
    [[ -n "$profile" ]] || continue
    if [[ "$valid" == "0" && "$status" == "ok" ]] && (( weekly_used < 100 && short_used < 100 )); then
	      if [[ "$include_active" != "1" && ( "$mark" == "*" || "$mark" == "=" ) ]]; then
	        continue
	      fi
      coverage_rank="$(usage_limit_coverage_rank "$weekly" "$short")"
      (( coverage_rank < 9 )) || continue
      short_score="$(usage_limit_sort_score "$short_used" "$short")"
      week_score="$(usage_limit_sort_score "$weekly_used" "$weekly")"
      if (( coverage_rank < best_coverage \
        || (coverage_rank == best_coverage && short_score < best_short) \
        || (coverage_rank == best_coverage && short_score == best_short && week_score < best_week) )) \
        || [[ "$include_active" == "1" && "$mark" == "*" && "$best_mark" != "*" && "$coverage_rank" == "$best_coverage" && "$short_score" == "$best_short" && "$week_score" == "$best_week" ]]; then
        best_profile="$profile"
        best_mark="$mark"
        best_coverage="$coverage_rank"
        best_week="$week_score"
        best_short="$short_score"
      fi
    fi
  done < <(printf '%s\n' "$records" | sed '/^[[:space:]]*$/d')

  if [[ -n "$best_profile" ]]; then
    printf '%s\t%s\t%s\t%s\n' "$best_profile" "$best_mark" "$best_week" "$best_short"
  else
    printf '\n'
  fi
}

prepare_usage_records() {
  local records="$1"
  local default_profile="${2:-}"
  local sorted_records=()

  mapfile -t sorted_records < <(
    printf '%s\n' "$records" \
      | sed '/^[[:space:]]*$/d' \
      | while IFS=$'\t' read -r valid weekly_used short_used mark profile plan weekly short status short_label weekly_reset short_reset cache_age; do
          local rank=6
          local coverage_rank short_score week_score
          if [[ "$status" == "offline" ]]; then
            rank=7
          elif [[ "$status" == "login" ]]; then
            rank=8
          elif [[ "$valid" != "0" ]]; then
            rank=9
          elif [[ "$status" == "ok" ]]; then
            rank=2
	            [[ "$mark" == "*" ]] && rank=1
	            [[ "$mark" == "=" ]] && rank=4
            [[ -n "$default_profile" && "$profile" == "$default_profile" ]] && rank=0
          elif [[ "$status" == stale* ]]; then
            rank=3
          elif [[ "$mark" == "*" ]]; then
            rank=4
          elif [[ "$status" == *cap* ]]; then
            rank=5
          fi
          coverage_rank="$(usage_limit_coverage_rank "$weekly" "$short")"
          short_score="$(usage_limit_sort_score "$short_used" "$short")"
          week_score="$(usage_limit_sort_score "$weekly_used" "$weekly")"
          printf '%s\t%s\t%03d\t%03d\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
            "$rank" "$coverage_rank" "$short_score" "$week_score" "$profile" \
            "$valid" "$weekly_used" "$short_used" "$mark" "$profile" "$plan" "$weekly" "$short" "$status" "$short_label" "$weekly_reset" "$short_reset" "$cache_age"
        done \
      | sort -t $'\t' -k1,1n -k2,2n -k3,3n -k4,4n -k5,5 \
      | cut -f6-
  )

  USAGE_SHORT_LABEL="5h"
  USAGE_PROFILE_WIDTH_HINT=12
  local record valid weekly_used short_used mark profile plan weekly short status record_short_label weekly_reset short_reset cache_age
  for record in "${sorted_records[@]}"; do
    IFS=$'\t' read -r valid weekly_used short_used mark profile plan weekly short status record_short_label weekly_reset short_reset cache_age <<<"$record"
    if (( ${#profile} > USAGE_PROFILE_WIDTH_HINT )); then
      USAGE_PROFILE_WIDTH_HINT="${#profile}"
    fi
    if [[ -n "$record_short_label" && "$record_short_label" != "short" && "$record_short_label" != "5h" ]]; then
      USAGE_SHORT_LABEL="$record_short_label"
    fi
  done

  SORTED_USAGE_RECORDS=("${sorted_records[@]}")
}

render_usage_records() {
  local records="$1"
  local default_profile="$2"
  local active_is_best="$3"

  prepare_usage_records "$records" "$default_profile"

  local mode role_w profile_w cell_w status_w bar_width
  local display_role display_status total_w group previous_group=""
  USAGE_COLOR_ENABLED=0
  color_enabled && USAGE_COLOR_ENABLED=1
  IFS=$'\t' read -r mode role_w profile_w cell_w status_w bar_width <<<"$(usage_render_widths "$(usage_static_render_columns)")"
  total_w="$(usage_render_total_width "$role_w" "$profile_w" "$cell_w" "$status_w")"

  print_palette_summary_header "Auth" "Codex profiles" "$(usage_metadata_summary_line "$total_w" "$default_profile" "${SORTED_USAGE_RECORDS[@]}")" "$total_w" usage 0
  if [[ "${CODEX_AUTH_USAGE_HEADER:-0}" == "1" ]]; then
    print_usage_render_header "$(usage_header_role "$mode" "$role_w")" "$(usage_header_profile "$mode")" "$(usage_header_week "$mode")" "$(usage_header_short "$mode")" "$(usage_header_state "$mode")" \
      "$role_w" "$profile_w" "$cell_w" "$status_w" "$mode"
  fi

  for record in "${SORTED_USAGE_RECORDS[@]}"; do
    IFS=$'\t' read -r valid weekly_used short_used mark profile plan weekly short status record_short_label weekly_reset short_reset cache_age <<<"$record"
	    group="$(usage_record_group "$valid" "$status")"
	    if [[ -z "$previous_group" ]]; then
	      if usage_show_group_label "$group"; then
	        print_usage_section_rule "$total_w" "$group"
	      fi
	    elif [[ "$group" != "$previous_group" ]] && usage_show_group_label "$group"; then
	      print_usage_section_rule "$total_w" "$group"
	    fi
    previous_group="$group"

    display_role="$(usage_role_label "$mark" "$profile" "$default_profile" "$mode" "$valid" "$status" "$role_w")"
    display_status="$(usage_display_status "$status" "$mode")"
    print_usage_render_data_line "$display_role" "$profile" "$weekly" "$weekly_reset" "$short" "$short_reset" \
      "$display_status" "$status" "$valid" "$weekly_used" "$short_used" "$role_w" "$profile_w" "$cell_w" "$status_w" "$bar_width" "$mode"
  done
}

parse_usage_args() {
  local -n auto_switch_ref="$1"
  local -n args_ref="$2"
  shift 2

  while (( $# > 0 )); do
    case "$1" in
      --auto)
        auto_switch_ref=1
        shift
        ;;
      --cached)
        USAGE_CACHED=1
        shift
        ;;
      --refresh)
        USAGE_REFRESH=1
        shift
        ;;
      --fast)
        USAGE_FAST_REFRESH=1
        shift
        ;;
      --sync)
        USAGE_FAST_REFRESH=0
        shift
        ;;
      --quiet|-q)
        USAGE_QUIET=1
        shift
        ;;
      --ttl)
        [[ "${2:-}" =~ ^[0-9]+$ ]] || die "usage: --ttl seconds"
        CACHE_TTL="$2"
        shift 2
        ;;
      --verbose|-v)
        USAGE_VERBOSE=1
        shift
        ;;
      --select|--menu)
        USAGE_SELECT=1
        shift
        ;;
      --)
        shift
        args_ref+=("$@")
        break
        ;;
      -*)
        die "unknown usage option: $1"
        ;;
      *)
        args_ref+=("$1")
        shift
        ;;
    esac
  done
}

usage_profile_files_for_args() {
  local name profile_file
  local profile_files=()

  if (( $# > 0 )); then
    for name in "$@"; do
      require_name "$name"
      profile_file="$(profile_path "$name")"
      [[ -f "$profile_file" ]] || die "profile not found: $name"
      profile_files+=("$profile_file")
    done
  else
    shopt -s nullglob
    profile_files=("$PROFILE_DIR"/*.json)
    shopt -u nullglob
  fi

  (( ${#profile_files[@]} == 0 )) || printf '%s\n' "${profile_files[@]}"
}

active_auth_fingerprint() {
  local active_meta=()

  [[ -f "$AUTH_FILE" ]] || return 0
  mapfile -t active_meta < <(auth_metadata "$AUTH_FILE" || true)
  printf '%s' "${active_meta[2]:-}"
}

usage_maybe_acquire_refresh_lock() {
  local profile_count="$1"
  local -n refresh_lock_held_ref="$2"
  local refresh_lock_wait

  if [[ "$USAGE_REFRESH" == "1" && "$USAGE_QUIET" != "1" && -t 2 ]]; then
    print_status_note refresh "$profile_count profiles" >&2
  fi
  if [[ "$USAGE_REFRESH" == "1" ]]; then
    exec 8>"$CODEX_HOME/.tmp/codex-auth-refresh.lock"
    refresh_lock_wait="${CODEX_AUTH_REFRESH_LOCK_WAIT:-1}"
    [[ "$refresh_lock_wait" =~ ^[0-9]+$ ]] || refresh_lock_wait=1
    if ! flock -w "$refresh_lock_wait" 8; then
      [[ "$USAGE_QUIET" == "1" ]] || print_status_note cache "refresh busy" >&2
      USAGE_REFRESH=0
      USAGE_CACHED=1
    else
      refresh_lock_held_ref=1
    fi
  fi
}

usage_collect_records_for_mode() {
  local active_fp="$1"
  shift

  if [[ "$USAGE_CACHED" == "1" && "$USAGE_REFRESH" != "1" ]]; then
    collect_usage_records_cached "$active_fp" "$@"
  elif [[ "$USAGE_REFRESH" == "1" && "$USAGE_FAST_REFRESH" != "1" ]]; then
    collect_usage_records_synced "$active_fp" "$@"
  else
    collect_usage_records "$active_fp" "$@"
  fi
}

usage_best_selection() {
  local records="$1"
  local best_profile best_mark best_week best_short
  local default_profile=""
  local active_is_best=0

  IFS=$'\t' read -r best_profile best_mark best_week best_short <<<"$(find_best_ok_profile "$records" 1)"
  if [[ -n "$best_profile" ]]; then
    if [[ "$best_mark" == "*" ]]; then
      active_is_best=1
    else
      default_profile="$best_profile"
    fi
  fi

  printf '%s\t%s\n' "$default_profile" "$active_is_best"
}

usage_render_or_prepare() {
  local records="$1"
  local default_profile="$2"
  local active_is_best="$3"
  local -n rendered_output_ref="$4"

  rendered_output_ref=0
  if [[ "$USAGE_SELECT" == "1" ]]; then
    prepare_usage_records "$records" "$default_profile"
  elif [[ "$USAGE_QUIET" != "1" ]]; then
    render_usage_records "$records" "$default_profile" "$active_is_best"
    rendered_output_ref=1
  fi
}

usage_auto_switch_result() {
  local rendered_output="$1"
  local default_profile="$2"
  local active_is_best="$3"

  if (( rendered_output )); then
    printf '\n'
  fi
  if [[ -n "$default_profile" ]]; then
    cmd_use "$default_profile"
  elif [[ "$active_is_best" == "1" && "$USAGE_QUIET" != "1" ]]; then
    print_status_note ready "already on best profile"
  elif [[ "$USAGE_QUIET" != "1" ]]; then
    print_status_note blocked "no ready profile"
  fi
}

usage_handle_menu_action() {
  case "$MENU_ACTION" in
    login)
      local refreshed_profile="$MENU_PROFILE"
      cmd_login "$refreshed_profile"
      printf '\n'
      print_status_note refresh "$refreshed_profile"
      refresh_active_profile_state "$refreshed_profile" || true
      USAGE_REFRESH=0
      USAGE_CACHED=1
      return 1
      ;;
    blocked)
      print_status_note blocked "choose switch/login/skip"
      return 0
      ;;
    switch)
      cmd_use "$MENU_PROFILE"
      return 0
      ;;
    skip|*)
      return 0
      ;;
  esac
}

cmd_usage() {
  ensure_dirs
  command -v jq >/dev/null 2>&1 || die "jq is required for usage output"

  local auto_switch=0
  local args=()
  local refresh_lock_held=0
  USAGE_QUIET=0
  USAGE_CACHED=0
  USAGE_REFRESH=0
  USAGE_SELECT=0
  USAGE_FAST_REFRESH=1
  parse_usage_args auto_switch args "$@"
  set -- "${args[@]}"

  local profile_files=()
  mapfile -t profile_files < <(usage_profile_files_for_args "$@")

  if (( ${#profile_files[@]} == 0 )); then
    [[ "$USAGE_QUIET" == "1" ]] || print_empty_profiles
    return 0
  fi
  usage_maybe_acquire_refresh_lock "${#profile_files[@]}" refresh_lock_held

  while true; do
    local active_fp
    active_fp="$(active_auth_fingerprint)"

    local records=""
    records="$(usage_collect_records_for_mode "$active_fp" "${profile_files[@]}")"
    if (( refresh_lock_held )); then
      flock -u 8 2>/dev/null || true
      refresh_lock_held=0
    fi

    local default_profile active_is_best
    IFS=$'\t' read -r default_profile active_is_best <<<"$(usage_best_selection "$records")"

    local rendered_output=0
    usage_render_or_prepare "$records" "$default_profile" "$active_is_best" rendered_output

    if (( auto_switch )); then
      usage_auto_switch_result "$rendered_output" "$default_profile" "$active_is_best"
      return 0
    fi

    if [[ "$USAGE_SELECT" != "1" ]]; then
      return 0
    fi

    arrow_action_menu "$default_profile" "${SORTED_USAGE_RECORDS[@]}"
    if usage_handle_menu_action; then
      return 0
    fi
  done
}

cache_stale_profile_names() {
  local profile_file profile_name fingerprint payload age

  for profile_file in "$@"; do
    profile_name="$(basename "$profile_file" .json)"
    fingerprint="$(credential_fingerprint "$profile_file" || true)"
    payload=""
    [[ -n "$fingerprint" ]] && payload="$(state_payload_for_profile "$profile_name" "$fingerprint" || true)"
    age="999999999"
    [[ -n "$fingerprint" ]] && age="$(state_age_for_profile "$profile_name" "$fingerprint")"
    if [[ -z "$payload" || ! "$age" =~ ^[0-9]+$ || "$age" -gt "$CACHE_TTL" ]]; then
      printf '%s\n' "$profile_name"
    fi
  done
}

background_refresh_profiles() {
  local script="${BASH_SOURCE[0]}"
  local background_jobs="${CODEX_AUTH_BACKGROUND_REFRESH_JOBS:-1}"
  (( USAGE_BACKGROUND )) || return 0
  [[ "${CODEX_AUTH_NO_BACKGROUND:-}" == "1" ]] && return 0
  (( $# > 0 )) || return 0
  [[ "$background_jobs" =~ ^[0-9]+$ && "$background_jobs" -gt 0 ]] || background_jobs=1

  nohup env CODEX_AUTH_REFRESH_LOCK=try CODEX_AUTH_NO_BACKGROUND=1 CODEX_AUTH_REFRESH_BLOCKED=1 CODEX_AUTH_REFRESH_FALLBACK_CACHE=1 CODEX_AUTH_REFRESH_JOBS="$background_jobs" "$script" refresh --quiet --fast "$@" >/dev/null 2>&1 &
}

cmd_refresh() {
  ensure_dirs
  command -v jq >/dev/null 2>&1 || die "jq is required for usage refresh"

  USAGE_QUIET=0
  USAGE_CACHED=0
  USAGE_REFRESH=1
  USAGE_BACKGROUND=0
  USAGE_FAST_REFRESH=1

  local args=()
  while (( $# > 0 )); do
    case "$1" in
      --quiet|-q)
        USAGE_QUIET=1
        shift
        ;;
      --fast)
        USAGE_FAST_REFRESH=1
        shift
        ;;
      --sync)
        USAGE_FAST_REFRESH=0
        shift
        ;;
      --)
        shift
        args+=("$@")
        break
        ;;
      *)
        args+=("$1")
        shift
        ;;
    esac
  done
  set -- "${args[@]}"

  if [[ "${CODEX_AUTH_REFRESH_LOCK:-}" == "try" ]]; then
    exec 9>"$CODEX_HOME/.tmp/codex-auth-refresh.lock"
    flock -n 9 || return 0
  else
    exec 9>"$CODEX_HOME/.tmp/codex-auth-refresh.lock"
    local refresh_lock_wait
    refresh_lock_wait="${CODEX_AUTH_REFRESH_LOCK_WAIT:-1}"
    [[ "$refresh_lock_wait" =~ ^[0-9]+$ ]] || refresh_lock_wait=1
    if ! flock -w "$refresh_lock_wait" 9; then
      [[ "$USAGE_QUIET" == "1" ]] || print_status_note cache "refresh busy" >&2
      return 0
    fi
  fi

  local profile_files=()
  if (( $# > 0 )); then
    local name profile_file
    for name in "$@"; do
      require_name "$name"
      profile_file="$(profile_path "$name")"
      [[ -f "$profile_file" ]] || die "profile not found: $name"
      profile_files+=("$profile_file")
    done
  else
    shopt -s nullglob
    profile_files=("$PROFILE_DIR"/*.json)
    shopt -u nullglob
  fi

  if (( ${#profile_files[@]} == 0 )); then
    [[ "$USAGE_QUIET" == "1" ]] || print_empty_profiles
    return 0
  fi
  if [[ "$USAGE_QUIET" != "1" && -t 2 ]]; then
    print_status_note refresh "${#profile_files[@]} profiles" >&2
  fi

  local active_fp=""
  if [[ -f "$AUTH_FILE" ]]; then
    active_fp="$(credential_fingerprint "$AUTH_FILE" || true)"
  fi

  local records best_profile best_mark best_week best_short default_profile active_is_best
  if [[ "$USAGE_FAST_REFRESH" == "1" ]]; then
    records="$(collect_usage_records "$active_fp" "${profile_files[@]}")"
  else
    records="$(collect_usage_records_synced "$active_fp" "${profile_files[@]}")"
  fi
  IFS=$'\t' read -r best_profile best_mark best_week best_short <<<"$(find_best_ok_profile "$records" 1)"
  default_profile=""
  active_is_best=0
  if [[ -n "$best_profile" ]]; then
    if [[ "$best_mark" == "*" ]]; then
      active_is_best=1
    else
      default_profile="$best_profile"
    fi
  fi

  [[ "$USAGE_QUIET" == "1" ]] || render_usage_records "$records" "$default_profile" "$active_is_best"
}

cmd_auto() {
  ensure_dirs
  command -v jq >/dev/null 2>&1 || return 0

  USAGE_QUIET=0
  USAGE_CACHED=1
  USAGE_REFRESH=0
  USAGE_BACKGROUND=1

  local args=()
  while (( $# > 0 )); do
    case "$1" in
      --quiet|-q)
        USAGE_QUIET=1
        shift
        ;;
      --ttl)
        [[ "${2:-}" =~ ^[0-9]+$ ]] || return 0
        CACHE_TTL="$2"
        USAGE_CACHED=0
        shift 2
        ;;
      --no-background)
        USAGE_BACKGROUND=0
        shift
        ;;
      --)
        shift
        args+=("$@")
        break
        ;;
      *)
        args+=("$1")
        shift
        ;;
    esac
  done
  set -- "${args[@]}"

  local profile_files=()
  if (( $# > 0 )); then
    local name profile_file
    for name in "$@"; do
      require_name "$name" || return 0
      profile_file="$(profile_path "$name")"
      if [[ ! -f "$profile_file" ]]; then
        [[ "$USAGE_QUIET" == "1" ]] && return 0
        die "profile not found: $name"
      fi
      profile_files+=("$profile_file")
    done
  else
    shopt -s nullglob
    profile_files=("$PROFILE_DIR"/*.json)
    shopt -u nullglob
  fi
  if (( ${#profile_files[@]} == 0 )); then
    [[ "$USAGE_QUIET" == "1" ]] || print_empty_profiles
    return 0
  fi

  local active_fp=""
  if [[ -f "$AUTH_FILE" ]]; then
    active_fp="$(credential_fingerprint "$AUTH_FILE" || true)"
  fi

  local records best_profile best_mark best_week best_short default_profile active_is_best
  records="$(collect_usage_records "$active_fp" "${profile_files[@]}")"
  IFS=$'\t' read -r best_profile best_mark best_week best_short <<<"$(find_best_ok_profile "$records" 1)"
  default_profile=""
  active_is_best=0
  if [[ -n "$best_profile" ]]; then
    if [[ "$best_mark" == "*" ]]; then
      active_is_best=1
    else
      default_profile="$best_profile"
    fi
  fi

  local rendered_output=0
  if [[ "$USAGE_QUIET" != "1" ]]; then
    render_usage_records "$records" "$default_profile" "$active_is_best"
    rendered_output=1
  fi

  if [[ -n "$default_profile" ]]; then
    if (( rendered_output )); then
      printf '\n'
    fi
    if [[ "$USAGE_QUIET" == "1" ]]; then
      cmd_use "$default_profile" >/dev/null
    else
      cmd_use "$default_profile"
    fi
  elif [[ "$USAGE_QUIET" != "1" ]]; then
    if (( rendered_output )); then
      printf '\n'
    fi
    if [[ "$active_is_best" == "1" ]]; then
      print_status_note ready "already on best profile"
    else
      print_status_note blocked "no ready profile"
    fi
  fi

  local stale_names=()
  mapfile -t stale_names < <(cache_stale_profile_names "${profile_files[@]}")
  if (( ${#stale_names[@]} > 0 )); then
    background_refresh_profiles "${stale_names[@]}"
  fi
}

codex_run_limit_detected() {
  local log_file="$1"
  local scan_bytes="${CODEX_AUTH_ROLL_LOG_SCAN_BYTES:-1048576}"

  [[ -s "$log_file" ]] || return 1
  [[ "$scan_bytes" =~ ^[1-9][0-9]*$ ]] || scan_bytes=1048576
  if command -v tail >/dev/null 2>&1; then
    LC_ALL=C tail -c "$scan_bytes" "$log_file" 2>/dev/null | grep -aEiq \
      'usage limit|rate limit|rate.?limit reached|limit reached|reached[^[:alnum:]]+limit|exceeded[^[:alnum:]]+limit|too many requests|429|rateLimitReached|5h cap|weekly cap|week cap|quota'
  else
    LC_ALL=C grep -aEiq \
      'usage limit|rate limit|rate.?limit reached|limit reached|reached[^[:alnum:]]+limit|exceeded[^[:alnum:]]+limit|too many requests|429|rateLimitReached|5h cap|weekly cap|week cap|quota' \
      "$log_file"
  fi
}

codex_run_make_resume_args() {
  CODEX_RUN_RESUME_ARGS=()

  while (( $# > 0 )); do
    case "$1" in
      --)
        shift
        break
        ;;
      -c|--config|--enable|--disable|--remote|--remote-auth-token-env|-i|--image|-m|--model|-p|--profile|--profile-v2|-s|--sandbox|-a|--ask-for-approval|-C|--cd|--cwd)
        CODEX_RUN_RESUME_ARGS+=("$1")
        shift
        if (( $# > 0 )); then
          CODEX_RUN_RESUME_ARGS+=("$1")
          shift
        fi
        ;;
      --dangerously-bypass-approvals-and-sandbox|--yolo|--oss|--strict-config|--dangerously-auto-approve-everything)
        CODEX_RUN_RESUME_ARGS+=("$1")
        shift
        ;;
      -*)
        CODEX_RUN_RESUME_ARGS+=("$1")
        shift
        ;;
      *)
        break
        ;;
    esac
  done

  if [[ "${1:-}" == "resume" ]]; then
    shift
    if [[ "${1:-}" == "--last" ]]; then
      CODEX_RUN_RESUME_ARGS+=(resume --last)
    elif [[ -n "${1:-}" && "${1:-}" != -* ]]; then
      CODEX_RUN_RESUME_ARGS+=(resume "$1")
    else
      CODEX_RUN_RESUME_ARGS+=(resume --last)
    fi
  else
    CODEX_RUN_RESUME_ARGS+=(resume --last)
  fi
}

codex_run_write_launcher() {
  local run_file="$1"
  local codex_cli="$2"
  shift 2
  local arg

  {
    printf '#!/usr/bin/env bash\n'
    printf 'set -euo pipefail\n'
    printf 'export CODEX_AUTH_RUNNER=1\n'
    printf 'exec %q' "$codex_cli"
    for arg in "$@"; do
      printf ' %q' "$arg"
    done
    printf '\n'
  } > "$run_file"
  chmod 700 "$run_file"
}

codex_run_watch_loop() {
  local auto_ttl="$1"
  local interval="${CODEX_AUTH_ROLL_INTERVAL:-60}"

  [[ "$interval" =~ ^[1-9][0-9]*$ ]] || interval=60
  while true; do
    sleep "$interval" || exit 0
    codex_run_auto_select 1 "$auto_ttl"
  done
}

codex_run_auto_args() {
  local auto_ttl="${1:-}"

  CODEX_RUN_AUTO_ARGS=(--quiet --no-background)
  if [[ "$auto_ttl" =~ ^[0-9]+$ ]]; then
    CODEX_RUN_AUTO_ARGS+=(--ttl "$auto_ttl")
  fi
  return 0
}

codex_run_auto_select() {
  local run_auto="${1:-1}"
  local auto_ttl="${2:-}"

  [[ "$run_auto" != "0" && "${CODEX_AUTH_AUTO:-1}" != "0" ]] || return 0
  codex_run_auto_args "$auto_ttl"
  CODEX_AUTH_NO_BACKGROUND=1 cmd_auto "${CODEX_RUN_AUTO_ARGS[@]}" || true
}

codex_run_start_watch_if_enabled() {
  local run_auto="${1:-1}"
  local watch_enabled="${2:-0}"
  local auto_ttl="${3:-}"

  CODEX_RUN_WATCH_PID=""
  if [[ "$run_auto" != "0" && "$watch_enabled" != "0" && "${CODEX_AUTH_AUTO:-1}" != "0" ]]; then
    codex_run_watch_loop "$auto_ttl" &
    CODEX_RUN_WATCH_PID=$!
  fi
}

codex_run_stop_watch() {
  local watch_pid="${1:-}"

  [[ "$watch_pid" =~ ^[0-9]+$ ]] || return 0
  kill "$watch_pid" 2>/dev/null || true
  wait "$watch_pid" 2>/dev/null || true
}

codex_run_kill_script_for_log() {
  local parent_pid="$1"
  local run_file="$2"
  local log_file="$3"
  local signal="${4:-TERM}"
  local child cmd grandchild killed_child

  [[ "$parent_pid" =~ ^[0-9]+$ ]] || return 0
  if ! command -v pgrep >/dev/null 2>&1; then
    return 0
  fi

  while IFS= read -r child; do
    [[ "$child" =~ ^[0-9]+$ ]] || continue
    [[ "$child" == "${BASHPID:-}" ]] && continue
    [[ -r "/proc/$child/cmdline" ]] || continue
    cmd="$(tr '\0' ' ' <"/proc/$child/cmdline" 2>/dev/null || true)"
    [[ "$cmd" == *"script "* && "$cmd" == *"$run_file"* && "$cmd" == *"$log_file"* ]] || continue
    killed_child=0
    while IFS= read -r grandchild; do
      [[ "$grandchild" =~ ^[0-9]+$ ]] || continue
      usage_kill_process_tree "$grandchild" "$signal"
      killed_child=1
    done < <(pgrep -P "$child" 2>/dev/null || true)
    if (( killed_child == 0 )); then
      usage_kill_process_tree "$child" "$signal"
    fi
  done < <(pgrep -P "$parent_pid" 2>/dev/null || true)
}

codex_run_limit_monitor_loop() {
  local log_file="$1"
  local target_pid="$2"
  local parent_pid="${3:-}"
  local run_file="${4:-}"
  local interval="${CODEX_AUTH_ROLL_MONITOR_INTERVAL:-2}"

  [[ "$interval" =~ ^[1-9][0-9]*$ ]] || interval=2

  while true; do
    if [[ "$target_pid" =~ ^[0-9]+$ ]]; then
      kill -0 "$target_pid" 2>/dev/null || return 0
    elif [[ "$parent_pid" =~ ^[0-9]+$ ]]; then
      kill -0 "$parent_pid" 2>/dev/null || return 0
    else
      return 0
    fi

    if codex_run_limit_detected "$log_file"; then
      if [[ "$target_pid" =~ ^[0-9]+$ ]]; then
        usage_kill_process_tree "$target_pid" TERM
      else
        codex_run_kill_script_for_log "$parent_pid" "$run_file" "$log_file" TERM
      fi
      sleep 1 || true
      if [[ "$target_pid" =~ ^[0-9]+$ ]] && kill -0 "$target_pid" 2>/dev/null; then
        usage_kill_process_tree "$target_pid" KILL
      elif [[ ! "$target_pid" =~ ^[0-9]+$ ]]; then
        codex_run_kill_script_for_log "$parent_pid" "$run_file" "$log_file" KILL
      fi
      return 0
    fi
    sleep "$interval" || return 0
  done
}

codex_run_start_limit_monitor() {
  local log_file="$1"
  local target_pid="$2"
  local parent_pid="${3:-}"
  local run_file="${4:-}"

  CODEX_RUN_LIMIT_MONITOR_PID=""
  if [[ "${CODEX_AUTH_ROLL_LIVE_MONITOR:-1}" == "0" || -z "$log_file" ]]; then
    return 0
  fi
  codex_run_limit_monitor_loop "$log_file" "$target_pid" "$parent_pid" "$run_file" &
  CODEX_RUN_LIMIT_MONITOR_PID=$!
}

codex_run_stop_limit_monitor() {
  local monitor_pid="${1:-}"

  [[ "$monitor_pid" =~ ^[0-9]+$ ]] || return 0
  kill "$monitor_pid" 2>/dev/null || true
  wait "$monitor_pid" 2>/dev/null || true
}

codex_run_cleanup() {
  local watch_pid="${1:-}"
  local monitor_pid="${2:-}"
  local run_file="${3:-}"
  local log_file="${4:-}"
  local keep_log="${5:-0}"

  codex_run_stop_limit_monitor "$monitor_pid"
  codex_run_stop_watch "$watch_pid"
  [[ -n "$run_file" ]] && rm -f "$run_file" 2>/dev/null || true
  if [[ "$keep_log" != "1" && -n "$log_file" ]]; then
    rm -f "$log_file" 2>/dev/null || true
  fi
}

cmd_run() {
  ensure_dirs

  local max_attempts="${CODEX_AUTH_ROLL_ATTEMPTS:-5}"
  local auto_ttl="${CODEX_AUTH_ROLL_AUTO_TTL:-}"
  local run_auto="${CODEX_AUTH_RUN_AUTO:-1}"
  local watch_enabled="${CODEX_AUTH_ROLL_WATCH:-0}"
  local keep_log="${CODEX_AUTH_KEEP_RUN_LOG:-0}"
  local log_enabled="${CODEX_AUTH_ROLL_LOG:-1}"
  local args=()
  local codex_cli attempt status log_file run_file watch_pid monitor_pid target_pid

  [[ "$max_attempts" =~ ^[1-9][0-9]*$ ]] || max_attempts=5
  [[ -z "$auto_ttl" || "$auto_ttl" =~ ^[0-9]+$ ]] || auto_ttl=""

  while (( $# > 0 )); do
    case "$1" in
      --attempts)
        [[ "${2:-}" =~ ^[1-9][0-9]*$ ]] || die "usage: codex-auth run [--attempts n] -- <codex args>"
        max_attempts="$2"
        shift 2
        ;;
      --no-auto)
        run_auto=0
        shift
        ;;
      --no-log)
        log_enabled=0
        shift
        ;;
      --)
        shift
        args+=("$@")
        break
        ;;
      *)
        args+=("$1")
        shift
        ;;
    esac
  done

  codex_cli="$(codex_bin)" || die "codex command not found"
  require_codex_launcher "$codex_cli"

  local run_args=("${args[@]}")
  CODEX_RUN_RESUME_ARGS=()
  attempt=1
  log_file=""
  run_file=""
  watch_pid=""
  monitor_pid=""
  target_pid=""
  trap 'codex_run_cleanup "${watch_pid:-}" "${monitor_pid:-}" "${run_file:-}" "${log_file:-}" "${keep_log:-0}"' EXIT
  trap 'codex_run_cleanup "${watch_pid:-}" "${monitor_pid:-}" "${run_file:-}" "${log_file:-}" "${keep_log:-0}"; exit 130' HUP INT TERM

  while true; do
    codex_run_auto_select "$run_auto" "$auto_ttl"

    codex_run_start_watch_if_enabled "$run_auto" "$watch_enabled" "$auto_ttl"
    watch_pid="$CODEX_RUN_WATCH_PID"

    log_file=""
    run_file=""
    monitor_pid=""
    if [[ "$log_enabled" != "0" ]]; then
      log_file="$(mktemp "$CODEX_HOME/.tmp/codex-run.XXXXXX.log")"
    fi

    status=0
    if [[ "$log_enabled" != "0" && -n "$log_file" && -t 0 && -t 1 && -r /dev/tty ]] && command -v script >/dev/null 2>&1; then
      run_file="$(mktemp "$CODEX_HOME/.tmp/codex-run.XXXXXX.sh")"
      codex_run_write_launcher "$run_file" "$codex_cli" "${run_args[@]}"
      set +e
      codex_run_start_limit_monitor "$log_file" "" "$$" "$run_file"
      monitor_pid="$CODEX_RUN_LIMIT_MONITOR_PID"
      script -qefc "$run_file" "$log_file"
      status=$?
      codex_run_stop_limit_monitor "$monitor_pid"
      monitor_pid=""
      set -e
      codex_run_stop_watch "$watch_pid"
      watch_pid=""
      rm -f "$run_file" 2>/dev/null || true
      run_file=""
    elif [[ "$log_enabled" != "0" && -n "$log_file" && ! -t 1 ]]; then
      set +e
      CODEX_AUTH_RUNNER=1 "$codex_cli" "${run_args[@]}" > >(tee "$log_file") 2> >(tee -a "$log_file" >&2) &
      target_pid=$!
      codex_run_start_limit_monitor "$log_file" "$target_pid"
      monitor_pid="$CODEX_RUN_LIMIT_MONITOR_PID"
      wait "$target_pid"
      status=$?
      codex_run_stop_limit_monitor "$monitor_pid"
      monitor_pid=""
      set -e
      codex_run_stop_watch "$watch_pid"
      watch_pid=""
    else
      set +e
      CODEX_AUTH_RUNNER=1 "$codex_cli" "${run_args[@]}"
      status=$?
      set -e
      codex_run_stop_watch "$watch_pid"
      watch_pid=""
      [[ -n "$log_file" ]] && : > "$log_file"
    fi

    if (( status == 0 )); then
      codex_run_cleanup "$watch_pid" "$monitor_pid" "$run_file" "$log_file" "$keep_log"
      trap - EXIT HUP INT TERM
      return 0
    fi

    if [[ -z "$log_file" ]] || ! codex_run_limit_detected "$log_file" || (( attempt >= max_attempts )); then
      codex_run_cleanup "$watch_pid" "$monitor_pid" "$run_file" "$log_file" "$keep_log"
      trap - EXIT HUP INT TERM
      return "$status"
    fi

    [[ "$keep_log" == "1" ]] || rm -f "$log_file" 2>/dev/null || true
    log_file=""
    print_status_note roll "usage limit, rotating" >&2
    codex_run_make_resume_args "${run_args[@]}"
    run_args=("${CODEX_RUN_RESUME_ARGS[@]}")
    attempt=$((attempt + 1))
  done
}

cmd_recover() {
  ensure_dirs
  [[ -t 0 && -t 1 ]] || die "recover needs tty"
  command -v jq >/dev/null 2>&1 || die "jq is required for recovery"

  local codex_cli
  codex_cli="$(codex_bin)" || die "codex command not found"
  require_codex_launcher "$codex_cli"

  cmd_auto --quiet --no-background

  export CODEX_AUTH_RUNNER=1
  if (( $# == 0 )); then
    print_status_note recover "latest session"
    exec "$codex_cli" resume --last
  fi

  print_status_note recover "session $*"
  exec "$codex_cli" resume "$@"
}

cmd_remove() {
  local name="$1"
  local yes="${2:-}"
  require_name "$name"
  [[ "$yes" == "--yes" ]] || die "refusing to remove without --yes"
  ensure_dirs
  acquire_mutation_lock

  local path active_matches=0 active_fp="" profile_fp="" active_name="" remaining_name="" other other_fp
  path="$(profile_path "$name")"
  [[ -f "$path" ]] || die "profile not found: $name"
  if [[ -f "$AUTH_FILE" ]]; then
    active_fp="$(credential_fingerprint "$AUTH_FILE" || true)"
    profile_fp="$(credential_fingerprint "$path" || true)"
    if [[ -n "$active_fp" && "$active_fp" == "$profile_fp" ]]; then
      shopt -s nullglob
      for other in "$PROFILE_DIR"/*.json; do
        other_fp="$(credential_fingerprint "$other" || true)"
        if [[ -n "$other_fp" && "$other_fp" == "$active_fp" ]]; then
          active_name="$(basename "$other" .json)"
          break
        fi
      done
      [[ "$active_name" == "$name" ]] && active_matches=1
    fi
  fi
  rm -f "$path"
  if (( active_matches )); then
    shopt -s nullglob
    for other in "$PROFILE_DIR"/*.json; do
      other_fp="$(credential_fingerprint "$other" || true)"
      if [[ -n "$other_fp" && "$other_fp" == "$active_fp" ]]; then
        remaining_name="$(basename "$other" .json)"
        break
      fi
    done
    if [[ -n "$remaining_name" ]]; then
      print_result_block "removed active $name" \
        "profile"$'\t'"$(display_path "$path")"$'\t'"bad" \
        "active"$'\t'"saved $remaining_name"$'\t'"active"
      return 0
    fi
    print_result_block "removed active $name" \
      "profile"$'\t'"$(display_path "$path")"$'\t'"bad" \
      "active"$'\t'"unsaved auth"$'\t'"active"
  else
    print_result_block "removed $name" \
      "profile"$'\t'"$(display_path "$path")"$'\t'"bad"
  fi
}

doctor_ps_rows() {
  if [[ -n "${CODEX_AUTH_DOCTOR_PS_FILE:-}" ]]; then
    cat "$CODEX_AUTH_DOCTOR_PS_FILE"
  else
    ps -eo pid=,ppid=,pgid=,sid=,tty=,stat=,etime=,args=
  fi
}

doctor_is_legacy_codex() {
  local args="$1"

  [[ "$args" == *"codex-auth run"* ]] && return 0
  [[ "$args" == *"/.bun/bin/codex --yolo"* ]] && return 0
  [[ "$args" == *"/codex/codex --yolo"* ]] && return 0
  return 1
}

doctor_is_sidecar() {
  local args="$1"

  case "$args" in
    *"/outlook-mcp/"*|*"/webex-mcp/"*|*"/drfirst-mcp/"*|*"/gemini_ui_mcp.mjs"*|*"/run_event_mcp.py"*|*"claude-runner-mcp"*|*"playwright-repl-mcp"*)
      return 0
      ;;
  esac
  return 1
}

cmd_doctor() {
  local kill_sidecars=0 yes=0
  while (( $# > 0 )); do
    case "$1" in
      --kill-sidecars)
        kill_sidecars=1
        shift
        ;;
      --yes)
        yes=1
        shift
        ;;
      *)
        die "usage: codex-auth doctor [--kill-sidecars --yes]"
        ;;
    esac
  done
  if (( kill_sidecars && ! yes )); then
    die "refusing to kill sidecars without --yes"
  fi

  local pid ppid pgid sid tty stat etime args root_count=0 sidecar_count=0 kill_count=0
  local -A legacy_pid=()
  local -A sidecar_by_parent=()
  local -A sidecar_args_by_pid=()
  local -a rows=()
  local row

  while read -r pid ppid pgid sid tty stat etime args; do
    [[ "$pid" =~ ^[0-9]+$ ]] || continue
    args="${args:-}"
    row="$pid"$'\t'"$ppid"$'\t'"$pgid"$'\t'"$tty"$'\t'"$etime"$'\t'"$args"
    rows+=("$row")
    if doctor_is_legacy_codex "$args"; then
      legacy_pid["$pid"]=1
      root_count=$((root_count + 1))
    fi
  done < <(doctor_ps_rows)

  for row in "${rows[@]}"; do
    IFS=$'\t' read -r pid ppid pgid tty etime args <<<"$row"
    if [[ -n "${legacy_pid["$ppid"]:-}" ]] && doctor_is_sidecar "$args"; then
      sidecar_count=$((sidecar_count + 1))
      sidecar_by_parent["$ppid"]="${sidecar_by_parent["$ppid"]:-} $pid"
      sidecar_args_by_pid["$pid"]="$args"
    fi
  done

  printf 'legacy codex processes: %s\n' "$root_count"
  printf 'direct sidecars under legacy codex: %s\n' "$sidecar_count"

  if (( root_count > 0 )); then
    printf '\n'
    printf 'pid\tppid\tpgid\ttty\tetime\tsidecars\tcommand\n'
    for row in "${rows[@]}"; do
      IFS=$'\t' read -r pid ppid pgid tty etime args <<<"$row"
      [[ -n "${legacy_pid["$pid"]:-}" ]] || continue
      local sidecars="${sidecar_by_parent["$pid"]:-}"
      local sidecar_total=0
      if [[ -n "$sidecars" ]]; then
        sidecar_total="$(wc -w <<<"$sidecars" | tr -d ' ')"
      fi
      printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$pid" "$ppid" "$pgid" "$tty" "$etime" "$sidecar_total" "$args"
    done
  fi

  if (( kill_sidecars )); then
    for pid in "${!sidecar_args_by_pid[@]}"; do
      if kill "$pid" 2>/dev/null; then
        kill_count=$((kill_count + 1))
      fi
    done
    printf '\nterminated sidecars: %s\n' "$kill_count"
  elif (( sidecar_count > 0 )); then
    printf '\nrun: codex-auth doctor --kill-sidecars --yes\n'
  fi
}

cmd_paths() {
  ensure_dirs
  local cols role_w target_w path_w total_w home_label
  cols="$(terminal_width)"
  IFS=$'\t' read -r role_w target_w path_w <<<"$(path_row_widths "$cols")"
  if (( target_w > 0 )); then
    total_w=$((role_w + 1 + target_w + 1 + path_w))
  else
    total_w=$((role_w + 1 + path_w))
  fi
  USAGE_COLOR_ENABLED=0
  color_enabled && USAGE_COLOR_ENABLED=1

  home_label="home $(compact_display_path "$CODEX_HOME" "$path_w")"
  print_palette_summary_header "Auth" "Paths" "$home_label" "$total_w"
  print_path_line "live" "auth" "$AUTH_FILE" "$role_w" "$target_w" "$path_w" active
  print_path_line "saved" "profiles" "$PROFILE_DIR" "$role_w" "$target_w" "$path_w" good
  print_path_line "undo" "backups" "$BACKUP_DIR" "$role_w" "$target_w" "$path_w" warn
  print_path_line "cache" "usage" "$STATE_FILE" "$role_w" "$target_w" "$path_w" muted
}

main() {
  local command="${1:-}"
  shift || true

  case "$command" in
    add) cmd_add "$@" ;;
    usage|limits) cmd_usage "$@" ;;
    list|ls) cmd_list "$@" ;;
    current|status) cmd_current "$@" ;;
    save) [[ $# -ge 1 && $# -le 2 ]] || die "usage: codex-auth save <name> [file]"; cmd_save "$@" ;;
    import) [[ $# -eq 2 ]] || die "usage: codex-auth import <name> <file>"; cmd_import "$1" "$2" ;;
    use|switch) [[ $# -eq 1 ]] || die "usage: codex-auth use <name>"; cmd_use "$1" ;;
    login) [[ $# -ge 1 ]] || die "usage: codex-auth login <name> [codex login args...]"; cmd_login "$@" ;;
    auto) cmd_auto "$@" ;;
    run|wrap) cmd_run "$@" ;;
    recover) cmd_recover "$@" ;;
    refresh) cmd_refresh "$@" ;;
    doctor) cmd_doctor "$@" ;;
    export) [[ $# -eq 2 ]] || die "usage: codex-auth export <name> <file>"; cmd_export "$@" ;;
    remove|rm) [[ $# -ge 1 && $# -le 2 ]] || die "usage: codex-auth remove <name> --yes"; cmd_remove "$@" ;;
    paths) cmd_paths ;;
    -h|--help|help|'') usage ;;
    *) die "unknown command: $command. Use: codex-auth help" ;;
  esac
}

main "$@"
