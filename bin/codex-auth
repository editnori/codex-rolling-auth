#!/usr/bin/env bash
set -euo pipefail

umask 077

CODEX_HOME="${CODEX_HOME:-$HOME/.codex}"
AUTH_FILE="$CODEX_HOME/auth.json"
PROFILE_DIR="${CODEX_AUTH_PROFILES_DIR:-$CODEX_HOME/auth-profiles}"
BACKUP_DIR="$CODEX_HOME/auth-backups"
STATE_FILE="${CODEX_AUTH_STATE_FILE:-$CODEX_HOME/auth-state.json}"
CACHE_TTL="${CODEX_AUTH_CACHE_TTL:-900}"
CODEX_BIN="${CODEX_AUTH_CODEX_BIN:-}"
USAGE_VERBOSE=0
USAGE_QUIET=0
USAGE_CACHED=0
USAGE_REFRESH=0
USAGE_SELECT=0
USAGE_FAST_REFRESH=0
MUTATION_LOCK_HELD=0
MUTATION_LOCK_FD=""

USAGE_RECORD_EXTRACT_JQ='
  def blanks: "", "", "", "", "", "", "", "", "";
  def no_usage($age; $stale): ["no_usage", "", $age, $stale, blanks];
  def empty_limit: {used: 0, window: "-", window_num: 0, reset: "-"};
  def limit_row: {used: ((.usedPercent // 0) | tonumber? // 0 | floor), window: (.windowDurationMins // "-"), window_num: ((.windowDurationMins // 0) | tonumber? // 0), reset: (.resetsAt // "-")};
  def credit_label: if . == null then "-" elif .unlimited then "unlimited" elif .hasCredits then (.balance // "yes") else "0" end;
  def error_label: ((.error.message // .error.data.message // .error.data.error.message // .error // "error") | tostring | gsub("[\n\t]+"; " ") | gsub("  +"; " ") | gsub("^ "; "") | gsub(" $"; ""));
  (._codexAuthAgeSec // "") as $age
  | (._codexAuthStale // false | tostring) as $stale
  | if .error? != null then
      ["error", error_label, $age, $stale, blanks]
    else
      (.rateLimitsByLimitId.codex // .rateLimits // null) as $r
      | if $r == null then
          no_usage($age; $stale)
        else
          [($r.primary // empty), ($r.secondary // empty)]
          | map(select(type == "object") | limit_row)
          | map(select(.window_num > 0))
          | sort_by(if .window_num == 0 then 999999999 else .window_num end) as $limits
          | if ($limits | length) == 0 then
              no_usage($age; $stale)
            else
              (if ($limits | length) == 1 and ($limits[0].window_num >= 1440)
               then empty_limit
               else $limits[0]
               end) as $shortLimit
              | (if ($limits | length) == 1 and ($limits[0].window_num < 1440)
               then empty_limit
               else $limits[-1]
               end) as $weeklyLimit
              | ["usage", "", $age, $stale, ($r.planType // "-"),
                 $shortLimit.used, $shortLimit.window, $shortLimit.reset,
                 $weeklyLimit.used, $weeklyLimit.window, $weeklyLimit.reset,
                 ($r.credits | credit_label), ($r.rateLimitReachedType // "")]
            end
        end
    end
  | map(tostring)
  | join("\u001f")
'
CODEX_AUTH_SELF="$(realpath "${BASH_SOURCE[0]}" 2>/dev/null || printf '%s\n' "${BASH_SOURCE[0]}")"
CODEX_AUTH_SCRIPT_DIR="$(cd "$(dirname "$CODEX_AUTH_SELF")" && pwd -P)"
CODEX_AUTH_LIB_DIR="${CODEX_AUTH_LIB_DIR:-$CODEX_AUTH_SCRIPT_DIR/../lib/codex-auth}"

CODEX_AUTH_BASE_LIB_FILES=(
  core.sh
  render.sh
  selector.sh
  output.sh
  profiles.sh
)

source_codex_auth_libs() {
  local lib_file lib_path

  for lib_file in "$@"; do
    lib_path="$CODEX_AUTH_LIB_DIR/$lib_file"
    if [[ ! -r "$lib_path" ]]; then
      printf 'codex-auth missing library: %s\n' "$lib_path" >&2
      exit 1
    fi
    . "$lib_path"
  done
}

main() {
  local command="${1:-}"
  shift || true

  source_codex_auth_libs "${CODEX_AUTH_BASE_LIB_FILES[@]}"
  case "$command" in
    add) cmd_add "$@" ;;
    usage|limits) source_codex_auth_libs usage.sh; cmd_usage "$@" ;;
    list|ls) cmd_list "$@" ;;
    current|status) cmd_current "$@" ;;
    save) require_arg_count_between "$#" 1 2 "usage: codex-auth save <name> [file]"; cmd_save "$@" ;;
    import) require_arg_count_between "$#" 2 2 "usage: codex-auth import <name> <file>"; cmd_save "$1" "$2" "imported $1" ;;
    use|switch) require_arg_count_between "$#" 1 1 "usage: codex-auth use <name>"; cmd_use "$1" ;;
    login) require_arg_count_between "$#" 1 999999 "usage: codex-auth login <name> [codex login args...]"; cmd_login "$@" ;;
    auto) source_codex_auth_libs usage.sh; cmd_auto "$@" ;;
    patch-codex) source_codex_auth_libs patch.sh; cmd_patch_codex "$@" ;;
    run|wrap) source_codex_auth_libs usage.sh run.sh; cmd_run "$@" ;;
    recover) source_codex_auth_libs usage.sh run.sh; cmd_recover "$@" ;;
    refresh) source_codex_auth_libs usage.sh; cmd_refresh "$@" ;;
    doctor) source_codex_auth_libs doctor.sh; cmd_doctor "$@" ;;
    export) require_arg_count_between "$#" 2 2 "usage: codex-auth export <name> <file>"; cmd_export "$@" ;;
    remove|rm) require_arg_count_between "$#" 1 2 "usage: codex-auth remove <name> --yes"; cmd_remove "$@" ;;
    paths) cmd_paths ;;
    -h|--help|help|'') source_codex_auth_libs help.sh; usage ;;
    *) die "unknown command: $command. Use: codex-auth help" ;;
  esac
}

main "$@"
