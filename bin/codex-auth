+        let now = Instant::now();
+        let Ok(mut last_check) = self.rolling_auth_last_check.lock() else {
+            return true;
+        };
+
+        if let Some(last) = *last_check
+            && now.duration_since(last) < interval
+        {
+            return false;
+        }
+
+        *last_check = Some(now);
+        true
+    }
