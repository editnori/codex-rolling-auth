#!/usr/bin/env bash
set -euo pipefail

CODEX_AUTH_SHIM=1
SHIM_PATH="$(realpath "$0" 2>/dev/null || printf '%s\n' "$0")"

emit_real_codex_candidate() {
  local candidate="$1" candidate_path

  [[ -x "$candidate" ]] || return 1
  candidate_path="$(realpath "$candidate" 2>/dev/null || printf '%s' "$candidate")"
  [[ "$candidate_path" == "$SHIM_PATH" ]] && return 1
  printf '%s\n' "$candidate"
}

find_first_codex_candidate() {
  local candidate

  for candidate in "$@"; do
    emit_real_codex_candidate "$candidate" && return 0
  done
  return 1
}

find_real_codex() {
  local wrapper_dir path_dir
  local path_candidates=()
  local path_dirs=()

  [[ -n "${CODEX_AUTH_CODEX_BIN:-}" ]] && emit_real_codex_candidate "$CODEX_AUTH_CODEX_BIN" && return 0
  wrapper_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
  find_first_codex_candidate \
    "$wrapper_dir/codex-real" \
    "$HOME/.bun/bin/codex-real" \
    "$HOME/.bun/bin/codex" \
    "$HOME/.npm-global/bin/codex" \
    /usr/local/bin/codex \
    /usr/bin/codex \
    /bin/codex \
    "$wrapper_dir"/codex.backup.* && return 0

  IFS=':' read -r -a path_dirs <<<"${PATH:-}"
  for path_dir in "${path_dirs[@]}"; do
    [[ -n "$path_dir" ]] || path_dir='.'
    path_candidates+=("$path_dir/codex")
  done
  find_first_codex_candidate "${path_candidates[@]}" && return 0

  return 1
}

should_wrap_session() {
  case "${1:-}" in
    login|logout|update|completion|mcp|plugin|features|app-server|help|--help|-h|--version|-V)
      return 1
      ;;
  esac

  return 0
}

should_auto_select() {
  should_wrap_session "$@" || return 1

  [[ "${CODEX_AUTH_AUTO:-1}" != "0" && "${CODEX_AUTH_RUNNER:-0}" != "1" ]]
}

should_add_yolo() {
  should_wrap_session "$@" || return 1
  [[ "${CODEX_AUTH_YOLO:-1}" != "0" ]] || return 1

  case "${1:-}" in
    --yolo|--dangerously-bypass-approvals-and-sandbox|--dangerously-auto-approve-everything)
      return 1
      ;;
  esac

  return 0
}

patched_codex_for_real() {
  local real_codex="$1"

  [[ "${CODEX_AUTH_PATCH_AUTO:-1}" != "0" ]] || return 1
  command -v codex-auth >/dev/null 2>&1 || return 1
  CODEX_AUTH_STOCK_CODEX_BIN="$real_codex" codex-auth patch-codex --print-bin --quiet 2>/dev/null
}

start_patch_codex_background() {
  local real_codex="$1"

  [[ "${CODEX_AUTH_PATCH_AUTO:-1}" != "0" ]] || return 0
  [[ "${CODEX_AUTH_PATCH_BUILD_AUTO:-0}" != "0" ]] || return 0
  command -v codex-auth >/dev/null 2>&1 || return 0
  CODEX_AUTH_STOCK_CODEX_BIN="$real_codex" codex-auth patch-codex --background --quiet >/dev/null 2>&1 || true
}

real_codex="$(find_real_codex)" || {
  printf 'codex-auth shim could not find the real codex binary\n' >&2
  exit 127
}

codex_args=("$@")
exec_codex="$real_codex"

if should_auto_select "$@" && command -v codex-auth >/dev/null 2>&1; then
  CODEX_AUTH_CODEX_BIN="$real_codex" CODEX_AUTH_NO_BACKGROUND=1 codex-auth auto --quiet --no-background || true
fi

if should_add_yolo "$@"; then
  codex_args=(--yolo "$@")
fi

if should_wrap_session "$@"; then
  if patched_codex="$(patched_codex_for_real "$real_codex")" && [[ -n "$patched_codex" ]]; then
    exec_codex="$patched_codex"
    export CODEX_AUTH_ROLLING="${CODEX_AUTH_ROLLING:-1}"
  else
    start_patch_codex_background "$real_codex"
  fi
fi

exec env CODEX_AUTH_RUNNER=1 CODEX_AUTH_CODEX_BIN="$real_codex" "$exec_codex" "${codex_args[@]}"
