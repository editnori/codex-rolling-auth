#!/usr/bin/env bash
set -euo pipefail

CODEX_AUTH_SHIM=1

shim_path() {
  realpath "$0" 2>/dev/null || printf '%s\n' "$0"
}

is_self() {
  local candidate="$1"
  [[ "$(realpath "$candidate" 2>/dev/null || printf '%s' "$candidate")" == "$(shim_path)" ]]
}

find_real_codex() {
  local candidate wrapper_dir path_dir

  if [[ -n "${CODEX_AUTH_CODEX_BIN:-}" && -x "${CODEX_AUTH_CODEX_BIN:-}" ]] && ! is_self "$CODEX_AUTH_CODEX_BIN"; then
    printf '%s\n' "$CODEX_AUTH_CODEX_BIN"
    return 0
  fi

  wrapper_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
  for candidate in \
    "$wrapper_dir/codex-real" \
    "$HOME/.bun/bin/codex-real" \
    "$HOME/.bun/bin/codex" \
    "$HOME/.npm-global/bin/codex" \
    /usr/local/bin/codex \
    /usr/bin/codex \
    /bin/codex
  do
    [[ -x "$candidate" ]] || continue
    [[ "$(realpath "$candidate" 2>/dev/null || printf '%s' "$candidate")" != "$(realpath "$0" 2>/dev/null || printf '%s' "$0")" ]] || continue
    printf '%s\n' "$candidate"
    return 0
  done

  for candidate in "$wrapper_dir"/codex.backup.*; do
    [[ -x "$candidate" ]] || continue
    is_self "$candidate" && continue
    printf '%s\n' "$candidate"
    return 0
  done

  IFS=':' read -r -a path_dirs <<<"${PATH:-}"
  for path_dir in "${path_dirs[@]}"; do
    [[ -n "$path_dir" ]] || path_dir='.'
    candidate="$path_dir/codex"
    [[ -x "$candidate" ]] || continue
    is_self "$candidate" && continue
    printf '%s\n' "$candidate"
    return 0
  done

  return 1
}

should_auto_select() {
  case "${1:-}" in
    login|logout|update|completion|mcp|plugin|features|app-server|help|--help|-h|--version|-V)
      return 1
      ;;
  esac

  [[ "${CODEX_AUTH_AUTO:-1}" != "0" && "${CODEX_AUTH_RUNNER:-0}" != "1" ]]
}

real_codex="$(find_real_codex)" || {
  printf 'codex-auth shim could not find the real codex binary\n' >&2
  exit 127
}

if should_auto_select "$@" && command -v codex-auth >/dev/null 2>&1; then
  CODEX_AUTH_CODEX_BIN="$real_codex" CODEX_AUTH_NO_BACKGROUND=1 codex-auth auto --quiet --no-background || true
fi

exec env CODEX_AUTH_RUNNER=1 CODEX_AUTH_CODEX_BIN="$real_codex" "$real_codex" "$@"
